gs": {"color_scheme": "", "text_alignment": "left"}, "blocks": {"image_tx7x9F": {"type": "image", "settings": {"image": "shopify://shop_images/Ingredient_Coco.jpg", "max_width": 100, "mobile_max_width": 100}, "blocks": {}}, "heading_EKNmRk": {"type": "heading", "settings": {"text": "MCT de coco", "heading_size": "h4", "html_tag": "p", "indent": "none", "highlight_effect": "default", "highlight_accent_color": "", "highlight_text_color": ""}, "blocks": {}}, "rich_text_kJM4bH": {"type": "rich-text", "settings": {"text": "<p>Les MCT du coco fournissent une énergie rapide et propre. Résultat : plus de coup de barre à 15h, plus besoin de café pour tenir. Alerte et concentrée, sans pic glycémique.</p>", "content_width": "sm"}, "blocks": {}}}, "block_order": ["image_tx7x9F", "heading_EKNmRk", "rich_text_kJM4bH"]}, "multi_column_column_ewmn7n": {"type": "_multi-column-column", "name": "t:sections.multi_column.blocks.column.name", "settings": {"color_scheme": "", "text_alignment": "left"}, "blocks": {"image_9rBDV9": {"type": "image", "settings": {"image": "shopify://shop_images/Ingredient_Gingembre.jpg", "max_width": 100, "mobile_max_width": 100}, "blocks": {}}, "heading_mMjLQD": {"type": "heading", "settings": {"text": "Le gingembre violet", "heading_size": "h4", "html_tag": "p", "indent": "none", "highlight_effect": "default", "highlight_accent_color": "", "highlight_text_color": ""}, "blocks": {}}, "rich_text_LBdppM": {"type": "rich-text", "settings": {"text": "<p>Le gingembre violet active ton métabolisme de l'intérieur. Résultat : ton métabolisme est soutenu, ta digestion devient fluide dès les premiers jours.</p>", "content_width": "sm"}, "blocks": {}}}, "block_order": ["image_9rBDV9", "heading_mMjLQD", "rich_text_LBdppM"]}, "multi_column_column_K36rBq": {"type": "_multi-column-column", "name": "t:sections.multi_column.blocks.column.name", "settings": {"color_scheme": "", "text_alignment": "left"}, "blocks": {"image_g3CE7k": {"type": "image", "settings": {"image": "shopify://shop_images/Ingredient_L-carnitine_tartrate.jpg", "max_width": 100, "mobile_max_width": 100}, "blocks": {}}, "heading_XAD6kC": {"type": "heading", "settings": {"text": "L-carnitine tartrate", "heading_size": "h4", "html_tag": "p", "indent": "none", "highlight_effect": "default", "highlight_accent_color": "", "highlight_text_color": ""}, "blocks": {}}, "rich_text_6L9HCj": {"type": "rich-text", "settings": {"text": "<p>La L-carnitine soutient le métabolisme énergétique et l'endurance. Résultat : ton corps fonctionne de manière optimale comme carburant — même au repos.</p>", "content_width": "sm"}, "blocks": {}}}, "block_order": ["image_g3CE7k", "heading_XAD6kC", "rich_text_6L9HCj"]}, "section-header": {"type": "_section-header", "static": true, "settings": {"subheading": "", "title": "DES ACTIFS NATURELS HAUTEMENT SÉLECTIONNÉS POUR BOOSTER VOS RÉSULTATS", "content": "", "button_text": "", "button_link": "", "button_style": "outline", "text_alignment": "left", "heading_size": "h3", "title_icon": "none", "show_scrolling_title": false}, "blocks": {}}}, "block_order": ["multi_column_column_CeQTkW", "multi_column_column_CzDwQE", "multi_column_column_gKPMg8", "multi_column_column_jcLUcy", "multi_column_column_ewmn7n", "multi_column_column_K36rBq"], "name": "t:sections.multi_column.name", "settings": {"color_scheme": "", "show_internal_borders": false, "add_horizontal_spacing": true, "add_top_spacing": true, "add_bottom_spacing": true, "items_per_row": 3, "stack_on_mobile": false, "stack_on_desktop": true, "column_spacing": "sm", "row_spacing": "sm"}}, "separator_adjustable_pQXxig": {"type": "separator-adjustable", "name": "Séparateur réglable", "settings": {"color": "#dad4e2", "thickness": 1, "width": 100, "line_style": "solid", "spacing_top": 0, "spacing_bottom": 0}}, "separator_adjustable_xxbed6": {"type": "separator-adjustable", "name": "Séparateur réglable", "settings": {"color": "#dad4e2", "thickness": 1, "width": 100, "line_style": "solid", "spacing_top": 0, "spacing_bottom": 0}}, "text_with_media_mwqBjX": {"type": "text-with-media", "blocks": {"subheading_Ec4aUM": {"type": "subheading", "settings": {"text": "valeurs", "position": "top_left"}}, "heading_xWBtGT": {"type": "heading", "settings": {"text": "6h de satiété · validé EFSA", "heading_tag": "h2", "position": "top_left", "highlight_effect": "default", "highlight_accent_color": "", "highlight_text_color": ""}}, "richtext_8g9Y3x": {"type": "richtext", "settings": {"text": "<p>Profitez des bienfaits du <strong>gingembre</strong>, naturellement riche en actifs qui facilitent la digestion.</p>", "position": "top_left"}}, "richtext_NFTkBh": {"type": "richtext", "settings": {"text": "<p>Ce duo, naturellement riche en acide chlorogénique et en L-carnitine, soutient l’organisme dans sa capacité à utiliser davantage de graisses comme source d’énergie. </p><p>Peut augmenter la dépense calorique d’environ <strong>10 % sur plusieurs heures</strong>, sans effet de chute d’énergie.Une saveur douce, ronde, avec une <strong>note de noisette vanillée</strong>.</p>", "position": "bottom_left"}}, "button_47CABF": {"type": "button", "settings": {"text": "je commande", "url": "shopify://collections/all", "position": "bottom_left", "style": "solid", "background": "#7d3fff", "text_color": "#ffffff"}}}, "block_order": ["subheading_Ec4aUM", "heading_xWBtGT", "richtext_8g9Y3x", "richtext_NFTkBh", "button_47CABF"], "name": "t:sections.text_with_media.name", "settings": {"color_scheme": "", "content_position": "start", "content_percentage_width": 50, "overlay_color": "#000000", "overlay_opacity": 20, "add_media_spacing": false, "autoplay_video": false, "primary_image": "shopify://shop_images/FOND_FIN.jpg", "secondary_media_width": 55, "secondary_media_mobile_width": 60, "show_secondary_media_on_mobile": true, "secondary_media_alignment": "place-self-center", "secondary_media_shape": "none"}}, "text_with_media_HYdW4P": {"type": "text-with-media", "blocks": {"subheading_AzRfPX": {"type": "subheading", "settings": {"text": "valeurs", "position": "top_left"}}, "heading_T6yRr8": {"type": "heading", "settings": {"text": "Effet coupe-faim. Résultats vérifiés en laboratoire.", "heading_tag": "h3", "position": "top_left", "highlight_effect": "default", "highlight_accent_color": "", "highlight_text_color": ""}}, "richtext_EqtyF9": {"type": "richtext", "settings": {"text": "<p>UBURN commence à agir dès la première prise grâce à plus de <strong>9 ingrédients naturels</strong> spécialement pensés pour les femmes qui veulent enfin <strong>arrêter de grignoter et reprendre le contrôle</strong>.</p>", "position": "top_left"}}, "richtext_JL8jd6": {"type": "richtext", "settings": {"text": "<p>Dans une dose, tu retrouves :</p><ul><li><strong>L’ube violet</strong>, une racine des Philippines ultra-riche en fibres qui aide vraiment à tenir entre les repas.<br/></li><li><strong>Le konjac</strong>, une fibre capable d’absorber jusqu’à 100× son poids en eau.<br/></li></ul><p>Une fois dans ton estomac, les deux forment un <strong>gel naturel qui remplit bien</strong> et calme les envies de manger.</p>", "position": "bottom_left"}}, "button_PTPMEK": {"type": "button", "settings": {"text": "Voir nos ingrédients", "url": "shopify://pages/ingredients", "position": "bottom_left", "style": "solid", "background": "#7d3fff", "text_color": "#ffffff"}}}, "block_order": ["subheading_AzRfPX", "heading_T6yRr8", "richtext_EqtyF9", "richtext_JL8jd6", "button_PTPMEK"], "name": "t:sections.text_with_media.name", "settings": {"color_scheme": "", "content_position": "end", "content_percentage_width": 50, "overlay_color": "#000000", "overlay_opacity": 20, "add_media_spacing": false, "autoplay_video": false, "primary_image": "shopify://shop_images/Powder.jpg", "secondary_media_width": 55, "secondary_media_mobile_width": 60, "show_secondary_media_on_mobile": true, "secondary_media_alignment": "place-self-center", "secondary_media_shape": "none"}}, "separator_adjustable_Fi6xnq": {"type": "separator-adjustable", "name": "Séparateur réglable", "settings": {"color": "#dad4e2", "thickness": 1, "width": 100, "line_style": "solid", "spacing_top": 0, "spacing_bottom": 0}}, "1763466816ac9eee2b": {"type": "apps", "blocks": {"loox_reviews_loox_dynamic_section_kaEhEh": {"type": "shopify://apps/loox-reviews/blocks/loox-dynamic-section/5c3b337f-fd14-4df5-b1d6-80ec13e6e28e", "settings": {"reviews_to_display": "", "default_tab": "automatic", "only_photos": false, "aggregated": false, "limit": 20, "hide_thumbnails": false, "maxwidth": 1080, "is_sample": false}}, "section-header": {"type": "_section-header", "static": true, "settings": {"subheading": "", "title": "Témoignages", "content": "<p>Découvrez les avis de celles et ceux qui ont fait d’<strong>Uburn</strong> un essentiel de leur routine.</p>", "button_text": "", "button_link": "", "button_style": "outline", "text_alignment": "left", "heading_size": "h3", "title_icon": "none", "show_scrolling_title": false}, "blocks": {}}}, "block_order": ["loox_reviews_loox_dynamic_section_kaEhEh"], "settings": {"color_scheme": "", "add_vertical_spacing": true, "add_horizontal_spacing": true}}, "collection_list_r8VBKW": {"type": "collection-list", "blocks": {"section-header": {"type": "_section-header", "static": true, "settings": {"subheading": "", "title": "étapes", "content": "<p>Prélevez simplement <strong>une dose d’UBE</strong> grâce à la cuillère doseuse fournie, la quantité idéale pour un <strong>apport précis et immédiat</strong>. Versez ensuite cette dose dans une gourde remplie de <strong>250 ml d’eau, de lait ou même de café</strong>, selon vos préférences. <strong>Secouez soigneusement</strong>, puis savourez une <strong>boisson gourmande, pratique et efficace</strong>, à déguster où vous voulez et quand vous le souhaitez.</p><p><a href=\"/products/ube-poudre\" title=\"UBE - POUDRE\"><strong>Passez à l’étape supérieure et commandez.</strong></a></p>", "button_text": "", "button_link": "", "button_style": "outline", "text_alignment": "left", "heading_size": "h3", "title_icon": "none", "show_scrolling_title": false}, "blocks": {}}}, "name": "t:sections.collection_list.name", "settings": {"color_scheme": "", "items_per_row": 3, "stack_on_mobile": true, "add_horizontal_spacing": true, "content_position": "inside", "column_spacing": "md", "image_size": "auto"}}, "faq_ahgahg": {"type": "faq", "blocks": {"category_securite": {"type": "category", "settings": {"title": "Sécurité et Composition", "icon": "picto-ingredient", "icon_width": 24, "mobile_icon_width": 20}}, "question_allergenes": {"type": "question", "settings": {"question": "UBurn contient-il des allergènes ou substances nocives ?", "answer": "<p>Non, UBurn ne contient pas d'allergènes courants. Tous nos ingrédients sont d'origine naturelle et soigneusement sélectionnés pour leur sécurité et leur efficacité. Notre formule est certifiée sans gluten, sans lactose et sans OGM.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "question_danger_sante": {"type": "question", "settings": {"question": "Est-ce que UBurn est sans danger pour la santé ?", "answer": "<p>Oui, UBurn est sans danger pour la santé lorsqu'il est consommé conformément aux recommandations. Notre formule est développée avec des ingrédients naturels et validée par des experts en nutrition. Toutefois, en cas de doute, consultez votre médecin avant de commencer.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "category_efficacite": {"type": "category", "settings": {"title": "Efficacité et Résultats", "icon": "picto-star", "icon_width": 24, "mobile_icon_width": 20}}, "question_perte_poids": {"type": "question", "settings": {"question": "Comment UBurn agit-il sur la satiété ?", "answer": "<p>UBurn agit sur plusieurs leviers : il booste le métabolisme, réduit l'appétit et favorise la gestion de l'appétit. Grâce à ses actifs naturels, il aide votre corps à transformer les graisses en énergie plus efficacement.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "question_combien_temps": {"type": "question", "settings": {"question": "Combien de temps avant de voir des résultats ?", "answer": "<p>La plupart des utilisateurs remarquent une satiété jusqu'à 6h dès la première semaine, associée à une alimentation équilibrée.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "category_utilisation": {"type": "category", "settings": {"title": "Utilisation et Préparation", "icon": "picto-recipe", "icon_width": 24, "mobile_icon_width": 20}}, "question_quand_prendre": {"type": "question", "settings": {"question": "Quand prendre UBurn et combien de fois par jour ?", "answer": "<p>Nous recommandons de prendre UBurn 1 à 3 fois par jour selon votre objectif, de préférence le matin ou avant les repas. Chaque dose se prépare en mélangeant 1 mesure de poudre avec 250 ml d'eau froide ou chaude.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "question_comment_preparer": {"type": "question", "settings": {"question": "Comment préparer UBurn ?", "answer": "<p>Mélangez simplement 1 mesure (10g) de poudre UBurn avec 250 ml d'eau. Vous pouvez le consommer chaud ou froid selon vos préférences. Vous pouvez aussi l'incorporer dans un smoothie ou un yaourt.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "category_contre_indications": {"type": "category", "settings": {"title": "Contre-indications et Précautions", "icon": "picto-document", "icon_width": 24, "mobile_icon_width": 20}}, "question_contre_indications": {"type": "question", "settings": {"question": "Y a-t-il des contre-indications à UBurn ?", "answer": "<p>UBurn est déconseillé aux femmes enceintes et allaitantes, aux enfants de moins de 18 ans, et aux personnes sous traitement médical sans avis préalable de leur médecin. En cas de doute, consultez votre professionnel de santé avant de commencer.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "category_commande": {"type": "category", "settings": {"title": "Commande et Livraison", "icon": "picto-delivery", "icon_width": 24, "mobile_icon_width": 20}}, "question_retour": {"type": "question", "settings": {"question": "Puis-je retourner le produit si je ne suis pas satisfait(e) ?", "answer": "<p>Oui, si vous n'êtes pas satisfait(e) de votre achat, contactez notre service client et nous trouverons une solution adaptée.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}, "question_delais_livraison": {"type": "question", "settings": {"question": "Quels sont les délais de livraison ?", "answer": "<p>Nous expédions votre commande sous 24-48h ouvrées. La livraison en France métropolitaine prend généralement 2 à 4 jours ouvrés. La livraison est offerte dès 30€ d'achat.</p>", "icon": "none", "icon_width": 24, "mobile_icon_width": 20}}}, "block_order": ["category_securite", "question_allergenes", "question_danger_sante", "category_efficacite", "question_perte_poids", "question_combien_temps", "category_utilisation", "question_quand_prendre", "question_comment_preparer", "category_contre_indications", "question_contre_indications", "category_commande", "question_retour", "question_delais_livraison"], "settings": {"color_scheme": "scheme-1", "layout": "stacked", "accordion_style": "border", "question_style": "text", "subheading": "QUESTIONS FRÉQUENTES", "title": "Tout ce que vous devez savoir sur UBurn", "title_tag": "h3", "content": "", "button_text": "", "button_url": "", "button_style": "solid"}}}, "order": ["main", "trust_icons_my9GCC", "multi_column_MHejQP", "ss_scrolling_logo_cloud_zHwEQq", "separator_adjustable_wJXUqG", "text_with_media_6nbr7X", "trust_icons_jAMQBc", "multi_column_QCLMjx", "separator_adjustable_pQXxig", "separator_adjustable_xxbed6", "text_with_media_mwqBjX", "text_with_media_HYdW4P", "separator_adjustable_Fi6xnq", "1763466816ac9eee2b", "collection_list_r8VBKW", "faq_ahgahg"]}