ff"},"blocks":{}}},"block_order":["button_mq7KxJ"]}},"block_order":["dynamic_grid_item_g6RBiT","dynamic_grid_item_pb4RbC","dynamic_grid_item_xKkK8W","dynamic_grid_item_UbGxRL","dynamic_grid_item_QXPMiw","dynamic_grid_item_e4R8qt","dynamic_grid_item_geACUx"],"name":"t:sections.dynamic_grid.name","settings":{"color_scheme":"","allow_transparent_header":true,"show_background_image_parallax":false,"add_vertical_spacing":true,"add_horizontal_spacing":true,"gap":16,"mobile_gap":10,"overlay_color":"#000000","overlay_opacity":20}},"multi_column_jzrPEJ":{"type":"multi-column","blocks":{"multi_column_column_zK7xzP":{"type":"_multi-column-column","settings":{"color_scheme":"","text_alignment":"left"},"blocks":{"image_KYqYn3":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Histoire_01.jpg","max_width":100,"mobile_max_width":100},"blocks":{}},"heading_M7gYYT":{"type":"heading","settings":{"text":"L’UBÉ, LE SECRET VIOLET","heading_size":"h4","html_tag":"p","indent":"none","highlight_effect":"default","highlight_accent_color":"","highlight_text_color":""},"blocks":{}},"rich_text_RJe8mh":{"type":"rich-text","settings":{"text":"<p>C’est lors d’un voyage en Asie que nous avons découvert l’UBÉ, ce tubercule violet au goût délicatement sucré, utilisé depuis des générations dans la cuisine traditionnelle pour ses vertus nutritives et énergisantes.<\/p><p>Fascinés par ses bienfaits naturels et sa richesse en antioxydants, nous avons décidé de le faire découvrir en France, sous une forme simple, authentique et accessible à tous.<\/p>","content_width":"sm"},"blocks":{}}},"block_order":["image_KYqYn3","heading_M7gYYT","rich_text_RJe8mh"]},"multi_column_column_PDNy9q":{"type":"_multi-column-column","settings":{"color_scheme":"","text_alignment":"left"},"blocks":{"image_aJaEtb":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Histoire_02.jpg","max_width":100,"mobile_max_width":100},"blocks":{}},"heading_HCDXQ3":{"type":"heading","settings":{"text":"UNE FORMULE À L’ACTION COMPLÈTE","heading_size":"h4","html_tag":"p","indent":"none","highlight_effect":"default","highlight_accent_color":"","highlight_text_color":""},"blocks":{}},"rich_text_YAMnPK":{"type":"rich-text","settings":{"text":"<p>Pour créer une boisson sur mesure et ultra performante, nous avons associé l’UBÉ à une sélection d’ingrédients soigneusement choisis.<br\/><br\/>Chaque ingrédient a un rôle : <\/p><ul><li> <strong>Glucomannane<\/strong> : aide à garder la satiété plus longtemps.<\/li><li><strong>Fibre d’acacia <\/strong>: soutient la digestion.   <\/li><li><strong>Gingembre violet <\/strong>: booste l’énergie et protège les cellules.<\/li><li><strong>L-Carnitine<\/strong> : aide à transformer les graisses en énergie.<\/li><li><strong>MCT de coco <\/strong>: apporte une énergie rapide et durable.<\/li><\/ul><p>Ces actifs naturels agissent ensemble pour booster la satiété, soutenir le métabolisme et restaurer l’énergie.<\/p>","content_width":"sm"},"blocks":{}}},"block_order":["image_aJaEtb","heading_HCDXQ3","rich_text_YAMnPK"]},"section-header":{"type":"_section-header","static":true,"settings":{"subheading":"","title":"","content":"","button_text":"","button_link":"","button_style":"outline","text_alignment":"left","heading_size":"h3","title_icon":"none","show_scrolling_title":false},"blocks":{}}},"block_order":["multi_column_column_zK7xzP","multi_column_column_PDNy9q"],"name":"t:sections.multi_column.name","settings":{"color_scheme":"","show_internal_borders":false,"add_horizontal_spacing":true,"add_top_spacing":true,"add_bottom_spacing":true,"items_per_row":2,"stack_on_mobile":false,"stack_on_desktop":true,"column_spacing":"md","row_spacing":"md"}},"image_with_text_overlay_VrGpkD":{"type":"image-with-text-overlay","blocks":{"subheading_PTHETG":{"type":"subheading","settings":{"text":""},"blocks":{}},"heading_DB3BN9":{"type":"heading","settings":{"text":"notre mission","heading_size":"h3","html_tag":"p","indent":"none","highlight_effect":"default","highlight_accent_color":"","highlight_text_color":""},"blocks":{}},"rich_text_WmhLp8":{"type":"rich-text","settings":{"text":"<p>Nous sélectionnons soigneusement nos tubercules d’Ubé, cultivés dans le respect des traditions locales et de la nature.Chaque étape, de la récolte à la transformation, se fait en collaboration avec des producteurs passionnés, afin de garantir une qualité irréprochable et un goût unique.<\/p><p>Proposer une alternative naturelle, savoureuse et fonctionnelle pour se sentir bien, jour après jour sans compromis entre efficacité et plaisir.<\/p>","content_width":"sm"},"blocks":{}}},"block_order":["subheading_PTHETG","heading_DB3BN9","rich_text_WmhLp8"],"name":"t:sections.image_with_text_overlay.name","settings":{"color_scheme":"","allow_transparent_header":true,"image_size":"auto","image":"shopify:\/\/shop_images\/Mission_D.jpg","mobile_image":"shopify:\/\/shop_images\/Mission_M.jpg","overlay_color":"#000000","overlay_opacity":20,"enable_sticky_content":false,"content_width":"md","desktop_text_position":"sm:place-self-end-start","mobile_text_position":"place-self-center"}}},"order":["main","image_with_text_overlay_Kjfc4k","dynamic_grid_nCiign","multi_column_jzrPEJ","image_with_text_overlay_VrGpkD"]}