{%- comment -%}
  UBurn V2 — PDP 3 simple steps (snippet) — rendered inline from u2-pdp-before-after-workday
  Bypass admin-lock on JSON template (Charles requested reorder above 'Your 4 PM. Rewritten.')
  Rev 2026-05-20
{%- endcomment -%}
<style>
  .u2-pdp-steps { padding: 80px 20px; background: var(--u2-cream); }
  .u2-pdp-steps__inner { max-width: 1200px; margin: 0 auto; }
  .u2-pdp-steps__head { text-align: center; margin-bottom: 56px; }
  .u2-pdp-steps__eyebrow {
    display: inline-block;
    font-family: var(--u2-sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .u2-pdp-steps__title {
    font-family: var(--u2-serif);
    font-size: 44px;
    line-height: 1.05;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0;
    letter-spacing: -0.025em;
  }
  .u2-pdp-steps__title em { font-style: italic; color: var(--u2-iris); }
  .u2-pdp-steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .u2-pdp-step-card {
    background: var(--u2-cream);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(42, 16, 84, 0.08);
    border: 1px solid rgba(107, 78, 158, 0.06);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .u2-pdp-step-card__media {
    aspect-ratio: 1 / 1;
    background: linear-gradient(135deg, var(--u2-lavender-soft), var(--u2-cream));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .u2-pdp-step-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .u2-pdp-step-card__num {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--u2-plum-black);
    color: var(--u2-cream);
    font-family: var(--u2-sans);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 6px 12px;
    border-radius: 999px;
  }
  .u2-pdp-step-card__body { padding: 28px 24px 32px; }
  .u2-pdp-step-card__title {
    font-family: var(--u2-serif);
    font-size: 24px;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0 0 10px;
    letter-spacing: -0.015em;
  }
  .u2-pdp-step-card__copy {
    font-family: var(--u2-sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--u2-plum);
    margin: 0;
  }
  @media (max-width: 900px) {
    .u2-pdp-steps { padding: 60px 16px; }
    .u2-pdp-steps__grid { grid-template-columns: 1fr; gap: 20px; }
    .u2-pdp-steps__title { font-size: 30px; }
  }
</style>
<section class="u2-root u2-pdp-steps" aria-labelledby="u2-pdp-steps-title">
  <div class="u2-pdp-steps__inner">
    <div class="u2-pdp-steps__head">
      <span class="u2-pdp-steps__eyebrow">3 simple steps</span>
      <h2 class="u2-pdp-steps__title" id="u2-pdp-steps-title">30 seconds <em>to change the moment.</em></h2>
    </div>
    <div class="u2-pdp-steps__grid">
      <article class="u2-pdp-step-card"><div class="u2-pdp-step-card__media"><img src="{{ 'uburn-us-pdp-step-1-mix.png' | asset_url }}" alt="Woman pouring UBurn violet powder into a glass of water" loading="lazy" decoding="async" width="1024" height="1024" style="width:100%;height:100%;object-fit:cover;"></div><div class="u2-pdp-step-card__num">01</div><div class="u2-pdp-step-card__body"><h3 class="u2-pdp-step-card__title">Mix</h3><p class="u2-pdp-step-card__copy">One scoop in a large glass of cold water or plant-based milk.</p></div></article>
      <article class="u2-pdp-step-card"><div class="u2-pdp-step-card__media"><img src="{{ 'uburn-us-pdp-step-2-sip.png' | asset_url }}" alt="Woman holding a tall iced violet UBurn glass" loading="lazy" decoding="async" width="1024" height="1024" style="width:100%;height:100%;object-fit:cover;"></div><div class="u2-pdp-step-card__num">02</div><div class="u2-pdp-step-card__body"><h3 class="u2-pdp-step-card__title">Sip</h3><p class="u2-pdp-step-card__copy">A purple drink, smooth, cool, and creamy.</p></div></article>
      <article class="u2-pdp-step-card"><div class="u2-pdp-step-card__media"><img src="{{ 'uburn-us-pdp-step-3-stay.png' | asset_url }}" alt="Calm focused woman in her kitchen after her UBurn ritual" loading="lazy" decoding="async" width="1024" height="1024" style="width:100%;height:100%;object-fit:cover;"></div><div class="u2-pdp-step-card__num">03</div><div class="u2-pdp-step-card__body"><h3 class="u2-pdp-step-card__title">Stay in control*</h3><p class="u2-pdp-step-card__copy">A feeling of fullness that helps you through the critical moment.*</p></div></article>
    </div>
  </div>
</section>
