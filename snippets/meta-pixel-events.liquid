{%- comment -%}
  Meta Pixel events — browser-side tracking
  Currency is dynamic via cart.currency.iso_code (EUR for FR, USD for US market)
  ViewContent: product page (immediate)
  AddToCart: hook into theme's cart:change custom event (AJAX-safe)
  InitiateCheckout: intercept checkout button click + form submit
{%- endcomment -%}

{%- assign _currency = cart.currency.iso_code -%}
{%- assign _market = localization.market.handle | upcase | default: 'FR' -%}

{% if request.page_type == 'product' %}
  <script>
    (function() {
      var eventID = 'VC-' + Date.now() + '-' + Math.random().toString(36).substring(2, 11);
      if (typeof fbq !== 'function') return;
      fbq('track', 'ViewContent', {
        content_name: {{ product.title | json }},
        content_ids: ['shopify_{{ _market }}_{{ product.id }}_{{ product.selected_or_first_available_variant.id }}'],
        content_type: 'product',
        value: {{ product.price | divided_by: 100.0 }},
        currency: {{ _currency | json }}
      }, { eventID: eventID });
    })();
  </script>
{% endif %}

<script>
  (function() {
    var _currency = {{ _currency | json }};
    var _market   = {{ _market | json }};

    document.documentElement.addEventListener('cart:change', function(e) {
      if (!e.detail || e.detail.baseEvent !== 'variant:add') return;
      var cart = e.detail.cart;
      if (!cart) return;

      var eventID = 'ATC-' + Date.now() + '-' + Math.random().toString(36).substring(2, 11);
      var items = cart.items || [];
      var lastItem = items[0];
      var value = lastItem ? (lastItem.final_line_price / 100) : (cart.total_price / 100);

      if (typeof fbq === 'function') {
        fbq('track', 'AddToCart', {
          content_ids: lastItem ? ['shopify_' + _market + '_' + lastItem.product_id + '_' + lastItem.variant_id] : [],
          content_type: 'product',
          value: value,
          currency: _currency,
          num_items: lastItem ? lastItem.quantity : 1
        }, { eventID: eventID });
      }

      if (typeof gtag === 'function' && lastItem) {
        gtag('event', 'add_to_cart', {
          currency: _currency,
          value: value,
          items: [{
            item_id: '' + lastItem.product_id,
            item_name: lastItem.title,
            item_variant: '' + lastItem.variant_id,
            price: value,
            quantity: lastItem.quantity
          }]
        });
      }
    });
  })();
</script>

<script>
  (function() {
    var icFired = false;
    var _currency = {{ _currency | json }};

    function fireIC() {
      if (icFired) return;
      icFired = true;
      var eventID = 'IC-' + Date.now() + '-' + Math.random().toString(36).substring(2, 11);
      if (typeof fbq === 'function') {
        fbq('track', 'InitiateCheckout', { currency: _currency }, { eventID: eventID });
      }
      if (typeof gtag === 'function') {
        gtag('event', 'begin_checkout', { currency: _currency });
      }
    }

    document.addEventListener('submit', function(e) {
      if (e.target && e.target.querySelector('[name="checkout"]')) fireIC();
    });
    document.addEventListener('click', function(e) {
      if (e.target.closest('[name="checkout"], a[href*="/checkout"], a[href*="checkouts"]')) fireIC();
    });
  })();
</script>
