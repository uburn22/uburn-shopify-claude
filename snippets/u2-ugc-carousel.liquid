{%- comment -%}
  UBurn V2 — UGC video carousel (snippet) — rendered inline from u2-pdp.liquid
  Mobile-first TikTok-style 9:16 cards · 4 videos hosted as theme assets
  Rev 2026-05-19 v2 — active-emphasis + progress bar + tap-to-pause + mute toggle
  + mini-CTA + keyboard nav + smart preload
{%- endcomment -%}
<style>
  .u2-ugc {
    background: transparent;
    padding: 4px 0 8px;
    margin: 8px -16px 14px;
    position: relative;
  }
  .u2-ugc__inner {
    max-width: 100%;
    margin: 0;
    position: relative;
  }

  /* Rail */
  .u2-ugc__rail {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 20px 20px 20px;
    scroll-padding-left: 20px;
    scroll-padding-right: 20px;
    margin-top: 8px;
  }
  .u2-ugc__rail::-webkit-scrollbar { display: none; }
  .u2-ugc__rail:focus-visible { outline: 2px solid var(--u2-iris); outline-offset: -2px; border-radius: 8px; }

  /* Card */
  .u2-ugc__card {
    flex: 0 0 78%;
    max-width: 320px;
    scroll-snap-align: center;
    scroll-snap-stop: always;
    background: var(--u2-warm-white);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 14px 32px -14px rgba(26, 15, 46, 0.18);
    border: 1px solid rgba(107, 78, 158, 0.10);
    display: flex;
    flex-direction: column;
    transition: transform 0.5s var(--u2-ease-luxe), box-shadow 0.5s var(--u2-ease-luxe), opacity 0.4s ease;
    position: relative;
    transform: scale(0.94);
    opacity: 0.78;
  }
  .u2-ugc__card.is-active {
    transform: scale(1);
    opacity: 1;
    box-shadow: 0 26px 56px -18px rgba(107, 78, 158, 0.32), 0 4px 14px rgba(26, 15, 46, 0.10);
  }

  /* Media */
  .u2-ugc__media {
    position: relative;
    aspect-ratio: 9 / 16;
    background: var(--u2-lavender-soft);
    overflow: hidden;
    cursor: pointer;
  }
  .u2-ugc__media video {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .u2-ugc__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 45%, rgba(26, 15, 46, 0.55) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Progress bar (TikTok-style at top of media) */
  .u2-ugc__progress {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.20);
    z-index: 3;
    overflow: hidden;
  }
  .u2-ugc__progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--u2-iris) 0%, var(--u2-iris-bright) 100%);
    transition: width 0.15s linear;
  }

  /* Verified */
  .u2-ugc__verified {
    position: absolute;
    top: 14px; left: 14px;
    z-index: 2;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--u2-plum-black);
    font-family: var(--u2-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .u2-ugc__verified::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--u2-iris);
    animation: u2-ugc-pulse 2s ease-in-out infinite;
  }
  @keyframes u2-ugc-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(107, 78, 158, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(107, 78, 158, 0); }
  }

  /* Mute toggle (top-right) */
  .u2-ugc__mute {
    position: absolute;
    top: 14px; right: 14px;
    z-index: 2;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--u2-plum-black);
    border: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s var(--u2-ease-luxe), background 0.2s ease;
    box-shadow: 0 3px 10px rgba(26, 15, 46, 0.25);
  }
  .u2-ugc__mute:hover { background: #fff; transform: scale(1.08); }
  .u2-ugc__mute svg { width: 16px; height: 16px; }
  .u2-ugc__mute .u2-ugc__mute-on { display: block; }
  .u2-ugc__mute .u2-ugc__mute-off { display: none; }
  .u2-ugc__mute.is-unmuted .u2-ugc__mute-on { display: none; }
  .u2-ugc__mute.is-unmuted .u2-ugc__mute-off { display: block; }

  /* Center play button (visible only when paused) */
  .u2-ugc__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.85);
    width: 56px; height: 56px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--u2-plum-black);
    border: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    z-index: 2;
    box-shadow: 0 6px 18px rgba(26, 15, 46, 0.35);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.25s var(--u2-ease-luxe), opacity 0.25s ease, background 0.25s ease;
  }
  .u2-ugc__card.is-paused .u2-ugc__play {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, -50%) scale(1);
  }
  .u2-ugc__play:hover { background: #fff; transform: translate(-50%, -50%) scale(1.06); }

  /* Quote overlay */
  .u2-ugc__quote-overlay {
    position: absolute;
    bottom: 14px; left: 14px; right: 14px;
    z-index: 2;
    color: #fff;
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 17px;
    line-height: 1.25;
    letter-spacing: -0.005em;
    margin: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
  }

  /* Body — name + city + mini CTA */
  .u2-ugc__body {
    padding: 14px 18px 16px;
    background: var(--u2-warm-white);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .u2-ugc__name {
    font-family: var(--u2-sans);
    font-size: 13px;
    font-weight: 700;
    color: var(--u2-plum-black);
    line-height: 1.25;
  }
  .u2-ugc__loc {
    display: block;
    font-size: 11px;
    color: var(--u2-text-muted);
    font-weight: 500;
    margin-top: 1px;
    letter-spacing: 0.02em;
  }
  .u2-ugc__cta {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    width: 100%;
    background: transparent;
    color: var(--u2-plum-black);
    font-family: var(--u2-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 10px 0 0;
    border: 0;
    border-top: 1px solid rgba(107, 78, 158, 0.14);
    cursor: pointer;
    transition: color 0.25s ease;
  }
  .u2-ugc__cta:hover { color: var(--u2-iris); }
  .u2-ugc__cta-arrow {
    font-size: 14px;
    transition: transform 0.25s var(--u2-ease-luxe);
  }
  .u2-ugc__cta:hover .u2-ugc__cta-arrow { transform: translateX(4px); }

  /* Dots */
  .u2-ugc__dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 8px 20px 0;
  }
  .u2-ugc__dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: rgba(107, 78, 158, 0.25);
    transition: background var(--u2-duration-fast) ease, width var(--u2-duration-fast) var(--u2-ease-luxe);
    cursor: pointer;
    border: 0;
    padding: 0;
  }
  .u2-ugc__dot.is-active {
    background: var(--u2-iris);
    width: 22px;
    border-radius: 999px;
  }

  /* Nav arrows desktop */
  .u2-ugc__nav { display: none; }
  @media (min-width: 768px) {
    .u2-ugc__rail { padding-left: 32px; padding-right: 32px; }
    .u2-ugc__card { flex: 0 0 280px; }
    .u2-ugc__nav {
      display: flex;
      justify-content: center;
      gap: 12px;
      margin-top: 16px;
    }
    .u2-ugc__nav button {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: var(--u2-warm-white);
      border: 1px solid rgba(107, 78, 158, 0.20);
      color: var(--u2-plum-black);
      cursor: pointer;
      transition: background var(--u2-duration-fast) ease, transform var(--u2-duration-fast) var(--u2-ease-luxe), border-color var(--u2-duration-fast) ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }
    .u2-ugc__nav button:hover {
      background: var(--u2-iris);
      color: var(--u2-bone);
      border-color: var(--u2-iris);
      transform: translateY(-1px);
    }
    .u2-ugc__nav button:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }
  }
  @media (min-width: 1024px) {
    .u2-ugc__card { flex: 0 0 300px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .u2-ugc__card,
    .u2-ugc__play,
    .u2-ugc__dot,
    .u2-ugc__progress-bar,
    .u2-ugc__verified::before { transition: none !important; animation: none !important; }
  }
</style>

<section class="u2-root u2-ugc" aria-label="Real users, real ritual">
  <div class="u2-ugc__inner">

    {%- liquid
      assign ugc_names = 'Sarah J., 32|Jennifer M., 38|Rachel B., 47|Megan T., 39' | split: '|'
      assign ugc_locs = 'Brooklyn, NY|Miami, FL|Denver, CO|Austin, TX' | split: '|'
      assign ugc_quotes = 'No more 4PM cravings.|Calmer afternoons. More stable energy.|Vanilla taste. Nothing chemical.|Before workouts. Stim-free.' | split: '|'
      assign ugc_videos = 'ugc-1-sarah.mp4|ugc-2-jennifer.mp4|ugc-3-rachel.mp4|ugc-4-megan.mp4' | split: '|'
    -%}

    <div class="u2-ugc__rail" id="u2-ugc-rail" role="region" aria-label="Customer video testimonials" tabindex="0">
      {%- for n in ugc_names -%}
        {%- liquid
          assign idx = forloop.index0
        -%}
        <article class="u2-ugc__card{% if forloop.first %} is-active{% endif %} is-paused" data-ugc-card data-index="{{ idx }}">
          <div class="u2-ugc__media" data-ugc-tap>
            <div class="u2-ugc__progress" aria-hidden="true"><div class="u2-ugc__progress-bar" data-ugc-progress></div></div>
            <span class="u2-ugc__verified" aria-hidden="true">Real user</span>
            <button type="button" class="u2-ugc__mute" data-ugc-mute aria-label="Unmute video" aria-pressed="false">
              <svg class="u2-ugc__mute-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
              <svg class="u2-ugc__mute-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
            </button>
            <video data-ugc-video muted loop playsinline preload="none">
              <source data-src="{{ ugc_videos[idx] | asset_url }}" type="video/mp4">
            </video>
            <button type="button" class="u2-ugc__play" data-ugc-play aria-label="Play video">▶</button>
            <p class="u2-ugc__quote-overlay">"{{ ugc_quotes[idx] }}"</p>
          </div>
          <div class="u2-ugc__body">
            <div>
              <div class="u2-ugc__name">{{ n }}</div>
              <span class="u2-ugc__loc">{{ ugc_locs[idx] }}</span>
            </div>
            <a href="#u2-pdp-form" class="u2-ugc__cta" data-ugc-cta>
              <span>Try the ritual</span>
              <span class="u2-ugc__cta-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    <div class="u2-ugc__dots" aria-hidden="true">
      {%- for n in ugc_names -%}
        <button type="button" class="u2-ugc__dot{% if forloop.first %} is-active{% endif %}" data-ugc-dot data-index="{{ forloop.index0 }}" aria-label="Story {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>

    <div class="u2-ugc__nav" aria-hidden="true">
      <button type="button" data-ugc-nav="prev" aria-label="Previous">←</button>
      <button type="button" data-ugc-nav="next" aria-label="Next">→</button>
    </div>

  </div>
</section>

<script>
(function(){
  'use strict';
  var rail = document.getElementById('u2-ugc-rail');
  if(!rail) return;
  var cards = rail.querySelectorAll('[data-ugc-card]');
  var dots = document.querySelectorAll('[data-ugc-dot]');
  var navBtns = document.querySelectorAll('[data-ugc-nav]');
  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var unmuted = false;

  function getActiveIndex(){
    var center = rail.scrollLeft + (rail.clientWidth / 2);
    var best = 0; var bestDist = Infinity;
    cards.forEach(function(card, i){
      var cardCenter = card.offsetLeft + (card.offsetWidth / 2);
      var dist = Math.abs(cardCenter - center);
      if(dist < bestDist){ bestDist = dist; best = i; }
    });
    return best;
  }

  // Smart preload — set src on adjacent cards (active ± 1), unload others
  function smartPreload(){
    var active = getActiveIndex();
    cards.forEach(function(card, i){
      var video = card.querySelector('[data-ugc-video]');
      if(!video) return;
      var src = video.querySelector('source');
      if(!src) return;
      var dist = Math.abs(i - active);
      if(dist <= 1){
        if(!src.getAttribute('src')){
          src.setAttribute('src', src.getAttribute('data-src'));
          video.preload = 'metadata';
          video.load();
        }
      }
    });
  }

  function syncActive(){
    var idx = getActiveIndex();
    dots.forEach(function(d, i){
      d.classList.toggle('is-active', i === idx);
      d.setAttribute('aria-current', i === idx ? 'true' : 'false');
    });
    cards.forEach(function(c, i){ c.classList.toggle('is-active', i === idx); });
    var prevBtn = document.querySelector('[data-ugc-nav="prev"]');
    var nextBtn = document.querySelector('[data-ugc-nav="next"]');
    if(prevBtn) prevBtn.disabled = idx === 0;
    if(nextBtn) nextBtn.disabled = idx === cards.length - 1;
    smartPreload();
  }

  var scrollT;
  rail.addEventListener('scroll', function(){
    clearTimeout(scrollT); scrollT = setTimeout(syncActive, 80);
  }, { passive: true });

  function scrollToIdx(i){
    var card = cards[i];
    if(!card) return;
    var target = card.offsetLeft - (rail.clientWidth - card.offsetWidth) / 2;
    rail.scrollTo({ left: target, behavior: reduceMotion ? 'auto' : 'smooth' });
  }

  dots.forEach(function(d){
    d.addEventListener('click', function(){ scrollToIdx(parseInt(d.dataset.index, 10)); });
  });
  navBtns.forEach(function(b){
    b.addEventListener('click', function(){
      var current = getActiveIndex();
      var next = b.dataset.ugcNav === 'next' ? Math.min(current + 1, cards.length - 1) : Math.max(current - 1, 0);
      scrollToIdx(next);
    });
  });

  // Keyboard nav (when rail focused)
  rail.addEventListener('keydown', function(e){
    if(e.key === 'ArrowRight'){
      e.preventDefault();
      scrollToIdx(Math.min(getActiveIndex() + 1, cards.length - 1));
    } else if(e.key === 'ArrowLeft'){
      e.preventDefault();
      scrollToIdx(Math.max(getActiveIndex() - 1, 0));
    }
  });

  // IntersectionObserver — autoplay on visible
  if('IntersectionObserver' in window){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        var card = e.target;
        var video = card.querySelector('[data-ugc-video]');
        if(!video) return;
        var src = video.querySelector('source[data-src]');
        if(src && !src.getAttribute('src')){
          src.setAttribute('src', src.getAttribute('data-src'));
          video.load();
        }
        if(e.isIntersecting && e.intersectionRatio > 0.5 && !reduceMotion){
          if(unmuted) { video.muted = false; }
          var p = video.play();
          if(p && p.catch) p.catch(function(){});
        } else {
          video.pause();
        }
      });
    }, { threshold: [0, 0.5, 1] });
    cards.forEach(function(c){ io.observe(c); });
  }

  // Per-card setup
  cards.forEach(function(card){
    var video = card.querySelector('[data-ugc-video]');
    var playBtn = card.querySelector('[data-ugc-play]');
    var tapArea = card.querySelector('[data-ugc-tap]');
    var muteBtn = card.querySelector('[data-ugc-mute]');
    var progressBar = card.querySelector('[data-ugc-progress]');
    if(!video) return;

    function reflectPause(){
      card.classList.toggle('is-paused', video.paused);
    }
    video.addEventListener('play', reflectPause);
    video.addEventListener('pause', reflectPause);

    // Progress bar update
    video.addEventListener('timeupdate', function(){
      if(!progressBar || !video.duration) return;
      var pct = (video.currentTime / video.duration) * 100;
      progressBar.style.width = pct + '%';
    });

    // Play button
    if(playBtn){
      playBtn.addEventListener('click', function(e){
        e.stopPropagation();
        if(video.paused){ var p = video.play(); if(p && p.catch) p.catch(function(){}); }
        else { video.pause(); }
      });
    }

    // Tap on media area
    if(tapArea){
      tapArea.addEventListener('click', function(e){
        if(e.target.closest('[data-ugc-mute]') || e.target.closest('[data-ugc-play]')) return;
        if(video.paused){ var p = video.play(); if(p && p.catch) p.catch(function(){}); }
        else { video.pause(); }
      });
    }

    // Mute toggle (global state — all videos sync)
    if(muteBtn){
      muteBtn.addEventListener('click', function(e){
        e.stopPropagation();
        unmuted = !unmuted;
        // Apply to all videos
        cards.forEach(function(c){
          var v = c.querySelector('[data-ugc-video]');
          var mb = c.querySelector('[data-ugc-mute]');
          if(v) v.muted = !unmuted;
          if(mb){
            mb.classList.toggle('is-unmuted', unmuted);
            mb.setAttribute('aria-pressed', unmuted ? 'true' : 'false');
            mb.setAttribute('aria-label', unmuted ? 'Mute video' : 'Unmute video');
          }
        });
      });
    }
  });

  syncActive();
})();
</script>
