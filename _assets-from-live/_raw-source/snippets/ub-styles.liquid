<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;800;900&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;800;900&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap" rel="stylesheet"></noscript>
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:'Red Hat Text',sans-serif;background:#fff;color:#242220;overflow-x:hidden;-webkit-font-smoothing:antialiased}
  a{text-decoration:none;color:inherit}img{max-width:100%;display:block}ul{list-style:none}

  :root{
    --purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;--purple-light:#b07de8;
    --purple-pale:#e8dcf5;--purple-wash:#f5f0fa;--cream:#faf9f7;--warm:#f2f0ed;
    --dark:#242220;--body:#5a5654;--muted:#8a8785;
    --grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%);
  }

  /* ===== ANNOUNCE ===== */
  .announce{background:var(--dark);color:#fff;text-align:center;padding:10px 20px;font-size:12.5px;font-weight:600;letter-spacing:.8px;text-transform:uppercase}

  /* ===== NAV ===== */
  .nav{position:sticky;top:0;z-index:100;padding:14px 40px;display:flex;align-items:center;justify-content:space-between;background:#fff;border-bottom:1px solid rgba(0,0,0,.05)}
  .nav-logo{height:28px}
  .nav-right{display:flex;align-items:center;gap:28px}
  .nav-link{font-size:13.5px;font-weight:500;color:var(--body);transition:.2s}
  .nav-link:hover{color:var(--purple-main)}
  .btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;border-radius:100px;font-family:'Red Hat Text',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:.3s;border:none}
  .btn-fill{background:var(--purple-main);color:#fff}
  .btn-fill:hover{background:var(--purple-deep);transform:translateY(-1px);box-shadow:0 6px 20px rgba(107,47,160,.3)}
  .btn-white{background:#fff;color:var(--purple-deep)}
  .btn-white:hover{background:var(--purple-wash);transform:translateY(-1px);box-shadow:0 6px 24px rgba(0,0,0,.15)}
  .btn-outline{background:transparent;color:var(--purple-main);border:1.5px solid var(--purple-pale)}
  .btn-outline:hover{background:var(--purple-wash)}

  /* ===== TRUST RIBBON ===== */
  .ribbon{background:var(--purple-wash);padding:10px 20px;display:flex;justify-content:center;gap:24px;flex-wrap:wrap;font-size:13px;color:var(--body);font-weight:500}

  /* ===== MARQUEE ===== */
  .marquee{padding:12px 0;overflow:hidden;border-bottom:1px solid rgba(0,0,0,.04)}
  .marquee-track{display:flex;gap:40px;animation:slide 25s linear infinite;width:max-content}
  .marquee-item{white-space:nowrap;font-size:12.5px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px;display:flex;align-items:center;gap:10px}
  .marquee-dot{width:5px;height:5px;border-radius:50%;background:var(--purple-light)}
  @keyframes slide{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* ===== HERO ===== */
  .hero{padding:80px 40px 60px;max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
  .hero-tag{display:inline-block;padding:8px 18px;border-radius:100px;background:var(--purple-wash);font-size:13px;font-weight:600;color:var(--purple-main);margin-bottom:24px}
  .hero h1{font-family:'Red Hat Display',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:800;line-height:1.06;margin-bottom:24px;color:var(--dark)}
  .hero h1 .accent{color:var(--purple-mid)}
  .hero-sub{font-size:17px;color:var(--body);line-height:1.65;margin-bottom:28px;max-width:460px}
  .hero-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px}
  .hero-badge{padding:8px 16px;border-radius:100px;border:1px solid rgba(0,0,0,.08);font-size:13px;font-weight:500;color:var(--body);display:flex;align-items:center;gap:6px}
  .hero-badge .ck{color:var(--purple-main);font-weight:700}
  .hero-visual{position:relative;display:flex;justify-content:center}
  .hero-visual img{max-height:520px;width:auto;border-radius:24px;box-shadow:0 32px 80px rgba(61,24,115,.22),0 0 0 1px rgba(107,47,160,.1)}
  .hero-float{position:absolute;background:#fff;border-radius:14px;padding:12px 18px;box-shadow:0 8px 30px rgba(0,0,0,.1);display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;color:var(--dark)}
  .hero-float.top{top:20px;right:0}
  .hero-float.bottom{bottom:40px;left:0}
  .float-badge{padding:4px 10px;border-radius:100px;background:var(--purple-wash);color:var(--purple-main);font-size:11px;font-weight:700}

  /* ===== HERO BONUS BLOCK ===== */
  .hero-bonus{margin-top:20px;background:var(--purple-wash);border:1px solid var(--purple-pale);border-radius:14px;padding:14px 18px}
  .hero-bonus-label{font-size:12px;font-weight:700;color:var(--purple-main);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px}
  .hero-bonus-items{display:flex;flex-direction:column;gap:5px}
  .hero-bonus-items span{font-size:13px;color:var(--dark);font-weight:500;line-height:1.4}
  .hero-bonus-items em{color:var(--muted);font-style:normal;font-size:12px}
  .hero-bonus-total{margin-top:10px;padding-top:10px;border-top:1px solid var(--purple-pale);font-size:13px;color:var(--body)}
  .hero-bonus-total strong{color:var(--purple-deep);font-weight:800}

  /* ===== SECTIONS ===== */
  .section{padding:100px 40px}
  .section-inner{max-width:1100px;margin:0 auto}
  .section-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:2.5px;color:var(--purple-main);margin-bottom:14px}
  .section-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3.2vw,40px);font-weight:700;color:var(--dark);line-height:1.15;margin-bottom:16px}
  .section-title .accent{color:var(--purple-mid)}

  /* ===== PROBLEM SECTION ===== */
  .problem-section{background:var(--cream)}
  .problem-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px}
  .problem-card{background:#fff;border-radius:18px;padding:32px;border:1px solid rgba(0,0,0,.04)}
  .problem-card h3{font-family:'Red Hat Display',sans-serif;font-size:17px;font-weight:700;color:var(--dark);margin-bottom:10px}
  .problem-card p{font-size:14px;color:var(--body);line-height:1.6}
  .problem-punchline{margin-top:40px;font-family:'Red Hat Display',sans-serif;font-size:clamp(20px,2.5vw,28px);font-weight:700;color:var(--dark);text-align:center;line-height:1.3}
  .problem-punchline .accent{color:var(--purple-mid)}

  /* ===== PRODUCT 2-COL ===== */
  .prod-block{padding:100px 40px;overflow:hidden}
  .prod-block.alt{background:var(--cream)}
  .prod-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
  .prod-block.reverse .prod-inner{direction:rtl}
  .prod-block.reverse .prod-text,.prod-block.reverse .prod-visual{direction:ltr}
  .prod-text h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3vw,38px);font-weight:700;color:var(--dark);line-height:1.12;margin-bottom:12px}
  .prod-text h2 .accent{color:var(--purple-mid)}
  .prod-text h3{font-family:'Red Hat Display',sans-serif;font-size:17px;font-weight:500;color:var(--body);margin-bottom:20px;line-height:1.45}
  .prod-text>p{font-size:15px;color:var(--body);line-height:1.7;margin-bottom:28px}
  .feats{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
  .feat{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--body)}
  .feat-ck{width:20px;height:20px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .feat-ck svg{width:12px;height:12px;stroke:var(--purple-main);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
  .prod-img{width:100%;border-radius:24px;overflow:hidden;background:linear-gradient(145deg,#e8dcf5,#f5f0fa);display:flex;align-items:center;justify-content:center;aspect-ratio:1/1}
  .prod-img img{width:85%;height:auto;filter:drop-shadow(0 12px 30px rgba(61,24,115,.15))}
  .prod-img-full img{width:100%;height:100%;object-fit:cover}

  /* ===== HOW IT WORKS ===== */
  .how-section{text-align:center}
  .how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;margin-top:56px;text-align:center}
  .how-step{}
  .how-num{width:52px;height:52px;margin:0 auto 16px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:var(--purple-main)}
  .how-step h4{font-family:'Red Hat Display',sans-serif;font-size:16px;font-weight:700;color:var(--dark);margin-bottom:8px}
  .how-step p{font-size:14px;color:var(--muted);line-height:1.55;max-width:260px;margin:0 auto}

  /* ===== INGREDIENTS ===== */
  .ingr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
  .ingr-card{background:#fff;border-radius:18px;overflow:hidden;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .ingr-card:hover{box-shadow:0 8px 28px rgba(0,0,0,.06);transform:translateY(-2px)}
  .ingr-card-img{width:100%;aspect-ratio:4/3;overflow:hidden;background:var(--cream)}
  .ingr-card-img img{width:100%;height:100%;object-fit:cover}
  .ingr-card-body{padding:20px}
  .ingr-card h4{font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:700;color:var(--dark);margin-bottom:6px}
  .ingr-card p{font-size:13px;color:var(--muted);line-height:1.55}

  /* ===== PRESS BAR ===== */
  .press-bar{padding:40px;text-align:center;border-top:1px solid rgba(0,0,0,.04);border-bottom:1px solid rgba(0,0,0,.04)}
  .press-bar p{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);font-weight:600;margin-bottom:24px}
  .press-logos{display:flex;gap:40px;justify-content:center;align-items:center;flex-wrap:wrap;opacity:.5}
  .press-logos img{height:22px;width:auto}

  /* ===== STATS BANNER ===== */
  .stats-section{padding:100px 40px;background:var(--grad);text-align:center;color:#fff;position:relative;overflow:hidden}
  .stats-section::before{content:'';position:absolute;inset:0;background:url('https://uburn.co/cdn/shop/files/FOND_FIN.jpg?v=1749644803&width=1600') center/cover no-repeat;opacity:.08;mix-blend-mode:luminosity}
  .stats-section>*{position:relative;z-index:1}
  .stats-section .section-inner{max-width:700px}
  .stats-section h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:700;margin-bottom:16px;line-height:1.15}
  .stats-section p{font-size:16px;color:rgba(255,255,255,.7);line-height:1.65;margin-bottom:36px}
  .stats-row{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-top:48px}
  .stat{text-align:center}
  .stat-num{font-family:'Red Hat Display',sans-serif;font-size:42px;font-weight:800}
  .stat-label{font-size:13px;color:rgba(255,255,255,.6);margin-top:4px}

  /* ===== TESTIMONIALS ===== */
  .testi-section{text-align:center}
  .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;text-align:left}
  .testi-card{background:var(--cream);border-radius:20px;padding:32px;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .testi-card:hover{box-shadow:0 8px 30px rgba(0,0,0,.06)}
  .testi-stars{color:var(--purple-main);font-size:14px;margin-bottom:14px;letter-spacing:2px}
  .testi-text{font-size:14.5px;color:var(--body);line-height:1.65;margin-bottom:20px}
  .testi-verified{font-size:11px;color:var(--purple-main);font-weight:600;margin-bottom:12px}
  .testi-author{display:flex;align-items:center;gap:10px}
  .testi-avatar{width:38px;height:38px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:13px;font-weight:700;color:var(--purple-main)}
  .testi-name{font-weight:600;font-size:13px;color:var(--dark)}
  .testi-role{font-size:12px;color:var(--muted)}

  /* ===== BONUS ===== */
  .bonus-section{background:var(--cream)}
  .bonus-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:36px}
  .bonus-card{background:#fff;border-radius:14px;padding:20px 24px;border:1px solid rgba(0,0,0,.04);display:flex;align-items:center;gap:14px}
  .bonus-tag{padding:5px 12px;border-radius:100px;background:var(--purple-wash);color:var(--purple-main);font-size:11px;font-weight:700;white-space:nowrap}
  .bonus-card span{font-size:14px;color:var(--dark);font-weight:500}

  /* ===== PRICING ===== */
  .pricing-section{text-align:center}
  .pricing-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;max-width:700px;margin:48px auto 0}
  .pricing-card{background:var(--cream);border-radius:22px;padding:36px;border:2px solid transparent;transition:.3s;position:relative}
  .pricing-card.pop{border-color:var(--purple-main);background:#fff}
  .pricing-pop-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);padding:5px 18px;border-radius:100px;background:var(--purple-main);color:#fff;font-size:11px;font-weight:700;white-space:nowrap}
  .pricing-card h3{font-family:'Red Hat Display',sans-serif;font-size:20px;font-weight:700;color:var(--dark);margin-bottom:4px}
  .pricing-desc{font-size:13px;color:var(--muted);margin-bottom:20px}
  .pricing-price{font-family:'Red Hat Display',sans-serif;font-size:38px;font-weight:800;color:var(--purple-deep)}
  .pricing-price small{font-size:14px;font-weight:500;color:var(--muted)}
  .pricing-per{font-size:13px;color:var(--muted);margin-bottom:24px}

  /* ===== FAQ ===== */
  .faq-section{background:var(--cream)}
  .faq-list{max-width:700px;margin:48px auto 0}
  .faq-item{border-bottom:1px solid rgba(0,0,0,.06);padding:20px 0;cursor:pointer}
  .faq-q{display:flex;justify-content:space-between;align-items:center;font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:600;color:var(--dark)}
  .faq-q::after{content:'+';font-size:20px;color:var(--purple-main);transition:.3s}
  .faq-item.open .faq-q::after{content:'\2212'}
  .faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease;font-size:14px;color:var(--body);line-height:1.65}
  .faq-item.open .faq-a{max-height:200px;padding-top:12px}

  /* ===== GUARANTEE ===== */
  .guar-bar{padding:44px 40px;border-top:1px solid rgba(0,0,0,.05);border-bottom:1px solid rgba(0,0,0,.05)}
  .guar-grid{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
  .guar-icon{width:48px;height:48px;margin:0 auto 10px}
  .guar-icon img{width:100%;height:100%}
  .guar-item h4{font-family:'Red Hat Display',sans-serif;font-size:13px;font-weight:700;color:var(--dark);margin-bottom:2px}
  .guar-item p{font-size:12px;color:var(--muted)}

  /* ===== FOOTER ===== */
  .footer{background:var(--cream);padding:56px 40px 28px}
  .footer-inner{max-width:1100px;margin:0 auto}
  .footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
  .footer-brand-logo{height:24px;margin-bottom:14px}
  .footer-brand p{font-size:13px;color:var(--muted);line-height:1.6;max-width:260px;margin-bottom:12px}
  .footer-contact{font-size:13px;color:var(--body)}
  .footer-col h4{font-family:'Red Hat Display',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--dark);margin-bottom:14px}
  .footer-col a{display:block;font-size:13px;color:var(--muted);padding:4px 0;transition:.2s}
  .footer-col a:hover{color:var(--purple-main)}
  .footer-bottom{padding-top:20px;border-top:1px solid rgba(0,0,0,.06);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
  .footer-bottom p{font-size:12px;color:var(--muted)}
  .footer-legal{display:flex;gap:16px}
  .footer-legal a{font-size:12px;color:var(--muted);transition:.2s}
  .footer-legal a:hover{color:var(--purple-main)}
  .footer-disc{margin-top:24px;padding:16px;background:var(--warm);border-radius:10px}
  .footer-disc p{font-size:11px;color:var(--muted);line-height:1.6}

  /* ===== ANIMATIONS ===== */
  .reveal{opacity:0;transform:translateY(36px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1)}
  .reveal.visible{opacity:1;transform:translateY(0)}
  .reveal-d{transition-delay:.15s}

  @keyframes ub-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
  @keyframes ub-pulse-glow{0%,100%{box-shadow:0 4px 20px rgba(107,47,160,.25)}50%{box-shadow:0 8px 40px rgba(107,47,160,.5)}}
  @keyframes ub-scale-in{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
  @keyframes ub-slide-up{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}

  .hero-visual img{animation:ub-float 5s ease-in-out infinite}
  .hero-visual img:hover{animation-play-state:paused}
  .btn-fill{animation:ub-pulse-glow 2.5s ease-in-out infinite}
  .btn-fill:hover{animation-play-state:paused}

  .stagger-children > *{opacity:0;transform:translateY(22px);transition:opacity .55s ease,transform .55s ease}
  .stagger-children.visible > *:nth-child(1){opacity:1;transform:none;transition-delay:0s}
  .stagger-children.visible > *:nth-child(2){opacity:1;transform:none;transition-delay:.1s}
  .stagger-children.visible > *:nth-child(3){opacity:1;transform:none;transition-delay:.2s}
  .stagger-children.visible > *:nth-child(4){opacity:1;transform:none;transition-delay:.3s}
  .stagger-children.visible > *:nth-child(5){opacity:1;transform:none;transition-delay:.4s}
  .stagger-children.visible > *:nth-child(6){opacity:1;transform:none;transition-delay:.5s}

  .stagger-scale > *{opacity:0;transform:scale(.88) translateY(16px);transition:opacity .5s ease,transform .5s ease}
  .stagger-scale.visible > *:nth-child(1){opacity:1;transform:none;transition-delay:0s}
  .stagger-scale.visible > *:nth-child(2){opacity:1;transform:none;transition-delay:.08s}
  .stagger-scale.visible > *:nth-child(3){opacity:1;transform:none;transition-delay:.16s}
  .stagger-scale.visible > *:nth-child(4){opacity:1;transform:none;transition-delay:.24s}
  .stagger-scale.visible > *:nth-child(5){opacity:1;transform:none;transition-delay:.32s}
  .stagger-scale.visible > *:nth-child(6){opacity:1;transform:none;transition-delay:.4s}

  .prob-cards{display:grid;grid-template-columns:repeat(3,1fr);margin-top:48px;border-radius:20px;overflow:hidden;box-shadow:0 4px 32px rgba(61,24,115,.1)}
  .prob-card{background:linear-gradient(145deg,#2e1060 0%,#5b2199 60%,#7c3abf 100%);padding:40px 32px;border-right:1px solid rgba(255,255,255,.08);position:relative;transition:filter .25s}
  .prob-card:last-child{border-right:none}
  .prob-card:hover{filter:brightness(1.08)}
  .prob-num{font-family:'Red Hat Display',sans-serif;font-size:68px;font-weight:900;color:rgba(255,255,255,.08);line-height:1;letter-spacing:-0.04em;margin-bottom:20px;user-select:none}
  .prob-title{font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:14px}
  .prob-sub{font-size:14px;color:rgba(255,255,255,.7);line-height:1.6;padding-top:14px;border-top:1px solid rgba(255,255,255,.15)}
  @media(max-width:700px){.prob-cards{grid-template-columns:1fr;border-radius:16px}.prob-card{border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}.prob-card:last-child{border-bottom:none}}

  .how-step__svg{width:80px;height:80px;margin:0 auto 18px;background:var(--purple-wash);border-radius:50%;display:flex;align-items:center;justify-content:center}
  .how-step__svg svg{width:36px;height:36px;stroke:var(--purple-main);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
  .how-step p{display:none}

  .faq-item.open .faq-a{animation:ub-slide-up .3s ease}
  .big-stat-num[data-count]{cursor:default}

  @media(prefers-reduced-motion:reduce){.hero-visual img,.btn-fill{animation:none !important}}

  h1,h2,h3,.section-title,.hero h1,.benefit-title,.expert-quote{text-wrap:balance}
