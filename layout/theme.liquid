  function hasMaxInCart(){
    var cartText = '';
    var cartContainer = document.querySelector('cart-drawer, .cart-drawer, [id*="cart"], .cart, .mini-cart, #CartDrawer');
    if(cartContainer) cartText = cartContainer.textContent;
    if(window.location.pathname.indexOf('/cart') !== -1) cartText = document.body.textContent;
    return cartText.indexOf('Maximum') !== -1;
  }

  function injectCartGift(){
    document.querySelectorAll('.ub-cart-gift').forEach(function(el){ el.remove(); });
    if(!hasMaxInCart()) return;

    var checkoutBtn = document.querySelector('cart-drawer [name="checkout"], .cart-drawer [name="checkout"], #CartDrawer [name="checkout"], [data-action="checkout"], .cart__checkout-button, button[name="checkout"]');
