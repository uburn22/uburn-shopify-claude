      <style>.badge-best{position:absolute !important;top:-14px !important;left:50% !important;transform:translateX(-50%) !important;background:#6c47d6 !important;color:#fff !important;font-size:10px !important;font-weight:700 !important;padding:3px 10px !important;border-radius:20px !important;white-space:nowrap !important;z-index:100 !important}.variant-picker__option-values label.block-swatch{overflow:visible !important;position:relative !important}.reassurance-bar{display:flex !important;justify-content:center !important;align-items:center !important;gap:14px !important;margin-top:10px !important;padding:8px 4px !important;flex-wrap:wrap !important}.reassurance-bar span{font-size:12px !important;color:#555 !important;display:inline-flex !important;align-items:center !important;white-space:nowrap !important}
      mportant;left:50% important;transform:translateX(-50%) !important;background:#6c47d6 !important;color:#fff !important;font-size:10px !important;font-weight:700 !important;padding:3px 10px !important;border-radius:20px !important;white-space:nowrap !important;z-index:100 !important;pointer-events:none !important}.variant-picker__option-values label.block-swatch{overflow:visible !important;position:relative !important}.reassurance-bar{display:flex !important;justify-content:center !important;align-items:center !important;gap:14px !important;margin-top:10px !important;padding:8px 4px !important;border-top:1px solid #ede8f8 !important;flex-wrap:wrap !important}.reassurance-bar span{font-size:12px !important;color:#555 !important;display:inline-flex !important;align-items:center !important;gap:4px !important;white-space:nowrap !important}<badge-best{position:absolute !important;top:-14px !i}</style>
<script>
(function() {
  var _lastRun = 0;
  var _debounceTimer = null;

  function initUburn() {
    var now = Date.now();
    if (now - _lastRun < 80) return;
    _lastRun = now;

    var cards = document.querySelectorAll('.variant-picker__option-values label.block-swatch');
    if (!cards.length) return;

    // MOD 1 — Prix/jour sur les cards
    var prixJour = ['€1,15/jour', '€0,61/jour'];
    cards.forEach(function(label, i) {
                var s = label.querySelector('.prix-jour');
                          if (!s) { s = document.createElement('span'); s.className = 'prix-jour'; label.appendChild(s); }
                                    s.textContent = prixJour[i];
    });

    // MOD 2 — Badge Meilleure valeur sur 270g (cards[0])
            cards.forEach(function(c){var ob=c.querySelector('.badge-best');if(ob)ob.remove();});
    if (cards[1] && !cards[1].querySelector('.badge-best')) {
      cards[1].style.position = 'relative';
      var b = document.createElement('span');
      b.className = 'badge-best';
      b.textContent = '⭐ Meilleure valeur';
      cards[1].appendChild(b);
    }

    // MOD 3 — Reassurance bar sans Remboursé 30 jours
    if (!document.querySelector('.reassurance-bar')) {
      var btns = Array.from(document.querySelectorAll('button'));
      var btn = btns.find(function(b){ return /acheter maintenant/i.test(b.textContent); });
      if (btn) {
        var bar = document.createElement('div');
        bar.className = 'reassurance-bar';
        bar.innerHTML = '<span>🔒 Paiement sécurisé</span><span>🚚 Livraison gratuite</span>';
        btn.parentNode.insertBefore(bar, btn.nextSibling);
      }
    }

    // MOD 4 — Bouton "Commencer ma cure →"
    document.querySelectorAll('.shopify-payment-button__button, [data-testid="Checkout-button"]').forEach(function(btn) {
      if (btn.innerText && /acheter|buy/i.test(btn.innerText)) {
        btn.innerText = 'Commencer ma cure →';
      }
    });

    // MOD 5 — Trust badges au-dessus du sélecteur de variante
    var vp = document.querySelector('variant-picker');
    if (vp && !document.querySelector('.uburn-trust-badges')) {
      var div = document.createElement('div');
      div.className = 'uburn-trust-badges';
      div.style.cssText = 'display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin:12px 0 16px 0;';
      div.innerHTML = '<span style="background:#f4f0ff;color:#5b21b6;padding:6px 12px;border-radius:20px;font-size:12px;font-weight:600;">🌿 100% Végétal</span><span style="background:#f4f0ff;color:#5b21b6;padding:6px 12px;border-radius:20px;font-size:12px;font-weight:600;">☕ Café vert décaféiné</span><span style="background:#f4f0ff;color:#5b21b6;padding:6px 12px;border-radius:20px;font-size:12px;font-weight:600;">🔬 Validé EFSA</span><span style="background:#f4f0ff;color:#5b21b6;padding:6px 12px;border-radius:20px;font-size:12px;font-weight:600;">⭐ 4.7/5 (17 avis)</span>';
      vp.parentNode.insertBefore(div, vp);
    }

    // MOD 6 — Tableau comparatif "POURQUOI UBURN ?"
    if (!document.querySelector('.uburn-comparatif')) {
      var table = document.createElement('div');
      table.className = 'uburn-comparatif';
      table.innerHTML = '<div style="max-width:800px;margin:60px auto;padding:0 20px;"><h2 style="text-align:center;font-size:24px;font-weight:800;color:#1a1a1a;margin-bottom:8px;text-transform:uppercase;">POURQUOI UBURN ?</h2><p style="text-align:center;color:#6b7280;font-size:14px;margin-bottom:32px;">Comparez par vous-même.</p><div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:13px;min-width:600px;"><thead><tr><th style="padding:12px 10px;text-align:left;border-bottom:2px solid #e5e7eb;"></th><th style="padding:12px 10px;text-align:center;border-bottom:2px solid #7c3aed;background:#f4f0ff;color:#5b21b6;font-weight:800;">🟣 UBURN</th><th style="padding:12px 10px;text-align:center;border-bottom:2px solid #e5e7eb;color:#6b7280;">Brûleurs classiques</th><th style="padding:12px 10px;text-align:center;border-bottom:2px solid #e5e7eb;color:#6b7280;">Shakes protéinés</th><th style="padding:12px 10px;text-align:center;border-bottom:2px solid #e5e7eb;color:#6b7280;">Coupe-faim chimiques</th></tr></thead><tbody><tr style="background:#fafafa;"><td style="padding:10px;font-weight:600;">Coupe la faim +4h</td><td style="padding:10px;text-align:center;background:#f9f5ff;font-weight:700;color:#16a34a;">✅ Oui (EFSA)</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Non</td><td style="padding:10px;text-align:center;color:#f59e0b;">⚠️ Partiel</td><td style="padding:10px;text-align:center;color:#16a34a;">✅ Oui</td></tr><tr><td style="padding:10px;font-weight:600;">Brûle les graisses</td><td style="padding:10px;text-align:center;background:#f9f5ff;font-weight:700;color:#16a34a;">✅ L-carnitine</td><td style="padding:10px;text-align:center;color:#16a34a;">✅ Caféine</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Non</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Non</td></tr><tr style="background:#fafafa;"><td style="padding:10px;font-weight:600;">Sans caféine</td><td style="padding:10px;text-align:center;background:#f9f5ff;font-weight:700;color:#16a34a;">✅ Décaféiné</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ 200-400mg</td><td style="padding:10px;text-align:center;color:#16a34a;">✅ 0mg</td><td style="padding:10px;text-align:center;color:#f59e0b;">⚠️ Variable</td></tr><tr><td style="padding:10px;font-weight:600;">100% naturel</td><td style="padding:10px;text-align:center;background:#f9f5ff;font-weight:700;color:#16a34a;">✅ Végétal</td><td style="padding:10px;text-align:center;color:#f59e0b;">⚠️ Mixte</td><td style="padding:10px;text-align:center;color:#f59e0b;">⚠️ Mixte</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Synthétique</td></tr><tr style="background:#fafafa;"><td style="padding:10px;font-weight:600;">Goût agréable</td><td style="padding:10px;text-align:center;background:#f9f5ff;font-weight:700;color:#16a34a;">✅ Noisette vanillaée</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Gélules</td><td style="padding:10px;text-align:center;color:#f59e0b;">⚠️ Artificiel</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Gélules</td></tr><tr><td style="padding:10px;font-weight:600;">Validé EFSA</td><td style="padding:10px;text-align:center;background:#f9f5ff;font-weight:700;color:#16a34a;">✅ Glucomannane</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Non</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Non</td><td style="padding:10px;text-align:center;color:#ef4444;">❌ Non</td></tr></tbody></table></div><div style="text-align:center;margin-top:24px;"><a href="#product-form-main" style="display:inline-block;background:#7c3aed;color:#fff;padding:14px 32px;border-radius:8px;text-decoration:none;font-weight:700;font-size:15px;">Commencer ma cure →</a></div></div>';
      var ingredSection = document.querySelector('[id*="ingredient"], [class*="ingredient"], [id*="trust"], [class*="trust-icon"]');
      if (ingredSection) { ingredSection.parentNode.insertBefore(table, ingredSection.nextSibling); }
    }
  }

  // MOD 7 — Aucune sélection + CTA désactivé
    var _ctaBtn = document.querySelector('[name="add"]') || document.querySelector('.product-form__submit');
    if (_ctaBtn && window.location.pathname.includes('/products/')) {
      document.querySelectorAll('.variant-picker__option-values input[type="radio"]').forEach(function(i){i.checked=false;});
      if (!_ctaBtn.dataset.uburnPatched) {
        _ctaBtn.dataset.uburnPatched = '1';
        document.querySelectorAll('.variant-picker__option-values label').forEach(function(l){
          l.addEventListener('click',function(){_ctaBtn.disabled=false;_ctaBtn.style.opacity='';_ctaBtn.style.cursor='';});
        });
      }
      var _anyChecked = document.querySelector('.variant-picker__option-values input[type="radio"]:checked');
      if (!_anyChecked) { _ctaBtn.disabled=true; _ctaBtn.style.opacity='0.5'; _ctaBtn.style.cursor='not-allowed'; if(_ctaBtn.tagName==='BUTTON'){_ctaBtn.textContent='Choisissez votre format';} }
      else { _ctaBtn.disabled=false; _ctaBtn.style.opacity=''; _ctaBtn.style.cursor=''; }

    }
    function debouncedInit() {
    clearTimeout(_debounceTimer);
    _debounceTimer = setTimeout(initUburn, 120);
  }

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', function(){ setTimeout(initUburn, 50); setTimeout(initUburn, 300); })
    : (initUburn(), setTimeout(initUburn, 300));

  window.addEventListener('load', function(){ initUburn(); setTimeout(initUburn, 500); });
  document.addEventListener('variant:changed', function(){ setTimeout(initUburn, 100); setTimeout(initUburn, 400); setTimeout(initUburn, 800); });

  try {
    new MutationObserver(debouncedInit).observe(document.body, {childList: true, subtree: true});
  } catch(e) {}

  setInterval(function() {
    var cards = document.querySelectorAll('.variant-picker__option-values label.block-swatch');
    if (cards.length && !cards[0].querySelector('.prix-jour')) { initUburn(); }
  }, 2000);
})();
</script>
{%- endif -%}
    </body>
