      wrapper.innerHTML = giftHTML;
      checkoutBtn.closest('div, form').insertBefore(wrapper.firstChild, checkoutBtn);
    }

    if(window.location.pathname.indexOf('/cart') !== -1){
      var pageCheckout = document.querySelector('[name="checkout"], .cart__checkout, [type="submit"][value*="Check"]');
      if(pageCheckout && !document.querySelector('.ub-cart-gift')){
        var wrapper2 = document.createElement('div');
        wrapper2.innerHTML = giftHTML;
        pageCheckout.closest('div, form').insertBefore(wrapper2.firstChild, pageCheckout);
      }
    }
  }

  var obs = new MutationObserver(function(){ setTimeout(injectCartGift, 300); });
  obs.observe(document.body, {childList: true, subtree: true});

  document.addEventListener('click', function(e){
    if(e.target.closest && (e.target.closest('.product-form__submit') || e.target.closest('[name="add"]') || e.target.closest('.ub-sticky-bar'))){
      setTimeout(injectCartGift, 1000);
      setTimeout(injectCartGift, 2000);
    }
  });
})();
</script>
