  <script>
// Bloc cadeau UBURN — V3 (prix barrés + badge GRATUIT)
(function(){
  function addGiftBlock(){
    var isMaxSelected = false;
    document.querySelectorAll('.variant-picker__option-values label').forEach(function(l){
      var inp = l.previousElementSibling;
      if(inp && inp.checked && l.textContent.indexOf('Maximum') !== -1) isMaxSelected = true;
    });

    var existing = document.querySelector('.ub-gift-wrapper');
    if(!isMaxSelected){ if(existing) existing.style.display = 'none'; return; }
    if(existing){ existing.style.display = ''; return; }

    var variantPicker = document.querySelector('variant-picker');
    if(!variantPicker) return;
    var variantBlock = variantPicker.closest('.product-info__block-item');
    if(!variantBlock) return;
    var priceBlock = variantBlock.nextElementSibling;

    var giftDiv = document.createElement('div');
    giftDiv.className = 'product-info__block-item ub-gift-wrapper';
    giftDiv.innerHTML = ''
      + '<div style="background:linear-gradient(135deg,#f5f0ff,#ede4f7);border:2px solid #7c3aed;border-radius:12px;padding:16px 18px;">'
      + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">'
      + '<span style="font-size:15px;font-weight:800;color:#7c3aed;">\ud83c\udf81 INCLUS GRATUITEMENT</span>'
      + '<span style="font-size:11px;background:#7c3aed;color:#fff;padding:3px 10px;border-radius:20px;font-weight:700;">valeur 201\u20ac</span>'
      + '</div>'
