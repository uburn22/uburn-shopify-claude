    <!-- UBurn Typography: Plus Jakarta Sans — AG1-inspired casing -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
          <style>
              /* ======================================================
                     UBURN — AG1-inspired typography rules
                            UPPERCASE only: ingredient labels, short tags, overlines
                                   Sentence case: everything else (headings, body, nav, buttons, footer)
                                       ====================================================== */
                                       
                                           /* 1. Reset the theme's global uppercase variable */
                                               :root { --text-transform: none !important; }
                                               
                                                   /* 2. Apply Plus Jakarta Sans everywhere */
                                                       *, body, p, span, a, li, td, th, label, input, button,
                                                           select, textarea, .rte, nav, header,
                                                               h1, h2, h3, h4, h5, h6 {
                                                                     font-family: 'Plus Jakarta Sans', sans-serif !important;
                                                                         }
                                                                         
                                                                             /* 3. Body: readable, clean */
                                                                                 body {
                                                                                       font-size: 16px !important;
                                                                                             line-height: 1.6 !important;
                                                                                                   font-weight: 400 !important;
                                                                                                         text-transform: none !important;
                                                                                                             }
                                                                                                             
                                                                                                                 /* 4. Headings: sentence case, elegant letter-spacing */
                                                                                                                     h1, h2, h3, h4, h5, h6,
                                                                                                                         .h1, .h2, .h3, .h4, .h5, .h6,
                                                                                                                             .product__title, .product-title,
                                                                                                                                 .card__heading, [class*="heading"], [class*="title"] {
                                                                                                                                       font-family: 'Plus Jakarta Sans', sans-serif !important;
                                                                                                                                             font-weight: 400 !important;
                                                                                                                                                   letter-spacing: -0.03em !important;
                                                                                                                                                        text-transform: none !important;
                                                                                                                                                              line-height: 1.15 !important;
                                                                                                                                                                  }
                                                                                                                                                                  
                                                                                                                                                                      /* 5. Navigation: mixed-case, medium weight */
                                                                                                                                                                          nav a, .header__menu-item, .header a,
                                                                                                                                                                              .menu-drawer a, .announcement-bar__message {
                                                                                                                                                                                    font-family: 'Plus Jakarta Sans', sans-serif !important;
                                                                                                                                                                                          text-transform: none !important;
                                                                                                                                                                                                letter-spacing: 0 !important;
                                                                                                                                                                                                      font-weight: 500 !important;
                                                                                                                                                                                                          }
                                                                                                                                                                                                          
                                                                                                                                                                                                              /* 6. Buttons: sentence case, semibold */
                                                                                                                                                                                                                  .button, .btn, [class*="button"], button[type="submit"],
                                                                                                                                                                                                                      a.button, input[type="submit"] {
                                                                                                                                                                                                                            font-family: 'Plus Jakarta Sans', sans-serif !important;
                                                                                                                                                                                                                                  font-weight: 600 !important;
                                                                                                                                                                                                                                        text-transform: none !important;
                                                                                                                                                                                                                                              letter-spacing: -0.01em !important;
                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                      /* 7. Footer: sentence case */
                                                                                                                                                                                                                                                          footer, footer a, footer li, footer p, footer span,
                                                                                                                                                                                                                                                              .footer, .footer a, .footer li, .footer p {
                                                                                                                                                                                                                                                                    text-transform: none !important;
                                                                                                                                                                                                                                                                          font-family: 'Plus Jakarta Sans', sans-serif !important;
                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                  /* 8. Body text / paragraphs / lists: sentence case */
                                                                                                                                                                                                                                                                                      p, li, blockquote, .rte, .prose {
                                                                                                                                                                                                                                                                                            text-transform: none !important;
                                                                                                                                                                                                                                                                                                font-family: 'Plus Jakarta Sans', sans-serif !important;
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                        /* 9. Short ingredient labels & overline badges: keep uppercase (AG1 style) */
                                                                                                                                                                                                                                                                                                          .subheading, .subheading-badge, [class*="overline"],
                                                                                                                                                                                                                                                                                                              .badge, .tag, .label-tag,
                                                                                                                                                                                                                                                                                                                .announcement-bar__message {
                                                                                                                                                                                                                                                                                                                      text-transform: uppercase !important;
                                                                                                                                                                                                                                                                                                                            letter-spacing: 0.08em !important;
                                                                                                                                                                                                                                                                                                                                font-size: 0.7rem !important;
                                                                                                                                                                                                                                                                                                                                      font-weight: 500 !important;
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                      </style>
