{%- comment -%}
  UBurn V2 — Footer (plum-black bg, lavender wordmark giant)
{%- endcomment -%}
<style>
  .u2-footer {
    background: var(--u2-plum-black);
    color: var(--u2-bone);
    padding: 64px 0 0;
    position: relative;
    overflow: hidden;
  }
  .u2-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .u2-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(184, 157, 217, 0.15);
  }
  @media (min-width: 768px) {
    .u2-footer__top {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 48px;
    }
  }
  .u2-footer__brand .u2-logo-wordmark {
    font-size: 28px;
    color: var(--u2-lavender);
    margin-bottom: 12px;
  }
  .u2-footer__tagline {
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--u2-bone);
    line-height: 1.5;
    max-width: 34ch;
    margin: 12px 0 18px;
  }
  .u2-footer__email {
    display: inline-block;
    font-size: 14px;
    color: var(--u2-lavender);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .u2-footer__col-title {
    font-family: var(--u2-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--u2-lavender);
    margin: 0 0 16px;
  }
  .u2-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .u2-footer__links a {
    font-size: 14px;
    color: rgba(248, 244, 238, 0.75);
    text-decoration: none;
    transition: color 0.2s var(--u2-ease-smooth);
  }
  .u2-footer__links a:hover {
    color: var(--u2-lavender);
  }
  .u2-footer__bottom {
    padding: 24px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
    text-align: center;
    font-size: 11px;
    color: rgba(248, 244, 238, 0.45);
  }
  @media (min-width: 768px) {
    .u2-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  .u2-footer__disclaimer {
    padding: 24px 0;
    font-size: 11px;
    line-height: 1.7;
    color: rgba(248, 244, 238, 0.55);
    max-width: 920px;
    margin: 0 auto;
  }
  .u2-footer__giant {
    font-family: var(--u2-sans);
    font-style: italic;
    font-weight: 900;
    font-size: clamp(80px, 18vw, 220px);
    line-height: 0.85;
    letter-spacing: -0.06em;
    color: rgba(184, 157, 217, 0.18);
    text-align: center;
    padding-top: 40px;
    user-select: none;
    -webkit-user-select: none;
  }
</style>

<footer class="u2-root u2-footer">
  <div class="u2-footer__inner">
    <div class="u2-footer__top">
      <div class="u2-footer__brand">
        {% render 'u2-logo-wordmark', size: 28, color: 'lavender' %}
        <p class="u2-footer__tagline">{{ section.settings.tagline | default: 'The afternoon ritual that resets your 4 PM.' }}</p>
        <a class="u2-footer__email" href="mailto:hello@uburn.co">hello@uburn.co</a>
      </div>

      <div>
        <h4 class="u2-footer__col-title">Product</h4>
        <ul class="u2-footer__links">
          <li><a href="/products/{{ section.settings.product_handle | default: 'ube-poudre' }}">The drink</a></li>
          <li><a href="/pages/the-science">The science</a></li>
          <li><a href="/pages/ingredients">Ingredients</a></li>
          <li><a href="/pages/reviews">Reviews</a></li>
        </ul>
      </div>

      <div>
        <h4 class="u2-footer__col-title">Support</h4>
        <ul class="u2-footer__links">
          <li><a href="/pages/contact">Contact us</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/shipping">Shipping</a></li>
          <li><a href="/pages/returns">Returns</a></li>
          <li><a href="/policies/refund-policy">Refund policy</a></li>
        </ul>
      </div>

      <div>
        <h4 class="u2-footer__col-title">Company</h4>
        <ul class="u2-footer__links">
          <li><a href="/pages/our-story">Our story</a></li>
          <li><a href="/pages/privacy-policy-us-en">Privacy</a></li>
          <li><a href="/pages/terms-us-en">Terms</a></li>
          <li><a href="/policies/terms-of-service">Terms of service</a></li>
          <li><a href="/pages/data-sharing-opt-out">Do not sell</a></li>
        </ul>
      </div>
    </div>

    <p class="u2-footer__disclaimer">
      Dietary supplement containing konjac glucomannan. Glucomannan supports satiety as part of a healthy lifestyle.* Recommended use: 3g/day in 3 doses of 1g with 1-2 large glasses of water before meals. Not a substitute for a balanced diet. Not recommended during pregnancy or breastfeeding. *These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure, or prevent any disease.
    </p>

    <div class="u2-footer__bottom">
      <span>© {{ 'now' | date: '%Y' }} UBurn. French brand · Made for the U.S.</span>
      <span>Plant-based · Caffeine-free · Cancel anytime</span>
    </div>
  </div>

  <div class="u2-footer__giant" aria-hidden="true">UBurn</div>
</footer>

{% schema %}
{
  "name": "U2 Footer",
  "tag": "section",
  "class": "shopify-section--u2-footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "The afternoon ritual that resets your 4 PM." },
    { "type": "text", "id": "product_handle", "label": "Primary product handle", "default": "ube-poudre" }
  ],
  "presets": [
    { "name": "U2 Footer" }
  ]
}
{% endschema %}
