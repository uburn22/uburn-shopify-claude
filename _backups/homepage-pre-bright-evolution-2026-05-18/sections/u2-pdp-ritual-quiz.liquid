{%- comment -%}
  UBurn V2 — PDP Ritual Quiz "Which one is right for you?"
  3-question matcher that recommends Starter / Maximum / Subscribe
{%- endcomment -%}
{%- liquid
  assign hp = all_products['ube-poudre']
  assign v1 = hp.variants[0]
  assign v2 = hp.variants[1] | default: v1
-%}
<style>
  .u2-quiz { background: var(--u2-bone); padding: var(--u2-space-section) 20px; }
  .u2-quiz__inner { max-width: 760px; margin: 0 auto; }
  .u2-quiz__head { text-align: center; margin-bottom: 36px; }
  .u2-quiz__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(28px,4.5vw,40px);
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.025em;
    margin: 12px 0 8px;
  }
  .u2-quiz__head h2 em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-quiz__head p { font-size: 15px; color: var(--u2-text-body); margin: 0; }
  .u2-quiz__card {
    background: white;
    border-radius: 20px;
    padding: 32px 24px;
    box-shadow: 0 22px 50px -22px rgba(58,31,89,0.15);
    border: 1px solid rgba(107,78,158,0.08);
  }
  .u2-quiz__step { display: none; }
  .u2-quiz__step[data-u2-quiz-step="1"] { display: block; }
  .u2-quiz__progress {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
  }
  .u2-quiz__dot {
    flex: 1;
    height: 4px;
    border-radius: 999px;
    background: rgba(107,78,158,0.15);
    transition: background 0.3s var(--u2-ease-smooth);
  }
  .u2-quiz__dot.is-active { background: var(--u2-iris); }
  .u2-quiz__q {
    font-family: var(--u2-sans);
    font-size: 22px;
    font-weight: 700;
    color: var(--u2-plum-black);
    margin: 0 0 20px;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }
  .u2-quiz__options { display: flex; flex-direction: column; gap: 10px; }
  .u2-quiz__opt {
    background: var(--u2-bone);
    border: 2px solid rgba(107,78,158,0.12);
    border-radius: 14px;
    padding: 16px 20px;
    text-align: left;
    font-family: var(--u2-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--u2-plum-black);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }
  .u2-quiz__opt:hover {
    border-color: var(--u2-iris);
    background: rgba(232,220,239,0.4);
    transform: translateY(-1px);
  }

  .u2-quiz__result { text-align: center; }
  .u2-quiz__result-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--u2-iris);
    margin-bottom: 12px;
  }
  .u2-quiz__result h3 {
    font-family: var(--u2-sans);
    font-size: 28px;
    font-weight: 800;
    color: var(--u2-plum-black);
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  .u2-quiz__result h3 em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-quiz__result p { font-size: 15px; color: var(--u2-text-body); margin: 0 0 24px; max-width: 44ch; margin-left: auto; margin-right: auto; }
  .u2-quiz__restart {
    background: transparent;
    border: 0;
    color: var(--u2-iris);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-top: 16px;
  }
  .u2-quiz__restart:hover { color: var(--u2-iris-deep); }
</style>

<section class="u2-root u2-quiz" aria-label="Which one is right for you?">
  <div class="u2-quiz__inner">
    <div class="u2-quiz__head u2-reveal">
      <span class="u2-section-eyebrow">— find your fit</span>
      <h2>Which one is <em>right for you?</em></h2>
      <p>3 questions. 30 seconds.</p>
    </div>

    <div class="u2-quiz__card u2-reveal delay-1" data-u2-quiz>
      <div class="u2-quiz__progress" aria-hidden="true">
        <span class="u2-quiz__dot is-active"></span>
        <span class="u2-quiz__dot"></span>
        <span class="u2-quiz__dot"></span>
      </div>

      <div class="u2-quiz__step" data-u2-quiz-step="1">
        <h3 class="u2-quiz__q">How often do you snack between meals?</h3>
        <div class="u2-quiz__options">
          <button class="u2-quiz__opt" data-u2-quiz-answer="rare">Rarely — once or twice a week</button>
          <button class="u2-quiz__opt" data-u2-quiz-answer="sometimes">Sometimes — most weekdays</button>
          <button class="u2-quiz__opt" data-u2-quiz-answer="daily">Daily — multiple times</button>
        </div>
      </div>

      <div class="u2-quiz__step" data-u2-quiz-step="2">
        <h3 class="u2-quiz__q">Are you looking for daily support or just occasional?</h3>
        <div class="u2-quiz__options">
          <button class="u2-quiz__opt" data-u2-quiz-answer="try">Just want to try it first</button>
          <button class="u2-quiz__opt" data-u2-quiz-answer="routine">Building a daily routine</button>
          <button class="u2-quiz__opt" data-u2-quiz-answer="forever">It's a lifestyle change</button>
        </div>
      </div>

      <div class="u2-quiz__step" data-u2-quiz-step="3">
        <h3 class="u2-quiz__q">Do you prefer single use or auto-refill?</h3>
        <div class="u2-quiz__options">
          <button class="u2-quiz__opt" data-u2-quiz-answer="single">Single use, no commitment</button>
          <button class="u2-quiz__opt" data-u2-quiz-answer="stock">Stock up for 3 months</button>
          <button class="u2-quiz__opt" data-u2-quiz-answer="auto">Auto-refill, set and forget</button>
        </div>
      </div>

      <div class="u2-quiz__step" data-u2-quiz-step="result">
        <div class="u2-quiz__result">
          <span class="u2-quiz__result-eyebrow">— our recommendation</span>
          <h3 data-u2-quiz-result-name>Starter Pack</h3>
          <p data-u2-quiz-result-desc>Perfect for first-time exploration.</p>
          <a class="u2-cta" data-u2-quiz-result-cta href="{{ hp.url }}?variant={{ v1.id }}">
            <span data-u2-quiz-result-cta-text>start with starter</span>
            <span class="u2-cta__arrow" aria-hidden="true">→</span>
          </a>
          <div>
            <button type="button" class="u2-quiz__restart" data-u2-quiz-restart>Restart quiz</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  var root = document.querySelector('[data-u2-quiz]');
  if(!root) return;
  var steps = root.querySelectorAll('.u2-quiz__step');
  var dots = root.querySelectorAll('.u2-quiz__dot');
  var answers = [];
  var current = 0;
  function show(idx){
    steps.forEach(function(s,i){ s.style.display = (i===idx) ? 'block' : 'none'; });
    dots.forEach(function(d,i){ d.classList.toggle('is-active', i <= idx); });
  }
  function showResult(){
    steps.forEach(function(s){ s.style.display = s.dataset.u2QuizStep === 'result' ? 'block' : 'none'; });
    dots.forEach(function(d){ d.classList.add('is-active'); });
    var rec = recommend(answers);
    document.querySelector('[data-u2-quiz-result-name]').textContent = rec.name;
    document.querySelector('[data-u2-quiz-result-desc]').textContent = rec.desc;
    var cta = document.querySelector('[data-u2-quiz-result-cta]');
    cta.setAttribute('href', rec.href);
    document.querySelector('[data-u2-quiz-result-cta-text]').textContent = rec.ctaText;
  }
  function recommend(a){
    var score = { starter:0, maximum:0, subscribe:0 };
    a.forEach(function(ans){
      if(ans === 'rare' || ans === 'try' || ans === 'single') score.starter++;
      if(ans === 'sometimes' || ans === 'routine' || ans === 'stock') score.maximum++;
      if(ans === 'daily' || ans === 'forever' || ans === 'auto') score.subscribe++;
    });
    var max = Math.max(score.starter, score.maximum, score.subscribe);
    if(max === score.subscribe){
      return { name: 'Subscribe & Save', desc: 'Auto-refills every 30 days. Free shipping. Save 15%. Cancel anytime.', href: '{{ hp.url }}?variant={{ v2.id }}#subscribe', ctaText: 'subscribe & save' };
    }
    if(max === score.maximum){
      return { name: 'Maximum Pack', desc: '90-day supply. Save 33% per scoop. Most popular choice.', href: '{{ hp.url }}?variant={{ v2.id }}', ctaText: 'choose maximum' };
    }
    return { name: 'Starter Pack', desc: 'Perfect first-time exploration. 30-day trial.', href: '{{ hp.url }}?variant={{ v1.id }}', ctaText: 'start with starter' };
  }
  root.querySelectorAll('.u2-quiz__opt').forEach(function(btn){
    btn.addEventListener('click', function(){
      answers.push(btn.dataset.u2QuizAnswer);
      current++;
      if(current >= 3) showResult();
      else show(current);
    });
  });
  root.querySelector('[data-u2-quiz-restart]').addEventListener('click', function(){
    answers = []; current = 0; show(0);
  });
})();
</script>

{% schema %}
{
  "name": "U2 PDP Ritual Quiz",
  "tag": "section",
  "class": "shopify-section--u2-quiz",
  "settings": [],
  "presets": [ { "name": "U2 PDP Ritual Quiz" } ]
}
{% endschema %}
