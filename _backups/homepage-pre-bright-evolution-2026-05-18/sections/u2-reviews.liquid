{%- comment -%}
  UBurn V2 — Reviews page (Loox widget embed + curated testimonials)
{%- endcomment -%}
{%- liquid
  assign hp = all_products['ube-poudre']
  assign rating = hp.metafields.loox.avg_rating | default: 4.7 | round: 1
-%}
<style>
  .u2-rev-hero {
    background: linear-gradient(180deg, var(--u2-cream) 0%, var(--u2-lavender-soft) 100%);
    padding: 120px 20px 60px;
    text-align: center;
  }
  .u2-rev-hero h1 {
    font-family: var(--u2-sans);
    font-size: clamp(40px,7vw,72px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--u2-plum-black);
    margin: 16px 0 16px;
  }
  .u2-rev-hero h1 em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-rev-hero p { font-size: 17px; color: var(--u2-text-body); max-width: 50ch; margin: 0 auto 20px; }
  .u2-rev-hero__stars {
    font-size: 28px;
    color: #F5B400;
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }
  .u2-rev-hero__rating {
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 22px;
    color: var(--u2-iris-deep);
  }

  .u2-rev-grid { padding: var(--u2-space-section) 20px; background: white; }
  .u2-rev-grid__inner { max-width: 1180px; margin: 0 auto; }
  .u2-rev-grid__head { text-align: center; margin-bottom: 48px; }
  .u2-rev-grid__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(32px,5vw,46px);
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.025em;
    margin: 12px 0 0;
  }
  .u2-rev-grid__head h2 em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-rev-cards { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media (min-width: 768px) { .u2-rev-cards { grid-template-columns: repeat(3,1fr); } }
  .u2-rev-card {
    background: var(--u2-bone);
    border-radius: 18px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .u2-rev-card__stars { color: #F5B400; font-size: 14px; letter-spacing: 0.1em; }
  .u2-rev-card__quote {
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 17px;
    line-height: 1.5;
    color: var(--u2-plum-black);
  }
  .u2-rev-card__verified {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--u2-iris);
  }
  .u2-rev-card__author { display: flex; align-items: center; gap: 12px; padding-top: 14px; border-top: 1px solid rgba(107,78,158,0.12); }
  .u2-rev-card__avatar {
    width: 44px; height: 44px; border-radius: 50%; overflow: hidden;
    background: var(--u2-lavender-soft); flex-shrink: 0;
  }
  .u2-rev-card__avatar img { width:100%; height:100%; object-fit: cover; }
  .u2-rev-card__name { font-size: 14px; font-weight: 700; color: var(--u2-plum-black); }
  .u2-rev-card__loc { font-size: 12px; color: var(--u2-text-muted); }

  .u2-rev-loox {
    padding: var(--u2-space-section) 20px;
    background: var(--u2-cream);
  }
  .u2-rev-loox__inner { max-width: 1180px; margin: 0 auto; }
  .u2-rev-loox__head { text-align: center; margin-bottom: 32px; }
  .u2-rev-loox__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(28px,4vw,38px);
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.025em;
    margin: 12px 0 0;
  }
  .u2-rev-loox__widget {
    background: white;
    border-radius: 16px;
    padding: 36px 24px;
    text-align: center;
    color: var(--u2-text-muted);
    font-size: 14px;
    border: 1px solid rgba(107,78,158,0.1);
  }

  .u2-rev-cta {
    background: linear-gradient(135deg, var(--u2-plum-deep), var(--u2-iris-deep));
    color: var(--u2-warm-white);
    padding: 64px 20px;
    text-align: center;
  }
  .u2-rev-cta h2 {
    font-family: var(--u2-sans);
    font-size: clamp(28px,4.5vw,40px);
    font-weight: 800;
    margin: 0 0 24px;
    color: var(--u2-warm-white);
    letter-spacing: -0.025em;
  }
  .u2-rev-cta h2 em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-lavender); }
</style>

<div class="u2-root">
  <section class="u2-rev-hero u2-reveal">
    <span class="u2-section-eyebrow">— what women say</span>
    <h1>Their words. <em>Not ours.</em></h1>
    <div class="u2-rev-hero__stars" aria-hidden="true">★★★★★</div>
    <div class="u2-rev-hero__rating">{{ rating }}/5 verified Loox rating</div>
    <p style="margin-top:14px;">Real customers. Verified purchases. No filters.</p>
  </section>

  <section class="u2-rev-grid">
    <div class="u2-rev-grid__inner">
      <div class="u2-rev-grid__head u2-reveal">
        <span class="u2-section-eyebrow">— curated favorites</span>
        <h2>Loved by women <em>across America.</em></h2>
      </div>
      <div class="u2-rev-cards">
        <article class="u2-rev-card u2-reveal delay-1">
          <span class="u2-rev-card__stars">★★★★★</span>
          <p class="u2-rev-card__quote">"I tried so many things that made me bored or jittery. This is different. My 4 PM cravings are gone."</p>
          <span class="u2-rev-card__verified">✓ Verified purchase</span>
          <div class="u2-rev-card__author">
            <div class="u2-rev-card__avatar"><img src="{{ 'u2-rev-ashley.jpg' | asset_url }}" alt="Ashley K." loading="lazy" width="100" height="100"></div>
            <div>
              <div class="u2-rev-card__name">Ashley K.</div>
              <div class="u2-rev-card__loc">Phoenix, AZ</div>
            </div>
          </div>
        </article>
        <article class="u2-rev-card u2-reveal delay-2">
          <span class="u2-rev-card__stars">★★★★★</span>
          <p class="u2-rev-card__quote">"The powder turns into a calm, indulgent moment. I actually look forward to it."</p>
          <span class="u2-rev-card__verified">✓ Verified purchase</span>
          <div class="u2-rev-card__author">
            <div class="u2-rev-card__avatar"><img src="{{ 'u2-rev-jennifer.jpg' | asset_url }}" alt="Jennifer M." loading="lazy" width="100" height="100"></div>
            <div>
              <div class="u2-rev-card__name">Jennifer M.</div>
              <div class="u2-rev-card__loc">Miami, FL</div>
            </div>
          </div>
        </article>
        <article class="u2-rev-card u2-reveal delay-3">
          <span class="u2-rev-card__stars">★★★★★</span>
          <p class="u2-rev-card__quote">"Smoother digestion, calmer mood, and no afternoon crash. I'm sold."</p>
          <span class="u2-rev-card__verified">✓ Verified purchase</span>
          <div class="u2-rev-card__author">
            <div class="u2-rev-card__avatar"><img src="{{ 'u2-rev-rachel.jpg' | asset_url }}" alt="Rachel R." loading="lazy" width="100" height="100"></div>
            <div>
              <div class="u2-rev-card__name">Rachel R.</div>
              <div class="u2-rev-card__loc">Denver, CO</div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="u2-rev-loox">
    <div class="u2-rev-loox__inner">
      <div class="u2-rev-loox__head u2-reveal">
        <h2>All verified reviews</h2>
      </div>
      <div class="u2-rev-loox__widget u2-reveal delay-1">
        {%- if hp.metafields.loox.reviews.value != blank -%}
          {{ hp.metafields.loox.reviews.value }}
        {%- else -%}
          <p>Loox reviews widget will render here once installed. Currently {{ hp.metafields.loox.num_reviews | default: 28 }} verified Loox reviews · {{ rating }}/5 average.</p>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="u2-rev-cta">
    <h2>Ready to <em>try it?</em></h2>
    {% render 'u2-cta-primary', text: 'start my pack', link: '/products/ube-poudre?variant=51289200034111', on_dark: true %}
  </section>
</div>

{% schema %}
{
  "name": "U2 Reviews page",
  "tag": "section",
  "class": "shopify-section--u2-reviews",
  "settings": [],
  "presets": [ { "name": "U2 Reviews page" } ]
}
{% endschema %}
