{%- comment -%}
  UBurn V2 — Hero section (atomic, extracted from u2-homepage)
{%- endcomment -%}
{%- liquid
  assign hp = section.settings.product
  if hp == blank
    assign hp = all_products['ube-poudre']
  endif
  assign min_price = hp.price_min | default: hp.price
  assign display_price = min_price | money_without_trailing_zeros
  assign variant_id = section.settings.variant_id | default: '51289200034111'
  assign cta_link = hp.url
  if variant_id != blank
    assign cta_link = hp.url | append: '?variant=' | append: variant_id
  endif
-%}
<style>
  .u2-hero {
    position: relative;
    background: var(--u2-cream);
    padding: 32px 20px 56px;
    overflow: hidden;
    min-height: 88vh;
    display: flex;
    align-items: center;
    isolation: isolate;
  }
  .u2-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(58% 50% at 78% 30%, rgba(139, 111, 191, 0.22), transparent 70%),
      radial-gradient(50% 45% at 18% 82%, rgba(184, 157, 217, 0.18), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }
  .u2-hero__grid {
    width: 100%; max-width: 1280px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr; gap: 36px; align-items: center;
  }
  .u2-hero__copy { display: flex; flex-direction: column; gap: 18px; order: 1; }
  .u2-hero__sub { font-size: 15px; line-height: 1.55; color: var(--u2-text-body); max-width: 34ch; margin: 4px 0 0; }
  .u2-hero__priceline { display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 12px; font-size: 14px; color: var(--u2-plum); margin: 6px 0 4px; }
  .u2-hero__price-prefix { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--u2-iris); }
  .u2-hero__price { font-size: 19px; font-weight: 700; color: var(--u2-plum-black); letter-spacing: -0.01em; }
  .u2-hero__price-divider { opacity: 0.4; }
  .u2-hero__trust { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; list-style: none; padding: 0; }
  .u2-hero__media { position: relative; order: 2; width: 100%; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; }
  .u2-hero__media::before { content: ""; position: absolute; width: 78%; height: 78%; border-radius: 50%; background: radial-gradient(circle, rgba(184,157,217,0.5), rgba(184,157,217,0) 65%); filter: blur(20px); z-index: 0; }
  .u2-hero__image { position: relative; z-index: 1; width: 92%; max-width: 520px; aspect-ratio: 1/1; border-radius: 24px; overflow: hidden; box-shadow: 0 30px 60px -30px rgba(58,31,89,0.45), 0 18px 36px -18px rgba(58,31,89,0.25); animation: u2-float 8s ease-in-out infinite alternate; }
  .u2-hero__image img { width: 100%; height: 100%; object-fit: cover; }
  @media (min-width: 1024px) {
    .u2-hero { padding: 64px 56px 96px; min-height: 92vh; }
    .u2-hero__grid { grid-template-columns: minmax(0,1.05fr) minmax(0,1fr); gap: 64px; }
    .u2-hero__copy { gap: 22px; }
    .u2-hero__media { order: 2; aspect-ratio: 4/5; }
    .u2-hero__image { max-width: 560px; aspect-ratio: 4/5; }
    .u2-hero__sub { font-size: 17px; max-width: 38ch; }
  }
</style>
<section class="u2-root u2-hero" aria-label="UBurn — Crush the 4PM crash">
  <div class="u2-hero__grid">
    <div class="u2-hero__copy u2-reveal">
      <span class="u2-eyebrow">{{ section.settings.eyebrow | default: 'the violet hour · est. 2024' }}</span>
      <h1 class="u2-h1-hero">{{ section.settings.headline_pre | default: 'Crush the' }} <em>{{ section.settings.headline_em | default: '4 PM' }}</em> {{ section.settings.headline_post | default: 'crash.' }}</h1>
      <p class="u2-hero__sub">{{ section.settings.sub | default: 'A violet wellness ritual. Plant-based satiety. 30 calories. French heritage.' }}</p>
      {%- if hp != blank -%}
      <p class="u2-hero__priceline">
        <span class="u2-hero__price-prefix">from</span>
        <span class="u2-hero__price">{{ display_price }}</span>
        <span class="u2-hero__price-divider">·</span>
        <span>free us shipping</span>
      </p>
      {%- endif -%}
      {% render 'u2-cta-primary', text: section.settings.cta | default: 'start my pack', link: cta_link %}
      <ul class="u2-hero__trust">
        <li>{% render 'u2-trust-pill', icon: 'check', text: 'EFSA-backed' %}</li>
        <li>{% render 'u2-trust-pill', icon: 'leaf', text: 'Caffeine-free' %}</li>
        <li>{% render 'u2-trust-pill', icon: 'flask', text: 'Third-party lab tested' %}</li>
      </ul>
    </div>
    <div class="u2-hero__media u2-reveal delay-1" data-u2-sticky-trigger>
      <div class="u2-hero__image">
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | image_url: width: 1200 | image_tag: loading: 'eager', fetchpriority: 'high', alt: 'UBurn', width: section.settings.hero_image.width, height: section.settings.hero_image.height, sizes: '(min-width:1024px) 560px, 92vw' }}
        {%- else -%}
          <img src="{{ 'u2-hero-lifestyle.jpg' | asset_url }}" alt="UBurn — woman with violet drink at 4 PM" loading="eager" fetchpriority="high" decoding="async" width="1024" height="1024">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{% render 'u2-sticky-atc', product: hp, cta_link: cta_link %}
{% schema %}
{
  "name": "U2 Hero",
  "tag": "section",
  "class": "shopify-section--u2-hero",
  "settings": [
    { "type": "product", "id": "product", "label": "Hero product" },
    { "type": "text", "id": "variant_id", "label": "Variant ID", "default": "51289200034111" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "the violet hour · est. 2024" },
    { "type": "text", "id": "headline_pre", "label": "Headline start", "default": "Crush the" },
    { "type": "text", "id": "headline_em", "label": "Headline italic", "default": "4 PM" },
    { "type": "text", "id": "headline_post", "label": "Headline end", "default": "crash." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "A violet wellness ritual. Plant-based satiety. 30 calories. French heritage." },
    { "type": "text", "id": "cta", "label": "CTA text", "default": "start my pack" }
  ],
  "presets": [ { "name": "U2 Hero" } ]
}
{% endschema %}
