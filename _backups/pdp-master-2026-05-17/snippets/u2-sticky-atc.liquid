{%- comment -%}
  UBurn V2 sticky ATC (renders bottom-fixed CTA, JS toggles is-visible on scroll past trigger)
  Usage: {% render 'u2-sticky-atc', product: product, cta_text: 'start my pack' %}
{%- endcomment -%}
{%- liquid
  if product == blank
    assign product = all_products['ube-poudre']
  endif
  comment
    rev 2026-05-16 — USD hardcoded display ($36.99) — Markets USD admin pending
  endcomment
  assign display_price = '$36.99'
  assign cta_text = cta_text | default: 'start my pack'
  assign cta_link = cta_link | default: product.url
-%}
<div class="u2-sticky-atc" data-u2-sticky>
  <div class="u2-sticky-atc__label">UBurn · from {{ display_price }}</div>
  <a class="u2-sticky-atc__cta" href="{{ cta_link }}">{{ cta_text }} →</a>
</div>
