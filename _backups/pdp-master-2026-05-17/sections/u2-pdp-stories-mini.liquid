{%- comment -%}
  UBurn V2 — Stories mini (4 customer avatar cards with quotes)
{%- endcomment -%}
<style>
  .u2-pdp-stories-mini { padding: 64px 20px; background: var(--u2-cream-deep); }
  .u2-pdp-stories-mini__inner { max-width: 1100px; margin: 0 auto; }
  .u2-pdp-stories-mini__head { text-align: center; margin-bottom: 40px; }
  .u2-pdp-stories-mini__eyebrow {
    display: inline-block;
    font-family: var(--u2-sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .u2-pdp-stories-mini__title {
    font-family: var(--u2-serif);
    font-size: 36px;
    line-height: 1.1;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .u2-pdp-stories-mini__sub {
    font-family: var(--u2-sans);
    font-size: 14px;
    color: var(--u2-plum);
    margin: 0 auto;
    max-width: 520px;
  }
  .u2-pdp-stories-mini__row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    margin-top: 16px;
  }
  .u2-pdp-stories-mini__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }
  .u2-pdp-stories-mini__avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(107, 78, 158, 0.08);
    box-shadow: 0 4px 16px rgba(42, 16, 84, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--u2-serif);
    font-size: 28px;
    color: var(--u2-iris);
    font-weight: 400;
  }
  .u2-pdp-stories-mini__avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .u2-pdp-stories-mini__name {
    font-family: var(--u2-sans);
    font-size: 14px;
    font-weight: 700;
    color: var(--u2-plum-black);
    line-height: 1.3;
  }
  .u2-pdp-stories-mini__loc {
    display: block;
    font-size: 11px;
    color: var(--u2-mauve);
    font-weight: 500;
    margin-top: 2px;
    letter-spacing: 0.04em;
  }
  .u2-pdp-stories-mini__quote {
    font-family: var(--u2-serif);
    font-size: 14px;
    line-height: 1.4;
    color: var(--u2-plum);
    font-style: italic;
    margin: 0;
    max-width: 200px;
  }
  @media (max-width: 768px) {
    .u2-pdp-stories-mini { padding: 48px 16px; }
    .u2-pdp-stories-mini__row { grid-template-columns: repeat(2, 1fr); gap: 32px 20px; }
    .u2-pdp-stories-mini__title { font-size: 28px; }
  }
</style>
<section class="u2-root u2-pdp-stories-mini" aria-labelledby="u2-stories-mini-title">
  <div class="u2-pdp-stories-mini__inner">
    <div class="u2-pdp-stories-mini__head">
      <span class="u2-pdp-stories-mini__eyebrow">{{ section.settings.eyebrow | default: 'They use it' }}</span>
      <h2 class="u2-pdp-stories-mini__title" id="u2-stories-mini-title">{{ section.settings.title | default: 'The ritual, in real life.' }}</h2>
      <p class="u2-pdp-stories-mini__sub">{{ section.settings.subtitle | default: 'Real women. Real routines. Real moments.' }}</p>
    </div>
    <div class="u2-pdp-stories-mini__row">
      {% for block in section.blocks %}
        <div class="u2-pdp-stories-mini__card" {{ block.shopify_attributes }}>
          <div class="u2-pdp-stories-mini__avatar">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.name | escape }}" loading="lazy" decoding="async" width="88" height="88">
            {% else %}
              <span aria-hidden="true">{{ block.settings.name | slice: 0, 1 }}</span>
            {% endif %}
          </div>
          <div class="u2-pdp-stories-mini__name">
            {{ block.settings.name }}<span class="u2-pdp-stories-mini__loc">{{ block.settings.location }}</span>
          </div>
          <p class="u2-pdp-stories-mini__quote">"{{ block.settings.quote }}"</p>
        </div>
      {% else %}
        <div class="u2-pdp-stories-mini__card"><div class="u2-pdp-stories-mini__avatar"><img src="{{ 'uburn-us-story-1-sarah-brooklyn.png' | asset_url }}" alt="Sarah J. — Brooklyn, NY" loading="lazy" decoding="async" width="200" height="200"></div><div class="u2-pdp-stories-mini__name">Sarah J., 32<span class="u2-pdp-stories-mini__loc">Brooklyn, NY</span></div><p class="u2-pdp-stories-mini__quote">"No more 4PM cravings."</p></div>
        <div class="u2-pdp-stories-mini__card"><div class="u2-pdp-stories-mini__avatar"><img src="{{ 'uburn-us-story-2-jennifer-miami.png' | asset_url }}" alt="Jennifer M. — Miami, FL" loading="lazy" decoding="async" width="200" height="200"></div><div class="u2-pdp-stories-mini__name">Jennifer M., 38<span class="u2-pdp-stories-mini__loc">Miami, FL</span></div><p class="u2-pdp-stories-mini__quote">"Calmer afternoons. More stable energy."</p></div>
        <div class="u2-pdp-stories-mini__card"><div class="u2-pdp-stories-mini__avatar"><img src="{{ 'uburn-us-story-3-rachel-denver.png' | asset_url }}" alt="Rachel B. — Denver, CO" loading="lazy" decoding="async" width="200" height="200"></div><div class="u2-pdp-stories-mini__name">Rachel B., 47<span class="u2-pdp-stories-mini__loc">Denver, CO</span></div><p class="u2-pdp-stories-mini__quote">"Vanilla taste. Nothing chemical."</p></div>
        <div class="u2-pdp-stories-mini__card"><div class="u2-pdp-stories-mini__avatar"><img src="{{ 'uburn-us-story-4-megan-austin.png' | asset_url }}" alt="Megan T. — Austin, TX" loading="lazy" decoding="async" width="200" height="200"></div><div class="u2-pdp-stories-mini__name">Megan T., 39<span class="u2-pdp-stories-mini__loc">Austin, TX</span></div><p class="u2-pdp-stories-mini__quote">"Before workouts. Stim-free."</p></div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "U2 PDP Stories Mini",
  "tag": "section",
  "class": "shopify-section--u2",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "They use it" },
    { "type": "text", "id": "title", "label": "Title", "default": "The ritual, in real life." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Real women. Real routines. Real moments." }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Avatar (optional)" },
        { "type": "text", "id": "name", "label": "Name + age", "default": "Sarah J., 32" },
        { "type": "text", "id": "location", "label": "Location", "default": "Brooklyn, NY" },
        { "type": "text", "id": "quote", "label": "Quote", "default": "No more 4PM cravings." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "U2 PDP Stories Mini",
      "blocks": [
        { "type": "story", "settings": { "name": "Sarah J., 32", "location": "Brooklyn, NY", "quote": "No more 4PM cravings." } },
        { "type": "story", "settings": { "name": "Jennifer M., 38", "location": "Miami, FL", "quote": "Calmer afternoons. More stable energy." } },
        { "type": "story", "settings": { "name": "Rachel B., 47", "location": "Denver, CO", "quote": "Vanilla taste. Nothing chemical." } },
        { "type": "story", "settings": { "name": "Megan T., 39", "location": "Austin, TX", "quote": "Before workouts. Stim-free." } }
      ]
    }
  ]
}
{% endschema %}
