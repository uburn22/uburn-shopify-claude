{%- comment -%}
  UBurn V2 — PDP 3 simple steps (Mix · Sip · Stay in control)
{%- endcomment -%}
<style>
  .u2-pdp-steps { padding: 80px 20px; background: var(--u2-cream); }
  .u2-pdp-steps__inner { max-width: 1200px; margin: 0 auto; }
  .u2-pdp-steps__head { text-align: center; margin-bottom: 56px; }
  .u2-pdp-steps__eyebrow {
    display: inline-block;
    font-family: var(--u2-sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .u2-pdp-steps__title {
    font-family: var(--u2-serif);
    font-size: 44px;
    line-height: 1.05;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0;
    letter-spacing: -0.025em;
  }
  .u2-pdp-steps__title em { font-style: italic; color: var(--u2-iris); }
  .u2-pdp-steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .u2-pdp-step-card {
    background: var(--u2-cream);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(42, 16, 84, 0.08);
    border: 1px solid rgba(107, 78, 158, 0.06);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .u2-pdp-step-card__media {
    aspect-ratio: 1 / 1;
    background: linear-gradient(135deg, var(--u2-lavender-soft), var(--u2-cream));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .u2-pdp-step-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .u2-pdp-step-card__placeholder {
    font-family: var(--u2-serif);
    font-size: 88px;
    color: var(--u2-iris);
    font-style: italic;
    opacity: 0.4;
  }
  .u2-pdp-step-card__num {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--u2-plum-black);
    color: var(--u2-cream);
    font-family: var(--u2-sans);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 6px 12px;
    border-radius: 999px;
  }
  .u2-pdp-step-card__body { padding: 28px 24px 32px; }
  .u2-pdp-step-card__title {
    font-family: var(--u2-serif);
    font-size: 24px;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0 0 10px;
    letter-spacing: -0.015em;
  }
  .u2-pdp-step-card__copy {
    font-family: var(--u2-sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--u2-plum);
    margin: 0;
  }
  @media (max-width: 900px) {
    .u2-pdp-steps { padding: 60px 16px; }
    .u2-pdp-steps__grid { grid-template-columns: 1fr; gap: 20px; }
    .u2-pdp-steps__title { font-size: 30px; }
  }
</style>
<section class="u2-root u2-pdp-steps" aria-labelledby="u2-pdp-steps-title">
  <div class="u2-pdp-steps__inner">
    <div class="u2-pdp-steps__head">
      <span class="u2-pdp-steps__eyebrow">{{ section.settings.eyebrow | default: '3 simple steps' }}</span>
      <h2 class="u2-pdp-steps__title" id="u2-pdp-steps-title">{{ section.settings.title | default: '30 seconds <em>to change the moment.</em>' }}</h2>
    </div>
    <div class="u2-pdp-steps__grid">
      {% for block in section.blocks %}
        <article class="u2-pdp-step-card" {{ block.shopify_attributes }}>
          <div class="u2-pdp-step-card__media">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy" decoding="async" width="800" height="800">
            {% else %}
              <span class="u2-pdp-step-card__placeholder" aria-hidden="true">{{ forloop.index | plus: 0 | prepend: '0' }}</span>
            {% endif %}
          </div>
          <div class="u2-pdp-step-card__num">{{ forloop.index | prepend: '0' }}</div>
          <div class="u2-pdp-step-card__body">
            <h3 class="u2-pdp-step-card__title">{{ block.settings.title }}</h3>
            <p class="u2-pdp-step-card__copy">{{ block.settings.copy }}</p>
          </div>
        </article>
      {% else %}
        <article class="u2-pdp-step-card"><div class="u2-pdp-step-card__media"><img src="{{ 'uburn-us-pdp-step-1-mix.png' | asset_url }}" alt="{% if request.locale.iso_code == 'fr' %}Femme versant la poudre violette UBurn dans un verre d'eau{% else %}Woman pouring UBurn violet powder into a glass of water{% endif %}" loading="lazy" decoding="async" width="1024" height="1024" style="width:100%;height:100%;object-fit:cover;"></div><div class="u2-pdp-step-card__num">01</div><div class="u2-pdp-step-card__body"><h3 class="u2-pdp-step-card__title">Mix</h3><p class="u2-pdp-step-card__copy">One scoop in a large glass of cold water or plant-based milk.</p></div></article>
        <article class="u2-pdp-step-card"><div class="u2-pdp-step-card__media"><img src="{{ 'uburn-us-pdp-step-2-sip.png' | asset_url }}" alt="{% if request.locale.iso_code == 'fr' %}Femme tenant un grand verre violet glacé UBurn{% else %}Woman holding a tall iced violet UBurn glass{% endif %}" loading="lazy" decoding="async" width="1024" height="1024" style="width:100%;height:100%;object-fit:cover;"></div><div class="u2-pdp-step-card__num">02</div><div class="u2-pdp-step-card__body"><h3 class="u2-pdp-step-card__title">Sip</h3><p class="u2-pdp-step-card__copy">A purple drink, smooth, cool, and creamy.</p></div></article>
        <article class="u2-pdp-step-card"><div class="u2-pdp-step-card__media"><img src="{{ 'uburn-us-pdp-step-3-stay.png' | asset_url }}" alt="{% if request.locale.iso_code == 'fr' %}Femme calme et focalisée dans sa cuisine après son rituel UBurn{% else %}Calm focused woman in her kitchen after her UBurn ritual{% endif %}" loading="lazy" decoding="async" width="1024" height="1024" style="width:100%;height:100%;object-fit:cover;"></div><div class="u2-pdp-step-card__num">03</div><div class="u2-pdp-step-card__body"><h3 class="u2-pdp-step-card__title">Stay in control*</h3><p class="u2-pdp-step-card__copy">A feeling of fullness that helps you through the critical moment.*</p></div></article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "U2 PDP Steps",
  "tag": "section",
  "class": "shopify-section--u2",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "3 simple steps" },
    { "type": "text", "id": "title", "label": "Title (em supported)", "default": "30 seconds <em>to change the moment.</em>" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "title", "label": "Step title" },
        { "type": "textarea", "id": "copy", "label": "Step copy" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "U2 PDP Steps",
      "blocks": [
        { "type": "step", "settings": { "title": "Mix", "copy": "One scoop in a large glass of cold water or plant-based milk." } },
        { "type": "step", "settings": { "title": "Sip", "copy": "A purple drink, smooth, cool, and creamy." } },
        { "type": "step", "settings": { "title": "Stay in control*", "copy": "A feeling of fullness that helps you through the critical moment.*" } }
      ]
    }
  ]
}
{% endschema %}
