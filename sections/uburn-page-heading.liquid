{%- comment -%}
  UBurn Page Heading — minimal LP-style H1 + optional subtitle.
  Used on pages that lack a proper H1 (ingredients, contact, FAQ, about).
  Pulls page.title dynamically; subtitle from section settings.
{%- endcomment -%}

<section class="uburn-page-heading">
  <h1 class="uburn-page-heading__h1">
    {{- section.settings.heading | default: page.title -}}
  </h1>
  {%- if section.settings.subtitle != blank -%}
    <p class="uburn-page-heading__subtitle">{{ section.settings.subtitle }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "UBurn Page Heading",
  "tag": "section",
  "class": "uburn-page-heading-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Custom heading (leave empty to use page title)"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "presets": [
    { "name": "UBurn Page Heading" }
  ]
}
{% endschema %}
