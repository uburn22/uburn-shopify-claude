{%- comment -%}
  ════════════════════════════════════════════════════════════════
  UBURN Contact v2 — clean, premium wellness
  Sections: Hero → Blocs contact → Trust → CTA retour produit
  ════════════════════════════════════════════════════════════════
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

<style>
  .ucont3 {
    --up-purple-deep:#3d1873; --up-purple-main:#6b2fa0; --up-purple-mid:#8b47c5;
    --up-purple-pale:#e8dcf5; --up-purple-wash:#f5f0fa;
    --up-cream:#faf9f7; --up-dark:#242220; --up-body:#5a5654; --up-muted:#8a8785;
    --up-ease:cubic-bezier(.22,1,.36,1);
    font-family:'Red Hat Text',sans-serif; -webkit-font-smoothing:antialiased; color:var(--up-dark);
  }
  .ucont3 *,.ucont3 *::before,.ucont3 *::after { box-sizing:border-box; }
  .ucont3-section { padding:56px 16px 64px; }
  @media(min-width:900px){ .ucont3-section{ padding:80px 32px 96px; } }
  .ucont3-eyebrow {
    display:inline-block; font-family:'Red Hat Text',sans-serif;
    font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1.6px;
    color:var(--up-purple-main); margin-bottom:14px;
  }
  .ucont3-h1 {
    font-family:'Red Hat Display',sans-serif; font-size:clamp(36px,5vw,60px);
    font-weight:800; line-height:1.06; color:var(--up-dark);
    margin-bottom:20px; text-wrap:balance;
  }
  .ucont3-h1 .accent { color:var(--up-purple-mid); }
  .ucont3-h2 {
    font-family:'Red Hat Display',sans-serif; font-size:clamp(26px,3.2vw,40px);
    font-weight:700; line-height:1.15; letter-spacing:-0.02em;
    color:var(--up-purple-deep); margin-bottom:16px; text-wrap:balance;
  }
  .ucont3-h2 .accent { color:var(--up-purple-mid); }
  .ucont3-lead {
    font-family:'Red Hat Text',sans-serif; font-size:17px; line-height:1.65;
    color:var(--up-body); font-weight:400; max-width:62ch; margin:0 auto 24px;
  }
  .ucont3-slot {
    background:var(--up-purple-wash); border:1px dashed var(--up-purple-pale);
    border-radius:16px; display:flex; align-items:center; justify-content:center;
    color:var(--up-muted); font-family:'Red Hat Text',sans-serif;
    font-size:11.5px; text-transform:uppercase; letter-spacing:1.2px;
  }
  .ucont3-slot--ratio-16-9 { aspect-ratio:16/9; }
  .ucont3-cta-primary {
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding:18px 32px; min-height:56px;
    background:var(--up-purple-main); color:#fff; border:none; border-radius:100px;
    text-decoration:none; font-family:'Red Hat Display',sans-serif;
    font-size:16px; font-weight:800; letter-spacing:.3px;
    box-shadow:0 8px 28px rgba(107,47,160,.28);
    transition:background .25s var(--up-ease),transform .25s var(--up-ease),box-shadow .25s var(--up-ease);
    -webkit-appearance:none; appearance:none;
    touch-action:manipulation; -webkit-tap-highlight-color:transparent;
  }
  .ucont3-cta-primary:hover { background:var(--up-purple-deep); transform:translateY(-2px); box-shadow:0 12px 36px rgba(107,47,160,.4); }
  .ucont3-cta-primary:focus-visible { outline:3px solid var(--up-purple-pale); outline-offset:4px; }
  /* Hero */
  .ucont3-hero { padding:56px 16px 48px; background:linear-gradient(180deg,#fff 0%,var(--up-purple-wash) 100%); text-align:center; }
  @media(min-width:900px){ .ucont3-hero{ padding:80px 32px 64px; } }
  .ucont3-hero__inner { max-width:780px; margin:0 auto; }
  .ucont3-hero__sub {
    font-family:'Red Hat Text',sans-serif; font-size:17px; line-height:1.65;
    color:var(--up-body); font-weight:400; max-width:560px; margin:0 auto 24px;
  }
  /* Blocs contact grid */
  .ucont3-blocks { background:var(--up-purple-wash); padding:48px 16px 56px; }
  @media(min-width:900px){ .ucont3-blocks{ padding:64px 32px 80px; } }
  .ucont3-blocks__grid {
    max-width:1100px; margin:0 auto;
    display:grid; grid-template-columns:1fr; gap:14px;
  }
  @media(min-width:700px){ .ucont3-blocks__grid{ grid-template-columns:1fr 1fr; gap:18px; } }
  .ucont3-card {
    background:#fff; border:1px solid var(--up-purple-pale); border-radius:16px;
    padding:24px 22px;
    transition:transform .2s var(--up-ease),box-shadow .2s var(--up-ease);
  }
  .ucont3-card:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(61,24,115,.08); }
  .ucont3-card__title {
    font-family:'Red Hat Display',sans-serif; font-size:16px; font-weight:800;
    color:var(--up-purple-deep); margin-bottom:8px; letter-spacing:-0.01em;
  }
  .ucont3-card__copy {
    font-family:'Red Hat Text',sans-serif; font-size:14px; line-height:1.55;
    color:var(--up-body); margin:0;
  }
  .ucont3-card a {
    color:var(--up-purple-main); text-decoration:none; font-weight:700;
  }
  .ucont3-card a:hover { color:var(--up-purple-deep); text-decoration:underline; }
  /* Trust */
  .ucont3-trust { background:#fff; text-align:center; }
  .ucont3-trust__inner {
    max-width:680px; margin:0 auto;
    background:var(--up-purple-wash); border:1px solid var(--up-purple-pale);
    border-radius:16px; padding:28px 24px;
  }
  .ucont3-trust__copy {
    font-family:'Red Hat Text',sans-serif; font-size:14.5px; line-height:1.65;
    color:var(--up-body); margin:0;
  }
  /* CTA section */
  .ucont3-cta-sec {
    background:linear-gradient(180deg,#fff 0%,var(--up-purple-wash) 100%);
    text-align:center;
  }
  .ucont3-cta-sec__inner { max-width:720px; margin:0 auto; }
  .ucont3-cta-sec__inner .ucont3-h2 { margin-bottom:14px; }
</style>

<div class="ucont3">

  {%- comment -%} ─── HERO ─── {%- endcomment -%}
  <section class="ucont3-hero">
    <div class="ucont3-hero__inner">
      <span class="ucont3-eyebrow">Contact</span>
      <h1 class="ucont3-h1">Besoin <span class="accent">d'aide ?</span></h1>
      <p class="ucont3-hero__sub">Une question sur l'utilisation, le goût, la livraison ou votre cure ? Notre équipe vous répond.</p>
      {%- comment -%} IMAGE SLOT — Contact / service client / lifestyle doux (16:9) — optionnel {%- endcomment -%}
    </div>
  </section>

  {%- comment -%} ─── BLOCS CONTACT ─── {%- endcomment -%}
  <section class="ucont3-blocks">
    <div class="ucont3-blocks__grid">
      <article class="ucont3-card">
        <h3 class="ucont3-card__title">Question sur l'utilisation</h3>
        <p class="ucont3-card__copy">Comment préparer ta cure, à quel moment la prendre, avec quoi la mélanger : on t'explique tout. <a href="mailto:hello@uburn.co?subject=Question%20utilisation">hello@uburn.co</a></p>
      </article>
      <article class="ucont3-card">
        <h3 class="ucont3-card__title">Question sur une commande</h3>
        <p class="ucont3-card__copy">Suivi, modification ou annulation : écris-nous avec ton numéro de commande. <a href="mailto:hello@uburn.co?subject=Question%20commande">hello@uburn.co</a></p>
      </article>
      <article class="ucont3-card">
        <h3 class="ucont3-card__title">Livraison ou retour</h3>
        <p class="ucont3-card__copy">Délais, transporteur, retour produit : on s'occupe de tout. <a href="mailto:hello@uburn.co?subject=Livraison%20retour">hello@uburn.co</a></p>
      </article>
      <article class="ucont3-card">
        <h3 class="ucont3-card__title">Partenariat ou collaboration</h3>
        <p class="ucont3-card__copy">Influence, presse, partenariat : présente-nous ton projet en quelques lignes. <a href="mailto:hello@uburn.co?subject=Partenariat">hello@uburn.co</a></p>
      </article>
    </div>
  </section>

  {%- comment -%} ─── TRUST ─── {%- endcomment -%}
  <section class="ucont3-section ucont3-trust">
    <div class="ucont3-trust__inner">
      <p class="ucont3-trust__copy">Nous lisons chaque message avec attention et faisons de notre mieux pour vous répondre rapidement.</p>
    </div>
  </section>

  {%- comment -%} ─── CTA RETOUR PRODUIT ─── {%- endcomment -%}
  <section class="ucont3-section ucont3-cta-sec">
    <div class="ucont3-cta-sec__inner">
      <span class="ucont3-eyebrow">Continuer</span>
      <h2 class="ucont3-h2">Retour <span class="accent">à la cure UBURN.</span></h2>
      <p class="ucont3-lead">Une boisson violette gourmande, sans caféine, pensée pour t'aider à mieux gérer les fringales.</p>
      <a href="/products/ube-poudre" class="ucont3-cta-primary">Voir la cure</a>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "UBurn Contact v2",
  "tag": "section",
  "class": "ucont3-wrap",
  "settings": [],
  "presets": [{ "name": "UBurn Contact v2" }]
}
{% endschema %}
