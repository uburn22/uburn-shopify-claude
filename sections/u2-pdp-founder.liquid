{%- comment -%}
  UBurn V2 — Founder story (Mariana quote + portrait)
{%- endcomment -%}
<style>
  .u2-pdp-founder { padding: 88px 20px; background: var(--u2-cream); }
  .u2-pdp-founder__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .u2-pdp-founder__copy { max-width: 540px; }
  .u2-pdp-founder__eyebrow {
    display: inline-block;
    font-family: var(--u2-sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .u2-pdp-founder__title {
    font-family: var(--u2-serif);
    font-size: 44px;
    line-height: 1.05;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0 0 24px;
    letter-spacing: -0.025em;
  }
  .u2-pdp-founder__title em { font-style: italic; color: var(--u2-iris); }
  .u2-pdp-founder__quote {
    font-family: var(--u2-serif);
    font-size: 22px;
    line-height: 1.4;
    font-style: italic;
    color: var(--u2-iris-deep);
    border-left: 3px solid var(--u2-iris);
    padding-left: 18px;
    margin: 24px 0;
    font-weight: 400;
  }
  .u2-pdp-founder__body {
    font-family: var(--u2-sans);
    font-size: 15px;
    line-height: 1.7;
    color: var(--u2-plum);
    margin: 16px 0;
  }
  .u2-pdp-founder__sig {
    margin-top: 24px;
    font-family: var(--u2-sans);
    font-size: 14px;
    font-weight: 700;
    color: var(--u2-iris-deep);
    letter-spacing: 0.02em;
  }
  .u2-pdp-founder__media {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(42, 16, 84, 0.18);
    aspect-ratio: 3 / 4;
    background: linear-gradient(135deg, var(--u2-lavender-soft), var(--u2-cream));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .u2-pdp-founder__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .u2-pdp-founder__placeholder {
    font-family: var(--u2-serif);
    font-size: 80px;
    color: var(--u2-iris);
    font-style: italic;
    opacity: 0.4;
  }
  @media (max-width: 900px) {
    .u2-pdp-founder { padding: 64px 20px; }
    .u2-pdp-founder__inner { grid-template-columns: 1fr; gap: 32px; }
    .u2-pdp-founder__title { font-size: 32px; }
    .u2-pdp-founder__quote { font-size: 18px; }
    .u2-pdp-founder__media { max-width: 360px; margin: 0 auto; }
  }
</style>
<section class="u2-root u2-pdp-founder" aria-labelledby="u2-founder-title">
  <div class="u2-pdp-founder__inner">
    <div class="u2-pdp-founder__copy">
      <span class="u2-pdp-founder__eyebrow">{{ section.settings.eyebrow | default: 'The story' }}</span>
      <h2 class="u2-pdp-founder__title" id="u2-founder-title">{{ section.settings.title | default: 'Made for women who handle cravings <em>their way.</em>' }}</h2>
      <p class="u2-pdp-founder__quote">"{{ section.settings.quote | default: 'I built the ritual I wished existed when I started.' }}"</p>
      <p class="u2-pdp-founder__body">{{ section.settings.body | default: 'Years of fighting 4PM cravings with coffee taught me one thing — willpower runs out. So I built UBurn. Plant-based. Caffeine-free. Indulgent. For women who want to handle cravings instead of fighting them every afternoon.' }}</p>
      <p class="u2-pdp-founder__sig">— {{ section.settings.signature | default: 'Mariana, Founder' }}</p>
    </div>
    <div class="u2-pdp-founder__media">
      {% if section.settings.portrait %}
        <img src="{{ section.settings.portrait | image_url: width: 800 }}" alt="{{ section.settings.signature | default: 'Founder portrait' | escape }}" loading="lazy" decoding="async" width="800" height="1067">
      {% else %}
        <span class="u2-pdp-founder__placeholder" aria-hidden="true">M</span>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "U2 PDP Founder",
  "tag": "section",
  "class": "shopify-section--u2",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The story" },
    { "type": "text", "id": "title", "label": "Title (em supported)", "default": "Made for women who handle cravings <em>their way.</em>" },
    { "type": "text", "id": "quote", "label": "Founder quote", "default": "I built the ritual I wished existed when I started." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "signature", "label": "Signature", "default": "Mariana, Founder" },
    { "type": "image_picker", "id": "portrait", "label": "Portrait" }
  ],
  "presets": [{ "name": "U2 PDP Founder" }]
}
{% endschema %}
