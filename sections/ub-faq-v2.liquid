{% comment %}Section: UB FAQ · Uburn 2026{% endcomment %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap');

:root{--purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;--purple-light:#b07de8;--purple-pale:#e8dcf5;--purple-wash:#f5f0fa;--cream:#faf9f7;--warm:#f2f0ed;--dark:#1a1118;--body:#5a5654;--muted:#8a8785;--grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Red Hat Text',sans-serif;background:var(--cream);color:var(--dark);-webkit-font-smoothing:antialiased;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Red Hat Display',sans-serif;letter-spacing:-0.02em}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
/* Hide Shopify default sections */
[id^="shopify-section-sections--"]{display:none !important}
main#main{padding:0 !important}
/* Nav */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:18px 48px;display:flex;align-items:center;justify-content:space-between;transition:background 0.4s,padding 0.4s,box-shadow 0.4s;background:rgba(250,249,247,0.96);backdrop-filter:blur(12px);box-shadow:0 1px 0 var(--purple-pale)}
.nav-logo{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:22px;color:var(--purple-main);letter-spacing:-0.03em}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none}
.nav-links a{font-size:14px;font-weight:500;color:var(--body);transition:color 0.2s}
.nav-links a:hover,.nav-links a.active{color:var(--purple-main)}
.nav-cta{background:var(--grad);color:#fff;padding:9px 22px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13.5px;transition:opacity 0.2s}
.nav-cta:hover{opacity:0.9}
@media(max-width:768px){.nav{padding:14px 20px}.nav-links{display:none}}
/* Section commons */
.section-label{font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--purple-mid);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.section-label::before{content:'';width:20px;height:1px;background:currentColor}
.section-title{font-size:clamp(32px,4vw,54px);font-weight:900;line-height:1.08;letter-spacing:-0.03em}
.section-title em{font-style:italic;font-weight:800;color:var(--purple-main)}
/* Before/After */
.ba-section{background:var(--warm);padding:100px 80px}
.ba-inner{max-width:1000px;margin:0 auto}
.ba-card{display:grid;grid-template-columns:1fr 56px 1fr;background:#fff;border-radius:24px;overflow:hidden;box-shadow:0 4px 60px rgba(61,24,115,0.1);margin-top:48px}
.ba-col{padding:40px 36px}
.ba-before{background:#f9f7f5}
.ba-divider{background:var(--purple-wash);display:flex;flex-direction:column;align-items:center;justify-content:center}
.ba-divider-arrow{width:36px;height:36px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;box-shadow:0 4px 16px rgba(107,47,160,0.4)}
.ba-label{font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.ba-week{font-family:'Red Hat Display',sans-serif;font-size:26px;font-weight:900;color:var(--dark);letter-spacing:-0.03em;margin-bottom:14px}
.ba-items{display:flex;flex-direction:column;gap:11px}
.ba-item{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.5;color:var(--body)}
.ba-item::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--purple-pale);flex-shrink:0;margin-top:6px}
.ba-after .ba-item::before{background:var(--purple-main)}
.ba-after .ba-item{color:var(--dark)}
.ba-profile{display:flex;align-items:center;gap:12px;margin-top:28px;padding-top:20px;border-top:1px solid var(--purple-pale)}
.ba-avatar{width:40px;height:40px;border-radius:50%;flex-shrink:0;background:var(--purple-pale);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;color:var(--purple-main)}
.ba-name{font-weight:700;font-size:14px;color:var(--dark)}
.ba-meta{font-size:12px;color:var(--muted);margin-top:1px}
.ba-stars{color:#f4b942;font-size:13px;margin-top:3px}
@media(max-width:720px){.ba-section{padding:72px 24px}.ba-card{grid-template-columns:1fr;grid-template-rows:auto 48px auto}.ba-divider{height:48px;flex-direction:row}.ba-col{padding:28px 24px}}
/* Reveal */
.reveal{opacity:0;transform:translateY(22px);transition:opacity 0.6s ease,transform 0.6s cubic-bezier(0.16,1,0.3,1)}
.reveal.visible{opacity:1;transform:none}
.rd1{transition-delay:0.1s}.rd2{transition-delay:0.2s}.rd3{transition-delay:0.3s}
/* Footer */
.footer{background:var(--dark);padding:64px 80px 36px;color:rgba(255,255,255,0.55)}
.footer-inner{max-width:1140px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:36px}
.footer-brand{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:20px;color:#fff;margin-bottom:14px;letter-spacing:-0.02em}
.footer-desc{font-size:13.5px;line-height:1.7;max-width:34ch;color:rgba(255,255,255,0.5);margin-bottom:20px}
.footer-legal{font-size:11px;line-height:1.7;color:rgba(255,255,255,0.28)}
.footer-col-title{font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13px;color:rgba(255,255,255,0.85);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:9px}
.footer-links a{font-size:13px;color:rgba(255,255,255,0.4);transition:color 0.2s}
.footer-links a:hover{color:rgba(255,255,255,0.85)}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:12px;color:rgba(255,255,255,0.22)}
@media(max-width:900px){.footer{padding:48px 24px 28px}.footer-top{grid-template-columns:1fr 1fr;gap:28px}}
@media(max-width:600px){.footer-top{grid-template-columns:1fr}}
/* Btn */
.btn-main{display:inline-flex;align-items:center;gap:8px;background:var(--grad);color:#fff;padding:16px 32px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;transition:transform 0.2s,opacity 0.2s;border:none;cursor:pointer}
.btn-main:hover{transform:translateY(-2px);opacity:0.92}


.faq-hero{padding:140px 80px 80px;background:var(--cream);text-align:center}
.faq-hero h1{font-size:clamp(40px,5vw,64px);font-weight:900;letter-spacing:-0.03em;margin-bottom:16px}
.faq-hero p{font-size:17px;color:var(--body);max-width:48ch;margin:0 auto}
.faq-body{padding:0 80px 80px;max-width:820px;margin:0 auto}
.faq-group{margin-bottom:56px}
.faq-group-title{font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:800;color:var(--dark);letter-spacing:-0.02em;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid var(--purple-pale)}
.faq-item{border-bottom:1px solid var(--purple-pale)}
.faq-q{font-family:'Red Hat Display',sans-serif;font-size:16px;font-weight:700;color:var(--dark);padding:20px 48px 20px 0;cursor:pointer;position:relative;letter-spacing:-0.01em}
.faq-q::after{content:'▾';position:absolute;right:0;top:50%;transform:translateY(-50%);color:var(--purple-main);transition:transform 0.3s;font-size:14px}
.faq-item.open .faq-q::after{transform:translateY(-50%) rotate(180deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height 0.4s cubic-bezier(0.16,1,0.3,1)}
.faq-item.open .faq-a{max-height:400px}
.faq-a-inner{font-size:15px;color:var(--body);line-height:1.7;padding:0 48px 20px 0;max-width:65ch}
.faq-a-inner strong{color:var(--dark);font-weight:600}
@media(max-width:768px){.faq-hero{padding:110px 24px 60px}.faq-body{padding:0 24px 60px}}

</style>
{% render 'ub-nav' %}

<section class="faq-hero">
  <div class="section-label reveal" style="justify-content:center">{% if request.locale.iso_code == 'en' %}Frequently asked questions{% else %}Questions fréquentes{% endif %}</div>
  <h1 class="reveal rd1">{% if request.locale.iso_code == 'en' %}Everything you want<br><em>to know.</em>{% else %}Toutes vos questions.<br><em>Vraiment.</em>{% endif %}</h1>
  <p class="reveal rd2">{% if request.locale.iso_code == 'en' %}Clear answers, no jargon. If your question isn't here, just email us.{% else %}Des réponses claires, sans jargon. Si votre question n'est pas ici, écrivez-nous.{% endif %}</p>
</section>

<div class="faq-body">
  <div class="faq-group reveal">
    <div class="faq-group-title">{% if request.locale.iso_code == 'en' %}The product{% else %}Le produit{% endif %}</div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}What exactly is UBurn?{% else %}C'est quoi exactement Uburn ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}UBurn is a plant-based powdered drink mix made with <strong>konjac glucomannan</strong>, purple ube, coconut MCT, L-Carnitine, ginger, and acacia fiber. It supports natural satiety as part of a balanced diet.*{% else %}Uburn est un complément alimentaire en poudre à base de <strong>glucomannane de konjac</strong>, d'ubé violet, de MCT de coco, de L-Carnitine, de gingembre et de fibre d'acacia. Il contribue au contrôle de l'appétit dans le cadre d'un régime hypocalorique (EFSA ID 3120).{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Is there caffeine in UBurn?{% else %}Y a-t-il de la caféine dans Uburn ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}No — <strong>caffeine-free</strong>. UBurn can be taken any time of day, including in the evening, without disrupting your sleep. It's one of our core differences vs. stimulant-based solutions.{% else %}Non, <strong>zéro caféine</strong>. Uburn peut être pris à n'importe quelle heure, y compris le soir, sans perturber le sommeil. C'est l'une de nos différences fondamentales avec les solutions stimulantes du marché.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}How many calories per scoop?{% else %}Combien de calories par dose ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}<strong>30 calories</strong> per scoop. No added sugar, no artificial sweeteners. Compatible with most diets.{% else %}<strong>30 kcal</strong> par dose. Aucun sucre ajouté, aucun édulcorant artificiel. Compatible avec tous les régimes alimentaires.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Is UBurn vegan?{% else %}Uburn est-il adapté aux végans ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}Yes, UBurn is <strong>100% plant-based</strong>. All ingredients are vegan.{% else %}Oui, Uburn est <strong>100% vegan</strong>. Tous les ingrédients sont d'origine végétale.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Any allergens?{% else %}Est-ce qu'il y a des allergènes ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}UBurn is produced in a facility that handles <strong>dairy, gluten, soy, and tree nuts</strong>. Please consult your doctor if you have a known allergy.{% else %}Uburn est fabriqué dans un atelier manipulant des produits à base de <strong>lait, gluten, soja et fruits à coque</strong>. Consultez votre médecin en cas d'allergie connue.{% endif %}</div></div>
    </div>
  </div>

  <div class="faq-group reveal rd1">
    <div class="faq-group-title">{% if request.locale.iso_code == 'en' %}How to use{% else %}Utilisation{% endif %}</div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}How do I take UBurn?{% else %}Comment prendre Uburn ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}Mix <strong>1 scoop (8g) in 8-10 oz of water</strong>, 30 minutes before a meal or whenever cravings hit (typically around 4PM). The research-backed* protocol requires 3g of glucomannan with 1-2 glasses of water.{% else %}Mélangez <strong>1 dose (8g) dans 200-300 ml d'eau</strong>, 30 minutes avant un repas ou à l'heure de vos fringales habituelles (souvent 15-16h). L'allégation EFSA nécessite 3g de glucomannane avec 1-2 verres d'eau.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Can I take it in the evening?{% else %}Peut-on le prendre le soir ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}Yes — <strong>no problem at all</strong>. Caffeine-free means UBurn can be taken any time, including before dinner. Many customers report best results when taken before dinner.*{% else %}Oui — <strong>sans aucun problème</strong>. L'absence de caféine permet une prise à toute heure, y compris le soir avant le dîner. C'est même souvent là où les résultats sont les plus spectaculaires.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}How quickly will I see results?{% else %}Combien de temps avant de voir des résultats ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}The fullness effect is <strong>immediate from the first scoop</strong>. Most customers report a noticeable shift in cravings and routine after <strong>7 to 14 days</strong> of consistent use.*{% else %}L'effet sur la satiété est <strong>immédiat dès la première prise</strong>. Les effets sur le poids et la digestion se font généralement sentir après <strong>7 à 14 jours</strong> d'utilisation régulière.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Can I mix it with something other than water?{% else %}Peut-on le mélanger avec autre chose qu'eau ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}Yes, with plant-based milk or a smoothie. Avoid sugary juices which work against the natural effect on blood sugar. Water remains the best option to activate glucomannan.{% else %}Oui, avec du lait végétal ou un smoothie. Évitez les jus sucrés qui annuleraient en partie l'effet sur la glycémie. L'eau reste la meilleure option pour activer le glucomannane.{% endif %}</div></div>
    </div>
  </div>

  <div class="faq-group reveal rd2">
    <div class="faq-group-title">{% if request.locale.iso_code == 'en' %}Order & shipping{% else %}Commande & livraison{% endif %}</div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Is shipping really free?{% else %}La livraison est-elle vraiment offerte ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}Yes — <strong>free U.S. shipping on all orders</strong>. Ships from France · typically arrives in 7–10 business days.{% else %}Oui, <strong>livraison offerte</strong> en France métropolitaine sans minimum d'achat. Délai : 2 à 4 jours ouvrés.{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}Is subscription required?{% else %}Y a-t-il un abonnement flexible ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}No. You can choose <strong>one-time purchase</strong> OR <strong>Subscribe & Save 10%</strong> with monthly delivery (cancel, skip, or pause anytime). No commitment.{% else %}Oui. Tu peux choisir un achat unique OU un abonnement avec -10% (annulable, sautable ou en pause à tout moment).{% endif %}</div></div>
    </div>
    <div class="faq-item">
      <div class="faq-q">{% if request.locale.iso_code == 'en' %}What's your refund policy?{% else %}Quelle est la politique de remboursement ?{% endif %}</div>
      <div class="faq-a"><div class="faq-a-inner">{% if request.locale.iso_code == 'en' %}Contact us at hello@uburn.co within 30 days of your first order for refund support. We process refunds within 5 business days.{% else %}Contactez-nous à hello@uburn.co et nous traitons le remboursement sous 5 jours ouvrés.{% endif %}</div></div>
    </div>
  </div>

  <div style="text-align:center;padding:40px 0 20px">
    <p style="font-size:16px;color:var(--body);margin-bottom:24px">{% if request.locale.iso_code == 'en' %}Don't see your question?{% else %}Votre question n'est pas ici ?{% endif %}</p>
    <a href="/pages/contact" class="btn-main">{% if request.locale.iso_code == 'en' %}Contact us{% else %}Nous contacter{% endif %}</a>
  </div>
  <p style="text-align:center;font-size:11px;color:var(--muted);margin-top:24px;line-height:1.5;">{% if request.locale.iso_code == 'en' %}*Individual results may vary. UBurn is a dietary supplement, not a medication. Not intended to diagnose, treat, cure, or prevent any disease.{% else %}*Les résultats varient selon les individus. Uburn est un complément alimentaire, pas un médicament.{% endif %}</p>
</div>

<script>
document.querySelectorAll('.faq-q').forEach(q=>{
  q.addEventListener('click',()=>{
    const item=q.parentElement;
    const wasOpen=item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));
    if(!wasOpen)item.classList.add('open');
  });
});
</script>

<section class="ba-section">
  <div class="ba-inner">
    <div class="section-label reveal">{% if request.locale.iso_code == 'en' %}Real result{% else %}Résultat réel{% endif %}</div>
    <h2 class="section-title reveal rd1">{% if request.locale.iso_code == 'en' %}What changes.<br><em>Not the rules.</em>{% else %}Ce qui change.<br><em>Pas les nôtres.</em>{% endif %}</h2>
    <div class="ba-card reveal rd2">
      <div class="ba-col ba-before">
        <div class="ba-label">{% if request.locale.iso_code == 'en' %}Before UBurn{% else %}Avant Uburn{% endif %}</div>
        <div class="ba-week">{% if request.locale.iso_code == 'en' %}Week 1{% else %}Semaine 1{% endif %}</div>
        <div class="ba-items">
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}Uncontrollable 4PM cravings — pantry open daily{% else %}Fringales incontrôlables à 16h — placard ouvert quotidiennement{% endif %}</div>
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}Guilt after every slip-up, chronic frustration{% else %}Culpabilité après chaque craquage, frustration chronique{% endif %}</div>
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}Dinner too heavy to make up for accumulated hunger{% else %}Dîner trop copieux pour compenser la faim accumulée{% endif %}</div>
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}Afternoon fatigue, difficult digestion{% else %}Fatigue l'après-midi, digestion difficile{% endif %}</div>
        </div>
        <div class="ba-profile">
          <div class="ba-avatar">{% if request.locale.iso_code == 'en' %}S{% else %}M{% endif %}</div>
          <div><div class="ba-name">{% if request.locale.iso_code == 'en' %}Sarah D.{% else %}Marie D.{% endif %}</div><div class="ba-meta">{% if request.locale.iso_code == 'en' %}42 yrs · Brooklyn, NY{% else %}42 ans · Paris 11e{% endif %}</div></div>
        </div>
      </div>
      <div class="ba-divider"><div class="ba-divider-arrow">→</div></div>
      <div class="ba-col ba-after">
        <div class="ba-label">{% if request.locale.iso_code == 'en' %}After 4 weeks{% else %}Après 4 semaines{% endif %}</div>
        <div class="ba-week">{% if request.locale.iso_code == 'en' %}Week 4{% else %}Semaine 4{% endif %}</div>
        <div class="ba-items">
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}No more 4PM cravings — she even forgets to open the pantry{% else %}Plus de fringale à 16h — elle oublie même d'ouvrir le placard{% endif %}</div>
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}Naturally lighter dinner, no willpower needed{% else %}Dîner naturellement plus léger, sans effort de volonté{% endif %}</div>
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}Smooth digestion, less bloating from week 2{% else %}Digestion fluide, ventre moins gonflé dès la 2e semaine{% endif %}</div>
          <div class="ba-item">{% if request.locale.iso_code == 'en' %}6 lbs released over 4 weeks with no specific diet*{% else %}Perte de 2,8 kg sur 4 semaines sans régime particulier{% endif %}</div>
        </div>
        <div class="ba-profile">
          <div class="ba-avatar" style="background:var(--purple-wash)">{% if request.locale.iso_code == 'en' %}S{% else %}M{% endif %}</div>
          <div><div class="ba-name">{% if request.locale.iso_code == 'en' %}Sarah D. — Verified purchase{% else %}Marie D. — Cliente vérifiée{% endif %}</div><div class="ba-meta">{% if request.locale.iso_code == 'en' %}After 28 days · Individual results{% else %}Après 28 jours · Résultats individuels{% endif %}</div><div class="ba-stars">★★★★★</div></div>
        </div>
      </div>
    </div>
    <p style="text-align:center;font-size:11.5px;color:var(--muted);margin-top:18px;line-height:1.6">{% if request.locale.iso_code == 'en' %}Individual results may vary. Glucomannan — FDA dietary fiber*. Use: 3g/day with water before meals.{% else %}Les résultats varient selon les individus. Glucomannane — EFSA ID 3120. Conditions : 3g/jour avec eau avant les repas.{% endif %}</p>
  </div>
</section>
{% render 'ub-footer' %}
<script>
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible')}),{threshold:0,rootMargin:'0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
requestAnimationFrame(()=>document.querySelectorAll('.reveal').forEach(el=>{const r=el.getBoundingClientRect();if(r.top<window.innerHeight&&r.bottom>0)el.classList.add('visible')}));
</script>
{% schema %}
{"name":"UB FAQ","settings":[]}
{% endschema %}