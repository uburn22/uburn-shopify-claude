{%- comment -%}
  Section: ub-home-v2
  Design: Uburn 2026 · Red Hat Display + Red Hat Text
  Generated from HTML prototype
{%- endcomment -%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap'); 
/* Hide Shopify default header/footer — custom nav rendered inline */
/* Hide Shopify default header/footer groups — custom nav/footer in section */
[id^="shopify-section-sections--"] { display: none !important; }
main#main { padding: 0 !important; }

:root {
  --purple-deep: #3d1873;
  --purple-main: #6b2fa0;
  --purple-mid: #8b47c5;
  --purple-light: #b07de8;
  --purple-pale: #e8dcf5;
  --purple-wash: #f5f0fa;
  --cream: #faf9f7;
  --warm: #f2f0ed;
  --dark: #1a1118;
  --body: #5a5654;
  --muted: #8a8785;
  --grad: linear-gradient(160deg, #3d1873 0%, #6b2fa0 40%, #8b47c5 100%);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Red Hat Text', sans-serif; background: var(--cream); color: var(--dark); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
h1,h2,h3,h4 { font-family: 'Red Hat Display', sans-serif; letter-spacing: -0.02em; }
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ═══ NAV ═══ */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  padding: 20px 48px;
  display: flex; align-items: center; justify-content: space-between;
  transition: background 0.4s, padding 0.4s, box-shadow 0.4s;
}
.nav.scrolled {
  background: rgba(250,249,247,0.96);
  backdrop-filter: blur(12px);
  padding: 14px 48px;
  box-shadow: 0 1px 0 var(--purple-pale);
}
.nav-logo {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 900;
  font-size: 22px;
  color: #fff;
  letter-spacing: -0.03em;
  transition: color 0.4s;
}
.nav.scrolled .nav-logo { color: var(--purple-main); }
.nav-links {
  display: flex; align-items: center; gap: 32px;
  list-style: none;
}
.nav-links a {
  font-size: 14px; font-weight: 500;
  color: rgba(255,255,255,0.85);
  transition: color 0.2s;
}
.nav.scrolled .nav-links a { color: var(--body); }
.nav-links a:hover { color: #fff; }
.nav.scrolled .nav-links a:hover { color: var(--purple-main); }
.nav-cta {
  background: #fff; color: var(--purple-main);
  padding: 9px 22px; border-radius: 50px;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700; font-size: 13.5px;
  transition: background 0.2s, color 0.2s;
}
.nav.scrolled .nav-cta { background: var(--grad); color: #fff; }
@media(max-width:768px){
  .nav { padding: 16px 20px; }
  .nav.scrolled { padding: 12px 20px; }
  .nav-links { display: none; }
}

/* ═══ HERO ═══ */
.hero {
  position: relative;
  height: 100dvh;
  min-height: 600px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0;
}
.hero-bg img {
  width: 100%; height: 100%; object-fit: cover; object-position: center 20%;
}
.hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(
    to right,
    rgba(26,17,24,0.72) 0%,
    rgba(26,17,24,0.45) 55%,
    rgba(26,17,24,0.1) 100%
  );
}
.hero-content {
  position: relative; z-index: 1;
  max-width: 640px;
  padding: 0 80px 80px;
  color: #fff;
  animation: heroIn 1.1s cubic-bezier(0.16,1,0.3,1) both;
}
@keyframes heroIn {
  from { opacity:0; transform: translateY(32px); }
  to { opacity:1; transform: none; }
}
.hero-label {
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--purple-light);
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 10px;
}
.hero-label::before {
  content: ''; width: 32px; height: 1px;
  background: var(--purple-light); flex-shrink: 0;
}
.hero-title {
  font-size: clamp(44px, 6vw, 80px);
  font-weight: 900; line-height: 1.02;
  color: #fff; margin-bottom: 20px;
}
.hero-title em { font-style: italic; color: var(--purple-light); }
.hero-sub {
  font-size: clamp(15px, 1.6vw, 18px);
  line-height: 1.65; color: rgba(255,255,255,0.78);
  margin-bottom: 36px; max-width: 44ch;
}
.hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.btn-hero {
  background: #fff; color: var(--purple-deep);
  padding: 16px 32px; border-radius: 50px;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800; font-size: 15px;
  border: none; cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  display: inline-block;
}
.btn-hero:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,.25); }
.hero-note { font-size: 13px; color: rgba(255,255,255,0.55); }
.hero-trust {
  position: absolute; bottom: 80px; right: 80px; z-index: 1;
  display: flex; flex-direction: column; gap: 10px; align-items: flex-end;
  animation: heroIn 1.1s 0.3s cubic-bezier(0.16,1,0.3,1) both;
}
.hero-trust-pill {
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  color: rgba(255,255,255,0.9);
  font-size: 12px; font-weight: 600;
  padding: 7px 16px; border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.18);
}
@media(max-width:768px){
  .hero-content { padding: 0 24px 72px; max-width: 100%; }
  .hero-trust { right: 24px; bottom: 72px; }
  .hero-title { font-size: 42px; }
}

/* ═══ TICKER ═══ */
.ticker {
  background: var(--dark);
  padding: 14px 0;
  overflow: hidden;
  white-space: nowrap;
}
.ticker-track {
  display: inline-flex; gap: 0;
  animation: ticker 28s linear infinite;
}
@keyframes ticker {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.ticker-item {
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.8px; text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  padding: 0 28px;
  display: flex; align-items: center; gap: 28px;
}
.ticker-item::after {
  content: '·';
  color: var(--purple-mid);
  font-size: 16px;
}

/* ═══ PRESS ═══ */
.press {
  background: var(--warm);
  padding: 32px 48px;
  display: flex; align-items: center; justify-content: center;
  gap: 48px; flex-wrap: wrap;
}
.press-label {
  font-size: 11px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; color: var(--muted);
  white-space: nowrap;
}
.press-logos { display: flex; align-items: center; gap: 36px; flex-wrap: wrap; justify-content: center; }
.press-logo img { height: 20px; width: auto; opacity: 0.4; filter: grayscale(1); transition: opacity 0.2s; }
.press-logo img:hover { opacity: 0.7; }
@media(max-width:600px){ .press { padding: 20px 20px; gap: 20px; } }

/* ═══ SECTIONS ═══ */
.section { padding: 120px 80px; }
.section-inner { max-width: 1140px; margin: 0 auto; }
.section-label {
  font-size: 11px; font-weight: 700; letter-spacing: 1.2px;
  text-transform: uppercase; color: var(--purple-mid); margin-bottom: 14px;
}
.section-title {
  font-size: clamp(32px, 4.5vw, 56px);
  font-weight: 900; line-height: 1.05; color: var(--dark); margin-bottom: 18px;
}
.section-title em { font-style: italic; color: var(--purple-main); }
.section-body { font-size: 17px; line-height: 1.75; color: var(--body); max-width: 58ch; }
@media(max-width:768px){ .section { padding: 72px 24px; } }

/* ═══ PROBLEM SECTION ═══ */
.problem {
  background: var(--dark);
  padding: 120px 80px;
  position: relative; overflow: hidden;
}
.problem::before {
  content: '';
  position: absolute; top: -200px; right: -200px;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(107,47,160,0.3) 0%, transparent 70%);
  pointer-events: none;
}
.problem-inner { max-width: 1140px; margin: 0 auto; }
.problem .section-label { color: var(--purple-light); }
.problem .section-title { color: #fff; }
.problem-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
  margin-top: 56px;
}
.problem-narrative p {
  font-size: 18px; line-height: 1.8;
  color: rgba(255,255,255,0.72); margin-bottom: 24px;
  max-width: 52ch;
}
.problem-narrative strong { color: #fff; font-weight: 700; }
.problem-moments { display: flex; flex-direction: column; gap: 0; }
.problem-moment {
  padding: 28px 0;
  display: grid; grid-template-columns: 80px 1fr;
  gap: 24px; align-items: start;
}
.problem-moment:not(:last-child) {
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.pm-time {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 36px; font-weight: 900;
  color: var(--purple-light); line-height: 1;
}
.pm-text { font-size: 15px; color: rgba(255,255,255,0.65); line-height: 1.6; padding-top: 8px; }
.pm-text strong { color: rgba(255,255,255,0.9); font-weight: 600; display: block; margin-bottom: 4px; }
@media(max-width:900px){
  .problem { padding: 72px 24px; }
  .problem-layout { grid-template-columns: 1fr; gap: 48px; }
}

/* ═══ PRODUCT SHOWCASE ═══ */
.showcase { background: var(--cream); padding: 120px 80px; }
.showcase-inner {
  max-width: 1140px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
}
.showcase-img {
  position: relative;
}
.showcase-img img {
  width: 100%; border-radius: 24px;
  filter: drop-shadow(0 40px 80px rgba(107,47,160,0.2));
}
.showcase-img-badge {
  position: absolute; bottom: -20px; left: 24px;
  background: #fff; border-radius: 16px;
  padding: 14px 20px; box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  display: flex; align-items: center; gap: 12px;
}
.showcase-img-badge-icon { font-size: 24px; }
.showcase-img-badge-text { font-size: 13px; font-weight: 700; color: var(--dark); line-height: 1.3; }
.showcase-img-badge-sub { font-size: 11px; color: var(--muted); }
.showcase-benefits { display: flex; flex-direction: column; gap: 0; margin: 32px 0; }
.showcase-benefit {
  display: grid; grid-template-columns: 48px 1fr;
  gap: 16px; align-items: center;
  padding: 18px 0;
}
.showcase-benefit:not(:last-child) { border-bottom: 1px solid var(--purple-pale); }
.sb-icon {
  width: 40px; height: 40px; border-radius: 12px;
  background: var(--purple-wash);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.sb-title { font-family: 'Red Hat Display', sans-serif; font-weight: 700; font-size: 15px; color: var(--dark); margin-bottom: 3px; }
.sb-desc { font-size: 13px; color: var(--body); line-height: 1.5; }
.showcase-pricing {
  background: var(--purple-wash);
  border-radius: 20px; padding: 24px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; flex-wrap: wrap;
}
.showcase-price {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 32px; font-weight: 900; color: var(--dark);
}
.showcase-price-sub { font-size: 13px; color: var(--body); margin-top: 2px; }
.btn-showcase {
  background: var(--grad); color: #fff;
  padding: 15px 28px; border-radius: 50px;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800; font-size: 14px;
  border: none; cursor: pointer; white-space: nowrap;
  transition: opacity 0.2s, transform 0.2s;
}
.btn-showcase:hover { opacity: 0.9; transform: translateY(-1px); }
@media(max-width:900px){
  .showcase { padding: 72px 24px; }
  .showcase-inner { grid-template-columns: 1fr; gap: 48px; }
  .showcase-img-badge { left: 16px; }
}

/* ═══ STATS ═══ */
.stats-split {
  display: grid;
  grid-template-columns: 420px 1fr;
  min-height: 500px;
  background: var(--purple-deep);
}
.stats-photo {
  position: relative; overflow: hidden;
}
.stats-photo img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  filter: brightness(0.72);
}
.stats-photo-cap {
  position: absolute; bottom: 24px; left: 20px; right: 20px;
  color: rgba(255,255,255,0.75); font-size: 13px;
  font-style: italic; font-weight: 500;
}
.stats-body {
  padding: 72px 64px;
  display: flex; flex-direction: column; justify-content: center;
}
.stats-body .section-label { color: var(--purple-light); }
.stats-body .section-title { color: #fff; margin-bottom: 48px; }
.stats-layout {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 40px; align-items: start;
}
.stat-big-val {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(72px, 9vw, 108px);
  font-weight: 900; color: #fff; line-height: 1;
  letter-spacing: -0.04em;
}
.stat-big-label {
  font-size: 15px; color: rgba(255,255,255,0.6);
  line-height: 1.5; margin-top: 10px; max-width: 22ch;
}
.stats-list { display: flex; flex-direction: column; gap: 22px; padding-top: 8px; }
.stat-row {
  padding-bottom: 22px;
}
.stat-row:not(:last-child) { border-bottom: 1px solid rgba(255,255,255,0.1); }
.stat-row-val {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 30px; font-weight: 800; color: #fff;
  letter-spacing: -0.02em;
}
.stat-row-lbl { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 2px; }
.stats-disclaimer {
  margin-top: 32px; font-size: 11px;
  color: rgba(255,255,255,0.35); line-height: 1.6;
}
@media(max-width:900px){
  .stats-split { grid-template-columns: 1fr; }
  .stats-photo { height: 280px; }
  .stats-body { padding: 48px 24px; }
  .stats-layout { grid-template-columns: 1fr; gap: 24px; }
  .stat-big-val { font-size: 80px; }
}

/* ═══ ORIGINE ═══ */
.origine { background: var(--warm); padding: 120px 80px; }
.origine-inner {
  max-width: 1140px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
}
.origine-photos {
  display: grid; grid-template-columns: 3fr 2fr;
  gap: 12px; height: 520px;
}
.origine-ph-main { border-radius: 20px; overflow: hidden; }
.origine-ph-main img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
.origine-ph-sec { display: flex; flex-direction: column; gap: 12px; }
.origine-ph-sec img { width: 100%; flex: 1; object-fit: cover; border-radius: 14px; min-height: 0; }
.origine-points { display: flex; flex-direction: column; gap: 14px; margin-top: 28px; }
.origine-point {
  display: flex; align-items: flex-start; gap: 12px;
  font-size: 14.5px; color: var(--body); line-height: 1.5;
}
.origine-point::before {
  content: '';
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--purple-main); flex-shrink: 0; margin-top: 7px;
}
.origine-point strong { color: var(--dark); font-weight: 600; display: block; }
@media(max-width:900px){
  .origine { padding: 72px 24px; }
  .origine-inner { grid-template-columns: 1fr; gap: 40px; }
  .origine-photos { height: 340px; }
}

/* ═══ BEFORE / AFTER ═══ */
.ba-section { background: var(--cream); padding: 120px 80px; }
.ba-inner { max-width: 1000px; margin: 0 auto; }
.ba-card {
  display: grid; grid-template-columns: 1fr auto 1fr;
  background: #fff; border-radius: 24px;
  overflow: hidden; box-shadow: 0 4px 40px rgba(107,47,160,0.1);
  margin-top: 48px;
}
.ba-col { padding: 44px 40px; }
.ba-before { background: #f9f7f5; }
.ba-after { background: var(--purple-wash); }
.ba-pill-label {
  display: inline-block; font-size: 11px; font-weight: 700;
  letter-spacing: 0.8px; text-transform: uppercase;
  padding: 5px 14px; border-radius: 50px; margin-bottom: 20px;
}
.ba-pill-before { background: var(--warm); color: var(--body); }
.ba-pill-after { background: var(--purple-main); color: #fff; }
.ba-headline {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700; font-size: clamp(15px, 1.6vw, 18px);
  font-style: italic; line-height: 1.4; color: var(--dark); margin-bottom: 20px;
}
.ba-list { list-style: none; display: flex; flex-direction: column; gap: 11px; }
.ba-list li { font-size: 14.5px; color: var(--body); line-height: 1.5; padding-left: 22px; position: relative; }
.ba-list li::before { content: '—'; position: absolute; left: 0; color: var(--muted); }
.ba-list.ba-list-after li { color: var(--purple-deep); }
.ba-list.ba-list-after li::before { content: '✓'; color: var(--purple-main); font-weight: 700; }
.ba-sep {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 32px 0; gap: 8px;
}
.ba-sep-line { width: 1px; flex: 1; background: var(--purple-pale); }
.ba-sep-icon {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--grad); color: #fff;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ba-author-row {
  display: flex; align-items: center; gap: 16px;
  margin-top: 28px; padding: 20px 28px;
  background: #fff; border-radius: 14px;
  box-shadow: 0 2px 12px rgba(107,47,160,0.08);
}
.ba-avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--grad); color: #fff;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700; font-size: 18px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ba-author-name { font-family: 'Red Hat Display', sans-serif; font-weight: 700; font-size: 15px; color: var(--dark); }
.ba-author-meta { font-size: 12.5px; color: var(--body); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.ba-verified { color: #16a34a; font-weight: 600; font-size: 11.5px; }
.ba-stars { color: #f59e0b; font-size: 17px; margin-left: auto; flex-shrink: 0; }
@media(max-width:700px){
  .ba-section { padding: 72px 24px; }
  .ba-card { grid-template-columns: 1fr; }
  .ba-col { padding: 28px 24px; }
  .ba-sep { flex-direction: row; padding: 0 24px; gap: 12px; }
  .ba-sep-line { width: auto; height: 1px; flex: 1; }
}

/* ═══ TESTIMONIALS ═══ */
.testi { background: var(--warm); padding: 120px 80px; }
.testi-inner { max-width: 1140px; margin: 0 auto; }
.testi-pull {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 700; font-style: italic;
  color: var(--dark); line-height: 1.4;
  max-width: 72ch; margin: 48px 0 16px;
}
.testi-pull-author {
  font-size: 13.5px; color: var(--muted); margin-bottom: 56px;
  display: flex; align-items: center; gap: 8px;
}
.testi-pull-author span { color: #f59e0b; }
.testi-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.testi-card {
  background: #fff; border-radius: 20px; padding: 28px 24px;
  box-shadow: 0 2px 12px rgba(107,47,160,0.07);
  display: flex; flex-direction: column;
}
.testi-stars { color: #f59e0b; font-size: 15px; letter-spacing: 2px; margin-bottom: 14px; }
.testi-q { font-size: 15px; color: var(--dark); line-height: 1.7; font-style: italic; flex: 1; margin-bottom: 20px; }
.testi-footer { display: flex; align-items: center; gap: 12px; }
.tav {
  width: 38px; height: 38px; border-radius: 50%;
  background: var(--grad); color: #fff;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700; font-size: 15px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.tname { font-family: 'Red Hat Display', sans-serif; font-weight: 700; font-size: 14px; color: var(--dark); }
.tmeta { font-size: 12px; color: var(--muted); }
.tverif { font-size: 11px; color: #16a34a; font-weight: 600; }
@media(max-width:800px){
  .testi { padding: 72px 24px; }
  .testi-grid { grid-template-columns: 1fr; max-width: 480px; }
}

/* ═══ FINAL CTA ═══ */
.final-cta {
  position: relative;
  min-height: 560px;
  display: flex; align-items: center;
  overflow: hidden;
}
.final-cta-bg {
  position: absolute; inset: 0;
}
.final-cta-bg img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 30%;
}
.final-cta-bg::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(
    to right,
    rgba(26,17,24,0.88) 0%,
