{%- comment -%}
  UBurn V2 — Hero Double-Face Split (Indulgent / Functional)
  Positioning: "The violet matcha. Functional like a shake. Indulgent like a latte."
{%- endcomment -%}
{%- liquid
  assign hp = section.settings.product
  if hp == blank
    assign hp = all_products['ube-poudre']
  endif
  comment
    rev 2026-05-16 — USD hardcoded display (Markets USD admin pending)
    Starter base: $36.99 · Subscribe -10%: $33.29 · per-day: $1.23
  endcomment
  assign display_price = '$36.99'
  assign sub_display = '$33.29'
  assign variant_id = section.settings.variant_id | default: '51289200034111'
  assign cta_link = hp.url
  if variant_id != blank
    assign cta_link = hp.url | append: '?variant=' | append: variant_id
  endif
  assign sub_plan = null
  for spg in hp.selling_plan_groups
    for sp in spg.selling_plans
      assign sub_plan = sp
      break
    endfor
    if sub_plan != null
      break
    endif
  endfor
-%}
<style>
  .u2-herospl { background: var(--u2-cream); padding: 0 0 56px; }
  .u2-herospl__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas: "left right";
    gap: 0;
    position: relative;
    isolation: isolate;
  }
  .u2-herospl__side {
    aspect-ratio: 4/5;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 20px;
  }
  @media (min-width: 768px) {
    .u2-herospl__side { aspect-ratio: 16/12; min-height: 520px; }
  }
  @media (min-width: 1024px) {
    .u2-herospl__side { aspect-ratio: 16/14; min-height: 620px; }
  }
  .u2-herospl__left {
    grid-area: left;
    background: linear-gradient(160deg, var(--u2-champagne) 0%, var(--u2-lavender) 55%, var(--u2-plum) 100%);
  }
  .u2-herospl__right {
    grid-area: right;
    background: linear-gradient(200deg, var(--u2-lavender-soft) 0%, var(--u2-iris) 55%, var(--u2-plum-deep) 100%);
  }
  .u2-herospl__label {
    position: absolute;
    top: 24px;
    font-family: var(--u2-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--u2-bone);
    background: rgba(26, 15, 46, 0.4);
    backdrop-filter: blur(6px);
    padding: 6px 14px;
    border-radius: 999px;
    z-index: 3;
  }
  .u2-herospl__left .u2-herospl__label { left: 24px; }
  .u2-herospl__right .u2-herospl__label { right: 24px; }
  .u2-herospl__art {
    width: 60%;
    max-width: 320px;
    aspect-ratio: 4/5;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 30px 60px rgba(26, 15, 46, 0.35));
  }
  .u2-herospl__or {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
    width: 88px; height: 88px;
    border-radius: 50%;
    background: var(--u2-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 26px;
    color: var(--u2-iris);
    box-shadow: 0 18px 40px -10px rgba(26, 15, 46, 0.4);
  }
  @media (min-width: 1024px) {
    .u2-herospl__or { width: 120px; height: 120px; font-size: 36px; }
  }
  .u2-herospl__tag {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(248, 244, 238, 0.92);
    backdrop-filter: blur(10px);
    color: var(--u2-plum-black);
    padding: 8px 18px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    z-index: 5;
    white-space: nowrap;
  }

  /* Copy block — Luxury Editorial polish 2026-05-15 */
  .u2-herospl__copy {
    max-width: 1080px;
    margin: 56px auto 0;
    padding: 0 24px;
    text-align: center;
  }
  .u2-herospl__copy h1 {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(44px, 7.5vw, 80px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--u2-plum-deep);
    max-width: var(--u2-headline-max);
    margin: 0 auto 20px;
  }
  .u2-herospl__copy h1 strong {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--u2-plum-deep);
  }
  .u2-herospl__copy h1 em {
    font-style: italic;
    color: var(--u2-iris);
    font-weight: 300;
  }
  .u2-herospl__copy p {
    font-size: 17px;
    line-height: 1.65;
    color: var(--u2-text-body);
    max-width: var(--u2-body-max);
    margin: 0 auto 18px;
    font-weight: 400;
  }
  .u2-herospl__priceline {
    font-size: 13px;
    color: var(--u2-text-body);
    margin: 14px 0 24px;
    letter-spacing: 0.04em;
  }
  .u2-herospl__priceline strong {
    color: var(--u2-plum-deep);
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .u2-herospl__trust {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 18px;
  }

  /* Social proof rating above CTA */
  .u2-herospl__rating {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0 auto 14px;
    padding: 8px 16px;
    background: rgba(232, 220, 239, 0.45);
    border: 1px solid rgba(107, 78, 158, 0.22);
    border-radius: 999px;
    font-family: var(--u2-sans);
    font-size: 13px;
    color: var(--u2-plum-black);
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .u2-herospl__rating-stars { color: #F2B741; letter-spacing: 1px; font-size: 14px; line-height: 1; }
  .u2-herospl__rating-score { color: var(--u2-plum-black); }
  .u2-herospl__rating-count { color: var(--u2-plum); font-weight: 500; }
  @media (max-width: 480px) {
    .u2-herospl__rating { font-size: 12px; padding: 6px 14px; gap: 8px; }
  }

  /* Direct-checkout form CTA */
  .u2-herospl__buy {
    margin: 6px 0 4px;
    display: inline-block;
  }
  .u2-herospl__buy .u2-cta {
    cursor: pointer;
    border: 0;
    font-family: var(--u2-sans);
  }
  .u2-herospl__buy-sub {
    display: block;
    font-size: 11px;
    color: var(--u2-plum);
    margin-top: 8px;
    letter-spacing: 0.04em;
    opacity: 0.78;
  }

  /* SVG placeholders */
  .u2-svg-mug, .u2-svg-bottle {
    width: 100%; height: 100%;
    color: rgba(248, 244, 238, 0.92);
  }

  /* rev 2026-05-15-1815 — mobile polish: tag wrap + zoom hero panels */
  @media (max-width: 640px) {
    .u2-herospl__side { padding: 24px 12px 64px; }
    .u2-herospl__art { width: 88%; max-width: none; }
    .u2-herospl__label {
      font-size: 9px;
      letter-spacing: 0.24em;
      padding: 5px 10px;
      top: 18px;
    }
    .u2-herospl__left .u2-herospl__label { left: 14px; }
    .u2-herospl__right .u2-herospl__label { right: 14px; }
    .u2-herospl__or {
      width: 64px;
      height: 64px;
      font-size: 20px;
    }
    .u2-herospl__tag {
      font-size: 9px;
      letter-spacing: 0.14em;
      padding: 6px 12px;
      white-space: normal;
      text-align: center;
      max-width: 88%;
      line-height: 1.3;
      bottom: 16px;
    }
  }
</style>

<section class="u2-root u2-herospl" aria-label="Hero — UBurn the violet matcha">
  <div class="u2-herospl__split" data-u2-sticky-trigger>
    <div class="u2-herospl__side u2-herospl__left u2-reveal">
      <span class="u2-herospl__label">{{ section.settings.label_left | default: 'indulgent' }}</span>
      <div class="u2-herospl__art">
        {%- if section.settings.image_left_filename != blank -%}
          <img class="u2-herospl__photo" src="{{ section.settings.image_left_filename | asset_url }}" alt="{{ section.settings.image_left_alt | default: 'Hot violet ube latte in a white ceramic mug' }}" loading="eager" fetchpriority="high" width="880" height="1168" style="width:100%;height:100%;object-fit:cover;border-radius:24px;display:block;">
        {%- elsif section.settings.image_left != blank -%}
          {{ section.settings.image_left | image_url: width: 800 | image_tag: loading: 'eager', fetchpriority: 'high', alt: 'Hot violet ube latte in a white ceramic mug', width: section.settings.image_left.width, height: section.settings.image_left.height }}
        {%- else -%}
          <img class="u2-herospl__photo" src="{{ 'uburn-us-homepage-01-hot-latte-hero-a.jpg' | asset_url }}" alt="{% if request.locale.iso_code == 'fr' %}Latte ube violet servi dans une tasse en céramique blanche, lumière du matin{% else %}Hot violet ube latte in a white ceramic mug, morning light{% endif %}" loading="eager" fetchpriority="high" width="880" height="1168" style="width:100%;height:100%;object-fit:cover;border-radius:24px;display:block;">
        {%- endif -%}
      </div>
      <span class="u2-herospl__tag">{{ section.settings.tag_left | default: 'hot latte · vanilla–hazelnut' }}</span>
    </div>

    <div class="u2-herospl__or" aria-hidden="true"><em>or</em></div>

    <div class="u2-herospl__side u2-herospl__right u2-reveal delay-1">
      <span class="u2-herospl__label">{{ section.settings.label_right | default: 'functional' }}</span>
      <div class="u2-herospl__art">
        {%- if section.settings.image_right_filename != blank -%}
          <img class="u2-herospl__photo" src="{{ section.settings.image_right_filename | asset_url }}" alt="{{ section.settings.image_right_alt | default: 'Violet shake in UB bottle' }}" loading="eager" fetchpriority="high" width="1400" height="1400" style="width:100%;height:100%;object-fit:cover;border-radius:24px;display:block;">
        {%- elsif section.settings.image_right != blank -%}
          {{ section.settings.image_right | image_url: width: 800 | image_tag: loading: 'eager', fetchpriority: 'high', alt: 'Violet shake in UB bottle', width: section.settings.image_right.width, height: section.settings.image_right.height }}
        {%- else -%}
          <img class="u2-herospl__photo" src="{{ 'uburn-us-homepage-hero-bottle-500ml-b.jpg' | asset_url }}" alt="{% if request.locale.iso_code == 'fr' %}Bouteille violette UBurn 500 ml prête-à-boire, tenue à la main{% else %}UBurn 500 ml ready-to-drink violet bottle held in hand{% endif %}" loading="eager" fetchpriority="high" width="1400" height="1400" style="width:100%;height:100%;object-fit:cover;border-radius:24px;display:block;">
        {%- endif -%}
      </div>
      <span class="u2-herospl__tag">{{ section.settings.tag_right | default: 'with water · on-the-go' }}</span>
    </div>
  </div>

  <div class="u2-herospl__copy">
    <span class="u2-section-eyebrow" style="justify-content:center;">{{ section.settings.eyebrow | default: 'the violet ritual' }}</span>
    <h1>{{ section.settings.h1 | default: '<strong>Functional</strong> like a shake. <em>Indulgent</em> like a latte.' }}</h1>
    <p>{{ section.settings.sub | default: 'Plant-based satiety. 30 calories. Your daily violet moment.' }}</p>
    {%- if section.settings.priceline != blank -%}
      <p class="u2-herospl__priceline">{{ section.settings.priceline }}</p>
    {%- else -%}
      <p class="u2-herospl__priceline">{{ sub_display }}/mo · subscribe &amp; save · free us shipping</p>
    {%- endif -%}

    <span class="u2-herospl__rating" aria-label="Rated 4.7 out of 5 by 2,847 customers">
      <span class="u2-herospl__rating-stars" aria-hidden="true">★★★★★</span>
      <span class="u2-herospl__rating-score">4.7</span>
      <span class="u2-herospl__rating-count">· 2,847+ customers</span>
    </span>

    <div class="u2-herospl__buy">
      <a href="{{ cta_link }}" class="u2-cta">
        <span>{{ section.settings.cta_text | default: 'start the ritual' }} — {{ sub_display }}</span>
        <span class="u2-cta__arrow" aria-hidden="true">→</span>
      </a>
      <span class="u2-herospl__buy-sub">{{ section.settings.cta_sub | default: 'subscribe · cancel anytime' }}</span>
    </div>

    <div class="u2-herospl__trust">
      {% render 'u2-trust-pill', icon: 'check', text: 'EFSA-backed' %}
      {% render 'u2-trust-pill', icon: 'leaf', text: 'Caffeine-free' %}
      {% render 'u2-trust-pill', icon: 'globe', text: 'French heritage' %}
    </div>
  </div>
</section>

{% render 'u2-sticky-atc', product: hp, cta_link: cta_link, cta_text: 'start the ritual' %}

{% schema %}
{
  "name": "U2 Hero Split",
  "tag": "section",
  "class": "shopify-section--u2-herospl",
  "settings": [
    { "type": "header", "content": "Product binding (LOCKED)" },
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "variant_id", "label": "Variant ID", "default": "51289200034111" },

    { "type": "header", "content": "Copy overrides (variant)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "info": "Default: est. 2024 · the violet matcha" },
    { "type": "textarea", "id": "h1", "label": "H1 (allow <strong>, <em>)", "info": "Default: Functional like a shake. Indulgent like a latte." },
    { "type": "textarea", "id": "sub", "label": "Hero sub" },
    { "type": "textarea", "id": "priceline", "label": "Priceline override (HTML allowed)", "info": "Leave blank for default price logic" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "start the ritual" },
    { "type": "text", "id": "cta_sub", "label": "CTA sub line" },

    { "type": "header", "content": "Left panel — image + label + tag" },
    { "type": "image_picker", "id": "image_left", "label": "Image (picker)" },
    { "type": "text", "id": "image_left_filename", "label": "Image — /assets/ filename (overrides picker)", "info": "e.g. lp-hero-stress-eater.jpg" },
    { "type": "text", "id": "image_left_alt", "label": "Image alt text" },
    { "type": "text", "id": "label_left", "label": "Label (top)", "default": "indulgent" },
    { "type": "text", "id": "tag_left", "label": "Tag (bottom)", "default": "hot latte · vanilla–hazelnut" },

    { "type": "header", "content": "Right panel — image + label + tag" },
    { "type": "image_picker", "id": "image_right", "label": "Image (picker)" },
    { "type": "text", "id": "image_right_filename", "label": "Image — /assets/ filename (overrides picker)" },
    { "type": "text", "id": "image_right_alt", "label": "Image alt text" },
    { "type": "text", "id": "label_right", "label": "Label (top)", "default": "functional" },
    { "type": "text", "id": "tag_right", "label": "Tag (bottom)", "default": "with water · on-the-go" }
  ],
  "presets": [ { "name": "U2 Hero Split" } ]
}
{% endschema %}
