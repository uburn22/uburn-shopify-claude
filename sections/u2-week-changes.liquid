{%- comment -%}
  U2 Week Changes — Ashley K. testimonial-style Before/After (Week 1 vs Week 4)
  High-conversion social proof block. Aligned on u2-* DA tokens (Helvetica Neue + Times italic + iris #6B4E9E).
{%- endcomment -%}

<style>
  .u2-wkc { background: var(--u2-warm-white); padding: var(--u2-space-section) 20px; }
  .u2-wkc__inner { max-width: 1180px; margin: 0 auto; }
  .u2-wkc__head { text-align: center; margin-bottom: 48px; }
  .u2-wkc__eyebrow {
    font-family: var(--u2-sans); font-size: 11px; font-weight: 500;
    letter-spacing: 0.32em; text-transform: uppercase; color: var(--u2-iris);
    display: inline-block; margin-bottom: 14px;
  }
  .u2-wkc__head h2 {
    font-family: var(--u2-sans); font-weight: 800;
    font-size: clamp(34px, 5.5vw, 52px);
    line-height: 1.05; letter-spacing: -0.025em;
    color: var(--u2-plum-black); margin: 0;
  }
  .u2-wkc__head h2 em {
    font-family: var(--u2-serif); font-style: italic;
    font-weight: 400; color: var(--u2-iris);
  }
  .u2-wkc__grid {
    display: grid; grid-template-columns: 1fr; gap: 16px;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .u2-wkc__grid { grid-template-columns: 1fr auto 1fr; gap: 24px; align-items: center; }
  }
  .u2-wkc__col {
    background: white;
    border-radius: 20px;
    padding: 32px 24px;
    border: 1px solid rgba(107,78,158,0.08);
    box-shadow: 0 2px 12px rgba(107,47,160,0.05);
  }
  .u2-wkc__col--before { border-left: 3px solid rgba(58,46,74,0.25); }
  .u2-wkc__col--after  { border-left: 3px solid var(--u2-iris); background: linear-gradient(180deg, #FDFAF5 0%, #F8F4EE 100%); }
  .u2-wkc__lbl {
    font-family: var(--u2-sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--u2-text-muted);
  }
  .u2-wkc__col--after .u2-wkc__lbl { color: var(--u2-iris); }
  .u2-wkc__week {
    font-family: var(--u2-serif); font-style: italic; font-weight: 400;
    font-size: 28px; color: var(--u2-plum-black); margin: 6px 0 22px;
    line-height: 1;
  }
  .u2-wkc__col--after .u2-wkc__week { color: var(--u2-iris); }
  .u2-wkc__list { list-style: none; margin: 0; padding: 0; }
  .u2-wkc__list li {
    display: flex; gap: 12px; padding: 10px 0;
    font-family: var(--u2-sans); font-size: 15px;
    line-height: 1.45; color: var(--u2-text-body);
    border-bottom: 1px solid rgba(107,78,158,0.06);
  }
  .u2-wkc__list li:last-child { border-bottom: none; }
  .u2-wkc__icon {
    flex-shrink: 0; width: 18px; height: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 12px; line-height: 1; margin-top: 2px;
  }
  .u2-wkc__col--before .u2-wkc__icon { color: rgba(58,46,74,0.45); }
  .u2-wkc__col--after .u2-wkc__icon { color: var(--u2-iris); }
  .u2-wkc__arrow {
    display: none;
    font-family: var(--u2-serif); font-style: italic;
    font-size: 42px; color: var(--u2-iris);
  }
  @media (min-width: 768px) { .u2-wkc__arrow { display: flex; align-items: center; justify-content: center; } }

  .u2-wkc__attribution {
    margin: 40px auto 0;
    max-width: 480px;
    display: flex; align-items: center; gap: 16px;
    background: white;
    border: 1px solid rgba(107,78,158,0.08);
    border-radius: 100px;
    padding: 12px 20px 12px 12px;
  }
  .u2-wkc__avatar {
    width: 56px; height: 56px; border-radius: 50%;
    object-fit: cover; flex-shrink: 0;
    background: var(--u2-lavender-soft);
  }
  .u2-wkc__attr-body { flex: 1; min-width: 0; }
  .u2-wkc__name {
    font-family: var(--u2-sans); font-weight: 700;
    font-size: 14px; color: var(--u2-plum-black);
    display: block; line-height: 1.2;
  }
  .u2-wkc__attr-meta {
    font-family: var(--u2-sans); font-size: 12px;
    color: var(--u2-text-muted); display: block;
    margin-top: 3px; line-height: 1.3;
  }
  .u2-wkc__attr-meta .u2-wkc__stars { color: var(--u2-iris); margin-right: 4px; letter-spacing: 0.5px; }
  .u2-wkc__verified { color: var(--u2-iris); font-weight: 600; }
  .u2-wkc__disc {
    max-width: 720px; margin: 32px auto 0;
    text-align: center;
    font-family: var(--u2-sans); font-size: 11px;
    color: var(--u2-text-muted); line-height: 1.55;
  }
</style>

<section class="u2-wkc">
  <div class="u2-wkc__inner">
    <div class="u2-wkc__head">
      <span class="u2-wkc__eyebrow">{{ section.settings.eyebrow | default: '— in her own words' }}</span>
      <h2>{{ section.settings.title_pre | default: 'What changes.' }} <em>{{ section.settings.title_em | default: 'After 4 weeks.' }}</em></h2>
    </div>

    <div class="u2-wkc__grid">
      <div class="u2-wkc__col u2-wkc__col--before">
        <div class="u2-wkc__lbl">{{ section.settings.before_label | default: 'Before UBurn' }}</div>
        <div class="u2-wkc__week">{{ section.settings.before_week | default: 'Week 1' }}</div>
        <ul class="u2-wkc__list">
          <li><span class="u2-wkc__icon" aria-hidden="true">✗</span><span>{{ section.settings.before_1 | default: 'Uncontrollable 4 PM cravings — pantry open daily' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✗</span><span>{{ section.settings.before_2 | default: 'Cookies, chocolate, sometimes worse' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✗</span><span>{{ section.settings.before_3 | default: 'Guilt after every slip-up, chronic frustration' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✗</span><span>{{ section.settings.before_4 | default: 'Dinner too heavy to make up for accumulated hunger' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✗</span><span>{{ section.settings.before_5 | default: 'Afternoon fatigue, difficult digestion' }}</span></li>
        </ul>
      </div>

      <div class="u2-wkc__arrow" aria-hidden="true">→</div>

      <div class="u2-wkc__col u2-wkc__col--after">
        <div class="u2-wkc__lbl">{{ section.settings.after_label | default: 'After 4 weeks' }}</div>
        <div class="u2-wkc__week">{{ section.settings.after_week | default: 'Week 4' }}</div>
        <ul class="u2-wkc__list">
          <li><span class="u2-wkc__icon" aria-hidden="true">✓</span><span>{{ section.settings.after_1 | default: 'No more 4 PM cravings — she forgets the pantry exists' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✓</span><span>{{ section.settings.after_2 | default: 'Naturally lighter dinner, no willpower needed' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✓</span><span>{{ section.settings.after_3 | default: 'Calmer afternoons, smoother digestion from week 2*' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✓</span><span>{{ section.settings.after_4 | default: 'Mood feels calmer, no afternoon crash' }}</span></li>
          <li><span class="u2-wkc__icon" aria-hidden="true">✓</span><span>{{ section.settings.after_5 | default: 'The ritual settled in naturally — feels like self-care' }}</span></li>
        </ul>
      </div>
    </div>

    {%- assign avatar = section.settings.avatar_filename | default: 'uburn-us-story-1-sarah-brooklyn.png' -%}
    <div class="u2-wkc__attribution">
      <img class="u2-wkc__avatar" src="{{ avatar | asset_url }}" alt="{{ section.settings.attr_name | default: 'Ashley K.' }}" loading="lazy" width="56" height="56">
      <div class="u2-wkc__attr-body">
        <span class="u2-wkc__name">{{ section.settings.attr_name | default: 'Ashley K.' }} — {{ section.settings.attr_city | default: 'Phoenix, AZ' }}</span>
        <span class="u2-wkc__attr-meta">
          {{ section.settings.attr_when | default: 'After 28 days' }} · <span class="u2-wkc__stars">★★★★★</span> <span class="u2-wkc__verified">Verified purchase</span>
        </span>
      </div>
    </div>

    <p class="u2-wkc__disc">{{ section.settings.disclaimer | default: '*Individual results may vary. Glucomannan — EFSA ID 3120. Use: 3g/day with water before meals. These statements have not been evaluated by the FDA.' }}</p>
  </div>
</section>

{% schema %}
{
  "name": "U2 Week Changes",
  "tag": "section",
  "class": "shopify-section--u2-wkc",
  "settings": [
    { "type": "header", "content": "Headline" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— in her own words" },
    { "type": "text", "id": "title_pre", "label": "Title start", "default": "What changes." },
    { "type": "text", "id": "title_em", "label": "Title italic", "default": "After 4 weeks." },
    { "type": "header", "content": "Before column" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before UBurn" },
    { "type": "text", "id": "before_week", "label": "Before week", "default": "Week 1" },
    { "type": "textarea", "id": "before_1", "label": "Before 1", "default": "Uncontrollable 4 PM cravings — pantry open daily" },
    { "type": "textarea", "id": "before_2", "label": "Before 2", "default": "Cookies, chocolate, sometimes worse" },
    { "type": "textarea", "id": "before_3", "label": "Before 3", "default": "Guilt after every slip-up, chronic frustration" },
    { "type": "textarea", "id": "before_4", "label": "Before 4", "default": "Dinner too heavy to make up for accumulated hunger" },
    { "type": "textarea", "id": "before_5", "label": "Before 5", "default": "Afternoon fatigue, difficult digestion" },
    { "type": "header", "content": "After column" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "After 4 weeks" },
    { "type": "text", "id": "after_week", "label": "After week", "default": "Week 4" },
    { "type": "textarea", "id": "after_1", "label": "After 1", "default": "No more 4 PM cravings — she forgets the pantry exists" },
    { "type": "textarea", "id": "after_2", "label": "After 2", "default": "Naturally lighter dinner, no willpower needed" },
    { "type": "textarea", "id": "after_3", "label": "After 3", "default": "Calmer afternoons, smoother digestion from week 2*" },
    { "type": "textarea", "id": "after_4", "label": "After 4", "default": "Mood feels calmer, no afternoon crash" },
    { "type": "textarea", "id": "after_5", "label": "After 5", "default": "The ritual settled in naturally — feels like self-care" },
    { "type": "header", "content": "Attribution" },
    { "type": "text", "id": "attr_name", "label": "Name", "default": "Ashley K." },
    { "type": "text", "id": "attr_city", "label": "City", "default": "Phoenix, AZ" },
    { "type": "text", "id": "attr_when", "label": "Time frame", "default": "After 28 days" },
    { "type": "text", "id": "avatar_filename", "label": "Avatar — /assets/ filename", "default": "uburn-us-story-1-sarah-brooklyn.png" },
    { "type": "header", "content": "Footer" },
    { "type": "textarea", "id": "disclaimer", "label": "Disclaimer", "default": "*Individual results may vary. Glucomannan — EFSA ID 3120. Use: 3g/day with water before meals. These statements have not been evaluated by the FDA." }
  ],
  "presets": [ { "name": "U2 Week Changes" } ]
}
{% endschema %}
