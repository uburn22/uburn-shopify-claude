<style>

/* ═══ DESIGN TOKENS ═══ */
:root {
  --purple-deep: #3d1873;
  --purple-main: #6b2fa0;
  --purple-mid: #8b47c5;
  --purple-light: #b07de8;
  --purple-pale: #e8dcf5;
  --purple-wash: #f5f0fa;
  --cream: #faf9f7;
  --warm: #f2f0ed;
  --dark: #242220;
  --body: #5a5654;
  --muted: #8a8785;
  --grad: linear-gradient(160deg, #3d1873 0%, #6b2fa0 40%, #8b47c5 100%);
  --shadow-soft: 0 4px 24px oklch(0.35 0.12 300 / 0.12);
  --shadow-card: 0 2px 12px oklch(0.35 0.12 300 / 0.08);
  --radius: 16px;
  --radius-sm: 10px;
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  --space-xl: 48px;
  --space-2xl: 80px;
  --space-3xl: 120px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Red Hat Text', sans-serif;
  color: var(--dark);
  background: var(--cream);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

h1, h2, h3, h4 {
  font-family: 'Red Hat Display', sans-serif;
  letter-spacing: -0.02em;
}

img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ═══ TRUST BAR ═══ */
.trust-bar {
  background: var(--grad);
  color: #fff;
  padding: 10px var(--space-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  font-family: 'Red Hat Text', sans-serif;
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: 0.3px;
  overflow: hidden;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  opacity: 0.95;
}
.trust-icon {
  width: 14px;
  height: 14px;
  opacity: 0.85;
  flex-shrink: 0;
}
@media (max-width: 640px) {
  .trust-bar { gap: 20px; font-size: 11.5px; overflow-x: auto; justify-content: flex-start; padding: 10px 16px; }
}

/* ═══ STICKY ATC BAR ═══ */
.sticky-atc {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid var(--purple-pale);
  padding: 12px var(--space-lg);
  display: flex;
  align-items: center;
  gap: 12px;
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 -8px 32px oklch(0.35 0.12 300 / 0.12);
}
.sticky-atc.visible { transform: translateY(0); }
.sticky-atc-title {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 14px;
  color: var(--dark);
  flex: 1;
  line-height: 1.3;
}
.sticky-atc-price {
  font-weight: 700;
  font-size: 15px;
  color: var(--purple-main);
}
.sticky-atc-btn {
  background: var(--grad);
  color: #fff;
  border: none;
  padding: 13px 24px;
  border-radius: 50px;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.sticky-atc-btn:hover { opacity: 0.9; }
@media (max-width: 500px) {
  .sticky-atc-title { display: none; }
  .sticky-atc { justify-content: space-between; }
}

/* ═══ HERO SECTION ═══ */
.hero {
  padding: 48px 40px 64px;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: flex-start;
}

/* Gallery */
.gallery-wrap { position: relative; }
.gallery-main {
  aspect-ratio: 4/5;
  border-radius: 20px;
  overflow: hidden;
  background: var(--purple-wash);
  margin-bottom: 12px;
  cursor: pointer;
  position: relative;
}
.gallery-main img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.gallery-main:hover img { transform: scale(1.03); }
.gallery-thumbs {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  scrollbar-width: none;
  padding-bottom: 4px;
}
.gallery-thumbs::-webkit-scrollbar { display: none; }
.gallery-thumb {
  flex-shrink: 0;
  width: 64px;
  height: 64px;
  border-radius: 10px;
  overflow: hidden;
  background: var(--purple-wash);
  cursor: pointer;
  border: 2px solid transparent;
  transition: border-color 0.2s, opacity 0.2s;
  opacity: 0.7;
}
.gallery-thumb:hover { opacity: 1; }
.gallery-thumb.active { border-color: var(--purple-main); opacity: 1; }
.gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }

/* Product Info */
.product-info { padding-top: 8px; }
.product-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--purple-wash);
  color: var(--purple-main);
  border-radius: 50px;
  padding: 5px 14px;
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.product-badge::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--purple-mid);
}
.product-title {
  font-size: clamp(26px, 3.5vw, 38px);
  font-weight: 900;
  line-height: 1.1;
  color: var(--dark);
  margin-bottom: 8px;
}
.product-subtitle {
  font-size: 16px;
  color: var(--body);
  line-height: 1.5;
  margin-bottom: 16px;
}
.product-rating {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 24px;
}
.stars { color: #f59e0b; font-size: 15px; letter-spacing: 1px; }
.rating-text { font-size: 13.5px; color: var(--body); font-weight: 500; }
.rating-count { color: var(--muted); }

/* Quick benefits */
.quick-benefits {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 28px;
}
.quick-benefit {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--cream);
  border: 1px solid var(--purple-pale);
  border-radius: 50px;
  padding: 6px 12px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--dark);
}
.quick-benefit svg { color: var(--purple-mid); flex-shrink: 0; }

/* Variant Selector */
.variant-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 12px;
}
.variants {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 28px;
}
.variant-card {
  border: 2px solid var(--purple-pale);
  border-radius: var(--radius);
  padding: 14px 16px;
  cursor: pointer;
  transition: all 0.2s;
  background: #fff;
  position: relative;
}
.variant-card:hover { border-color: var(--purple-light); }
.variant-card.active {
  border-color: var(--purple-main);
  background: var(--purple-wash);
}
.variant-badge-pop {
  position: absolute;
  top: -10px;
  right: 12px;
  background: var(--purple-main);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 50px;
  letter-spacing: 0.3px;
}
.variant-name {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 13.5px;
  color: var(--dark);
  margin-bottom: 4px;
  line-height: 1.3;
}
.variant-desc { font-size: 11.5px; color: var(--body); margin-bottom: 8px; }
.variant-price {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 18px;
  color: var(--purple-main);
}
.variant-per-day { font-size: 11px; color: var(--muted); font-weight: 500; margin-top: 2px; }

/* Price block */
.price-block {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 20px;
}
.price-main {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 32px;
  font-weight: 900;
  color: var(--dark);
}
.price-sub { font-size: 14px; color: var(--body); }

/* ATC */
.btn-atc {
  width: 100%;
  background: var(--grad);
  color: #fff;
  border: none;
  padding: 18px 32px;
  border-radius: 50px;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 16px;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
  margin-bottom: 12px;
  letter-spacing: 0.2px;
}
.btn-atc:hover { opacity: 0.92; transform: translateY(-1px); }
.btn-atc:active { transform: translateY(0); }

.atc-sub {
  text-align: center;
  font-size: 12.5px;
  color: var(--muted);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-bottom: 24px;
}
.atc-sub span { display: flex; align-items: center; gap: 4px; }

/* Guarantees */
.guarantees {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  padding-top: 20px;
  border-top: 1px solid var(--purple-pale);
}
.guarantee-item {
  text-align: center;
  padding: 12px 8px;
}
.guarantee-icon { font-size: 20px; margin-bottom: 4px; }
.guarantee-text {
  font-size: 11px;
  font-weight: 600;
  color: var(--body);
  line-height: 1.4;
}

@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 24px 20px 48px;
  }
  .gallery-main { aspect-ratio: 1/1; }
}
@media (max-width: 500px) {
  .variants { grid-template-columns: 1fr; }
}

/* ═══ PRESS BAR ═══ */
.press-bar {
  background: var(--warm);
  padding: 28px 40px;
  border-top: 1px solid var(--purple-pale);
  border-bottom: 1px solid var(--purple-pale);
}
.press-bar-inner {
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48px;
  flex-wrap: wrap;
}
.press-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}
.press-logos { display: flex; align-items: center; gap: 36px; flex-wrap: wrap; justify-content: center; }
.press-logo img { height: 22px; width: auto; opacity: 0.5; filter: grayscale(1); transition: opacity 0.2s; }
.press-logo img:hover { opacity: 0.75; }
@media (max-width: 600px) {
  .press-bar { padding: 20px 16px; }
  .press-bar-inner { gap: 24px; }
  .press-logos { gap: 20px; }
  .press-logo img { height: 18px; }
}

/* ═══ SECTION WRAPPER ═══ */
.section {
  padding: var(--space-3xl) 40px;
}
.section-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.section-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--purple-mid);
  margin-bottom: 12px;
}
.section-title {
  font-size: clamp(28px, 4vw, 46px);
  font-weight: 900;
  line-height: 1.1;
  color: var(--dark);
  margin-bottom: 16px;
}
.section-title em {
  font-style: italic;
  color: var(--purple-main);
}
.section-body {
  font-size: 17px;
  line-height: 1.7;
  color: var(--body);
  max-width: 60ch;
}
@media (max-width: 600px) {
  .section { padding: 64px 20px; }
}

/* ═══ PROBLEM SECTION ═══ */
.problem-section {
  background: linear-gradient(160deg, var(--purple-deep) 0%, var(--purple-main) 100%);
  color: #fff;
  padding: var(--space-3xl) 40px;
}
.problem-inner {
  max-width: 900px;
  margin: 0 auto;
}
.problem-section .section-label { color: var(--purple-light); }
.problem-section .section-title { color: #fff; }
.problem-section .section-body { color: rgba(255,255,255,0.8); max-width: 55ch; }

.problem-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 56px;
}
.problem-card {
  background: rgba(255,255,255,0.1);
  border-radius: var(--radius);
  padding: 28px 24px;
  backdrop-filter: blur(10px);
}
.problem-time {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 28px;
  font-weight: 900;
  color: var(--purple-light);
  margin-bottom: 8px;
}
.problem-desc {
  font-size: 14.5px;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
}

@media (max-width: 700px) {
  .problem-cards { grid-template-columns: 1fr; gap: 12px; margin-top: 40px; }
  .problem-section { padding: 64px 20px; }
}

/* ═══ HOW IT WORKS ═══ */
.steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  margin-top: 56px;
}
.step-card { text-align: center; }
.step-photo {
  aspect-ratio: 1/1;
  border-radius: 20px;
  overflow: hidden;
  background: var(--purple-wash);
  margin-bottom: 20px;
}
.step-photo img { width: 100%; height: 100%; object-fit: cover; }
.step-number {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--purple-main);
  color: #fff;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
}
.step-title {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 17px;
  color: var(--dark);
  margin-bottom: 6px;
}
.step-desc { font-size: 14px; color: var(--body); line-height: 1.6; }

@media (max-width: 700px) {
  .steps-grid { grid-template-columns: 1fr; gap: 24px; }
}

/* ═══ INGREDIENTS ═══ */
.ingr-section { background: var(--warm); }
.ingr-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 56px;
}
.ingr-card {
  background: #fff;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s;
}
.ingr-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-soft);
}
.ingr-photo {
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--purple-wash);
}
.ingr-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.ingr-card:hover .ingr-photo img { transform: scale(1.06); }
.ingr-body { padding: 18px 20px 22px; }
.ingr-tag {
  display: inline-block;
  background: var(--purple-wash);
  color: var(--purple-main);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.5px;
  padding: 3px 10px;
  border-radius: 50px;
  margin-bottom: 8px;
}
.ingr-name {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 16px;
  color: var(--dark);
  margin-bottom: 4px;
}
.ingr-dose { font-size: 12px; color: var(--purple-mid); font-weight: 600; margin-bottom: 8px; }
.ingr-desc { font-size: 13px; color: var(--body); line-height: 1.6; }

@media (max-width: 800px) {
  .ingr-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 500px) {
  .ingr-grid { grid-template-columns: 1fr; }
}

/* ═══ COMPARE TABLE ═══ */
.compare-section { background: var(--cream); }
.compare-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 48px;
  font-size: 14.5px;
}
.compare-table th {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.3px;
  padding: 14px 20px;
  text-align: left;
  background: var(--warm);
  color: var(--dark);
}
.compare-table th:first-child { border-radius: 12px 0 0 0; width: 35%; }
.compare-table th:last-child { border-radius: 0 12px 0 0; }
.compare-table th.col-uburn {
  background: var(--purple-main);
  color: #fff;
}
.compare-table td {
  padding: 14px 20px;
  border-bottom: 1px solid var(--warm);
  color: var(--body);
  line-height: 1.5;
}
.compare-table tr:last-child td { border-bottom: none; }
.compare-table td:first-child { font-weight: 600; color: var(--dark); }
.compare-table td.col-uburn {
  background: var(--purple-wash);
  color: var(--purple-main);
  font-weight: 600;
}
.compare-table .check { color: #16a34a; font-size: 16px; }
.compare-table .cross { color: #dc2626; font-size: 16px; }
.compare-table .neutral { color: var(--muted); }

@media (max-width: 660px) {
  .compare-table { font-size: 12px; }
  .compare-table th, .compare-table td { padding: 9px 10px; }
  .compare-table th:nth-child(2),
  .compare-table td:nth-child(2) { display: none; }
}

/* ═══ EXPERT SECTION ═══ */
.expert-section {
  background: linear-gradient(160deg, var(--cream) 0%, var(--purple-wash) 100%);
}
.expert-inner {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 64px;
  align-items: center;
}
.expert-photo {
  width: 260px;
  height: 320px;
  border-radius: 24px;
  overflow: hidden;
  background: var(--purple-wash);
}
.expert-photo img { width: 100%; height: 100%; object-fit: cover; }
.expert-quote {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(18px, 2.5vw, 24px);
  font-weight: 700;
  line-height: 1.45;
  color: var(--dark);
  font-style: italic;
  margin-bottom: 24px;
}
.expert-quote::before { content: '«\00a0'; color: var(--purple-mid); }
.expert-quote::after { content: '\00a0»'; color: var(--purple-mid); }
.expert-name {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 16px;
  color: var(--dark);
  margin-bottom: 4px;
}
.expert-role { font-size: 13.5px; color: var(--body); margin-bottom: 16px; }
.expert-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--purple-wash);
  color: var(--purple-main);
  border-radius: 50px;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 600;
}

@media (max-width: 700px) {
  .expert-inner { grid-template-columns: 1fr; gap: 32px; }
  .expert-photo { width: 180px; height: 220px; margin: 0 auto; }
}

/* ═══ RESULTS STATS ═══ */
.stats-section { background: var(--purple-deep); color: #fff; }
.stats-section .section-label { color: var(--purple-light); }
.stats-section .section-title { color: #fff; }
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 56px;
}
.stat-card {
  text-align: center;
  padding: 32px 16px;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius);
}
.stat-value {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(36px, 5vw, 52px);
  font-weight: 900;
  color: #fff;
  line-height: 1;
  margin-bottom: 8px;
}
.stat-label { font-size: 13.5px; color: rgba(255,255,255,0.7); line-height: 1.4; }
.stats-disclaimer {
  margin-top: 32px;
  font-size: 11.5px;
  color: rgba(255,255,255,0.45);
  max-width: 60ch;
}

@media (max-width: 700px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ═══ TESTIMONIALS ═══ */
.testi-section { background: var(--warm); }
.testi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 56px;
}
.testi-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 28px 24px;
  box-shadow: var(--shadow-card);
}
.testi-stars { color: #f59e0b; font-size: 16px; letter-spacing: 2px; margin-bottom: 16px; }
.testi-quote {
  font-size: 15px;
  color: var(--dark);
