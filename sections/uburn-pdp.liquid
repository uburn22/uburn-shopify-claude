<!-- ═══ JAVASCRIPT ═══ -->
<script>
/* Gallery */
const galleryImages = [
  { src: "https://uburn.co/cdn/shop/files/Uburn_Listing_ecom_1.jpg?v=1772700007&width=800", alt: "Uburn Poudre Ubé — vue principale" },
  { src: "https://uburn.co/cdn/shop/files/PRODUCTPAGE_0004_3.jpg?v=1773911263&width=800", alt: "Uburn — photo produit 2" },
  { src: "https://uburn.co/cdn/shop/files/PRODUCT_PAGE_0005_2_1.jpg?v=1773911263&width=800", alt: "Uburn — photo produit 3" },
  { src: "https://uburn.co/cdn/shop/files/PRODUCTPAGE_0002_5.jpg?v=1773911263&width=800", alt: "Uburn — photo produit 4" },
  { src: "https://uburn.co/cdn/shop/files/PRODUCT_PAGE_0001_6_6cd95d50-55ff-4349-b486-02ff851786de.jpg?v=1773911263&width=800", alt: "Uburn — photo produit 5" },
  { src: "https://uburn.co/cdn/shop/files/PRODUCTPAGE_0003_4.jpg?v=1773911263&width=800", alt: "Uburn — photo produit 6" },
  { src: "https://uburn.co/cdn/shop/files/PRODUCTPAGE_0000_7.jpg?v=1773911263&width=800", alt: "Uburn — photo produit 7" },
];

const thumbsContainer = document.getElementById('galleryThumbs');
const mainImg = document.getElementById('galleryMainImg');
let activeThumb = 0;

galleryImages.forEach((img, i) => {
  const thumb = document.createElement('div');
  thumb.className = 'gallery-thumb' + (i === 0 ? ' active' : '');
  thumb.innerHTML = `<img src="${img.src.replace('width=800','width=200')}" alt="${img.alt}" loading="lazy">`;
  thumb.addEventListener('click', () => {
    switchImage(i);
  });
  thumbsContainer.appendChild(thumb);
});

function switchImage(idx) {
  const thumbs = document.querySelectorAll('.gallery-thumb');
  thumbs[activeThumb].classList.remove('active');
  thumbs[idx].classList.add('active');
  mainImg.style.opacity = '0';
  mainImg.style.transform = 'scale(0.98)';
  setTimeout(() => {
    mainImg.src = galleryImages[idx].src;
    mainImg.alt = galleryImages[idx].alt;
    mainImg.style.opacity = '1';
    mainImg.style.transform = 'scale(1)';
  }, 150);
  activeThumb = idx;
}

mainImg.style.transition = 'opacity 0.3s ease, transform 0.3s ease';

/* Variant selector */
function selectVariant(el) {
  document.querySelectorAll('.variant-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  const price = el.dataset.price;
  const daily = el.dataset.daily;
  const formatted = parseFloat(price).toFixed(2).replace('.', ',') + ' €';
  document.getElementById('priceMain').textContent = formatted;
  document.getElementById('pricePerDay').textContent = daily + '/jour';
  document.getElementById('stickyPrice').textContent = formatted;
  const variantId = el.dataset.variantId;
  if (variantId) document.getElementById('variant-id').value = variantId;
}

/* FAQ */
function toggleFaq(btn) {
  const answer = btn.nextElementSibling;
  const isOpen = answer.classList.contains('open');

  document.querySelectorAll('.faq-a.open').forEach(a => {
    a.classList.remove('open');
    a.previousElementSibling.classList.remove('open');
  });

  if (!isOpen) {
    answer.classList.add('open');
    btn.classList.add('open');
  }
}

/* Sticky ATC */
const atcBtn = document.getElementById('atc-btn');
const stickyAtc = document.getElementById('stickyAtc');

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) {
      stickyAtc.classList.add('visible');
    } else {
      stickyAtc.classList.remove('visible');
    }
  });
}, { threshold: 0 });

observer.observe(atcBtn);

/* Scroll reveals */
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
</script>

