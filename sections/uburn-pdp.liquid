<style>
/* ─── RESET ─────────────────────────────────────────────────────────────────── */
#pdp-v10 *, #pdp-v10 *::before, #pdp-v10 *::after { box-sizing: border-box; margin: 0; padding: 0; }
#pdp-v10 img  { display: block; max-width: 100%; }
#pdp-v10 ul   { list-style: none; }
#pdp-v10 a    { color: inherit; text-decoration: none; }
html { scroll-behavior: smooth; overflow-x: hidden; }
body { -webkit-font-smoothing: antialiased; overflow-x: hidden; }
[id$="__uburn-pdp"] { display: block !important; }

/* ─── TOKENS ─────────────────────────────────────────────────────────────────── */
#pdp-v10 {
  --purple-deep:  #3d1873;
  --purple-main:  #6b2fa0;
  --purple-mid:   #8b47c5;
  --purple-light: #b07de8;
  --purple-pale:  #e8dcf5;
  --purple-wash:  #f5f0fa;
  --cream:        #faf9f7;
  --warm:         #f2f0ed;
  --dark:         #242220;
  --body:         #5a5654;
  --muted:        #8a8785;
  --grad:         linear-gradient(160deg, #3d1873 0%, #6b2fa0 40%, #8b47c5 100%);
  font-family: 'Red Hat Text', sans-serif;
  color: var(--dark);
}

/* ─── STICKY TOP BAR ─────────────────────────────────────────────────────────── */
.pdp-topbar {
  background: var(--dark);
  color: #fff;
  text-align: center;
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: .8px;
  text-transform: uppercase;
  height: 38px;
  overflow: hidden;
  position: relative;
}
.pdp-topbar-slide {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity .4s ease, transform .4s ease;
}
.pdp-topbar-slide.tb-active {
  opacity: 1;
  transform: translateY(0);
}
.pdp-topbar-slide.tb-exit {
  opacity: 0;
  transform: translateY(-6px);
}

/* ─── HERO WRAPPER ───────────────────────────────────────────────────────────── */
.pdp-hero {
  background: #fff;
  padding-bottom: 48px;
}

/* ─── CAROUSEL ───────────────────────────────────────────────────────────────── */
.pdp-carousel-wrap {
  position: relative;
  background: var(--cream);
}
.pdp-carousel-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.pdp-carousel-track::-webkit-scrollbar { display: none; }
.pdp-carousel-slide {
  flex: 0 0 100%;
  scroll-snap-align: start;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  max-height: 480px;
}
.pdp-carousel-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
/* Desktop prev/next arrows — hidden mobile */
.pdp-carousel-btn {
  display: none;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  background: rgba(255,255,255,.92);
  border: none;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 12px rgba(0,0,0,.12);
  transition: box-shadow .2s;
}
.pdp-carousel-btn:hover { box-shadow: 0 4px 20px rgba(0,0,0,.18); }
.pdp-carousel-btn svg { width: 18px; height: 18px; stroke: var(--dark); fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
.pdp-carousel-btn.prev { left: 14px; }
.pdp-carousel-btn.next { right: 14px; }
/* Dots */
.pdp-carousel-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 14px 0 10px;
}
.pdp-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--purple-pale);
  transition: background .3s, width .3s, border-radius .3s;
  cursor: pointer;
}
.pdp-dot.dot-active {
  background: var(--purple-main);
  width: 20px;
  border-radius: 3px;
}

/* ─── HERO CONTENT ───────────────────────────────────────────────────────────── */
.pdp-hero-content {
  padding: 20px 16px 0;
}
/* Rating */
.pdp-rating {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}
.pdp-stars {
  color: var(--purple-main);
  font-size: 15px;
  letter-spacing: 1px;
}
.pdp-rating-score {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--dark);
}
.pdp-rating-count {
  font-size: 13px;
  color: var(--muted);
}
/* H1 */
.pdp-h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(26px, 7.5vw, 34px);
  font-weight: 900;
  line-height: 1.08;
  color: var(--dark);
  letter-spacing: -0.02em;
  margin-bottom: 12px;
  text-wrap: balance;
}
.pdp-h1 .accent { color: var(--purple-mid); }
/* Subtitle */
.pdp-sub {
  font-size: 14.5px;
  color: var(--body);
  line-height: 1.65;
  margin-bottom: 20px;
  max-width: 52ch;
}
/* Bullets */
.pdp-bullets {
  display: flex;
  flex-direction: column;
  gap: 9px;
  margin-bottom: 24px;
}
.pdp-bullet {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  font-weight: 500;
  color: var(--dark);
}
.pdp-bullet-ck {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--purple-wash);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.pdp-bullet-ck svg {
  width: 11px;
  height: 11px;
  stroke: var(--purple-main);
  fill: none;
  stroke-width: 2.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* ─── VARIANT CARDS ──────────────────────────────────────────────────────────── */
.pdp-variants {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}
.pdp-variant-card {
  border: 1.5px solid var(--purple-pale);
  border-radius: 14px;
  padding: 14px 16px;
  cursor: pointer;
  transition: border-color .2s, background .2s, box-shadow .2s;
  background: #fff;
  position: relative;
  overflow: hidden;
}
.pdp-variant-card.vc-active {
  border-color: var(--purple-main);
  background: var(--purple-wash);
  box-shadow: 0 0 0 3px rgba(107,47,160,.1);
}
.pdp-variant-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 3px;
}
.pdp-variant-name {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--dark);
}
.pdp-variant-desc {
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 8px;
}
.pdp-variant-price-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.pdp-variant-price-old {
  font-size: 13px;
  color: var(--muted);
  text-decoration: line-through;
}
.pdp-variant-price {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 20px;
  font-weight: 800;
  color: var(--purple-deep);
}
.pdp-variant-per-day {
  font-size: 12px;
  color: var(--muted);
  margin-top: 3px;
}
.pdp-variant-badge {
  position: absolute;
  top: 0;
  right: 14px;
  background: var(--purple-main);
  color: #fff;
  font-size: 9.5px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 0 0 8px 8px;
  text-transform: uppercase;
  letter-spacing: .5px;
  white-space: nowrap;
}
.pdp-variant-save {
  font-size: 11px;
  font-weight: 700;
  color: #16a34a;
  background: #dcfce7;
  padding: 2px 8px;
  border-radius: 100px;
  white-space: nowrap;
}

/* ─── BONUS BLOCK ────────────────────────────────────────────────────────────── */
.pdp-bonus {
  background: #FFF4E6;
  border: 1.5px solid #F5C47A;
  border-radius: 14px;
  padding: 14px 16px;
  margin-bottom: 20px;
}
.pdp-bonus-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}
.pdp-bonus-icon { font-size: 18px; line-height: 1; flex-shrink: 0; }
.pdp-bonus-title {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: #8B5E00;
  text-transform: uppercase;
  letter-spacing: .5px;
  flex: 1;
}
.pdp-bonus-value {
  background: #D4900A;
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  padding: 3px 10px;
  border-radius: 100px;
  white-space: nowrap;
}
.pdp-bonus-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pdp-bonus-item {
  display: flex;
  align-items: flex-start;
  gap: 7px;
  font-size: 13px;
  color: #6B4500;
  line-height: 1.45;
}
.pdp-bonus-ck {
  color: #D4900A;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}
.pdp-bonus-val {
  color: #8a8785;
  font-size: 12px;
  margin-left: 2px;
}

/* ─── CTA ────────────────────────────────────────────────────────────────────── */
.pdp-cta-wrap { margin-bottom: 10px; }
.pdp-form { display: contents; }
.pdp-cta {
  display: block;
  width: 100%;
  text-align: center;
  background: var(--grad);
  color: #fff;
  border: none;
  border-radius: 100px;
  padding: 18px 24px;
  font-family: 'Red Hat Display', sans-serif;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: transform .2s ease, box-shadow .2s ease;
  animation: ub-pulse-glow 2.5s ease-in-out infinite;
  letter-spacing: .2px;
  -webkit-appearance: none;
}
.pdp-cta:hover { transform: scale(1.02); box-shadow: 0 8px 32px rgba(107,47,160,.4); animation-play-state: paused; }
.pdp-cta:active { transform: scale(0.99); }

/* ─── PAYMENT BADGES ─────────────────────────────────────────────────────────── */
.pdp-payment {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 14px;
  padding: 4px 0;
}
.pdp-pay-badge {
  background: var(--warm);
  border: 1px solid rgba(0,0,0,.07);
  border-radius: 6px;
  padding: 4px 9px;
  font-size: 11px;
  font-weight: 600;
  color: var(--body);
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 4px;
}
.pdp-pay-badge svg { width: 14px; height: 14px; flex-shrink: 0; }

/* ─── TRUST SIGNALS ──────────────────────────────────────────────────────────── */
.pdp-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
  padding: 10px 0 0;
  border-top: 1px solid rgba(0,0,0,.05);
}
.pdp-trust-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: var(--muted);
  font-weight: 500;
  padding: 4px 12px;
}
.pdp-trust-item + .pdp-trust-item {
  border-left: 1px solid rgba(0,0,0,.08);
}
.pdp-trust-item svg {
  width: 13px;
  height: 13px;
  stroke: var(--purple-main);
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}

/* ─── ANIMATIONS (LP exact) ──────────────────────────────────────────────────── */
@keyframes ub-pulse-glow {
  0%,100% { box-shadow: 0 4px 20px rgba(107,47,160,.25); }
  50%      { box-shadow: 0 8px 40px rgba(107,47,160,.5);  }
}
@keyframes ub-float {
  0%,100% { transform: translateY(0); }
  50%     { transform: translateY(-8px); }
}
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
}
.reveal.visible { opacity: 1; transform: none; }
.reveal-d { transition-delay: .15s; }

/* ─── MOBILE FIRST: clamp and safe area ──────────────────────────────────────── */
@media (max-width: 767px) {
  .pdp-hero-content { padding: 18px 16px 0; }
  .pdp-bonus, .pdp-variants, .pdp-cta-wrap, .pdp-payment, .pdp-trust { margin-left: 0; margin-right: 0; }
}

/* ─── DESKTOP ≥768px ─────────────────────────────────────────────────────────── */
@media (min-width: 768px) {
  .pdp-hero {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
    padding: 48px 40px 80px;
  }
  .pdp-carousel-wrap {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(61,24,115,.12), 0 0 0 1px rgba(107,47,160,.07);
    position: sticky;
    top: 80px;
  }
  .pdp-carousel-slide { max-height: 560px; aspect-ratio: 1/1; }
  .pdp-carousel-btn   { display: flex; }
  .pdp-hero-content   { padding: 0; }
  .pdp-h1             { font-size: clamp(30px, 3.2vw, 44px); }
  .pdp-sub            { font-size: 16px; }
  .pdp-cta            { font-size: 16px; }
}

/* ─── REDUCED MOTION ─────────────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .pdp-cta { animation: none; }
  .reveal  { opacity: 1; transform: none; transition: none; }
}
</style>

