/* ── STAGGER ANIMATIONS ──────────────────────────────────────────────────── */
.stagger-children > * {
  opacity: 0;
  transform: translateY(22px);
  transition: opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1);
}
.stagger-children.visible > *:nth-child(1) { opacity:1; transform:none; transition-delay:0s; }
.stagger-children.visible > *:nth-child(2) { opacity:1; transform:none; transition-delay:.08s; }
.stagger-children.visible > *:nth-child(3) { opacity:1; transform:none; transition-delay:.16s; }
.stagger-children.visible > *:nth-child(4) { opacity:1; transform:none; transition-delay:.24s; }

.stagger-scale > * {
  opacity: 0;
  transform: scale(.93);
  transition: opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1);
}
.stagger-scale.visible > *:nth-child(1) { opacity:1; transform:none; transition-delay:0s; }
.stagger-scale.visible > *:nth-child(2) { opacity:1; transform:none; transition-delay:.09s; }
.stagger-scale.visible > *:nth-child(3) { opacity:1; transform:none; transition-delay:.18s; }
.stagger-scale.visible > *:nth-child(4) { opacity:1; transform:none; transition-delay:.27s; }

@media (prefers-reduced-motion: reduce) {
  .stagger-children > *, .stagger-scale > * {
    opacity:1; transform:none; transition:none;
  }
}

/* ── DESKTOP OVERRIDES (sections 3-8) ────────────────────────────────────── */
@media (min-width: 768px) {
  .pdp-rv-grid          { grid-template-columns: repeat(4, 1fr); }
  .pdp-s4-cards         { grid-template-columns: repeat(3, 1fr); }
  .pdp-s5-grid          { grid-template-columns: repeat(3, 1fr); }
  .pdp-s6-inner         { grid-template-columns: 180px 1fr; gap: 48px; }
  .pdp-s6-photo         { width: 180px; height: 180px; }
  .pdp-s7-grid          { grid-template-columns: repeat(4, 1fr); }
}

/* ── STAGGER FIX: make all children visible (5+ child support) ───────────── */
.stagger-scale.visible > *,
.stagger-children.visible > * { opacity:1; transform:none; }
.stagger-scale.visible    > *:nth-child(5) { transition-delay:.33s; }
.stagger-scale.visible    > *:nth-child(6) { transition-delay:.39s; }
.stagger-children.visible > *:nth-child(5) { transition-delay:.30s; }
.stagger-children.visible > *:nth-child(6) { transition-delay:.36s; }

