/* ── S6: EXPERT ──────────────────────────────────────────────────────────── */
.pdp-s6 {
  background: #f5f0fa;
  padding: 72px 20px;
}
.pdp-s6-inner {
  max-width: 860px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  align-items: center;
}
.pdp-s6-photo-wrap {
  display: flex;
