     SECTION 14 — STICKY ATC (mobile only · fixed bottom)
══════════════════════════════════════════════════════════════ -->
<div id="pdp-sticky-atc" class="pdp-sticky-atc" role="region" aria-label="Commande rapide">
  <div class="pdp-sticky-inner">
    <div class="pdp-sticky-product">
      <img src="https://uburn.co/cdn/shop/files/PRODUCTPAGE_0000_7.jpg?v=1773911263&width=80&format=webp"
           alt="Uburn" class="pdp-sticky-img" loading="lazy" decoding="async">
