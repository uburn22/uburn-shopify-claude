  transition: box-shadow 0.2s;
}
.offer-card:hover { box-shadow: var(--shadow-soft); }
.offer-card.featured {
  border: 2px solid var(--purple-main);
  background: var(--purple-wash);
}
.offer-card-badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--purple-main);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  padding: 4px 14px;
  border-radius: 50px;
  white-space: nowrap;
  letter-spacing: 0.3px;
}
.offer-card-name {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 16px;
  color: var(--dark);
  margin-bottom: 4px;
}
.offer-card-sub { font-size: 12.5px; color: var(--body); margin-bottom: 16px; }
.offer-card-price {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 30px;
  font-weight: 900;
  color: var(--purple-main);
  margin-bottom: 2px;
}
.offer-card-daily { font-size: 12px; color: var(--muted); margin-bottom: 16px; }
.offer-card-btn {
  width: 100%;
  background: var(--grad);
  color: #fff;
  border: none;
  padding: 14px;
  border-radius: 50px;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  transition: opacity 0.2s;
}
.offer-card-btn:hover { opacity: 0.9; }

/* Bonus block */
.bonus-block {
  background: #fff;
  border-radius: var(--radius);
  padding: 28px 32px;
  margin-bottom: 40px;
  box-shadow: var(--shadow-card);
}
.bonus-title {
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 800;
  font-size: 15px;
  color: var(--dark);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.bonus-list { display: flex; flex-direction: column; gap: 10px; }
.bonus-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  font-size: 14px;
}
.bonus-item-name { color: var(--body); display: flex; align-items: center; gap: 8px; }
.bonus-item-name::before { content: '✓'; color: #16a34a; font-weight: 700; flex-shrink: 0; }
.bonus-item-value { font-weight: 700; color: var(--muted); text-decoration: line-through; font-size: 13px; }
.bonus-total {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--purple-pale);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 15px;
}
.bonus-total-val { color: var(--purple-main); font-size: 17px; }

/* Trust grid */
.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-top: 40px;
}
.trust-cell {
  text-align: center;
  padding: 16px;
  background: #fff;
  border-radius: var(--radius-sm);
}
.trust-cell-icon { font-size: 22px; margin-bottom: 6px; }
.trust-cell-text { font-size: 12px; font-weight: 600; color: var(--body); line-height: 1.4; }

@media (max-width: 700px) {
  .offer-pricing { grid-template-columns: 1fr; max-width: 420px; margin-left: auto; margin-right: auto; }
  .offer-section { padding: 64px 20px; }
  .trust-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ═══ LEGAL FOOTER ═══ */
.legal-mention {
  background: var(--warm);
  padding: 32px 40px;
  border-top: 1px solid var(--purple-pale);
}
.legal-mention p {
  max-width: 900px;
  margin: 0 auto;
  font-size: 11.5px;
  color: var(--muted);
  line-height: 1.7;
  text-align: center;
}

/* ═══ REVEAL ANIMATIONS ═══ */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.reveal.visible {
  opacity: 1;
  transform: none;
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }
.reveal-delay-5 { transition-delay: 0.5s; }

/* ═══ ORIGINE SECTION ═══ */
.origine-section {
  background: var(--cream);
  padding: var(--space-3xl) 40px;
}
.origine-inner {
  max-width: 1100px;
  margin: 0 auto;
