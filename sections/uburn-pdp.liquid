<script>
(function () {
  'use strict';

  /* ── TOP BAR ROTATION ───────────────────────────────────── */
  var tbSlides  = [document.getElementById('tb0'), document.getElementById('tb1'), document.getElementById('tb2')];
  var tbCurrent = 0;
  function tbNext() {
    tbSlides[tbCurrent].classList.remove('tb-active');
    tbSlides[tbCurrent].classList.add('tb-exit');
    var prev = tbCurrent;
    tbCurrent = (tbCurrent + 1) % tbSlides.length;
    tbSlides[tbCurrent].classList.add('tb-active');
    setTimeout(function () { tbSlides[prev].classList.remove('tb-exit'); }, 450);
  }
  setInterval(tbNext, 4000);

  /* ── CAROUSEL ───────────────────────────────────────────── */
  var track  = document.getElementById('carTrack');
  var dots   = document.querySelectorAll('.pdp-dot');
  var slides = track ? track.querySelectorAll('.pdp-carousel-slide') : [];
  var total  = slides.length;
  var current = 0;

  function goTo(idx) {
    idx = Math.max(0, Math.min(idx, total - 1));
    current = idx;
    if (track) track.scrollTo({ left: track.offsetWidth * idx, behavior: 'smooth' });
    dots.forEach(function (d, i) { d.classList.toggle('dot-active', i === idx); });
  }

  /* Scroll-snap sync dots */
  if (track) {
    track.addEventListener('scroll', function () {
      var idx = Math.round(track.scrollLeft / track.offsetWidth);
      if (idx !== current) { current = idx; dots.forEach(function (d, i) { d.classList.toggle('dot-active', i === idx); }); }
    }, { passive: true });
  }

  /* Dot clicks */
  dots.forEach(function (d, i) { d.addEventListener('click', function () { goTo(i); }); });

  /* Desktop arrow buttons */
  var btnPrev = document.getElementById('carPrev');
  var btnNext = document.getElementById('carNext');
  if (btnPrev) btnPrev.addEventListener('click', function () { goTo(current - 1); });
  if (btnNext) btnNext.addEventListener('click', function () { goTo(current + 1); });

  /* ── VARIANT SELECTION ──────────────────────────────────── */
  var variantInput = document.getElementById('pdp-variant-id');
  var ctaBtn       = document.getElementById('pdp-cta-btn');

  window.pdpSelectVariant = function (card) {
    document.querySelectorAll('.pdp-variant-card').forEach(function (c) { c.classList.remove('vc-active'); });
    card.classList.add('vc-active');
    var id    = card.dataset.variantId;
    var price = card.dataset.priceDisplay;
    if (variantInput) variantInput.value = id;
    if (ctaBtn) ctaBtn.textContent = 'Je reprends le contrôle — ' + price + '€ →';
  };

  /* ── REVEAL OBSERVER (LP pattern) ──────────────────────── */
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.pdp-v10-scope .reveal, #pdp-v10 .reveal').forEach(function (el) { obs.observe(el); });
  /* Fallback: also observe all .reveal inside this section */
  document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });

  /* ── STAGGER OBSERVER ───────────────────────────────────── */
  var staggerObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); staggerObs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.stagger-children, .stagger-scale').forEach(function (el) {
    staggerObs.observe(el);
  });

  /* ── COUNT-UP ANIMATION ─────────────────────────────────── */
  var cuObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (!e.isIntersecting) return;
      cuObs.unobserve(e.target);
      var el = e.target;
      var target = parseFloat(el.dataset.countup);
      var suffix = el.dataset.countupSuffix || '';
      var isDecimal = target !== Math.floor(target);
      var duration = 1400;
      var startTime = null;
      function tick(ts) {
        if (!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        var current = target * eased;
        el.textContent = (isDecimal ? current.toFixed(1) : Math.round(current)) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-countup]').forEach(function (el) { cuObs.observe(el); });

})();
</script>

