}

@media (max-width: 800px) {
  .testi-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
}

/* ═══ FAQ ═══ */
.faq-section { background: var(--cream); }
.faq-list { margin-top: 48px; max-width: 760px; }
.faq-item {
  border-bottom: 1px solid var(--purple-pale);
}
.faq-q {
  width: 100%;
  background: none;
  border: none;
  padding: 22px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  cursor: pointer;
  text-align: left;
  font-family: 'Red Hat Display', sans-serif;
  font-weight: 700;
  font-size: 16px;
  color: var(--dark);
  transition: color 0.2s;
}
.faq-q:hover { color: var(--purple-main); }
.faq-q.open { color: var(--purple-main); }
.faq-arrow {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid var(--purple-pale);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s, border-color 0.2s, transform 0.3s;
  color: var(--purple-mid);
}
.faq-q.open .faq-arrow {
  background: var(--purple-main);
  border-color: var(--purple-main);
  color: #fff;
  transform: rotate(180deg);
}
.faq-a {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
.faq-a.open { grid-template-rows: 1fr; }
.faq-a-inner {
  overflow: hidden;
  font-size: 15px;
  color: var(--body);
  line-height: 1.7;
  padding-bottom: 0;
  transition: padding-bottom 0.35s;
}
.faq-a.open .faq-a-inner { padding-bottom: 20px; }

/* ═══ OFFER BLOCK ═══ */
.offer-section {
  background: linear-gradient(160deg, var(--cream) 0%, var(--purple-wash) 100%);
  padding: var(--space-3xl) 40px;
}
.offer-inner { max-width: 980px; margin: 0 auto; }
.offer-section .section-title { text-align: center; }
.offer-section .section-label { text-align: center; display: block; }

.offer-img {
  max-width: 420px;
  margin: 48px auto 56px;
}
.offer-img img {
  width: 100%;
  filter: drop-shadow(0 40px 80px oklch(0.35 0.12 300 / 0.25));
}

.offer-pricing {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 48px;
}
.offer-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 24px;
  box-shadow: var(--shadow-card);
