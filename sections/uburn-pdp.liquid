<script>
function ubSwitchImg(thumb, src) {
  document.getElementById('ub-gallery-main').src = src;
  document.querySelectorAll('.ub-hero-thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
}

function ubSelectOffer(card, variantId) {
  document.querySelectorAll('.ub-offer-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  document.getElementById('ub-variant-id').value = variantId;
  var name = card.querySelector('.ub-offer-name').textContent;
  var price = card.querySelector('.ub-offer-price-main').textContent;
  var per = card.querySelector('.ub-offer-price-per').textContent;
  document.getElementById('ub-sticky-label').textContent = name;
  document.querySelector('.ub-sticky-price').innerHTML = price + ' <span class="ub-sticky-per">· ' + per + '</span>';
}

function ubAddToCart(variantId) {
  document.getElementById('ub-variant-id').value = variantId;
  document.getElementById('ub-pdp-form').submit();
}

function ubToggleFaq(btn) {
  var item = btn.parentElement;
  var isOpen = item.classList.contains('open');
  document.querySelectorAll('.ub-faq-item').forEach(function(i) {
    i.classList.remove('open');
    i.querySelector('.ub-faq-icon').textContent = '+';
  });
  if (!isOpen) {
    item.classList.add('open');
    btn.querySelector('.ub-faq-icon').textContent = '−';
  }
}
</script>
