{%- assign variant_max = product.variants | where: "id", 51289200066879 | first -%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Yeseva+One&family=Jost:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap');

[id^="shopify-section-sections--"]{display:none !important}
main#main{padding:0 !important}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

:root{
  --purple:        #2d1b69;
  --purple-mid:    #5b35a8;
  --purple-light:  #c4a8f0;
  --purple-pale:   #f0eafa;
  --cream:         #faf9f6;
  --dark:          #1a1028;
  --text:          #3a2e50;
  --muted:         #8076a3;
  --white:         #fefefe;
  --gold:          #c8963c;
  --radius-sm:     8px;
  --radius-md:     16px;
  --radius-lg:     24px;
  --radius-xl:     40px;
}

body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);font-size:16px;line-height:1.6;overflow-x:hidden}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}

/* ── NAV ── */
.ub-nav{
  position:sticky;top:0;z-index:100;
  background:var(--white);
  border-bottom:1px solid rgba(91,53,168,.1);
  padding:0 clamp(16px,5vw,64px);
  height:60px;
  display:flex;align-items:center;justify-content:space-between;
}
.ub-nav-logo{font-family:'Yeseva One',serif;font-size:22px;color:var(--purple);text-decoration:none}
.ub-nav-trust{display:flex;gap:40px;font-size:12px;font-weight:500;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
.ub-nav-cta{
  background:var(--purple);color:var(--white);
  padding:10px 20px;border-radius:100px;
  font-size:13px;font-weight:600;letter-spacing:.02em;
  transition:opacity .2s;
}
.ub-nav-cta:hover{opacity:.85}

/* ── HERO ── */
.ub-hero{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:calc(100vh - 60px);
  background:var(--white);
}
.ub-hero-gallery{
  position:relative;
  background:var(--purple-pale);
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;order:2;
}
.ub-hero-gallery-main{
  width:100%;height:100%;
  object-fit:cover;display:block;
}
.ub-hero-badge{
  position:absolute;top:20px;left:20px;
  background:var(--white);color:var(--purple);
  font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  padding:6px 14px;border-radius:100px;
  display:flex;align-items:center;gap:6px;
}
.ub-hero-thumbs{
  position:absolute;bottom:20px;left:50%;transform:translateX(-50%);
  display:flex;gap:8px;
}
.ub-hero-thumb{
  width:52px;height:52px;border-radius:8px;overflow:hidden;
  border:2px solid transparent;cursor:pointer;background:var(--white);
  transition:border-color .2s;flex-shrink:0;
}
.ub-hero-thumb.active{border-color:var(--purple)}
.ub-hero-thumb img{width:100%;height:100%;object-fit:cover}

.ub-hero-info{
  padding:clamp(32px,5vw,80px) clamp(24px,5vw,64px);
  display:flex;flex-direction:column;justify-content:center;gap:20px;
  order:1;
}
.ub-eyebrow{font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--purple-mid)}
.ub-hero-title{
  font-family:'Yeseva One',serif;
  font-size:clamp(30px,3.5vw,50px);
  line-height:1.1;color:var(--dark);
}
.ub-hero-title em{font-style:normal;color:var(--purple-mid)}
.ub-hero-sub{font-size:15px;color:var(--muted);line-height:1.65;max-width:400px;font-weight:300}
.ub-rating{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)}
.ub-stars{color:var(--gold);letter-spacing:-1px}
.ub-rating-count{color:var(--purple);font-weight:600}

.ub-pills{display:flex;flex-wrap:wrap;gap:8px}
.ub-pill{
  display:flex;align-items:center;gap:6px;
  background:var(--purple-pale);color:var(--purple);
  padding:6px 14px;border-radius:100px;
  font-size:13px;font-weight:500;
}

/* Offer selector */
.ub-offer-label{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.ub-offer-cards{display:flex;flex-direction:column;gap:10px}
.ub-offer-card{
  display:grid;grid-template-columns:20px 1fr auto;
  align-items:center;gap:14px;
  padding:14px 18px;
  border:2px solid rgba(91,53,168,.15);
  border-radius:var(--radius-md);
  cursor:pointer;background:var(--white);
  position:relative;transition:border-color .2s,background .2s;
}
.ub-offer-card.active{border-color:var(--purple);background:var(--purple-pale)}
.ub-offer-radio{
  width:18px;height:18px;border-radius:50%;
  border:2px solid rgba(91,53,168,.3);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all .2s;
}
.ub-offer-card.active .ub-offer-radio{background:var(--purple);border-color:var(--purple)}
.ub-offer-card.active .ub-offer-radio::after{content:'';width:6px;height:6px;border-radius:50%;background:#fff}
.ub-offer-name{font-size:14px;font-weight:600;color:var(--dark)}
.ub-offer-desc{font-size:12px;color:var(--muted)}
.ub-offer-price-main{font-size:18px;font-weight:700;color:var(--dark)}
.ub-offer-price-per{font-size:11px;color:var(--muted)}
.ub-offer-badge{
  position:absolute;top:-10px;right:14px;
  background:var(--purple);color:#fff;
  font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  padding:3px 10px;border-radius:100px;
}

.ub-btn-primary{
  background:var(--purple);color:#fff;
  padding:18px 32px;border-radius:100px;
  font-size:15px;font-weight:600;letter-spacing:.02em;
  text-align:center;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:opacity .2s,transform .1s;
  width:100%;font-family:'Jost',sans-serif;
}
.ub-btn-primary:hover{opacity:.88;transform:translateY(-1px)}
.ub-btn-primary:active{transform:translateY(0)}

.ub-reassurance{display:flex;gap:20px;flex-wrap:wrap}
.ub-reassurance-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted)}

/* ── SECTION BASE ── */
.ub-section{padding:clamp(48px,7vw,100px) clamp(16px,5vw,64px)}
.ub-inner{max-width:1100px;margin:0 auto}
.ub-section-title{
  font-family:'Yeseva One',serif;
  font-size:clamp(26px,3vw,42px);
  line-height:1.15;color:var(--dark);margin-bottom:16px;
}
.ub-section-title em{font-style:normal;color:var(--purple-mid)}

/* ── USAGES (comme un matcha) ── */
.ub-usages{background:var(--purple)}
.ub-usages .ub-eyebrow{color:rgba(255,255,255,.6)}
.ub-usages .ub-section-title{color:#fff}
.ub-usages .ub-section-title em{color:var(--purple-light)}
.ub-usage-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}
.ub-usage-card{background:rgba(255,255,255,.08);border-radius:var(--radius-lg);overflow:hidden}
.ub-usage-card-img{
  width:100%;aspect-ratio:4/3;object-fit:cover;display:block;
  background:rgba(255,255,255,.05);
}
.ub-usage-placeholder{
  width:100%;aspect-ratio:4/3;
  background:rgba(255,255,255,.07);
  display:flex;align-items:center;justify-content:center;font-size:56px;
}
.ub-usage-body{padding:20px}
.ub-usage-tag{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--purple-light);margin-bottom:6px}
.ub-usage-title{font-family:'Yeseva One',serif;font-size:20px;color:#fff;margin-bottom:8px}
.ub-usage-desc{font-size:13px;color:rgba(255,255,255,.6);line-height:1.55;font-weight:300}

/* ── PROBLÈME 16H ── */
.ub-problem{background:var(--cream)}
.ub-problem-inner{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.ub-problem-text p{font-size:16px;line-height:1.8;color:var(--text);font-weight:300;margin-bottom:20px}
.ub-problem-text strong{font-weight:600;color:var(--dark)}
.ub-problem-visual{
  background:var(--purple);border-radius:var(--radius-xl);
  padding:40px;display:flex;flex-direction:column;gap:24px;
}
.ub-problem-time{
  font-family:'Yeseva One',serif;font-size:72px;color:#fff;
  line-height:1;opacity:.15;
}
.ub-problem-items{display:flex;flex-direction:column;gap:16px}
.ub-problem-item{display:flex;gap:14px;align-items:flex-start}
.ub-problem-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--purple-light);margin-top:8px;flex-shrink:0;
}
.ub-problem-item-text{font-size:14px;color:#fff;font-weight:300;line-height:1.55}
.ub-problem-item-text strong{font-weight:600}

/* ── COMMENT ÇA MARCHE ── */
.ub-how{background:var(--white)}
.ub-how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;margin-top:40px}
.ub-how-step{display:flex;flex-direction:column;gap:14px}
.ub-how-img{
  width:100%;aspect-ratio:4/3;object-fit:cover;
  border-radius:var(--radius-lg);display:block;
  background:var(--purple-pale);
}
.ub-how-step-num{font-size:11px;font-weight:700;letter-spacing:.1em;color:var(--purple-mid);text-transform:uppercase}
.ub-how-step-title{font-size:18px;font-weight:600;color:var(--dark);line-height:1.3}
.ub-how-step-desc{font-size:14px;color:var(--muted);line-height:1.6;font-weight:300}

/* ── DIFFÉRENCE ── */
.ub-diff{background:var(--purple-pale)}
.ub-diff-table{
  display:grid;grid-template-columns:2fr 1fr 1fr;
  margin-top:40px;border-radius:var(--radius-lg);
  overflow:hidden;border:1px solid rgba(91,53,168,.15);
}
.ub-diff-col{}
.ub-diff-head{
  padding:16px 20px;font-size:12px;font-weight:700;
  letter-spacing:.06em;text-transform:uppercase;
  background:rgba(91,53,168,.06);color:var(--muted);
}
.ub-diff-col:first-child .ub-diff-head{background:transparent}
.ub-diff-col-uburn .ub-diff-head{
  background:var(--purple);color:#fff;
  font-family:'Yeseva One',serif;font-size:18px;
  text-transform:none;letter-spacing:0;
}
.ub-diff-cell{
  padding:12px 20px;font-size:14px;
  border-bottom:1px solid rgba(91,53,168,.08);
  display:flex;align-items:center;background:var(--white);
}
.ub-diff-col-uburn .ub-diff-cell{
  background:var(--purple-pale);justify-content:center;
}
.ub-diff-col:first-child .ub-diff-cell{color:var(--text)}
.ub-check{color:var(--purple);font-size:18px;font-weight:700}
.ub-cross{color:#c0b8d8;font-size:18px}
.ub-partial{color:var(--muted);font-size:18px}

/* ── INGRÉDIENTS ── */
.ub-ingredients{background:var(--white)}
.ub-ingredient-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:12px;margin-top:40px;
}
.ub-ingredient-card{
  background:var(--cream);border-radius:var(--radius-md);
  padding:20px;display:flex;flex-direction:column;gap:8px;
  transition:transform .2s;
}
.ub-ingredient-card:hover{transform:translateY(-3px)}
.ub-ingredient-img{
  width:100%;aspect-ratio:3/2;object-fit:cover;
  border-radius:var(--radius-sm);margin-bottom:4px;
  background:var(--purple-pale);
}
.ub-ingredient-name{font-size:15px;font-weight:700;color:var(--dark)}
.ub-ingredient-origin{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--purple-mid)}
.ub-ingredient-benefit{font-size:13px;color:var(--muted);line-height:1.5;font-weight:300}

/* ── PREUVE ── */
.ub-proof{background:var(--purple-pale)}
.ub-proof-stat{display:flex;align-items:baseline;gap:12px;margin-bottom:40px}
.ub-proof-number{
  font-family:'Yeseva One',serif;
  font-size:clamp(56px,7vw,88px);
  color:var(--purple);line-height:1;
}
.ub-proof-label{font-size:15px;color:var(--muted);font-weight:300;max-width:220px;line-height:1.4}
.ub-proof-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.ub-proof-card{
  background:var(--white);border-radius:var(--radius-lg);
  padding:28px;display:flex;flex-direction:column;gap:14px;
}
.ub-proof-stars{color:var(--gold);font-size:15px;letter-spacing:2px}
.ub-proof-quote{font-size:14px;line-height:1.7;color:var(--text);font-weight:300;font-style:italic}
.ub-proof-author{display:flex;align-items:center;gap:10px;margin-top:auto}
.ub-proof-avatar{
  width:36px;height:36px;border-radius:50%;
  background:var(--purple-pale);display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;color:var(--purple);flex-shrink:0;
}
.ub-proof-author-name{font-size:13px;font-weight:600;color:var(--dark)}
.ub-proof-author-meta{font-size:11px;color:var(--muted)}

/* ── OFFRE FINALE ── */
.ub-finale{background:var(--dark)}
.ub-finale .ub-eyebrow{color:rgba(255,255,255,.4)}
.ub-finale .ub-section-title{color:#fff}
.ub-finale .ub-section-title em{color:var(--purple-light)}
.ub-finale-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:40px}
.ub-finale-card{
  border-radius:var(--radius-xl);padding:32px;
  display:flex;flex-direction:column;gap:16px;
  position:relative;
}
.ub-finale-card-dec{background:rgba(255,255,255,.07)}
.ub-finale-card-pro{background:var(--purple)}
.ub-finale-badge{
  position:absolute;top:-14px;left:50%;transform:translateX(-50%);
  background:var(--gold);color:var(--dark);
  font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  padding:5px 16px;border-radius:100px;white-space:nowrap;
}
.ub-finale-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.ub-finale-title{font-family:'Yeseva One',serif;font-size:24px;color:#fff;line-height:1.2}
.ub-finale-price{display:flex;align-items:baseline;gap:8px}
.ub-finale-price-main{font-size:40px;font-weight:700;color:#fff;line-height:1}
.ub-finale-price-per{font-size:13px;color:rgba(255,255,255,.5)}
.ub-finale-features{display:flex;flex-direction:column;gap:10px}
.ub-finale-feature{
  display:flex;align-items:flex-start;gap:8px;
  font-size:13px;color:rgba(255,255,255,.7);font-weight:300;
}
.ub-finale-feature::before{content:'✓';color:var(--purple-light);font-weight:700;flex-shrink:0}
.ub-finale-card-pro .ub-finale-feature::before{color:#fff}
.ub-btn-finale{
  background:#fff;color:var(--purple);
  padding:16px 32px;border-radius:100px;
  font-size:14px;font-weight:700;text-align:center;
  border:none;cursor:pointer;display:block;
  margin-top:auto;transition:opacity .2s;
  letter-spacing:.02em;font-family:'Jost',sans-serif;
  width:100%;
}
.ub-finale-card-pro .ub-btn-finale{background:var(--dark);color:#fff}
.ub-btn-finale:hover{opacity:.85}

/* ── FAQ ── */
.ub-faq{background:var(--cream)}
.ub-faq-list{display:flex;flex-direction:column;gap:2px;margin-top:40px;max-width:720px}
.ub-faq-item{background:var(--white);border-radius:var(--radius-sm)}
.ub-faq-q{
  width:100%;background:none;border:none;
  padding:18px 24px;display:flex;justify-content:space-between;align-items:center;
  font-size:15px;font-weight:500;color:var(--dark);
  cursor:pointer;text-align:left;font-family:'Jost',sans-serif;gap:16px;
}
.ub-faq-icon{
  width:28px;height:28px;border-radius:50%;
  background:var(--purple-pale);color:var(--purple);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;transition:background .2s;line-height:1;
}
.ub-faq-item.open .ub-faq-icon{background:var(--purple);color:#fff}
.ub-faq-a{
  display:none;padding:0 24px 18px;
  font-size:14px;color:var(--muted);line-height:1.7;font-weight:300;
}
.ub-faq-item.open .ub-faq-a{display:block}

/* ── STICKY MOBILE ── */
.ub-sticky{
  display:none;position:fixed;bottom:0;left:0;right:0;
  background:var(--white);
  padding:12px 20px;box-shadow:0 -4px 24px rgba(0,0,0,.1);
  z-index:99;align-items:center;justify-content:space-between;gap:16px;
}
.ub-sticky-info{}
.ub-sticky-label{font-size:11px;color:var(--muted)}
.ub-sticky-price{font-size:20px;font-weight:700;color:var(--dark)}
.ub-sticky-per{font-size:11px;color:var(--muted)}

/* ── FOOTER ── */
.ub-footer{
  background:var(--dark);color:rgba(255,255,255,.4);
  padding:32px clamp(16px,5vw,64px);
  display:flex;justify-content:space-between;align-items:center;
  flex-wrap:wrap;gap:12px;font-size:12px;
}
.ub-footer-logo{font-family:'Yeseva One',serif;font-size:18px;color:rgba(255,255,255,.7)}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .ub-nav-trust{display:none}
  .ub-hero{grid-template-columns:1fr;min-height:auto}
  .ub-hero-gallery{order:1;aspect-ratio:1;min-height:320px}
  .ub-hero-info{order:2;padding:28px 20px}
  .ub-usage-cards{grid-template-columns:1fr}
  .ub-problem-inner{grid-template-columns:1fr}
  .ub-problem-visual{display:none}
  .ub-how-steps{grid-template-columns:1fr}
  .ub-ingredient-grid{grid-template-columns:repeat(2,1fr)}
  .ub-proof-cards{grid-template-columns:1fr}
  .ub-finale-cards{grid-template-columns:1fr}
  .ub-sticky{display:flex}
  body{padding-bottom:80px}
  .ub-diff-table{font-size:12px}
}
@media(max-width:600px){
  .ub-hero-title{font-size:30px}
  .ub-pill{font-size:12px;padding:5px 10px}
  .ub-ingredient-grid{grid-template-columns:1fr}
  .ub-diff-head{padding:10px 12px}
  .ub-diff-cell{padding:10px 12px;font-size:12px}
}
</style>

<!-- NAV -->
<nav class="ub-nav">
  <a href="{{ routes.root_url }}" class="ub-nav-logo">UBurn</a>
  <div class="ub-nav-trust">
    <span>⭐ 4.8 / 5</span>
    <span>Livraison offerte</span>
    <span>Marque française</span>
  </div>
  <a href="#ub-offre" class="ub-nav-cta">Commander →</a>
</nav>

<!-- HERO -->
<section class="ub-hero">
  <div class="ub-hero-gallery">
    <div class="ub-hero-badge">⭐ #1 Marque Française</div>
    <img
      id="ub-gallery-main"
      class="ub-hero-gallery-main"
      src="https://uburn.co/cdn/shop/files/Uburn_Listing_ecom_1.jpg?v=1772700007&width=900"
      alt="UBurn — Latte ubé violet anti-fringales"
      loading="eager">
    <div class="ub-hero-thumbs">
      <div class="ub-hero-thumb active" onclick="ubSwitchImg(this,'https://uburn.co/cdn/shop/files/Uburn_Listing_ecom_1.jpg?v=1772700007&width=900')">
        <img src="https://uburn.co/cdn/shop/files/Uburn_Listing_ecom_1.jpg?v=1772700007&width=120" alt="">
      </div>
      {%- for image in product.images limit:4 -%}
      <div class="ub-hero-thumb" onclick="ubSwitchImg(this,'{{ image | img_url: '900x' }}')">
        <img src="{{ image | img_url: '120x' }}" alt="{{ image.alt }}">
      </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="ub-hero-info">
    <div class="ub-eyebrow">Boisson wellness · Formule active</div>

    <h1 class="ub-hero-title">
      Le latte ubé<br>qui calme<br><em>les fringales de 16h.</em>
    </h1>

    <p class="ub-hero-sub">
      À boire chaud, glacé, avec du lait végétal ou dans un smoothie.
      Un rituel violet, gourmand et pratique — 30 kcal, 0% caféine.
    </p>

    <div class="ub-rating">
      <span class="ub-stars">★★★★★</span>
      <span class="ub-rating-count">4.8/5</span>
      <span>· 1 320+ avis vérifiés</span>
    </div>

    <div class="ub-pills">
      <span class="ub-pill">⏱ 4h de satiété</span>
      <span class="ub-pill">🔥 30 kcal</span>
      <span class="ub-pill">✨ 0% caféine</span>
      <span class="ub-pill">☕ Chaud · Glacé · Smoothie</span>
