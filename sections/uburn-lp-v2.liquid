{% schema %}
{
  "name": "UBurn LP V2",
  "tag": "section",
  "class": "shopify-section--uburn-lp-v2",
  "settings": [
    { "type": "header", "content": "Product binding" },
    { "type": "product", "id": "product", "label": "Product (default ube-poudre)" },
    { "type": "header", "content": "Hero" },
    { "type": "textarea", "id": "hero_h1", "label": "Hero H1 (use <em>...</em>)", "default": "End your 4 PM crash." },
    { "type": "textarea", "id": "hero_sub", "label": "Hero sub", "default": "The violet matcha. Plant-based satiety. 30 calories. Caffeine-free. Crafted in France." },
    { "type": "header", "content": "Trust strip (4 items)" },
    { "type": "text", "id": "trust_1", "label": "Trust 1", "default": "EFSA-backed fiber" },
    { "type": "text", "id": "trust_2", "label": "Trust 2", "default": "0% caffeine" },
    { "type": "text", "id": "trust_3", "label": "Trust 3", "default": "30 calories" },
    { "type": "text", "id": "trust_4", "label": "Trust 4", "default": "Made in France" }
  ],
  "presets": [ { "name": "UBurn LP V2" } ]
}
{% endschema %}
