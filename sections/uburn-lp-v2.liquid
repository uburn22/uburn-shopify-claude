{%- comment -%}
  UBurn LP V2 — Violet Matcha · aligned on PDP DA (u2-* tokens)
  Rev 2026-05-19 v3 — drop Bloom Fraunces, adopt Times serif + Helvetica Neue from u2-base.css
{%- endcomment -%}
{%- liquid
  assign hp = section.settings.product
  if hp == blank
    assign hp = all_products['ube-poudre']
  endif
  assign v_starter = hp.variants[0]
  assign v_maximum = hp.variants[1] | default: hp.variants[0]
  assign sub_plan = null
  for spg in hp.selling_plan_groups
    for sp in spg.selling_plans
      assign sub_plan = sp
      break
    endfor
    if sub_plan != null
      break
    endif
  endfor
-%}

<meta name="robots" content="noindex,nofollow">
{{ 'uburn-lp-v2.css' | asset_url | stylesheet_tag }}

<script id="uburn-lp-v2-data">
  window.__UBLP2 = {
    product_id: {{ hp.id }},
    starter: { id: {{ v_starter.id }}, price_one: 3699, price_sub: 3329, label: 'Starter — 90g · 30 servings' },
    maximum: { id: {{ v_maximum.id }}, price_one: 5899, price_sub: 5309, label: 'Maximum — 270g · 90 servings' },
    {%- if sub_plan -%}
    selling_plan_id: {{ sub_plan.id }},
    {%- else -%}
    selling_plan_id: null,
    {%- endif -%}
    currency: 'USD',
    cart_add_url: '/cart/add.js'
  };
</script>

