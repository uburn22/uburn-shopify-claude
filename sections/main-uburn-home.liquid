<script>
(function() {
  'use strict';

  // ── IntersectionObserver reveal ──
  var revealObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('uhome-visible');
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.uhome-reveal, .uhome-stagger, .uhome-stagger-scale').forEach(function(el) {
    revealObs.observe(el);
  });

  // Déclencher immédiatement pour les éléments déjà visibles
  requestAnimationFrame(function() {
    document.querySelectorAll('.uhome-reveal, .uhome-stagger, .uhome-stagger-scale').forEach(function(el) {
      var r = el.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) {
        el.classList.add('uhome-visible');
      }
    });
  });

  // ── Cart preview toggle (Découverte/Maximum) ──
  var cartBlock = document.getElementById('uhome-cart-block');
  var cardDec = document.getElementById('uhome-card-dec');
  var cardMax = document.getElementById('uhome-card-max');

  function selectMax() {
    if (cartBlock) cartBlock.style.display = '';
    if (cardMax) cardMax.style.outline = '2px solid var(--uhome-purple-main)';
    if (cardDec) cardDec.style.outline = '';
  }
  function selectDec() {
    if (cartBlock) cartBlock.style.display = 'none';
    if (cardDec) cardDec.style.outline = '2px solid var(--uhome-purple-main)';
    if (cardMax) cardMax.style.outline = '';
  }

  if (cardDec) cardDec.addEventListener('click', selectDec);
  if (cardMax) cardMax.addEventListener('click', selectMax);
  selectMax(); // Maximum sélectionné par défaut

  // ── FAQ accordion ──
  document.querySelectorAll('.uhome-faq-item').forEach(function(item) {
    item.querySelector('.uhome-faq-q').addEventListener('click', function() {
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.uhome-faq-item').forEach(function(i) { i.classList.remove('open'); });
      if (!isOpen) item.classList.add('open');
    });
  });

  // ── Nav scroll scroll—> sticky ──
  var nav = document.querySelector('.nav, .ub-nav, header');
  if (nav) {
    window.addEventListener('scroll', function() {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });
  }

})();
</script>

