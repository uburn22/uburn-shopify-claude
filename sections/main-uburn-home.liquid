{{- 'uburn-home.css' | asset_url | stylesheet_tag -}}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,700;0,800;0,900;1,700&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,700;0,800;0,900;1,700&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
<link rel="preload" as="image" fetchpriority="high" href="https://uburn.co/cdn/shop/files/focus_product_1_3dab8125-eab7-4b9d-a33f-e28cdd57aa67.jpg?v=1776425406&width=1200&format=webp">

<style>
  main#main, .main-content { padding-top: 0 !important; margin-top: 0 !important; }
  .uhome-root { font-family: 'Red Hat Text', sans-serif; -webkit-font-smoothing: antialiased; }
  .uhome-root h1, .uhome-root h2, .uhome-root h3, .uhome-root h4 {
    font-family: 'Red Hat Display', sans-serif; letter-spacing: -0.02em;
  }
</style>

<div class="uhome-root">

  {%- comment -%} ══ S1 — HERO ══ {%- endcomment -%}
  <section class="uhome-hero" aria-label="UBurn — hero">
    <div class="uhome-hero-bg">
      <img
        src="https://uburn.co/cdn/shop/files/focus_product_1_3dab8125-eab7-4b9d-a33f-e28cdd57aa67.jpg?v=1776425406&width=1200&format=webp"
        {% if request.locale.iso_code == 'en' %}alt="Woman holding a purple UBurn drink — anti-cravings ritual"{% else %}alt="Femme tenant une boisson Uburn violette — {% if request.locale.iso_code == 'en' %}anti-cravings ritual{% else %}rituel anti-{% if request.locale.iso_code == 'en' %}craving{% else %}fringale{% endif %}s{% endif %}"{% endif %}
        loading="eager" decoding="async" fetchpriority="high"
        width="1200" height="800"
      >
    </div>
    <div class="uhome-hero-content">
      <div class="uhome-hero-eyebrow">Glucomannane · {% if request.locale.iso_code == 'en' %}FDA dietary fiber*{% else %}EFSA ID 3120{% endif %}</div>
      <h1 class="uhome-hero-title">{% if request.locale.iso_code == 'en' %}4PM.<br><em>Take back<br>control.</em>{% else %}16h.<br><em>Tu reprends<br>le contrôle.</em>{% endif %}</h1>
      <p class="uhome-hero-sub">{% if request.locale.iso_code == 'en' %}The morning ritual that keeps you going for 4 hours without cracking. 6 natural active ingredients. Caffeine-free. French brand.{% else %}Le rituel matinal qui te tient 4h sans craquer. 6 actifs naturels. 0% caféine. Marque française.{% endif %}</p>
      <div class="uhome-hero-actions">
        <a href="/products/ube-poudre?variant=51289200066879" class="uhome-btn uhome-btn-fill">
          Commander — dès 34,50&nbsp;€
        </a>
        <span class="uhome-hero-note">{% if request.locale.iso_code == 'en' %}Free shipping{% else %}Livraison offerte{% endif %} · {% if request.locale.iso_code == 'en' %}Cancel anytime{% else %}Annulable à tout moment{% endif %}</span>
      </div>
    </div>
    <div class="uhome-hero-trust">
      <div class="uhome-hero-pill">★★★★★ 4,7/5 · 1&nbsp;500+ clientes</div>
      <div class="uhome-hero-pill">{% if request.locale.iso_code == 'en' %}Research-backed*{% else %}Allégation{% endif %} EFSA validée</div>
      <div class="uhome-hero-pill">{% if request.locale.iso_code == 'en' %}Free U.S. shipping on orders $40+{% else %}Livraison offerte en France{% endif %}</div>
    </div>
  </section>

  {%- comment -%} ══ S2 — MARQUEE ══ {%- endcomment -%}
  <div class="uhome-marquee" aria-hidden="true">
    <div class="uhome-marquee-track">
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}FDA dietary fiber*{% else %}EFSA ID 3120{% endif %}</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}Caffeine-free{% else %}0% {% if request.locale.iso_code == 'en' %}Caffeine-free{% else %}{% if request.locale.iso_code == 'en' %}caffeine{% else %}caféine{% endif %}{% endif %}{% endif %}</span>
      <span class="uhome-marquee-item">30 kcal par dose</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}Free shipping{% else %}Livraison offerte{% endif %}</span>
      <span class="uhome-marquee-item">1&nbsp;500+ clientes</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}Cancel anytime{% else %}Annulable à tout moment{% endif %}</span>
      {% if request.locale.iso_code == 'en' %}<span class="uhome-marquee-item">Lasting 4-hour satiety*</span>{% else %}<span class="uhome-marquee-item">Satiété durable 4h</span>{% endif %}
      <span class="uhome-marquee-item">6 actifs naturels</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}French brand{% else %}Marque française{% endif %}</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}FDA dietary fiber*{% else %}EFSA ID 3120{% endif %}</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}Caffeine-free{% else %}0% {% if request.locale.iso_code == 'en' %}Caffeine-free{% else %}{% if request.locale.iso_code == 'en' %}caffeine{% else %}caféine{% endif %}{% endif %}{% endif %}</span>
      <span class="uhome-marquee-item">30 kcal par dose</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}Free shipping{% else %}Livraison offerte{% endif %}</span>
      <span class="uhome-marquee-item">1&nbsp;500+ clientes</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}Cancel anytime{% else %}Annulable à tout moment{% endif %}</span>
      {% if request.locale.iso_code == 'en' %}<span class="uhome-marquee-item">Lasting 4-hour satiety*</span>{% else %}<span class="uhome-marquee-item">Satiété durable 4h</span>{% endif %}
      <span class="uhome-marquee-item">6 actifs naturels</span>
      <span class="uhome-marquee-item">{% if request.locale.iso_code == 'en' %}French brand{% else %}Marque française{% endif %}</span>
    </div>
  </div>

  {%- comment -%} ══ S3 — PRESS ══ {%- endcomment -%}
  <div class="uhome-press uhome-reveal">
    <span class="uhome-press-label">{% if request.locale.iso_code == 'en' %}As seen in{% else %}Ils parlent de nous{% endif %}</span>
    <div class="uhome-press-logos">
      <div class="uhome-press-logo"><img src="https://uburn.co/cdn/shop/files/TF1_1989-1990.png?v=1749644803&width=150&format=webp" alt="TF1" loading="lazy"></div>
      <div class="uhome-press-logo"><img src="https://uburn.co/cdn/shop/files/Brut_logo_svg.png?v=1749644803&width=150&format=webp" alt="Brut" loading="lazy"></div>
      <div class="uhome-press-logo"><img src="https://uburn.co/cdn/shop/files/logo-femmeactuelle-copie_cb5c498d-5470-4a4d-83fc-7b16c264a030.png?v=1749644803&width=150&format=webp" alt="Femme Actuelle" loading="lazy"></div>
      <div class="uhome-press-logo"><img src="https://uburn.co/cdn/shop/files/VOGUE_revista_-_logo.png?v=1749644803&width=150&format=webp" alt="Vogue" loading="lazy"></div>
      <div class="uhome-press-logo"><img src="https://uburn.co/cdn/shop/files/ELLE_Magazine_Logo.svg" alt="Elle" style="height:18px;width:auto;opacity:0.4;filter:grayscale(1)" loading="lazy"></div>
    </div>
  </div>

  {%- comment -%} ══ S4 — EXPERT ══ {%- endcomment -%}
  <section class="uhome-expert">
    <div class="uhome-expert-card uhome-reveal">
      <div class="uhome-expert-img">
        <img
          src="https://uburn.co/cdn/shop/files/Gemini_Generated_Image_gjm16fgjm16fgjm1.png?v=1776424158&width=800"
          alt="Dr. Claire Dubois — Nutritionniste"
          loading="lazy" decoding="async" width="800" height="800"
        >
      </div>
      <div>
        <p class="uhome-expert-quote">« Une formule rare : la science du konjac au service du quotidien des femmes. »</p>
        <div class="uhome-expert-body">
          {% if request.locale.iso_code == 'en' %}The UBurn formula combines research-backed glucomannan with 5 synergistic actives, each scientifically formulated for a level of support rarely found in a single drink. Designed for real life.*{% else %}La formule UBurn combine glucomannane validé EFSA et 5 actifs synergiques, chacun dosé cliniquement pour un niveau de soutien rarement atteint dans une seule boisson. Pensée pour la vraie vie.{% endif %}
        </div>
        <div class="uhome-expert-name">Dr. Claire Dubois</div>
        {% if request.locale.iso_code == 'en' %}<div class="uhome-expert-creds">Nutritionist · Food behavior specialist</div>{% else %}<div class="uhome-expert-creds">Nutritionniste · Spécialiste comportement alimentaire</div>{% endif %}
        <a href="#uhome-offer" class="uhome-expert-link">Membre du Comité Scientifique UBurn →</a>
      </div>
    </div>
  </section>

  {%- comment -%} ══ S5 — LE RITUEL ══ {%- endcomment -%}
  <section class="uhome-rituel">
    <div class="uhome-rituel-inner">
      <div class="uhome-rituel-head uhome-reveal">
        <span class="uhome-section-label">{% if request.locale.iso_code == 'en' %}2 minutes in the morning{% else %}2 minutes {% if request.locale.iso_code == 'en' %}in the morning{% else %}le matin{% endif %}{% endif %}</span>
        <h2 class="uhome-section-title">{% if request.locale.iso_code == 'en' %}The <span class="uhome-accent">UBurn</span> ritual.{% else %}Le rituel <span class="uhome-accent">Uburn.</span>{% endif %}</h2>
        <p class="uhome-rituel-desc">« {% if request.locale.iso_code == 'en' %}In the morning{% else %}Le matin{% endif %}, tu prends 2 minutes pour toi. Tu mesures, tu mélanges, tu profites. C'est tout. »</p>
      </div>
      <div class="uhome-rituel-steps uhome-stagger">
        <div class="uhome-rituel-step">
          <div class="uhome-rituel-step-img">
            <img src="https://uburn.co/cdn/shop/files/etape_1.jpg?v=1763147054&width=1200&format=webp" srcset="https://uburn.co/cdn/shop/files/etape_1.jpg?v=1763147054&width=600&format=webp 600w, https://uburn.co/cdn/shop/files/etape_1.jpg?v=1763147054&width=900&format=webp 900w, https://uburn.co/cdn/shop/files/etape_1.jpg?v=1763147054&width=1200&format=webp 1200w" sizes="(min-width:900px) 33vw, 100vw" {% if request.locale.iso_code == 'en' %}alt="UBURN measure — 1 scoop of purple powder in the shaker"{% else %}alt="Mesure UBURN — 1 cuillère de poudre violette dans le shaker"{% endif %} loading="lazy" decoding="async" width="1200" height="1200">
          </div>
          <div class="uhome-rituel-step-num">1</div>
          {% if request.locale.iso_code == 'en' %}<div class="uhome-rituel-step-title">Measure</div>{% else %}<div class="uhome-rituel-step-title">Mesure</div>{% endif %}
          {% if request.locale.iso_code == 'en' %}<div class="uhome-rituel-step-desc">1 scoop (5 g) in your shaker. Simple, precise, no math.</div>{% else %}<div class="uhome-rituel-step-desc">1 cuillère (5 g) dans ton shaker. Simple, précis, sans calculs.</div>{% endif %}
        </div>
        <div class="uhome-rituel-step">
          <div class="uhome-rituel-step-img">
            <img src="https://uburn.co/cdn/shop/files/etape_2.jpg?v=1763147054&width=1200&format=webp" srcset="https://uburn.co/cdn/shop/files/etape_2.jpg?v=1763147054&width=600&format=webp 600w, https://uburn.co/cdn/shop/files/etape_2.jpg?v=1763147054&width=900&format=webp 900w, https://uburn.co/cdn/shop/files/etape_2.jpg?v=1763147054&width=1200&format=webp 1200w" sizes="(min-width:900px) 33vw, 100vw" alt="Mélange UBURN avec eau, lait végétal ou lait de coco" loading="lazy" decoding="async" width="1200" height="1200">
          </div>
          <div class="uhome-rituel-step-num">2</div>
          {% if request.locale.iso_code == 'en' %}<div class="uhome-rituel-step-title">Mix</div>{% else %}<div class="uhome-rituel-step-title">Mélange</div>{% endif %}
          <div class="uhome-rituel-step-desc">Eau froide, lait végétal ou lait de coco. Secoue 15 secondes.</div>
        </div>
        <div class="uhome-rituel-step">
          <div class="uhome-rituel-step-img">
            <img src="https://uburn.co/cdn/shop/files/etape_3.jpg?v=1763147054&width=1200&format=webp" srcset="https://uburn.co/cdn/shop/files/etape_3.jpg?v=1763147054&width=600&format=webp 600w, https://uburn.co/cdn/shop/files/etape_3.jpg?v=1763147054&width=900&format=webp 900w, https://uburn.co/cdn/shop/files/etape_3.jpg?v=1763147054&width=1200&format=webp 1200w" sizes="(min-width:900px) 33vw, 100vw" {% if request.locale.iso_code == 'en' %}alt="Sipping the purple UBURN latte — ube flavor, 4-hour satiety*"{% else %}alt="Dégustation du latte violet UBURN — saveur ubé, satiété {% if request.locale.iso_code == 'en' %}4 hours{% else %}4 heures{% endif %}"{% endif %} loading="lazy" decoding="async" width="1200" height="1200">
          </div>
          <div class="uhome-rituel-step-num">3</div>
          {% if request.locale.iso_code == 'en' %}<div class="uhome-rituel-step-title">Sip</div>{% else %}<div class="uhome-rituel-step-title">Dégustation</div>{% endif %}
          {% if request.locale.iso_code == 'en' %}<div class="uhome-rituel-step-desc">Smooth ube flavor. Cravings fade for 4 hours.*</div>{% else %}<div class="uhome-rituel-step-desc">Saveur douce de l'ubé. Les {% if request.locale.iso_code == 'en' %}craving{% else %}fringale{% endif %}s s'effacent pour {% if request.locale.iso_code == 'en' %}4 hours{% else %}4 heures{% endif %}.</div>{% endif %}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ══ S6 — PROBLÈME ══ {%- endcomment -%}
  <section class="uhome-problem">
    <div class="uhome-problem-inner uhome-reveal">
      <span class="uhome-section-label">{% if request.locale.iso_code == 'en' %}It's not a willpower problem{% else %}Ce n'est pas un manque de volonté{% endif %}</span>
      <h2 class="uhome-section-title">C'est <span class="uhome-accent">biologique.</span></h2>
      <div class="uhome-prob-cards uhome-stagger-scale">
        <div class="uhome-prob-card">
          <div class="uhome-prob-num">16h</div>
          <div class="uhome-prob-title">{% if request.locale.iso_code == 'en' %}The pantry calls you{% else %}Le placard vous appelle{% endif %}</div>
          {% if request.locale.iso_code == 'en' %}<div class="uhome-prob-sub">Blood sugar crashing. It's physiology — not a character flaw.</div>{% else %}<div class="uhome-prob-sub">Glycémie en chute libre. C'est physiologique — pas un défaut de caractère.</div>{% endif %}
        </div>
        <div class="uhome-prob-card">
          <div class="uhome-prob-num">Soir</div>
          <div class="uhome-prob-title">{% if request.locale.iso_code == 'en' %}In front of the fridge{% else %}Devant le frigo{% endif %}</div>
          <div class="uhome-prob-sub">{% if request.locale.iso_code == 'en' %}Fatigue lowers your guard. Morning intentions fade one by one.{% else %}La fatigue baisse la garde. Les bonnes intentions du matin s'effacent une par une.{% endif %}</div>
        </div>
        <div class="uhome-prob-card">
          <div class="uhome-prob-num">→</div>
          <div class="uhome-prob-title">{% if request.locale.iso_code == 'en' %}Willpower isn't enough{% else %}La volonté ne suffit pas{% endif %}</div>
          {% if request.locale.iso_code == 'en' %}<div class="uhome-prob-sub">It's a biological response. It calls for a biological answer.</div>{% else %}<div class="uhome-prob-sub">C'est une réponse biologique. Elle demande une réponse biologique.</div>{% endif %}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ══ S7 — OFFRE / PRIX ══ {%- endcomment -%}
  <section class="uhome-offer" id="uhome-offer">
    <div class="uhome-offer-inner">
      <div class="uhome-offer-header uhome-reveal">
        <span class="uhome-section-label">{% if request.locale.iso_code == 'en' %}Your offer{% else %}Votre offre{% endif %}</span>
        <h2 class="uhome-section-title">{% if request.locale.iso_code == 'en' %}One flavor. <span class="uhome-accent">Six actives.</span>{% else %}Une saveur. <span class="uhome-accent">Six actifs.</span>{% endif %}</h2>
        <p style="max-width:400px;margin:10px auto 0;color:var(--uhome-body);font-size:14px;text-align:center;font-family:'Red Hat Text',sans-serif">
          {% if request.locale.iso_code == 'en' %}One-time payment · Free U.S. shipping on $40+{% else %}Paiement unique · Livraison offerte en France{% endif %}
        </p>
      </div>
      <div class="uhome-offer-img uhome-reveal uhome-rd1">
        <img
          src="https://uburn.co/cdn/shop/files/Uburn_Listing_ecom_1.jpg?v=1772700007&width=800"
          alt="UBurn Ube Poudre — pack produit"
          loading="lazy" decoding="async" width="800" height="1000"
