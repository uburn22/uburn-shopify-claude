      </div>
      <div class="uhome-pricing-grid uhome-reveal uhome-rd2">
        <div class="uhome-pricing-card" id="uhome-card-dec">
          {% if request.locale.iso_code == 'en' %}<h3>Starter</h3>{% else %}<h3>{% if request.locale.iso_code == 'en' %}Starter{% else %}Découverte{% endif %}</h3>{% endif %}
          <p class="uhome-pricing-desc">{% if request.locale.iso_code == 'en' %}Perfect to try · 90g · 1 dose/day{% else %}Idéal pour tester · 90g · 1 dose/jour{% endif %}</p>
          <div class="uhome-pricing-price">34,50&nbsp;€</div>
          <p class="uhome-pricing-per">soit 1,15&nbsp;€/jour</p>
          <p class="uhome-pricing-dur">30 jours · 1 dose/jour</p>
          <a href="/products/ube-poudre?variant=51289200034111" class="uhome-btn uhome-btn-fill" style="width:100%;justify-content:center">
            Commander →
          </a>
        </div>
        <div class="uhome-pricing-card uhome-pop" id="uhome-card-max">
          <div class="uhome-pop-badge">{% if request.locale.iso_code == 'en' %}Best value{% else %}Meilleure valeur{% endif %}</div>
          {% if request.locale.iso_code == 'en' %}<h3>Maximum Pack</h3>{% else %}<h3>{% if request.locale.iso_code == 'en' %}Maximum Pack{% else %}Résultats Maximum{% endif %}</h3>{% endif %}
          <p class="uhome-pricing-desc">{% if request.locale.iso_code == 'en' %}Best Value{% else %}Le + populaire{% endif %} — 3× plus de résultats</p>
          <div class="uhome-pricing-price">54,50&nbsp;€ <small><s>69&nbsp;€</s></small></div>
          <p class="uhome-pricing-per">= 0,61&nbsp;€/jour</p>
          <p class="uhome-pricing-dur">90 jours · 3 doses/jour</p>
          <a href="/products/ube-poudre?variant=51289200066879" class="uhome-btn uhome-btn-fill" style="width:100%;justify-content:center">
            Commander →
          </a>
        </div>
      </div>
      <div class="uhome-cart-block uhome-reveal uhome-rd3" id="uhome-cart-block">
        <div class="uhome-cart-block-head">
          <span class="uhome-section-label" style="text-align:center;display:block">{% if request.locale.iso_code == 'en' %}Your order{% else %}Votre commande{% endif %}</span>
          <h2 class="uhome-section-title" style="text-align:center">{% if request.locale.iso_code == 'en' %}With your{% else %}Avec votre{% endif %} Cure Maximum, <span class="uhome-accent">vous recevez :</span></h2>
        </div>
        <div class="uhome-cart-preview">
          <div class="uhome-cart-title">{% if request.locale.iso_code == 'en' %}Your cart{% else %}Votre panier{% endif %}</div>
          <div class="uhome-cart-item">
            <div class="uhome-cart-thumb">
              <img src="https://uburn.co/cdn/shop/files/PRODUCT_PAGE_0005_2_1.jpg?v=1749644803&width=200&format=webp" alt="UBurn Cure Maximum 270g" loading="lazy" width="200" height="200">
            </div>
            <div class="uhome-cart-body">
              <div class="uhome-cart-name">{% if request.locale.iso_code == 'en' %}Maximum Pack — Ube Powder 270g{% else %}Cure Maximum — Poudre Ubé 270g{% endif %}</div>
              <div class="uhome-cart-meta">{% if request.locale.iso_code == 'en' %}Hazelnut-vanilla flavor · 90-day pack{% else %}Saveur noisette-vanille · Cure 90 jours{% endif %}</div>
            </div>
            <div class="uhome-cart-price">54,50&nbsp;€</div>
          </div>
          <div class="uhome-cart-item">
            <div class="uhome-cart-thumb"><span class="uhome-cart-thumb-letter">E</span></div>
            <div class="uhome-cart-body">
              <div class="uhome-cart-name">{% if request.locale.iso_code == 'en' %}E-book "30 days to take back control"{% else %}E-book « 30j pour reprendre le contrôle »{% endif %}</div>
              <span class="uhome-gift-tag">Offert</span>
            </div>
            <div class="uhome-cart-price"><s>47&nbsp;€</s> 0&nbsp;€</div>
          </div>
          <div class="uhome-cart-item">
            <div class="uhome-cart-thumb"><span class="uhome-cart-thumb-letter">G</span></div>
            <div class="uhome-cart-body">
              <div class="uhome-cart-name">Groupe privé Uburn Collective</div>
              <span class="uhome-gift-tag">Offert</span>
            </div>
            <div class="uhome-cart-price"><s>40&nbsp;€</s> 0&nbsp;€</div>
          </div>
          <div class="uhome-cart-item">
            <div class="uhome-cart-thumb"><span class="uhome-cart-thumb-letter">W</span></div>
            <div class="uhome-cart-body">
              <div class="uhome-cart-name">Suivi nutrition WhatsApp 30j</div>
              <span class="uhome-gift-tag">Offert</span>
            </div>
            <div class="uhome-cart-price"><s>47&nbsp;€</s> 0&nbsp;€</div>
          </div>
          <div class="uhome-cart-sub">
            <div class="uhome-cart-sub-row save">{% if request.locale.iso_code == 'en' %}<span>Total savings</span>{% else %}<span>Économies totales</span>{% endif %}<span>−184&nbsp;€</span></div>
            <div class="uhome-cart-sub-row total"><span>Total</span><span>54,50&nbsp;€</span></div>
            <div class="uhome-cart-sub-note">soit 0,61&nbsp;€/jour sur 90 jours</div>
          </div>
          <p class="uhome-cart-rating">★★★★★ 4,7/5 · 1&nbsp;500+ clientes satisfaites</p>
          <a href="/products/ube-poudre?variant=51289200066879" class="uhome-cart-cta">
