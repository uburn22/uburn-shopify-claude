<script>
/* ── Add to cart ── */
async function addAndCheckout(handle, vi) {
  vi = vi || 0;
  try {
    var r = await fetch('/products/' + handle + '.js');
    var p = await r.json();
    var vid = p.variants[vi] ? p.variants[vi].id : p.variants[0].id;
    var res = await fetch('/cart/add.js', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:vid,quantity:1})});
    if(res.ok) window.location.href = '/checkout';
    else window.location.href = '/products/' + handle;
  } catch(e) { window.location.href = '/products/' + handle; }
}

/* ── Sticky bar ── */
(function(){
  var s = document.getElementById('ulp-sticky');
  if (!s) return;
  window.addEventListener('scroll', function() {
    s.classList.toggle('ulp-sticky--visible', (window.scrollY||window.pageYOffset) > 400);
  }, { passive: true });
})();

/* ── Countdown ── */
(function(){
  var el = document.getElementById('ulp-countdown');
  if(!el) return;
  var end = new Date(Date.now() + 24*3600*1000);
  (function tick(){
    var d = Math.max(0, end - new Date());
    el.textContent = [Math.floor(d/3600000),Math.floor(d%3600000/60000),Math.floor(d%60000/1000)].map(function(n){return String(n).padStart(2,'0')}).join(':');
    if(d>0) setTimeout(tick,1000);
  })();
})();

/* ── IntersectionObserver factory ── */
function observe(el, cb, opts) {
  if (!el || !window.IntersectionObserver) return;
  new IntersectionObserver(function(entries, io) {
    entries.forEach(function(e) { if(e.isIntersecting){ cb(el); io.unobserve(el); } });
  }, opts || { threshold: 0.12 }).observe(el);
}

/* ── Scroll reveal ── */
document.querySelectorAll('.ulp-reveal').forEach(function(el){
  observe(el, function(t){ t.classList.add('is-visible'); });
});

/* ── Stagger groups (features, ingredients, steps, stats) ── */
['ulp-features','ulp-ingredients','ulp-steps','ulp-stats'].forEach(function(id){
  var el = document.getElementById(id);
  observe(el, function(t){ t.classList.add('is-visible'); });
});

/* ── Count-up for stats ── */
(function(){
  var stats = document.getElementById('ulp-stats');
  if(!stats) return;
  observe(stats, function(){
    stats.querySelectorAll('[data-count]').forEach(function(el){
      var target = parseInt(el.dataset.count, 10);
      var suffix = el.dataset.suffix || '';
      var start = Date.now();
      var duration = 900;
      (function frame(){
        var progress = Math.min(1, (Date.now()-start)/duration);
        var eased = 1 - Math.pow(1-progress, 3);
        el.textContent = Math.round(eased * target) + suffix;
        if(progress < 1) requestAnimationFrame(frame);
      })();
    });
  }, { threshold: 0.3 });
})();
</script>

</div>

