<script>
async function addAndCheckout(handle, variantIndex) {
  variantIndex = variantIndex || 0;
  try {
    var r = await fetch('/products/' + handle + '.js');
    var p = await r.json();
    var vid = p.variants[variantIndex] ? p.variants[variantIndex].id : p.variants[0].id;
    var res = await fetch('/cart/add.js', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:vid,quantity:1})});
    if(res.ok) window.location.href = '/checkout';
    else window.location.href = '/products/' + handle;
  } catch(e) { window.location.href = '/products/' + handle; }
}

(function(){
  var s = document.getElementById('ulp-sticky');
  if (!s) return;
  var v = false;
  window.addEventListener('scroll', function() {
    var y = window.scrollY || window.pageYOffset;
    if (y > 500 && !v) { s.classList.add('ulp-sticky--visible'); v = true; }
    else if (y <= 500 && v) { s.classList.remove('ulp-sticky--visible'); v = false; }
  }, { passive: true });
})();
</script>

