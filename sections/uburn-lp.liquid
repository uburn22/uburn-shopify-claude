{{ 'uburn-lp.css' | asset_url | stylesheet_tag }}

<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap');

:root {
  --ub-bg: #FAFAF8;
  --ub-white: #FFFFFF;
  --ub-black: #111111;
  --ub-violet: #8B5CF6;
  --ub-violet-dark: #7C3AED;
  --ub-violet-deeper: #6D28D9;
  --ub-violet-light: #EDE9FE;
  --ub-violet-bg: #F5F3FF;
  --ub-gradient: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 50%, #5B21B6 100%);
  --ub-gradient-soft: linear-gradient(135deg, #A78BFA 0%, #8B5CF6 100%);
  --ub-gray: #6B7280;
  --ub-gray-light: #F4F4F5;
  --ub-gold: #D4A853;
  --ub-green: #059669;
  --ub-red: #DC2626;
  --ub-heading: 'Montserrat', sans-serif;
  --ub-body: 'DM Sans', sans-serif;
  --ub-ease: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  --ub-radius: 16px;
  --ub-shadow: 0 8px 30px rgba(139, 92, 246, 0.08);
  --ub-shadow-lg: 0 20px 60px rgba(139, 92, 246, 0.12);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.ulp { font-family: var(--ub-body); color: var(--ub-black); background: var(--ub-bg); -webkit-font-smoothing: antialiased; line-height: 1.65; }
.ulp img { max-width: 100%; height: auto; display: block; }
.ulp a { text-decoration: none; color: inherit; }

/* ===== KEYFRAMES ===== */
@keyframes ub-float    { 0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-12px) scale(1.01);} }
@keyframes ub-pulse    { 0%,100%{box-shadow:0 4px 20px rgba(139,92,246,0.35);}50%{box-shadow:0 10px 44px rgba(139,92,246,0.62);} }
@keyframes ub-shimmer  { 0%,100%{box-shadow:0 0 0 0 rgba(139,92,246,0);}50%{box-shadow:0 0 0 7px rgba(139,92,246,0.12);} }
@keyframes ub-orb      { 0%,100%{transform:scale(1) translate(0,0);}50%{transform:scale(1.35) translate(-8%,6%);} }
@keyframes ub-ticker   { 0%{transform:translateX(0);}100%{transform:translateX(-50%);} }
@keyframes ub-faq-open { from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:translateY(0);} }
@keyframes ub-count-in { from{opacity:0;transform:scale(0.7);}to{opacity:1;transform:scale(1);} }

/* ===== SCROLL REVEAL ===== */
.ulp-reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
.ulp-reveal.is-visible { opacity: 1; transform: translateY(0); }

/* ===== HEADER ===== */
.ulp-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; background: rgba(255,255,255,0.92); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.04); position: sticky; top: 0; z-index: 100; }
.ulp-header__logo img { height: 28px; width: auto; }
.ulp-header__cart { font-size: 20px; opacity: 0.4; transition: var(--ub-ease); }
.ulp-header__cart:hover { opacity: 1; }

/* ===== HERO ===== */
.ulp-hero { background: var(--ub-white); padding: 52px 20px 44px; text-align: left; position: relative; overflow: hidden; }
.ulp-hero::before { content: ''; position: absolute; top: -50%; right: -30%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(139,92,246,0.07) 0%, transparent 70%); border-radius: 50%; pointer-events: none; animation: ub-orb 9s ease-in-out infinite; }
.ulp-hero__inner { max-width: 520px; margin: 0 auto; position: relative; z-index: 1; }
.ulp-hero__badge { display: inline-block; background: var(--ub-gradient); color: var(--ub-white); font-family: var(--ub-heading); font-size: 0.68rem; font-weight: 700; padding: 7px 16px; border-radius: 100px; margin-bottom: 22px; letter-spacing: 0.8px; text-transform: uppercase; animation: ub-shimmer 2.8s ease-in-out infinite; }
.ulp-hero h1 { font-family: var(--ub-heading); font-size: 2.5rem; font-weight: 900; line-height: 1.06; letter-spacing: -0.035em; margin: 0 0 18px; color: var(--ub-black); }
.ulp-hero h1 span { background: var(--ub-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ulp-hero__sub { font-size: 1rem; color: var(--ub-gray); line-height: 1.6; margin: 0 0 28px; max-width: 360px; }
.ulp-hero__cta-row { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
.ulp-hero__micro { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; font-size: 0.78rem; color: var(--ub-gray); }
.ulp-hero__micro span { display: flex; align-items: center; gap: 4px; }
.ulp-hero__product { text-align: center; margin: 32px 0 0; }
.ulp-hero__product img { max-width: 220px; margin: 0 auto; border-radius: 20px; box-shadow: var(--ub-shadow-lg); animation: ub-float 5s ease-in-out infinite; }
.ulp-hero__product img:hover { animation-play-state: paused; transform: scale(1.04) rotate(0.5deg); }

/* ===== BUTTONS ===== */
.ulp-btn { display: block; text-align: center; padding: 17px 32px; border-radius: 12px; font-family: var(--ub-heading); font-size: 0.95rem; font-weight: 700; text-decoration: none; cursor: pointer; border: none; width: 100%; box-sizing: border-box; transition: var(--ub-ease); letter-spacing: 0.2px; position: relative; overflow: hidden; }
.ulp-btn:hover { transform: translateY(-2px); }
.ulp-btn:active { transform: translateY(0); }
.ulp-btn--gradient { background: var(--ub-gradient); color: var(--ub-white); animation: ub-pulse 2.5s ease-in-out infinite; }
.ulp-btn--gradient:hover { animation-play-state: paused; box-shadow: 0 10px 36px rgba(139,92,246,0.5); }
.ulp-btn--outline { background: transparent; color: var(--ub-violet); border: 2px solid var(--ub-violet); }
.ulp-btn--outline:hover { background: var(--ub-violet-light); }
.ulp-btn--large { padding: 19px 40px; font-size: 1.05rem; }
.ulp-btn--white { background: var(--ub-white); color: var(--ub-violet-deeper); box-shadow: 0 4px 20px rgba(0,0,0,0.15); }

/* ===== TRUST TICKER ===== */
.ulp-ticker { background: var(--ub-gradient); overflow: hidden; white-space: nowrap; padding: 13px 0; }
.ulp-ticker__track { display: inline-flex; animation: ub-ticker 25s linear infinite; }
.ulp-ticker__item { color: rgba(255,255,255,0.92); font-family: var(--ub-heading); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 0 36px; }

/* ===== SECTIONS ===== */
.ulp-section { padding: 64px 20px; max-width: 620px; margin: 0 auto; }
.ulp-section h2 { font-family: var(--ub-heading); font-size: 1.9rem; font-weight: 800; letter-spacing: -0.03em; margin: 0 0 12px; line-height: 1.1; color: var(--ub-black); }
.ulp-section h2 span { background: var(--ub-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ulp-section__sub { font-size: 1rem; color: var(--ub-gray); margin: 0 0 36px; line-height: 1.5; }
.ulp-section--alt { background: var(--ub-violet-bg); }
.ulp-section--white { background: var(--ub-white); }
.ulp-section--dark { background: var(--ub-black); color: var(--ub-white); }

/* ===== BEFORE / AFTER ===== */
.ulp-ba { display: grid; grid-template-columns: 1fr; gap: 0; border-radius: var(--ub-radius); overflow: hidden; margin-bottom: 32px; }
@media (min-width: 500px) { .ulp-ba { grid-template-columns: 1fr 1fr; } }
.ulp-ba__before { background: #1E1B2E; color: #C4B5FD; padding: 32px 24px; opacity: 0; transform: translateX(-24px); transition: opacity 0.6s ease 0.15s, transform 0.6s ease 0.15s; }
.ulp-ba__after  { background: var(--ub-gradient); color: var(--ub-white); padding: 32px 24px; opacity: 0; transform: translateX(24px); transition: opacity 0.6s ease 0.3s, transform 0.6s ease 0.3s; }
.ulp-reveal.is-visible .ulp-ba__before,
.ulp-reveal.is-visible .ulp-ba__after { opacity: 1; transform: translateX(0); }
.ulp-ba h3 { font-family: var(--ub-heading); font-size: 1.05rem; font-weight: 800; margin-bottom: 14px; }
.ulp-ba__before h3 { color: #A78BFA; }
.ulp-ba ul { list-style: none; font-size: 0.9rem; line-height: 2.2; }
.ulp-ba__before li::before { content: "✗ "; color: #EF4444; font-weight: 700; }
.ulp-ba__after li::before { content: "✓ "; font-weight: 700; }

/* ===== FEATURE LIST ===== */
.ulp-features { display: flex; flex-direction: column; gap: 10px; margin: 0 0 36px; }
.ulp-feature { display: flex; align-items: center; gap: 16px; padding: 14px 18px; background: var(--ub-white); border-radius: 14px; border: 1px solid rgba(0,0,0,0.04); transition: var(--ub-ease); opacity: 0; transform: translateY(14px); }
.ulp-features.is-visible .ulp-feature { opacity: 1; transform: translateY(0); }
.ulp-features.is-visible .ulp-feature:nth-child(1){transition-delay:0s;}
.ulp-features.is-visible .ulp-feature:nth-child(2){transition-delay:0.08s;}
.ulp-features.is-visible .ulp-feature:nth-child(3){transition-delay:0.16s;}
.ulp-features.is-visible .ulp-feature:nth-child(4){transition-delay:0.24s;}
.ulp-features.is-visible .ulp-feature:nth-child(5){transition-delay:0.32s;}
.ulp-feature:hover { border-color: var(--ub-violet-light); box-shadow: var(--ub-shadow); transform: translateY(-2px) !important; }
.ulp-feature__icon { font-size: 1.3rem; flex-shrink: 0; width: 46px; height: 46px; background: var(--ub-violet-light); border-radius: 13px; display: flex; align-items: center; justify-content: center; }
.ulp-feature__text { font-size: 0.95rem; font-weight: 600; color: var(--ub-black); }
.ulp-feature__text small { display: block; font-size: 0.78rem; font-weight: 400; color: var(--ub-gray); margin-top: 2px; }

/* ===== INGREDIENTS GRID ===== */
.ulp-ingredients { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
@media (min-width: 500px) { .ulp-ingredients { grid-template-columns: repeat(3, 1fr); } }
.ulp-ingredient { background: var(--ub-white); border: 1px solid rgba(0,0,0,0.04); border-radius: 14px; padding: 20px 14px; text-align: center; transition: var(--ub-ease); opacity: 0; transform: scale(0.88) translateY(10px); }
.ulp-ingredients.is-visible .ulp-ingredient { opacity: 1; transform: scale(1) translateY(0); }
.ulp-ingredients.is-visible .ulp-ingredient:nth-child(1){transition-delay:0s;}
.ulp-ingredients.is-visible .ulp-ingredient:nth-child(2){transition-delay:0.07s;}
.ulp-ingredients.is-visible .ulp-ingredient:nth-child(3){transition-delay:0.14s;}
.ulp-ingredients.is-visible .ulp-ingredient:nth-child(4){transition-delay:0.21s;}
.ulp-ingredients.is-visible .ulp-ingredient:nth-child(5){transition-delay:0.28s;}
.ulp-ingredients.is-visible .ulp-ingredient:nth-child(6){transition-delay:0.35s;}
.ulp-ingredient:hover { box-shadow: var(--ub-shadow); transform: translateY(-3px) scale(1.02) !important; }
.ulp-ingredient__img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; margin: 0 auto 10px; border: 2px solid var(--ub-violet-light); }
.ulp-ingredient__name { font-family: var(--ub-heading); font-size: 0.8rem; font-weight: 700; margin-bottom: 3px; }
.ulp-ingredient__desc { font-size: 0.7rem; color: var(--ub-gray); line-height: 1.35; }

/* ===== STEPS ===== */
.ulp-steps { display: flex; flex-direction: column; gap: 0; margin-bottom: 36px; position: relative; }
.ulp-steps::before { content: ''; position: absolute; left: 23px; top: 44px; bottom: 44px; width: 2px; background: var(--ub-violet-light); z-index: 0; }
.ulp-step { display: flex; align-items: flex-start; gap: 18px; padding: 16px 0; position: relative; z-index: 1; }
.ulp-step__num { background: var(--ub-gradient); color: var(--ub-white); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--ub-heading); font-weight: 800; font-size: 1.1rem; flex-shrink: 0; box-shadow: 0 4px 12px rgba(139,92,246,0.25); }
.ulp-step__content { padding-top: 4px; }
.ulp-step__content strong { display: block; font-family: var(--ub-heading); font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
.ulp-step__content p { margin: 0; font-size: 0.88rem; color: var(--ub-gray); line-height: 1.5; }

/* ===== PHOTO STEPS ===== */
.ulp-photo-steps { display: grid; grid-template-columns: 1fr; gap: 24px; margin-bottom: 36px; }
@media (min-width: 500px) { .ulp-photo-steps { grid-template-columns: repeat(3, 1fr); } }
.ulp-photo-step { text-align: center; opacity: 0; transform: translateY(22px); transition: opacity 0.5s ease, transform 0.5s ease; }
.ulp-photo-steps.is-visible .ulp-photo-step:nth-child(1){opacity:1;transform:none;transition-delay:0s;}
.ulp-photo-steps.is-visible .ulp-photo-step:nth-child(2){opacity:1;transform:none;transition-delay:0.14s;}
.ulp-photo-steps.is-visible .ulp-photo-step:nth-child(3){opacity:1;transform:none;transition-delay:0.28s;}
.ulp-photo-step__img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: var(--ub-radius); margin-bottom: 14px; box-shadow: var(--ub-shadow); transition: transform 0.4s ease; }
.ulp-photo-step__img:hover { transform: scale(1.03); }
.ulp-photo-step__num { font-family: var(--ub-heading); font-size: 0.68rem; font-weight: 700; color: var(--ub-violet); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 5px; }
.ulp-photo-step__title { font-family: var(--ub-heading); font-size: 0.95rem; font-weight: 700; margin-bottom: 3px; }
.ulp-photo-step__text { font-size: 0.82rem; color: var(--ub-gray); line-height: 1.45; }

/* ===== TESTIMONIALS ===== */
.ulp-testimonials-scroll { display: flex; gap: 14px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding: 4px 20px 20px; margin: 0 -20px; scrollbar-width: none; }
.ulp-testimonials-scroll::-webkit-scrollbar { display: none; }
.ulp-tcard { min-width: 260px; max-width: 280px; scroll-snap-align: start; background: var(--ub-white); border: 1px solid rgba(0,0,0,0.04); border-radius: var(--ub-radius); padding: 22px; flex-shrink: 0; transition: var(--ub-ease); }
.ulp-tcard:hover { box-shadow: var(--ub-shadow); transform: translateY(-3px); }
.ulp-tcard__stars { color: var(--ub-gold); font-size: 0.82rem; margin-bottom: 12px; letter-spacing: 2px; }
.ulp-tcard__text { font-size: 0.9rem; line-height: 1.6; color: var(--ub-black); font-style: italic; margin: 0 0 14px; }
.ulp-tcard__author { font-family: var(--ub-heading); font-size: 0.75rem; font-weight: 700; color: var(--ub-violet); }

/* ===== STAT COUNTER ===== */
.ulp-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 36px; }
.ulp-stat { text-align: center; padding: 20px 12px; background: var(--ub-white); border-radius: 14px; border: 1px solid rgba(0,0,0,0.04); opacity: 0; transform: scale(0.8); transition: opacity 0.45s ease, transform 0.45s ease; }
.ulp-stats.is-visible .ulp-stat:nth-child(1){opacity:1;transform:scale(1);transition-delay:0s;}
.ulp-stats.is-visible .ulp-stat:nth-child(2){opacity:1;transform:scale(1);transition-delay:0.1s;}
.ulp-stats.is-visible .ulp-stat:nth-child(3){opacity:1;transform:scale(1);transition-delay:0.2s;}
.ulp-stat__num { font-family: var(--ub-heading); font-size: 1.6rem; font-weight: 900; background: var(--ub-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ulp-stat__label { font-size: 0.7rem; color: var(--ub-gray); margin-top: 4px; }

/* ===== OFFER ===== */
.ulp-offers { display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }
.ulp-offer-card { border: 2px solid rgba(0,0,0,0.06); border-radius: var(--ub-radius); padding: 28px 24px; position: relative; background: var(--ub-white); transition: var(--ub-ease); }
.ulp-offer-card:hover { border-color: var(--ub-violet-light); transform: translateY(-2px); box-shadow: var(--ub-shadow); }
.ulp-offer-card--best { border-color: var(--ub-violet); box-shadow: var(--ub-shadow); }
.ulp-offer-badge { position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: var(--ub-gradient); color: var(--ub-white); font-family: var(--ub-heading); font-size: 0.68rem; font-weight: 700; padding: 6px 18px; border-radius: 100px; white-space: nowrap; letter-spacing: 0.3px; text-transform: uppercase; }
.ulp-offer-label { font-family: var(--ub-heading); font-size: 0.7rem; font-weight: 700; color: var(--ub-violet); text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 5px; }
.ulp-offer-name { font-family: var(--ub-heading); font-size: 1.2rem; font-weight: 800; margin: 0 0 3px; }
.ulp-offer-format { font-size: 0.82rem; color: var(--ub-gray); margin: 0 0 14px; }
.ulp-offer-price { font-family: var(--ub-heading); font-size: 2rem; font-weight: 900; color: var(--ub-black); margin: 0 0 2px; }
.ulp-offer-price del { font-size: 1rem; color: #ccc; font-weight: 400; margin-right: 6px; }
.ulp-offer-daily { font-size: 0.85rem; background: var(--ub-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 700; margin: 0 0 18px; }

/* ===== COMPARE ===== */
.ulp-compare { background: var(--ub-gray-light); border-radius: 14px; padding: 20px; margin: 24px 0; }
.ulp-compare__title { font-family: var(--ub-heading); font-size: 0.82rem; color: var(--ub-black); margin: 0 0 12px; font-weight: 700; }
.ulp-compare__row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; font-size: 0.88rem; }
.ulp-compare__row + .ulp-compare__row { border-top: 1px solid rgba(0,0,0,0.06); }
.ulp-compare__bad { color: var(--ub-red); font-weight: 600; }
.ulp-compare__good { color: var(--ub-green); font-weight: 700; }

/* ===== URGENCY ===== */
.ulp-urgency { background: var(--ub-gradient); border-radius: 12px; padding: 14px 20px; text-align: center; margin-bottom: 28px; }
.ulp-urgency p { margin: 0; font-family: var(--ub-heading); font-size: 0.85rem; font-weight: 700; color: var(--ub-white); }

/* ===== TRUST ROW ===== */
.ulp-trust-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 8px 24px; margin-top: 24px; }
.ulp-trust-row span { font-size: 0.78rem; color: var(--ub-gray); }

/* ===== FAQ ===== */
.ulp-faq-item { border-bottom: 1px solid rgba(0,0,0,0.06); }
.ulp-faq-item summary { padding: 18px 0; font-family: var(--ub-heading); font-size: 0.92rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; transition: color 0.2s; }
.ulp-faq-item summary:hover { color: var(--ub-violet); }
.ulp-faq-item summary::-webkit-details-marker { display: none; }
.ulp-faq-item summary::after { content: '+'; color: var(--ub-violet); font-size: 1.4rem; font-weight: 300; flex-shrink: 0; margin-left: 12px; transition: var(--ub-ease); }
.ulp-faq-item[open] summary::after { content: '−'; }
.ulp-faq-item__body { padding: 0 0 18px; font-size: 0.88rem; color: var(--ub-gray); line-height: 1.65; }
details[open] .ulp-faq-item__body { animation: ub-faq-open 0.28s ease; }

/* ===== SCOOP ===== */
.ulp-scoop { display: flex; align-items: center; gap: 20px; background: var(--ub-white); border-radius: var(--ub-radius); padding: 22px; margin-top: 32px; box-shadow: var(--ub-shadow); }
.ulp-scoop__img { width: 72px; flex-shrink: 0; filter: drop-shadow(0 4px 8px rgba(139,92,246,0.15)); }
.ulp-scoop__text { font-size: 0.88rem; line-height: 1.5; }
.ulp-scoop__text strong { display: block; font-family: var(--ub-heading); font-size: 0.95rem; margin-bottom: 3px; }

/* ===== UGC ===== */
.ulp-ugc { text-align: center; margin-top: 36px; padding: 28px 20px; background: var(--ub-white); border-radius: var(--ub-radius); box-shadow: var(--ub-shadow); }
.ulp-ugc__photo { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; margin: 0 auto 14px; border: 3px solid var(--ub-violet-light); }
.ulp-ugc__quote { font-size: 1rem; font-style: italic; color: var(--ub-black); line-height: 1.5; margin: 0 auto 10px; max-width: 380px; }
.ulp-ugc__sig { font-family: var(--ub-heading); font-size: 0.75rem; font-weight: 700; color: var(--ub-violet); }

/* ===== CTA FINAL ===== */
.ulp-cta-final { background: var(--ub-black); color: var(--ub-white); padding: 72px 20px; text-align: center; position: relative; overflow: hidden; }
.ulp-cta-final::before { content: ''; position: absolute; top: -100px; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(139,92,246,0.15) 0%, transparent 60%); pointer-events: none; animation: ub-orb 10s ease-in-out infinite; }
.ulp-cta-final h2 { color: var(--ub-white); font-family: var(--ub-heading); font-size: 2.2rem; font-weight: 900; margin-bottom: 10px; position: relative; z-index: 1; letter-spacing: -0.03em; }
.ulp-cta-final h2 span { background: var(--ub-gradient-soft); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.ulp-cta-final__sub { color: rgba(255,255,255,0.5); font-size: 0.95rem; margin-bottom: 32px; position: relative; z-index: 1; }
.ulp-cta-final .ulp-btn--gradient { max-width: 380px; margin: 0 auto; position: relative; z-index: 1; }
.ulp-cta-final__trust { display: flex; justify-content: center; flex-wrap: wrap; gap: 20px; margin-top: 24px; font-size: 0.75rem; color: rgba(255,255,255,0.3); position: relative; z-index: 1; }

/* ===== FOOTER ===== */
.ulp-footer { background: var(--ub-black); color: rgba(255,255,255,0.35); padding: 32px 20px; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }
.ulp-footer__links { display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 20px; margin-bottom: 14px; }
.ulp-footer__links a { color: rgba(255,255,255,0.35); font-size: 0.78rem; transition: var(--ub-ease); }
.ulp-footer__links a:hover { color: var(--ub-white); }
