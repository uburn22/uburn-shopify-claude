  <script>
    // Scroll reveal
    const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}})},{threshold:.12});
    document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

    // FAQ accordion
    document.querySelectorAll('.faq-item').forEach(item=>{
      item.querySelector('.faq-q').addEventListener('click',()=>{
        document.querySelectorAll('.faq-item').forEach(i=>{if(i!==item)i.classList.remove('open')});
        item.classList.toggle('open');
      });
    });

    // Benefit cards interactive
    const benefits = {
      satiete: {label: 'Glucomannane · EFSA · Fibres', title: 'Satiété durable', desc: 'Système complet basé sur le glucomannane (EFSA ID 3120) et 5g de fibres par dose. Le konjac absorbe jusqu\'à 100x son poids en eau pour former un gel qui occupe naturellement l\'estomac.'},
      energie: {label: 'MCT · L-Carnitine', title: 'Énergie stable', desc: 'MCT coco et L-Carnitine 400mg pour une énergie sans pic ni crash. Parfait pour les après-midis longs.'},
      digestion: {label: 'Gingembre · Acacia', title: 'Digestion apaisée', desc: 'Gingembre bio et fibre d\'acacia prébiotique pour un confort digestif au quotidien.'},
      antioxydants: {label: 'Ubé · Anthocyanes', title: 'Antioxydants puissants', desc: 'Ubé violet riche en anthocyanes naturelles pour la protection cellulaire et l\'éclat de la peau.'},
      metabolisme: {label: 'L-Carnitine · Gingembre', title: 'Métabolisme soutenu', desc: 'L-Carnitine 400mg et gingembre pour un support métabolique naturel et durable.'},
      bien_etre: {label: 'Formule complète', title: 'Équilibre global', desc: 'Une formule synergique de 6 actifs pour un bien-être quotidien apaisé et durable.'}
    };
    document.querySelectorAll('[data-benefit]').forEach(card => {
      card.addEventListener('click', () => {
        const key = card.getAttribute('data-benefit');
        document.querySelectorAll('[data-benefit]').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        const detail = document.querySelector('.benefit-detail');
        if (detail && benefits[key]) {
          detail.querySelector('.benefit-label').textContent = benefits[key].label;
          detail.querySelector('.benefit-title').textContent = benefits[key].title;
          detail.querySelector('.benefit-desc').textContent = benefits[key].desc;
        }
      });
    });
  </script>

