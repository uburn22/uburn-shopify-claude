{{ 'uburn-lp.css' | asset_url | stylesheet_tag }}

<div class="ulp">

<!-- HEADER — Logo seul -->
<header class="ulp-header">
  <a href="/" aria-label="Uburn">
    {%- if settings.logo -%}
      {{ settings.logo | image_url: height: 56 | image_tag: loading: 'eager', height: 28 }}
    {%- else -%}
      <span style="font-size:20px;font-weight:900;color:#6B21A8;">UBURN</span>
    {%- endif -%}
  </a>
</header>

<!-- ============================================================ -->
<!-- SECTION 1 — HERO + PRODUCT IMAGE                             -->
<!-- ============================================================ -->
<section class="ulp-hero">
  <div class="ulp-hero__bg">
    <img src="{{ 'HOME_M.png' | file_img_url: '800x' }}" alt="Uburn" class="ulp-hero__bgimg" loading="eager" fetchpriority="high">
    <div class="ulp-hero__overlay"></div>
  </div>
  <div class="ulp-hero__content">
    <span class="ulp-hero__badge">🎁 OFFRE PREMIÈRE COMMANDE</span>
    <h1>Tu craques encore le soir ?</h1>
    <p class="ulp-hero__sub">Rejoins 500+ femmes qui ont repris le contrôle de leurs fringales avec Uburn</p>
    <div class="ulp-hero__product">
      <img src="{{ 'POUDRE_UBE_90GR_M.jpg' | file_img_url: '400x' }}" alt="Uburn Poudre 90g" loading="eager" width="180" height="225">
    </div>
    <div class="ulp-hero__price">
      <del>€49,50</del>
      <strong>€34,50</strong>
      <span class="ulp-badge-discount">-30%</span>
    </div>
    <a href="/products/ube-poudre" class="ulp-btn ulp-btn--white">Essayer maintenant →</a>
    <p class="ulp-hero__micro">€0,61/jour · Livraison gratuite · Made in France · Pas d'abonnement caché</p>
    <p class="ulp-hero__stock">⚠️ Plus que 14 unités disponibles</p>
  </div>
</section>

<!-- ============================================================ -->
<!-- SECTION 2 — SOCIAL PROOF + REAL PRESS LOGOS                  -->
<!-- ============================================================ -->
<section class="ulp-social ulp-section">
  <div class="ulp-stars">★★★★★</div>
  <p class="ulp-social__rating">4.8/5 · 127 avis vérifiés</p>

  <div class="ulp-testimonials">
    <div class="ulp-tcard">
      <div class="ulp-tcard__stars">★★★★★</div>
      <p class="ulp-tcard__text">"Je ne craque plus devant le frigo le soir. Ça fait 3 semaines et c'est la première fois que je tiens aussi longtemps."</p>
      <p class="ulp-tcard__author">Marion L. · 38 ans · Lyon</p>
    </div>
    <div class="ulp-tcard">
      <div class="ulp-tcard__stars">★★★★★</div>
      <p class="ulp-tcard__text">"Le goût violet est vraiment agréable. Je le prends le matin et les fringales de l'après-midi ont disparu."</p>
      <p class="ulp-tcard__author">Sophie M. · 44 ans · Paris</p>
    </div>
    <div class="ulp-tcard">
      <div class="ulp-tcard__stars">★★★★★</div>
      <p class="ulp-tcard__text">"J'étais sceptique mais après une semaine j'ai compris pourquoi les copines m'en avaient parlé."</p>
      <p class="ulp-tcard__author">Nathalie R. · 51 ans · Bordeaux</p>
    </div>
  </div>

  <div class="ulp-press">
    <img src="{{ 'TF1_1989-1990.png' | file_img_url: '120x' }}" alt="TF1" height="28" loading="lazy">
    <img src="{{ 'logo-femmeactuelle-copie_cb5c498d-5470-4a4d-83fc-7b16c264a030.png' | file_img_url: '120x' }}" alt="Femme Actuelle" height="22" loading="lazy">
    <img src="{{ 'ELLE_Magazine_Logo.svg' | file_img_url: '120x' }}" alt="Elle" height="24" loading="lazy">
    <img src="{{ 'Brut_logo_svg.png' | file_img_url: '120x' }}" alt="Brut" height="22" loading="lazy">
    <img src="{{ 'VOGUE_revista_-_logo.png' | file_img_url: '120x' }}" alt="Vogue" height="20" loading="lazy">
  </div>
  <p style="text-align:center;font-size:11px;color:#9ca3af;margin-top:8px;">Ils parlent de nous</p>
</section>

<!-- ============================================================ -->
<!-- SECTION 3 — BEFORE/AFTER + UGC PHOTO                        -->
<!-- ============================================================ -->
<section class="ulp-viral ulp-section">
  <h2 class="ulp-viral__title">Ce qu'elles disent vraiment 💜</h2>
  <p class="ulp-viral__sub">Des vraies femmes · pas des actrices</p>

  <div class="ulp-ba">
    <div class="ulp-ba__before">
      <h3>Avant Uburn</h3>
      <ul>
        <li>Fringales dès 16h · impossible à ignorer</li>
        <li>Soir devant le frigo · perte de contrôle</li>
        <li>Fatigue qui amplifie tout</li>
      </ul>
    </div>
    <div class="ulp-ba__after">
      <h3>Après Uburn</h3>
      <ul>
        <li>4h sans fringales · signal de faim calmé</li>
        <li>Énergie stable · plus de coup de mou</li>
        <li>Routine 30 secondes · reprise du contrôle</li>
      </ul>
    </div>
  </div>
  <div class="ulp-ba__badge">Glucomannane · allégation EFSA autorisée · 30 kcal</div>

  <div class="ulp-ugc-block">
    <img src="{{ 'WhatsApp_Image_2026-03-07_at_15.35.46.jpg' | file_img_url: '400x' }}" alt="Résultat Uburn" class="ulp-ugc-photo" loading="lazy" width="200" height="200">
    <blockquote class="ulp-ugc-quote">"30 secondes le matin et les fringales du soir ont disparu."</blockquote>
    <p class="ulp-ugc-sig">— Iness · @uburn.co</p>
  </div>
</section>

<!-- ============================================================ -->
<!-- SECTION 4 — INGRÉDIENTS · VRAIES PHOTOS                     -->
<!-- ============================================================ -->
<section class="ulp-section" style="background:#fff;">
  <h2 class="ulp-features__title">Ce que contient chaque scoop</h2>
  <p class="ulp-features__sub">6 actifs sélectionnés · 30 kcal</p>

  <div class="ulp-cards">
    <div class="ulp-card">
      <img src="{{ 'Ingredient_Ube.jpg' | file_img_url: '200x200' }}" alt="Ube Violet" class="ulp-card__img" loading="lazy" width="100" height="100">
      <p class="ulp-card__name">Ube Violet</p>
      <p class="ulp-card__desc">Riche en antioxydants · régule naturellement l'appétit</p>
    </div>
    <div class="ulp-card">
      <img src="{{ 'Ingredient_Glucomannane.jpg' | file_img_url: '200x200' }}" alt="Glucomannane" class="ulp-card__img" loading="lazy" width="100" height="100">
      <p class="ulp-card__name">Glucomannane de Konjac</p>
      <p class="ulp-card__desc">Forme un gel naturel · 4h de satiété · allégation EFSA</p>
    </div>
    <div class="ulp-card">
      <img src="{{ 'Ingredient_Acacia.jpg' | file_img_url: '200x200' }}" alt="Fibre d'Acacia" class="ulp-card__img" loading="lazy" width="100" height="100">
      <p class="ulp-card__name">Fibre d'Acacia</p>
      <p class="ulp-card__desc">Prébiotique doux · nourrit le microbiote intestinal</p>
    </div>
    <div class="ulp-card">
      <img src="{{ 'Ingredient_Coco.jpg' | file_img_url: '200x200' }}" alt="MCT de Coco" class="ulp-card__img" loading="lazy" width="100" height="100">
      <p class="ulp-card__name">MCT de Coco</p>
      <p class="ulp-card__desc">Énergie rapide · sans pic glycémique · anti coup de fatigue</p>
    </div>
    <div class="ulp-card">
      <img src="{{ 'Ingredient_Gingembre.jpg' | file_img_url: '200x200' }}" alt="Gingembre Violet" class="ulp-card__img" loading="lazy" width="100" height="100">
      <p class="ulp-card__name">Gingembre Violet</p>
      <p class="ulp-card__desc">Soutient la digestion · propriétés thermogéniques douces</p>
    </div>
    <div class="ulp-card">
      <img src="{{ 'Ingredient_L-carnitine_tartrate.jpg' | file_img_url: '200x200' }}" alt="L-Carnitine" class="ulp-card__img" loading="lazy" width="100" height="100">
      <p class="ulp-card__name">L-Carnitine Tartrate</p>
      <p class="ulp-card__desc">Soutient l'endurance · métabolisme énergétique</p>
    </div>
  </div>
</section>

<!-- ============================================================ -->
<!-- SECTION 5 — COMMENT ÇA MARCHE · PHOTOS ÉTAPES + SCOOP       -->
<!-- ============================================================ -->
<section class="ulp-edu ulp-section">
  <h2 class="ulp-edu__title">Comment ça marche ?</h2>
  <p class="ulp-edu__sub">Le mécanisme expliqué simplement</p>

  <div class="ulp-steps">
    <div class="ulp-step">
      <img src="{{ 'etape_1.jpg' | file_img_url: '300x300' }}" alt="Étape 1" class="ulp-step__img" loading="lazy" width="150" height="150">
      <p class="ulp-step__num">01</p>
      <p class="ulp-step__title">Le matin · 30 secondes</p>
      <p class="ulp-step__text">Un scoop dans 250ml d'eau ou de lait · secouez · c'est prêt.</p>
    </div>
    <div class="ulp-step">
      <img src="{{ 'etape_2.jpg' | file_img_url: '300x300' }}" alt="Étape 2" class="ulp-step__img" loading="lazy" width="150" height="150">
      <p class="ulp-step__num">02</p>
      <p class="ulp-step__title">Dans l'estomac</p>
      <p class="ulp-step__text">Le glucomannane absorbe l'eau et forme un gel naturel qui calme le signal de faim.</p>
    </div>
    <div class="ulp-step">
      <img src="{{ 'etape_3.jpg' | file_img_url: '300x300' }}" alt="Étape 3" class="ulp-step__img" loading="lazy" width="150" height="150">
      <p class="ulp-step__num">03</p>
      <p class="ulp-step__title">Pendant 4 heures</p>
      <p class="ulp-step__text">Ton corps reçoit le signal qu'il est rassasié. Les fringales diminuent.</p>
    </div>
  </div>

  <div class="ulp-scoop-block">
    <img src="{{ 'Uburn_Scoop.png' | file_img_url: '300x' }}" alt="Scoop Uburn" class="ulp-scoop-img" loading="lazy" width="150">
    <p class="ulp-scoop-text">1 scoop = 30 kcal · 0% caféine · 100% végétal</p>
  </div>

  <div class="ulp-science">
    Le glucomannane est la seule fibre à bénéficier d'une allégation officielle de l'EFSA pour la satiété et le contrôle du poids dans le cadre d'un régime hypocalorique.
    <small>Source : Règlement CE 432/2012 · EFSA 2010</small>
  </div>
</section>

<!-- ============================================================ -->
<!-- SECTION 6 — FAQ                                               -->
<!-- ============================================================ -->
<section class="ulp-section" style="background:#fff;">
  <h2 class="ulp-faq__title">Questions fréquentes</h2>

  <details class="ulp-faq-item">
    <summary>Quel goût a Uburn ?</summary>
    <div class="ulp-faq-item__body">Un goût doux de noisette vanillée, naturellement coloré en violet par l'ube. Ça se mélange dans de l'eau, du lait ou un smoothie.</div>
  </details>
  <details class="ulp-faq-item">
    <summary>Est-ce que ça contient de la caféine ?</summary>
    <div class="ulp-faq-item__body">Non, 0% caféine. Uburn peut se prendre à n'importe quelle heure, y compris le soir.</div>
  </details>
  <details class="ulp-faq-item">
    <summary>Combien de temps dure un pot ?</summary>
    <div class="ulp-faq-item__body">Le format Découverte (90g) dure 30 jours à 1 scoop/jour. Le format Résultats Maximum (270g) dure 30 jours à 3 scoops/jour.</div>
  </details>
  <details class="ulp-faq-item">
    <summary>Y a-t-il un abonnement ?</summary>
    <div class="ulp-faq-item__body">Non, jamais. Aucun abonnement caché. Vous commandez quand vous voulez, vous arrêtez quand vous voulez.</div>
  </details>
  <details class="ulp-faq-item">
    <summary>Quand vais-je voir des résultats ?</summary>
    <div class="ulp-faq-item__body">La plupart des utilisatrices ressentent une satiété durable dès la première prise. Les résultats s'installent après 2 à 3 semaines d'utilisation régulière.</div>
  </details>
  <details class="ulp-faq-item">
    <summary>C'est remboursable ?</summary>
    <div class="ulp-faq-item__body">Oui, satisfait(e) ou remboursé(e) pendant 30 jours. On vous rembourse sans poser de question.</div>
  </details>
</section>

<!-- ============================================================ -->
<!-- SECTION 7 — CTA FINAL + PRODUCT IMAGE                       -->
<!-- ============================================================ -->
