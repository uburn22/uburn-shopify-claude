  <script>
    // ---- UTM H1 DYNAMIQUE ----
    (function(){
      var params = new URLSearchParams(window.location.search);
      var utmContent = params.get('utm_content') || '';
      var map = {
        'violet': {h1:'La boisson <span class="accent">violette</span> qui coupe les fringales 4h', sub:'30 kcal · 0% caféine · satisfaction durable.'},
        'ube':    {h1:'Ube + Konjac = <span class="accent">4h</span> sans fringales', sub:'100% naturel · 30 kcal · Marque Française.'},
        'soir':   {h1:'Votre nouvelle <span class="accent">routine</span> commence ici', sub:'0% caféine · se prend à toute heure · 30 kcal.'},
        'energie':{h1:'Pourquoi vous avez un coup de pompe <span class="accent">à 15h</span>&nbsp;?', sub:'MCT de coco · énergie stable · sans excitants.'}
      };
      var v = map[utmContent.toLowerCase()];
      if(v){
        var h1 = document.querySelector('.hero h1');
        var sub = document.querySelector('.hero-sub');
        if(h1) h1.innerHTML = v.h1;
        if(sub) sub.textContent = v.sub;
      }
    })();

    // Countdown timer (6h, sessionStorage)
    (function(){
      var el=document.getElementById('countdown');
      if(!el)return;
      var KEY='ub_timer_end';
      var end=parseInt(sessionStorage.getItem(KEY)||'0');
      if(!end||end<Date.now()){end=Date.now()+6*3600*1000;sessionStorage.setItem(KEY,end);}
      function tick(){
        var diff=Math.max(0,end-Date.now());
        var h=Math.floor(diff/3600000);
        var m=Math.floor((diff%3600000)/60000);
        el.textContent=h+'h '+String(m).padStart(2,'0')+'min';
        if(diff>0)setTimeout(tick,30000);
      }
      tick();
    })();

    // Scroll reveal + stagger
    const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}})},{threshold:.12});
    document.querySelectorAll('.reveal,.stagger-children,.stagger-scale').forEach(el=>obs.observe(el));

    // Count-up animation
    const countObs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){
      const el=e.target,target=+el.dataset.count,suffix=el.dataset.suffix||'',dur=1400;
      let start=null;
      function step(ts){
        if(!start)start=ts;
        const p=Math.min((ts-start)/dur,1);
        el.textContent=Math.round(p*target)+suffix;
        if(p<1)requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      countObs.unobserve(el);
    }})},{threshold:.3});
    document.querySelectorAll('[data-count]').forEach(el=>countObs.observe(el));

    // FAQ accordion
    document.querySelectorAll('.faq-item').forEach(item=>{
      item.querySelector('.faq-q').addEventListener('click',()=>{
        document.querySelectorAll('.faq-item').forEach(i=>{if(i!==item)i.classList.remove('open')});
        item.classList.toggle('open');
      });
    });

    // Benefit cards interactive
    const benefits = {
      satiete: {label: 'Glucomannane · EFSA · Fibres', title: 'Satiété durable', desc: 'Système complet basé sur le glucomannane (EFSA ID 3120) et 5g de fibres par dose. Le konjac absorbe jusqu\'à 100x son poids en eau pour former un gel qui occupe naturellement l\'estomac.'},
      energie: {label: 'MCT · L-Carnitine', title: 'Énergie stable', desc: 'MCT coco et L-Carnitine 400mg pour une énergie sans pic ni crash. Parfait pour les après-midis longs.'},
      digestion: {label: 'Gingembre · Acacia', title: 'Digestion apaisée', desc: 'Gingembre bio et fibre d\'acacia prébiotique pour un confort digestif au quotidien.'},
      antioxydants: {label: 'Ubé · Anthocyanes', title: 'Antioxydants puissants', desc: 'Ubé violet riche en anthocyanes naturelles pour la protection cellulaire et l\'éclat de la peau.'},
      metabolisme: {label: 'L-Carnitine · Gingembre', title: 'Métabolisme soutenu', desc: 'L-Carnitine 400mg et gingembre pour un support métabolique naturel et durable.'},
      bien_etre: {label: 'Formule complète', title: 'Équilibre global', desc: 'Une formule synergique de 6 actifs pour un bien-être quotidien apaisé et durable.'}
    };
    document.querySelectorAll('[data-benefit]').forEach(card => {
      card.addEventListener('click', () => {
        const key = card.getAttribute('data-benefit');
        document.querySelectorAll('[data-benefit]').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        const detail = document.querySelector('.benefit-detail');
        if (detail && benefits[key]) {
          detail.querySelector('.benefit-label').textContent = benefits[key].label;
          detail.querySelector('.benefit-title').textContent = benefits[key].title;
          detail.querySelector('.benefit-desc').textContent = benefits[key].desc;
        }
      });
    });
  </script>

