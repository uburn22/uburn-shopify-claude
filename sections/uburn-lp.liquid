<style>
/* ===== UBURN LP — Medvi-inspired — Mobile-first ===== */
:root {
  --ulp-violet: #8B5CF6;
  --ulp-violet-dark: #7C3AED;
  --ulp-violet-light: #F5F0FF;
  --ulp-text: #111111;
  --ulp-muted: #6B7280;
  --ulp-bg: #FFFFFF;
  --ulp-border: #E5E7EB;
  --ulp-radius: 12px;
}

.ulp * { box-sizing: border-box; margin: 0; padding: 0; }
.ulp { font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: var(--ulp-text); background: var(--ulp-bg); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
.ulp img { max-width: 100%; height: auto; display: block; }
.ulp a { text-decoration: none; color: inherit; }
.ulp h1, .ulp h2, .ulp h3 { font-weight: 700; letter-spacing: -0.02em; }

/* ===== LAYOUT ===== */
.ulp-section { padding: 64px 20px; }
.ulp-container { max-width: 560px; margin: 0 auto; }
.ulp-section--wide .ulp-container { max-width: 720px; }
.ulp-section-title { font-size: 1.75rem; line-height: 1.2; margin-bottom: 12px; text-align: center; }
.ulp-section-sub { font-size: 1rem; color: var(--ulp-muted); line-height: 1.6; text-align: center; margin-bottom: 40px; }

/* ===== CTA BUTTON ===== */
.ulp-cta { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 16px 32px; border-radius: 999px; font-size: 1rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s ease; width: 100%; }
.ulp-cta--violet { background: var(--ulp-violet); color: #fff; box-shadow: 0 4px 16px rgba(139,92,246,0.25); }
.ulp-cta--violet:hover { background: var(--ulp-violet-dark); box-shadow: 0 6px 24px rgba(139,92,246,0.35); transform: translateY(-1px); }
.ulp-cta--violet:active { transform: translateY(0); }

/* ===== HEADER ===== */
.ulp-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; background: #fff; border-bottom: 1px solid var(--ulp-border); position: sticky; top: 0; z-index: 100; }
.ulp-header__logo { font-size: 20px; font-weight: 800; color: var(--ulp-violet); letter-spacing: -0.03em; }
.ulp-header__cart { font-size: 22px; }

/* ===== 1. HERO ===== */
.ulp-hero { padding: 48px 20px 40px; text-align: center; }
.ulp-hero__inner { max-width: 560px; margin: 0 auto; }
.ulp-hero__badge { display: inline-block; font-size: 0.8rem; font-weight: 600; color: var(--ulp-violet); background: var(--ulp-violet-light); padding: 8px 16px; border-radius: 999px; margin-bottom: 24px; }
.ulp-hero h1 { font-size: 2.25rem; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 16px; }
.ulp-hero__sub { font-size: 1.05rem; color: var(--ulp-muted); line-height: 1.6; margin-bottom: 28px; max-width: 440px; margin-left: auto; margin-right: auto; }
.ulp-hero__bullets { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px 16px; margin-bottom: 32px; }
.ulp-hero__bullets span { font-size: 0.85rem; font-weight: 500; color: var(--ulp-muted); white-space: nowrap; }
.ulp-hero__cta-wrap { margin-bottom: 32px; max-width: 380px; margin-left: auto; margin-right: auto; }
.ulp-hero__image { margin: 0 auto; max-width: 280px; }
.ulp-hero__image img { border-radius: 16px; }

/* ===== 2. TICKER ===== */
.ulp-ticker { overflow: hidden; background: var(--ulp-violet); padding: 12px 0; white-space: nowrap; }
.ulp-ticker__track { display: inline-flex; animation: ulp-scroll 30s linear infinite; }
.ulp-ticker__item { font-size: 0.8rem; font-weight: 600; color: #fff; padding: 0 24px; text-transform: uppercase; letter-spacing: 0.05em; flex-shrink: 0; }
.ulp-ticker__item::after { content: '·'; margin-left: 24px; opacity: 0.5; }
@keyframes ulp-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ===== 3. PROBLEME ===== */
.ulp-problem__grid { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
.ulp-problem__card { background: #FAFAFA; border-radius: var(--ulp-radius); padding: 24px; border: 1px solid var(--ulp-border); }
.ulp-problem__card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
.ulp-problem__card p { font-size: 0.9rem; color: var(--ulp-muted); line-height: 1.55; }
.ulp-problem__transition { text-align: center; font-size: 1rem; font-weight: 600; color: var(--ulp-violet); font-style: italic; }

/* ===== 4. MECANISME ===== */
.ulp-meca__steps { display: flex; flex-direction: column; gap: 24px; margin-bottom: 28px; }
.ulp-meca__step { display: flex; gap: 16px; align-items: flex-start; }
.ulp-meca__num { width: 40px; height: 40px; border-radius: 50%; background: var(--ulp-violet); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1rem; font-weight: 700; flex-shrink: 0; }
.ulp-meca__step-body h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; }
.ulp-meca__step-body p { font-size: 0.88rem; color: var(--ulp-muted); line-height: 1.5; }
.ulp-meca__efsa { display: inline-flex; align-items: center; gap: 8px; font-size: 0.8rem; font-weight: 600; color: var(--ulp-violet); background: var(--ulp-violet-light); padding: 10px 16px; border-radius: 999px; margin: 0 auto; }

/* ===== 5. INGREDIENTS ===== */
.ulp-ingr__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 20px; }
.ulp-ingr__card { background: #FAFAFA; border-radius: var(--ulp-radius); padding: 20px 16px; text-align: center; border: 1px solid var(--ulp-border); }
.ulp-ingr__emoji { font-size: 1.6rem; margin-bottom: 8px; }
.ulp-ingr__card h3 { font-size: 0.88rem; font-weight: 700; margin-bottom: 4px; }
.ulp-ingr__card p { font-size: 0.78rem; color: var(--ulp-muted); line-height: 1.4; }
.ulp-ingr__note { text-align: center; font-size: 0.82rem; color: var(--ulp-muted); font-weight: 500; }

/* ===== 6. TEMOIGNAGES ===== */
.ulp-testi__scroll { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding-bottom: 8px; scrollbar-width: none; }
.ulp-testi__scroll::-webkit-scrollbar { display: none; }
.ulp-tcard { min-width: 300px; max-width: 340px; background: #FAFAFA; border-radius: var(--ulp-radius); padding: 24px; border: 1px solid var(--ulp-border); scroll-snap-align: start; flex-shrink: 0; }
.ulp-tcard__stars { color: #F59E0B; font-size: 0.9rem; letter-spacing: 1px; margin-bottom: 12px; display: block; }
.ulp-tcard__text { font-size: 0.92rem; line-height: 1.6; color: var(--ulp-text); font-style: italic; margin-bottom: 16px; }
.ulp-tcard__author { font-size: 0.85rem; font-weight: 600; color: var(--ulp-text); }
.ulp-tcard__meta { font-size: 0.78rem; color: var(--ulp-muted); }

/* ===== 7. OFFRE ===== */
.ulp-offer { background: var(--ulp-violet-light); }
.ulp-offer__box { background: #fff; border-radius: 16px; padding: 32px 24px; text-align: center; box-shadow: 0 2px 24px rgba(139,92,246,0.08); border: 1px solid rgba(139,92,246,0.15); }
.ulp-offer__prices { margin-bottom: 4px; }
.ulp-offer__old { font-size: 1.1rem; color: #9CA3AF; text-decoration: line-through; margin-right: 8px; }
.ulp-offer__new { font-size: 2.25rem; font-weight: 800; color: var(--ulp-text); }
.ulp-offer__daily { font-size: 0.9rem; font-weight: 600; color: var(--ulp-violet); margin-bottom: 24px; }
.ulp-offer__list { list-style: none; text-align: left; margin: 0 0 28px; padding: 0; }
.ulp-offer__list li { font-size: 0.88rem; color: var(--ulp-text); padding: 6px 0; font-weight: 500; display: flex; align-items: center; gap: 8px; }
.ulp-offer__list li::before { content: '✓'; color: var(--ulp-violet); font-weight: 700; flex-shrink: 0; }
.ulp-offer__secure { display: flex; justify-content: center; flex-wrap: wrap; gap: 6px 20px; margin-top: 16px; }
.ulp-offer__secure span { font-size: 0.78rem; color: var(--ulp-muted); font-weight: 500; }
.ulp-offer__countdown { font-size: 0.82rem; font-weight: 600; color: var(--ulp-violet); margin-bottom: 20px; }

/* ===== 8. FAQ ===== */
.ulp-faq-item { border-bottom: 1px solid var(--ulp-border); }
.ulp-faq-item summary { padding: 18px 0; font-size: 0.95rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: var(--ulp-text); gap: 12px; }
.ulp-faq-item summary::-webkit-details-marker { display: none; }
.ulp-faq-item summary::after { content: '+'; color: var(--ulp-violet); font-size: 1.3rem; font-weight: 400; flex-shrink: 0; transition: transform 0.2s; }
.ulp-faq-item[open] summary::after { content: '−'; }
.ulp-faq-item__body { padding: 0 0 18px; font-size: 0.9rem; color: var(--ulp-muted); line-height: 1.65; }

/* ===== 9. MENTIONS LEGALES ===== */
.ulp-legal { padding: 32px 20px; background: #F9FAFB; }
.ulp-legal__inner { max-width: 560px; margin: 0 auto; font-size: 0.72rem; color: #9CA3AF; line-height: 1.7; text-align: center; }

/* ===== FOOTER ===== */
.ulp-footer { background: var(--ulp-text); color: #9CA3AF; padding: 40px 20px; text-align: center; }
.ulp-footer__links { display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 20px; margin-bottom: 16px; }
.ulp-footer__links a { color: #9CA3AF; font-size: 0.8rem; transition: color 0.2s; }
.ulp-footer__links a:hover { color: #fff; }
.ulp-footer__copy { font-size: 0.72rem; color: #6B7280; }

/* ===== STICKY ATC MOBILE ===== */
.ulp-sticky { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; gap: 12px; z-index: 200; transform: translateY(100%); transition: transform 0.3s ease; box-shadow: 0 -2px 16px rgba(0,0,0,0.08); border-top: 1px solid var(--ulp-border); }
.ulp-sticky--visible { transform: translateY(0); }
.ulp-sticky__info strong { display: block; font-size: 1rem; font-weight: 700; }
.ulp-sticky__info small { font-size: 0.75rem; color: var(--ulp-muted); }
.ulp-sticky__btn { background: var(--ulp-violet); color: #fff; padding: 12px 24px; border-radius: 999px; font-weight: 600; font-size: 0.88rem; white-space: nowrap; cursor: pointer; border: none; transition: background 0.2s; box-shadow: 0 4px 14px rgba(139,92,246,0.25); }
.ulp-sticky__btn:hover { background: var(--ulp-violet-dark); }

/* ===== SCROLL REVEAL ===== */
.ulp-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
.ulp-reveal--visible { opacity: 1; transform: translateY(0); }

/* ===== DESKTOP ===== */
@media (min-width: 768px) {
  .ulp-hero { padding: 72px 40px 56px; }
  .ulp-hero__inner { display: grid; grid-template-columns: 1fr 300px; align-items: center; gap: 56px; max-width: 860px; text-align: left; }
  .ulp-hero__badge { margin-bottom: 20px; }
  .ulp-hero__bullets { justify-content: flex-start; }
  .ulp-hero__cta-wrap { margin-left: 0; margin-right: 0; max-width: 320px; }
  .ulp-hero__image { max-width: 300px; }
  .ulp-hero h1 { font-size: 2.75rem; }
  .ulp-container { max-width: 640px; }
  .ulp-section-title { font-size: 2rem; }
  .ulp-problem__grid { flex-direction: row; }
  .ulp-problem__card { flex: 1; }
  .ulp-meca__steps { flex-direction: row; }
  .ulp-meca__step { flex: 1; flex-direction: column; text-align: center; align-items: center; }
  .ulp-ingr__grid { grid-template-columns: repeat(3, 1fr); }
  .ulp-tcard { min-width: 320px; }
  .ulp-sticky { display: none; }
}
</style>

