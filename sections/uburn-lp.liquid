  #ub-exit-modal .exit-value{display:inline-block;background:#f5f0fa;border-radius:100px;padding:6px 16px;font-size:12.5px;font-weight:700;color:#6b2fa0;margin-bottom:20px}
  #ub-exit-form{display:flex;flex-direction:column;gap:10px}
  #ub-exit-email{padding:13px 18px;border-radius:100px;border:1.5px solid #e8dcf5;font-size:14px;font-family:inherit;outline:none;transition:border-color .2s;text-align:center}
  #ub-exit-email:focus{border-color:#6b2fa0}
  #ub-exit-submit{padding:13px 24px;border-radius:100px;border:none;background:#6b2fa0;color:#fff;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;transition:.25s}
  #ub-exit-submit:hover{background:#3d1873;transform:translateY(-1px)}
  #ub-exit-form .exit-legal{font-size:11.5px;color:#8a8785;margin-top:4px}
  #ub-exit-close{position:absolute;top:14px;right:18px;background:none;border:none;font-size:22px;cursor:pointer;color:#8a8785;line-height:1}
  #ub-exit-success{display:none;padding:16px 0 4px}
  #ub-exit-success p{color:#6b2fa0;font-weight:700;font-size:15px}
  @media(max-width:480px){#ub-exit-modal{padding:32px 24px}#ub-exit-modal h2{font-size:19px}}
</style>

<div id="ub-exit-overlay" role="dialog" aria-modal="true" aria-labelledby="ub-exit-title">
  <div id="ub-exit-modal">
    <button id="ub-exit-close" onclick="ubExitClose()" aria-label="Fermer">×</button>
    <div class="exit-icon">🎁</div>
    <span class="exit-value">PDF offert — valeur 47€</span>
    <h2 id="ub-exit-title">Avant de partir</h2>
    <p>Recevez notre guide <strong>"30j pour reprendre le contrôle"</strong> — plan nutrition complet, gratuit.</p>
    <div id="ub-exit-form-wrap">
      <form id="ub-exit-form" onsubmit="ubExitSubmit(event)">
        <input id="ub-exit-email" type="email" name="contact[email]" placeholder="Votre adresse email" required autocomplete="email">
        <button id="ub-exit-submit" type="submit">Je veux mon guide →</button>
        <p class="exit-legal">Pas de spam. Désabonnement en 1 clic.</p>
      </form>
      <div id="ub-exit-success"><p>✓ Guide envoyé — vérifiez vos emails !</p></div>
    </div>
  </div>
</div>

<script>
  // ---- EXIT-INTENT ----
  (function(){
    var SEEN_KEY='ub_exit_seen', SUB_KEY='ub_exit_sub';
    var ready=false, fired=false;

    // Guards
    function canShow(){
      if(fired) return false;
      if(localStorage.getItem(SUB_KEY)) return false;
      var seen=parseInt(localStorage.getItem(SEEN_KEY)||'0');
      if(seen && (Date.now()-seen) < 7*24*3600*1000) return false;
      return true;
    }

    function show(){
      if(!canShow()) return;
      fired=true;
      localStorage.setItem(SEEN_KEY, Date.now());
      document.getElementById('ub-exit-overlay').classList.add('open');
    }

    // Activer après 5s
    setTimeout(function(){ ready=true; }, 5000);

    // Desktop : mouseleave (souris vers le haut)
    document.addEventListener('mouseleave', function(e){
      if(!ready || e.clientY > 50) return;
      show();
    });

    // Mobile : scroll rapide vers le haut
    var lastY=0, lastT=0;
    window.addEventListener('scroll', function(){
      var y=window.scrollY, t=Date.now(), dy=y-lastY, dt=t-lastT;
      if(ready && dy < -80 && dt < 300 && y > 300) show();
      lastY=y; lastT=t;
    }, {passive:true});

    // Fermer overlay click
    document.getElementById('ub-exit-overlay').addEventListener('click', function(e){
      if(e.target===this) ubExitClose();
    });
  })();

  function ubExitClose(){
    document.getElementById('ub-exit-overlay').classList.remove('open');
  }

  function ubExitSubmit(e){
    e.preventDefault();
    var email = document.getElementById('ub-exit-email').value.trim();
    if(!email) return;
    // Submit Shopify newsletter
    var fd = new FormData();
    fd.append('form_type','newsletter');
    fd.append('utf8','✓');
    fd.append('contact[email]', email);
    fetch('/contact', {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}, body:fd})
      .catch(function(){});
    // Show success
    document.getElementById('ub-exit-form').style.display='none';
    document.getElementById('ub-exit-success').style.display='block';
    localStorage.setItem('ub_exit_sub','1');
    setTimeout(ubExitClose, 3000);
  }
</script>

