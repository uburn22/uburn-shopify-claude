<style>
/* ===== UBURN LP — Premium Wellness — Mobile-first ===== */
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&family=Inter:wght@400;500;600&display=swap');

:root {
  --ulp-cream: #FDFAF5;
  --ulp-violet: #8B5CF6;
  --ulp-violet-dark: #7C3AED;
  --ulp-violet-light: #F3EFFE;
  --ulp-text: #1C1917;
  --ulp-muted: #57534E;
  --ulp-border: rgba(0,0,0,0.06);
  --ulp-shadow: 0 2px 20px rgba(0,0,0,0.06);
  --ulp-radius: 16px;
}

.ulp * { box-sizing: border-box; margin: 0; padding: 0; }
.ulp { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; color: var(--ulp-text); background: var(--ulp-cream); -webkit-font-smoothing: antialiased; }
.ulp h1, .ulp h2, .ulp h3 { font-family: 'Montserrat', sans-serif; font-weight: 800; }
.ulp img { max-width: 100%; height: auto; }
.ulp a { text-decoration: none; }

/* ===== HEADER ===== */
.ulp-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; background: #fff; border-bottom: 1px solid var(--ulp-border); position: sticky; top: 0; z-index: 100; }
.ulp-header__logo img { height: 28px; width: auto; }
.ulp-header__cart { font-size: 22px; text-decoration: none; }

/* ===== BOUTON CTA ===== */
.ulp-btn { display: block; text-align: center; padding: 16px 28px; border-radius: 999px; font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 700; cursor: pointer; border: none; width: 100%; transition: background 0.2s, transform 0.1s, box-shadow 0.2s; }
.ulp-btn:hover { transform: translateY(-1px); }
.ulp-btn:active { transform: translateY(0); }
.ulp-btn--violet { background: var(--ulp-violet); color: #fff; box-shadow: 0 4px 14px rgba(139,92,246,0.3); }
.ulp-btn--violet:hover { background: var(--ulp-violet-dark); box-shadow: 0 6px 20px rgba(139,92,246,0.4); }
.ulp-btn--outline { background: #fff; color: var(--ulp-violet); border: 2px solid var(--ulp-violet); }
.ulp-btn--outline:hover { background: var(--ulp-violet-light); }
.ulp-btn--large { padding: 18px 32px; font-size: 1.1rem; }

/* ===== SECTION WRAPPER ===== */
.ulp-wrap { padding: 56px 20px; }
.ulp-inner { max-width: 540px; margin: 0 auto; }
.ulp-bg-white { background: #fff; }
.ulp-bg-cream { background: var(--ulp-cream); }
.ulp-bg-violet { background: var(--ulp-violet-light); }

/* ===== 1. HERO ===== */
.ulp-hero { background: var(--ulp-cream); padding: 40px 20px 32px; }
.ulp-hero__inner { max-width: 540px; margin: 0 auto; }
.ulp-hero h1 { font-size: 2rem; line-height: 1.12; letter-spacing: -0.03em; margin: 0 0 14px; }
.ulp-hero h1 em { color: var(--ulp-violet); font-style: normal; }
.ulp-hero__sub { font-size: 1rem; color: var(--ulp-muted); line-height: 1.6; margin: 0 0 24px; font-weight: 500; }
.ulp-hero__cta-wrap { margin-bottom: 24px; }
.ulp-hero__trust { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
.ulp-hero__trust span { font-size: 0.78rem; font-weight: 600; color: var(--ulp-muted); background: #fff; padding: 6px 12px; border-radius: 999px; border: 1px solid var(--ulp-border); white-space: nowrap; }
.ulp-hero__product { text-align: center; margin: 24px 0 0; }
.ulp-hero__product img { max-width: 220px; border-radius: 12px; }

/* ===== 2. PROBLEME ===== */
.ulp-problem__grid { display: flex; flex-direction: column; gap: 16px; }
.ulp-problem__card { background: #fff; border-radius: var(--ulp-radius); padding: 24px; box-shadow: var(--ulp-shadow); display: flex; align-items: flex-start; gap: 14px; }
.ulp-problem__icon { font-size: 1.5rem; flex-shrink: 0; width: 44px; height: 44px; background: var(--ulp-violet-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.ulp-problem__text h3 { font-size: 1rem; font-weight: 800; margin-bottom: 4px; }
.ulp-problem__text p { font-size: 0.9rem; color: var(--ulp-muted); line-height: 1.5; }

/* ===== 3. MECANISME ===== */
.ulp-meca__visual { background: #fff; border-radius: var(--ulp-radius); padding: 24px; box-shadow: var(--ulp-shadow); margin-bottom: 24px; }
.ulp-meca__visual h3 { font-size: 1.1rem; margin-bottom: 12px; }
.ulp-meca__visual p { font-size: 0.9rem; color: var(--ulp-muted); line-height: 1.6; }
.ulp-meca__stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 24px 0; }
.ulp-meca__stat { text-align: center; background: #fff; border-radius: var(--ulp-radius); padding: 20px 12px; box-shadow: var(--ulp-shadow); }
.ulp-meca__stat strong { display: block; font-family: 'Montserrat', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--ulp-violet); }
.ulp-meca__stat span { font-size: 0.78rem; color: var(--ulp-muted); font-weight: 500; }
.ulp-meca__efsa { font-size: 0.78rem; color: var(--ulp-muted); text-align: center; margin-top: 12px; line-height: 1.5; }

/* ===== 4. INGREDIENTS ===== */
.ulp-ingr__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
.ulp-ingr__card { background: #fff; border-radius: var(--ulp-radius); padding: 20px 16px; box-shadow: var(--ulp-shadow); text-align: center; }
.ulp-ingr__emoji { font-size: 1.8rem; margin-bottom: 8px; }
.ulp-ingr__card h3 { font-size: 0.9rem; font-weight: 800; margin-bottom: 4px; }
.ulp-ingr__card p { font-size: 0.78rem; color: var(--ulp-muted); line-height: 1.4; }

/* ===== 5. TEMOIGNAGES ===== */
.ulp-testi__list { display: flex; flex-direction: column; gap: 16px; }
.ulp-tcard { background: #fff; border-radius: var(--ulp-radius); padding: 24px; box-shadow: var(--ulp-shadow); }
.ulp-tcard__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.ulp-tcard__stars { color: #F59E0B; font-size: 0.95rem; letter-spacing: 1px; }
.ulp-tcard__text { font-size: 0.9rem; line-height: 1.6; color: var(--ulp-text); font-style: italic; margin-bottom: 14px; }
.ulp-tcard__author { font-size: 0.85rem; font-weight: 600; color: var(--ulp-violet); }
.ulp-tcard__meta { font-size: 0.78rem; color: var(--ulp-muted); }

/* ===== 6. FAQ ===== */
.ulp-faq-item { border-bottom: 1px solid rgba(0,0,0,0.08); }
.ulp-faq-item summary { padding: 16px 0; font-size: 0.95rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: var(--ulp-text); font-family: 'Inter', sans-serif; }
.ulp-faq-item summary::-webkit-details-marker { display: none; }
.ulp-faq-item summary::after { content: '+'; color: var(--ulp-violet); font-size: 1.4rem; font-weight: 300; flex-shrink: 0; margin-left: 12px; transition: transform 0.2s; }
.ulp-faq-item[open] summary::after { content: '\2212'; }
.ulp-faq-item__body { padding: 0 0 16px; font-size: 0.9rem; color: var(--ulp-muted); line-height: 1.6; }

/* ===== 7. OFFRE ===== */
.ulp-offer__box { background: #fff; border: 2px solid var(--ulp-violet); border-radius: var(--ulp-radius); padding: 28px 24px; text-align: center; box-shadow: 0 4px 24px rgba(139,92,246,0.12); }
.ulp-offer__countdown { font-size: 0.85rem; font-weight: 600; color: var(--ulp-violet); margin-bottom: 16px; }
.ulp-offer__price-old { font-size: 1.1rem; color: #aaa; text-decoration: line-through; }
.ulp-offer__price-new { font-size: 2.2rem; font-family: 'Montserrat', sans-serif; font-weight: 800; color: var(--ulp-text); margin: 4px 0 6px; }
.ulp-offer__daily { font-size: 0.9rem; font-weight: 600; color: var(--ulp-violet); margin-bottom: 20px; }
.ulp-offer__checklist { list-style: none; text-align: left; margin: 0 0 24px; padding: 0; }
.ulp-offer__checklist li { font-size: 0.88rem; color: var(--ulp-text); padding: 5px 0; font-weight: 500; }
.ulp-offer__checklist li::before { content: "\2713  "; color: var(--ulp-violet); font-weight: 700; }
.ulp-offer__secure { display: flex; justify-content: center; flex-wrap: wrap; gap: 6px 16px; margin-top: 16px; }
.ulp-offer__secure span { font-size: 0.78rem; color: var(--ulp-muted); font-weight: 500; }

/* ===== 8. MENTIONS LEGALES ===== */
.ulp-legal { padding: 32px 20px; background: #F7F5F0; }
.ulp-legal__inner { max-width: 540px; margin: 0 auto; font-size: 0.75rem; color: #999; line-height: 1.7; text-align: center; }
.ulp-legal__inner p + p { margin-top: 6px; }

/* ===== FOOTER ===== */
.ulp-footer { background: #111; color: #888; padding: 40px 20px; text-align: center; }
.ulp-footer__links { display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 16px; margin-bottom: 16px; }
.ulp-footer__links a { color: #999; font-size: 0.8rem; transition: color 0.2s; }
.ulp-footer__links a:hover { color: #fff; }
.ulp-footer__copy { font-size: 0.75rem; color: #555; }

/* ===== STICKY ATC MOBILE ===== */
.ulp-sticky { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; z-index: 200; transform: translateY(100%); transition: transform 0.3s ease; box-shadow: 0 -4px 20px rgba(0,0,0,0.1); }
.ulp-sticky--visible { transform: translateY(0); }
.ulp-sticky__info strong { display: block; font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 800; }
.ulp-sticky__info small { font-size: 0.75rem; color: var(--ulp-muted); }
.ulp-sticky__btn { background: var(--ulp-violet); color: #fff; padding: 12px 24px; border-radius: 999px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.9rem; white-space: nowrap; cursor: pointer; border: none; transition: background 0.2s; box-shadow: 0 4px 14px rgba(139,92,246,0.3); }
.ulp-sticky__btn:hover { background: var(--ulp-violet-dark); }

/* ===== SECTION TITLE ===== */
.ulp-title { font-size: 1.7rem; line-height: 1.15; letter-spacing: -0.03em; margin: 0 0 8px; }
.ulp-subtitle { font-size: 0.95rem; color: var(--ulp-muted); line-height: 1.5; margin: 0 0 28px; }

/* ===== SCROLL REVEAL ===== */
.ulp-reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
.ulp-reveal--visible { opacity: 1; transform: translateY(0); }

/* ===== DESKTOP ===== */
@media (min-width: 700px) {
  .ulp-hero { padding: 64px 40px; }
  .ulp-hero__inner { display: grid; grid-template-columns: 1fr 300px; align-items: center; gap: 48px; max-width: 900px; }
  .ulp-hero__product { margin: 0; }
  .ulp-hero__product img { max-width: 280px; }
  .ulp-hero h1 { font-size: 2.8rem; }
  .ulp-inner { max-width: 680px; }
  .ulp-title { font-size: 2.2rem; }
  .ulp-problem__grid { flex-direction: row; }
  .ulp-problem__card { flex: 1; flex-direction: column; text-align: center; align-items: center; }
  .ulp-ingr__grid { grid-template-columns: repeat(3, 1fr); }
  .ulp-testi__list { flex-direction: row; }
  .ulp-tcard { flex: 1; }
  .ulp-sticky { display: none; }
}
</style>

