<style>
/* ═══════ UBURN LP — MEDVi-inspired · Montserrat ExtraBold + DM Sans ═══════ */
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600;700&display=swap');

:root {
  --ub-bg: #FBF8F4;
  --ub-white: #FFFFFF;
  --ub-black: #1a1a1a;
  --ub-violet: #8B5CF6;
  --ub-violet-dark: #6D28D9;
  --ub-violet-light: #EDE9FE;
  --ub-violet-bg: #F5F3FF;
  --ub-gray: #6B7280;
  --ub-gray-light: #F3F4F6;
  --ub-gold: #D4A853;
  --ub-green: #059669;
  --ub-red: #DC2626;
  --ub-heading: 'Montserrat', sans-serif;
  --ub-body: 'DM Sans', sans-serif;
  --ub-ease: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --ub-radius: 16px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
.ulp { font-family: var(--ub-body); color: var(--ub-black); background: var(--ub-bg); -webkit-font-smoothing: antialiased; line-height: 1.6; }
.ulp img { max-width: 100%; height: auto; display: block; }
.ulp a { text-decoration: none; color: inherit; }

/* ===== HEADER ===== */
.ulp-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; background: var(--ub-white); border-bottom: 1px solid #f0f0f0; position: sticky; top: 0; z-index: 100; }
.ulp-header__logo img { height: 28px; width: auto; }
.ulp-header__cart { font-size: 20px; opacity: 0.5; transition: var(--ub-ease); }
.ulp-header__cart:hover { opacity: 1; }

/* ===== HERO ===== */
.ulp-hero { background: var(--ub-white); padding: 48px 20px 40px; text-align: left; }
.ulp-hero__inner { max-width: 520px; margin: 0 auto; }
.ulp-hero__badge { display: inline-block; background: var(--ub-violet-light); color: var(--ub-violet-dark); font-family: var(--ub-heading); font-size: 0.7rem; font-weight: 700; padding: 6px 14px; border-radius: 100px; margin-bottom: 20px; letter-spacing: 0.5px; text-transform: uppercase; }
.ulp-hero h1 { font-family: var(--ub-heading); font-size: 2.4rem; font-weight: 800; line-height: 1.08; letter-spacing: -0.03em; margin: 0 0 16px; color: var(--ub-black); }
.ulp-hero h1 span { color: var(--ub-violet); }
.ulp-hero__sub { font-size: 1.05rem; color: var(--ub-gray); line-height: 1.55; margin: 0 0 24px; max-width: 440px; }
.ulp-hero__product { text-align: center; margin: 28px 0 0; }
.ulp-hero__product img { max-width: 240px; margin: 0 auto; border-radius: var(--ub-radius); }

/* ===== BUTTONS ===== */
.ulp-btn { display: block; text-align: center; padding: 16px 32px; border-radius: 10px; font-family: var(--ub-heading); font-size: 0.95rem; font-weight: 700; text-decoration: none; cursor: pointer; border: none; width: 100%; box-sizing: border-box; transition: var(--ub-ease); letter-spacing: 0.2px; }
.ulp-btn:hover { transform: translateY(-1px); }
.ulp-btn:active { transform: translateY(0); }
.ulp-btn--violet { background: var(--ub-violet); color: var(--ub-white); }
.ulp-btn--violet:hover { background: var(--ub-violet-dark); }
.ulp-btn--outline { background: transparent; color: var(--ub-violet); border: 2px solid var(--ub-violet); }
.ulp-btn--large { padding: 18px 36px; font-size: 1.05rem; }

/* ===== TRUST TICKER (MEDVi marquee) ===== */
.ulp-ticker { background: var(--ub-black); overflow: hidden; white-space: nowrap; padding: 12px 0; }
.ulp-ticker__track { display: inline-flex; animation: ticker 20s linear infinite; }
.ulp-ticker__item { color: var(--ub-white); font-family: var(--ub-heading); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 0 32px; opacity: 0.9; }
@keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ===== SECTIONS ===== */
.ulp-section { padding: 56px 20px; max-width: 600px; margin: 0 auto; }
.ulp-section h2 { font-family: var(--ub-heading); font-size: 1.8rem; font-weight: 800; letter-spacing: -0.03em; margin: 0 0 12px; line-height: 1.1; color: var(--ub-black); }
.ulp-section h2 span { color: var(--ub-violet); }
.ulp-section__sub { font-size: 1rem; color: var(--ub-gray); margin: 0 0 36px; line-height: 1.5; }
.ulp-section--alt { background: var(--ub-violet-bg); }
.ulp-section--white { background: var(--ub-white); }

/* ===== FEATURE LIST (MEDVi icon list) ===== */
.ulp-features { display: flex; flex-direction: column; gap: 14px; margin: 0 0 32px; }
.ulp-feature { display: flex; align-items: center; gap: 14px; padding: 14px 16px; background: var(--ub-white); border-radius: 12px; border: 1px solid #f0f0f0; transition: var(--ub-ease); }
.ulp-feature:hover { border-color: var(--ub-violet-light); box-shadow: 0 4px 16px rgba(139,92,246,0.06); }
.ulp-feature__icon { font-size: 1.4rem; flex-shrink: 0; width: 44px; height: 44px; background: var(--ub-violet-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.ulp-feature__text { font-size: 0.95rem; font-weight: 600; color: var(--ub-black); }
.ulp-feature__text small { display: block; font-size: 0.8rem; font-weight: 400; color: var(--ub-gray); margin-top: 2px; }

/* ===== STEPS ===== */
.ulp-steps { display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px; }
.ulp-step { display: flex; align-items: center; gap: 16px; }
.ulp-step__num { background: var(--ub-violet); color: var(--ub-white); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--ub-heading); font-weight: 800; font-size: 1rem; flex-shrink: 0; }
.ulp-step__text { font-size: 0.95rem; }
.ulp-step__text strong { display: block; font-weight: 700; margin-bottom: 2px; }
.ulp-step__text p { margin: 0; font-size: 0.85rem; color: var(--ub-gray); }

/* ===== TESTIMONIALS (horizontal scroll) ===== */
.ulp-testimonials-scroll { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding: 4px 20px 20px; margin: 0 -20px; scrollbar-width: none; }
.ulp-testimonials-scroll::-webkit-scrollbar { display: none; }
.ulp-tcard { min-width: 280px; max-width: 300px; scroll-snap-align: start; background: var(--ub-white); border: 1px solid #f0f0f0; border-radius: var(--ub-radius); padding: 24px; flex-shrink: 0; transition: var(--ub-ease); }
.ulp-tcard:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
.ulp-tcard__stars { color: var(--ub-gold); font-size: 0.9rem; margin-bottom: 12px; letter-spacing: 2px; }
.ulp-tcard__text { font-size: 0.9rem; line-height: 1.6; color: var(--ub-black); font-style: italic; margin: 0 0 14px; }
.ulp-tcard__author { font-family: var(--ub-heading); font-size: 0.8rem; font-weight: 700; color: var(--ub-violet); }

/* ===== OFFER ===== */
.ulp-offers { display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }
.ulp-offer-card { border: 2px solid #f0f0f0; border-radius: var(--ub-radius); padding: 28px 24px; position: relative; background: var(--ub-white); transition: var(--ub-ease); }
.ulp-offer-card:hover { border-color: var(--ub-violet-light); }
.ulp-offer-card--best { border-color: var(--ub-violet); }
.ulp-offer-badge { position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: var(--ub-violet); color: var(--ub-white); font-family: var(--ub-heading); font-size: 0.7rem; font-weight: 700; padding: 5px 16px; border-radius: 100px; white-space: nowrap; letter-spacing: 0.3px; text-transform: uppercase; }
.ulp-offer-label { font-family: var(--ub-heading); font-size: 0.75rem; font-weight: 700; color: var(--ub-violet); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 4px; }
.ulp-offer-name { font-family: var(--ub-heading); font-size: 1.2rem; font-weight: 800; margin: 0 0 4px; }
.ulp-offer-format { font-size: 0.85rem; color: var(--ub-gray); margin: 0 0 14px; }
.ulp-offer-price { font-family: var(--ub-heading); font-size: 1.8rem; font-weight: 800; color: var(--ub-black); margin: 0 0 2px; }
.ulp-offer-price del { font-size: 1rem; color: #bbb; font-weight: 400; margin-right: 6px; }
.ulp-offer-daily { font-size: 0.85rem; color: var(--ub-violet); font-weight: 700; margin: 0 0 18px; }

/* ===== COMPARE ===== */
.ulp-compare { background: var(--ub-gray-light); border-radius: 12px; padding: 18px; margin: 20px 0; }
.ulp-compare__title { font-family: var(--ub-heading); font-size: 0.85rem; color: var(--ub-black); margin: 0 0 12px; font-weight: 700; }
.ulp-compare__row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; font-size: 0.9rem; }
.ulp-compare__row + .ulp-compare__row { border-top: 1px solid #e5e7eb; }
.ulp-compare__bad { color: var(--ub-red); font-weight: 600; }
.ulp-compare__good { color: var(--ub-green); font-weight: 700; }

/* ===== URGENCY ===== */
.ulp-urgency { background: #FEF3C7; border: 1px solid #FCD34D; border-radius: 10px; padding: 14px 18px; text-align: center; margin-bottom: 28px; }
.ulp-urgency p { margin: 0; font-family: var(--ub-heading); font-size: 0.85rem; font-weight: 700; color: #92400E; }

/* ===== TRUST ROW ===== */
.ulp-trust-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 8px 24px; margin-top: 20px; }
.ulp-trust-row span { font-size: 0.8rem; color: var(--ub-gray); }

/* ===== FAQ ===== */
.ulp-faq-item { border-bottom: 1px solid #f0f0f0; }
.ulp-faq-item summary { padding: 18px 0; font-family: var(--ub-heading); font-size: 0.95rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.ulp-faq-item summary::-webkit-details-marker { display: none; }
.ulp-faq-item summary::after { content: '+'; color: var(--ub-violet); font-size: 1.4rem; font-weight: 300; flex-shrink: 0; margin-left: 12px; transition: var(--ub-ease); }
.ulp-faq-item[open] summary::after { content: '−'; }
.ulp-faq-item__body { padding: 0 0 18px; font-size: 0.9rem; color: var(--ub-gray); line-height: 1.7; }

/* ===== CTA FINAL ===== */
.ulp-cta-final { background: var(--ub-black); color: var(--ub-white); padding: 64px 20px; text-align: center; }
.ulp-cta-final h2 { color: var(--ub-white); font-family: var(--ub-heading); font-size: 2rem; font-weight: 800; margin-bottom: 12px; }
.ulp-cta-final h2 span { color: var(--ub-violet); }
.ulp-cta-final__sub { color: rgba(255,255,255,0.6); font-size: 1rem; margin-bottom: 32px; }
.ulp-cta-final .ulp-btn--violet { max-width: 360px; margin: 0 auto; }
.ulp-cta-final__trust { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; margin-top: 24px; font-size: 0.8rem; color: rgba(255,255,255,0.4); }

/* ===== FOOTER ===== */
.ulp-footer { background: var(--ub-black); color: rgba(255,255,255,0.4); padding: 32px 20px; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); }
.ulp-footer__links { display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 20px; margin-bottom: 16px; }
.ulp-footer__links a { color: rgba(255,255,255,0.4); font-size: 0.8rem; transition: var(--ub-ease); }
.ulp-footer__links a:hover { color: var(--ub-white); }
.ulp-footer__legal { font-size: 0.72rem; line-height: 1.8; margin-bottom: 16px; }
.ulp-footer__copy { font-size: 0.72rem; }

/* ===== STICKY ===== */
.ulp-sticky { position: fixed; bottom: 0; left: 0; right: 0; background: var(--ub-white); border-top: 1px solid #f0f0f0; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; z-index: 200; transform: translateY(100%); transition: transform 0.3s ease; box-shadow: 0 -4px 20px rgba(0,0,0,0.06); }
.ulp-sticky--visible { transform: translateY(0); }
.ulp-sticky__info { }
.ulp-sticky__info strong { display: block; font-family: var(--ub-heading); font-size: 1rem; font-weight: 800; }
.ulp-sticky__info small { font-size: 0.75rem; color: var(--ub-gray); }
.ulp-sticky__btn { background: var(--ub-violet); color: var(--ub-white); padding: 12px 28px; border-radius: 10px; font-family: var(--ub-heading); font-weight: 700; font-size: 0.9rem; border: none; cursor: pointer; transition: var(--ub-ease); white-space: nowrap; }
.ulp-sticky__btn:hover { background: var(--ub-violet-dark); }

/* ===== DESKTOP ===== */
@media (min-width: 700px) {
  .ulp-hero { padding: 72px 40px; }
  .ulp-hero__inner { display: grid; grid-template-columns: 1fr 280px; align-items: center; gap: 48px; max-width: 900px; }
  .ulp-hero__product { margin: 0; }
  .ulp-hero__product img { max-width: 260px; }
  .ulp-hero h1 { font-size: 3.2rem; }
  .ulp-section { max-width: 720px; padding: 72px 40px; }
  .ulp-offers { flex-direction: row; }
  .ulp-offer-card { flex: 1; }
  .ulp-sticky { display: none; }
  .ulp-cta-final h2 { font-size: 2.6rem; }
}
</style>

