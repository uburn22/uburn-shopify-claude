<script>
/* Checkout direct — add to cart then redirect */
async function uburnCheckout() {
  try {
    var r = await fetch('/products/ube-poudre.js');
    var p = await r.json();
    var vid = p.variants[0].id;
    var res = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: vid, quantity: 1 })
    });
    if (res.ok) window.location.href = '/checkout';
    else window.location.href = '/products/ube-poudre';
  } catch (e) {
    window.location.href = '/products/ube-poudre';
  }
}

/* Sticky ATC — show after 400px scroll */
(function() {
  var s = document.getElementById('ulp-sticky');
  if (!s) return;
  window.addEventListener('scroll', function() {
    s.classList.toggle('ulp-sticky--visible', (window.scrollY || window.pageYOffset) > 400);
  }, { passive: true });
})();

/* Countdown 24h with localStorage persistence */
(function() {
  var el = document.getElementById('ulp-countdown');
  if (!el) return;
  var key = 'ulp_countdown_end';
  var stored = localStorage.getItem(key);
  var end;
  if (stored && Number(stored) > Date.now()) {
    end = Number(stored);
  } else {
    end = Date.now() + 24 * 3600 * 1000;
    localStorage.setItem(key, end);
  }
  function tick() {
    var diff = Math.max(0, end - Date.now());
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var sc = Math.floor((diff % 60000) / 1000);
    el.textContent = [h, m, sc].map(function(n) { return String(n).padStart(2, '0'); }).join(':');
    if (diff > 0) requestAnimationFrame(function() { setTimeout(tick, 1000); });
  }
  tick();
})();

/* Scroll reveal — IntersectionObserver */
(function() {
  var els = document.querySelectorAll('.ulp-reveal');
  if (!els.length) return;
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('ulp-reveal--visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function(el) { obs.observe(el); });
  } else {
    els.forEach(function(el) { el.classList.add('ulp-reveal--visible'); });
  }
})();
</script>

</div>

