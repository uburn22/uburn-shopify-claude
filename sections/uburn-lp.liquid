  </div>
</section>

<!-- ============================================================ -->
<!-- SECTION 3 — LE SECRET · hero ingredient + before/after       -->
<!-- ============================================================ -->
<section class="ulp-secret ulp-section">
  <h2 class="ulp-secret__title">Le secret : le glucomannane de konjac</h2>
