{{ 'uburn-lp.css' | asset_url | stylesheet_tag }}

<div class="ulp">

<!-- HEADER — Logo seul -->
<header class="ulp-header">
  <a href="/" aria-label="Uburn">
    {%- if settings.logo -%}
      {{ settings.logo | image_url: height: 56 | image_tag: loading: 'eager', height: 28 }}
    {%- else -%}
      <span style="font-size:20px;font-weight:900;color:#6B21A8;">UBURN</span>
    {%- endif -%}
  </a>
</header>

<!-- ============================================================ -->
<!-- SECTION 1 — HERO · benefit-first · product visible           -->
<!-- ============================================================ -->
<section class="ulp-hero">
  <div class="ulp-hero__bg">
    <img src="{{ 'HOME_M.png' | file_img_url: '800x' }}" alt="Uburn" class="ulp-hero__bgimg" loading="eager" fetchpriority="high">
    <div class="ulp-hero__overlay"></div>
  </div>
  <div class="ulp-hero__content">
    <span class="ulp-hero__badge">🎁 -30% PREMIÈRE COMMANDE</span>
    <h1>Tes fringales du soir ?<br>C'est terminé.</h1>
    <p class="ulp-hero__sub">Le glucomannane calme la faim pendant 4 heures.<br>30 kcal · 0% caféine · résultats dès la 1ère semaine.</p>
    <div class="ulp-hero__product">
      <img src="{{ 'POUDRE_UBE_90GR_M.jpg' | file_img_url: '400x' }}" alt="Uburn Poudre 90g" loading="eager" width="180" height="225">
    </div>
    <div class="ulp-hero__price">
      <del>€49,50</del>
      <strong>€34,50</strong>
      <span class="ulp-badge-discount">-30%</span>
    </div>
    <a href="/products/ube-poudre" class="ulp-btn ulp-btn--white">Commencer ma cure →</a>
    <div class="ulp-hero__guarantee">✅ Satisfaite ou remboursée 30 jours</div>
    <p class="ulp-hero__micro">€0,61/jour · Livraison offerte · Pas d'abonnement</p>
    <p class="ulp-hero__stock">⚠️ Plus que <span id="ulp-stock">14</span> unités en stock</p>
  </div>
</section>

<!-- ============================================================ -->
