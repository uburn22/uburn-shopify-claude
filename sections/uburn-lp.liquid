     JAVASCRIPT
     ═══════════════════════════════════════════════════ -->
<script>
/* ATC → Checkout direct */
async function uburnAddToCart() {
  var btn = event && event.target;
  if (btn && btn.tagName === 'BUTTON') {
    btn.disabled = true;
    btn.textContent = 'Ajout en cours…';
  }
  try {
    var r = await fetch('/products/ube-poudre.js');
    var p = await r.json();
    var vid = p.variants[0].id;
    var res = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: vid, quantity: 1 }] })
    });
    if (res.ok) {
      window.location.href = '/checkout';
    } else {
      window.location.href = '/cart';
    }
  } catch (e) {
    window.location.href = '/cart';
  }
}

/* Sticky ATC mobile — show after 400px scroll */
(function() {
  var s = document.getElementById('ulp-sticky');
  if (!s) return;
  window.addEventListener('scroll', function() {
    s.classList.toggle('ulp-sticky--visible', (window.scrollY || window.pageYOffset) > 400);
  }, { passive: true });
})();

/* Countdown timer — 4h rolling from page load */
(function() {
  var el = document.getElementById('ulp-countdown-timer');
  if (!el) return;
  var key = 'ulp_countdown_end';
  var stored = sessionStorage.getItem(key);
  var end = stored ? parseInt(stored, 10) : Date.now() + 4 * 60 * 60 * 1000;
  if (!stored) sessionStorage.setItem(key, end);

  function tick() {
    var diff = Math.max(0, end - Date.now());
    if (diff <= 0) { el.textContent = '00:00:00'; return; }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var sec = Math.floor((diff % 60000) / 1000);
    el.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
    requestAnimationFrame(tick);
  }
  tick();
})();

/* Scroll reveal — IntersectionObserver */
(function() {
  var els = document.querySelectorAll('.ulp-reveal');
  if (!els.length) return;
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('ulp-reveal--visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(function(el) { obs.observe(el); });
  } else {
    els.forEach(function(el) { el.classList.add('ulp-reveal--visible'); });
  }
})();
</script>

</div>

