<style>
/* ===== UBURN LP — Premium Medvi/AG1 Redesign — Mobile-first ===== */
.ulp { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; color: #1C1917; background: #FAF7F2; }

/* HEADER */
.ulp-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; background: #fff; border-bottom: 1px solid rgba(0,0,0,0.06); position: sticky; top: 0; z-index: 100; }
.ulp-header__logo img { height: 28px; width: auto; }
.ulp-header__cart { font-size: 22px; text-decoration: none; }

/* HERO */
.ulp-hero { background: #FAF7F2; padding: 40px 20px 32px; }
.ulp-hero__inner { max-width: 540px; margin: 0 auto; }
.ulp-hero h1 { font-size: 2.2rem; font-weight: 800; line-height: 1.1; letter-spacing: -0.04em; margin: 0 0 14px; color: #1C1917; }
.ulp-hero h1 em { color: #8B5CF6; font-style: normal; }
.ulp-hero__sub { font-size: 1rem; color: #57534E; line-height: 1.6; margin: 0 0 20px; }
.ulp-hero__stars { color: #8B5CF6; font-size: 0.85rem; font-weight: 600; margin-bottom: 16px; }
.ulp-hero__bullets { list-style: none; padding: 0; margin: 0 0 28px; }
.ulp-hero__bullets li { font-size: 0.9rem; color: #57534E; padding: 5px 0; }
.ulp-hero__bullets li::before { content: "✓ "; color: #8B5CF6; font-weight: 700; }
.ulp-hero__product { text-align: center; margin: 24px 0 0; }
.ulp-hero__product img { max-width: 200px; height: auto; }

/* TRUST BAR */
.ulp-trust { display: flex; justify-content: center; gap: 0; background: #fff; padding: 12px 20px; flex-wrap: wrap; border-bottom: 1px solid rgba(0,0,0,0.06); }
.ulp-trust span { color: #8B5CF6; font-size: 0.8rem; font-weight: 600; padding: 4px 14px; white-space: nowrap; }
.ulp-trust span + span { border-left: 1px solid rgba(139,92,246,0.2); }

/* BOUTONS */
.ulp-btn { display: block; text-align: center; padding: 16px 28px; border-radius: 999px; font-size: 1rem; font-weight: 700; text-decoration: none; cursor: pointer; border: none; width: 100%; box-sizing: border-box; transition: background 0.2s, transform 0.1s; }
.ulp-btn:hover { transform: translateY(-1px); }
.ulp-btn:active { transform: translateY(0); }
.ulp-btn--violet { background: #8B5CF6; color: #fff; }
.ulp-btn--violet:hover { background: #7C3AED; }
.ulp-btn--white { background: #fff; color: #8B5CF6; border: 2px solid #8B5CF6; }
.ulp-btn--white:hover { background: #F5F0FF; }
.ulp-btn--large { padding: 18px 32px; font-size: 1.1rem; }

/* SECTIONS */
.ulp-section { padding: 56px 20px; max-width: 540px; margin: 0 auto; }
.ulp-section h2 { font-size: 1.8rem; font-weight: 700; letter-spacing: -0.03em; margin: 0 0 28px; line-height: 1.2; color: #1C1917; }
.ulp-section--white { background: #fff; }
.ulp-section--alt { background: #F5F0FF; }
.ulp-section--cream { background: #FAF7F2; }
.ulp-section--alt .ulp-section,
.ulp-section--white .ulp-section,
.ulp-section--cream .ulp-section { background: transparent; }

/* BÉNÉFICES */
.ulp-benefits { display: flex; flex-direction: column; gap: 16px; margin: 0 0 36px; }
.ulp-benefit { background: #fff; border-radius: 16px; padding: 20px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); display: flex; align-items: flex-start; gap: 14px; }
.ulp-benefit__icon { font-size: 1.6rem; flex-shrink: 0; }
.ulp-benefit__text strong { display: block; font-size: 1rem; font-weight: 700; margin-bottom: 4px; color: #1C1917; }
.ulp-benefit__text p { margin: 0; font-size: 0.9rem; color: #57534E; line-height: 1.5; }

/* ÉTAPES */
.ulp-steps { display: flex; flex-direction: column; gap: 20px; margin-bottom: 36px; }
.ulp-step { display: flex; align-items: center; gap: 16px; background: #fff; border-radius: 16px; padding: 18px 20px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); }
.ulp-step__num { background: #8B5CF6; color: #fff; width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
.ulp-step__text strong { display: block; font-size: 0.95rem; font-weight: 700; color: #1C1917; }
.ulp-step__text p { margin: 0; font-size: 0.85rem; color: #57534E; }

/* TÉMOIGNAGES */
.ulp-testimonials { display: flex; flex-direction: column; gap: 16px; margin-bottom: 36px; }
.ulp-tcard { background: #fff; border-radius: 16px; padding: 24px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); }
.ulp-tcard__stars { color: #f59e0b; font-size: 1rem; margin-bottom: 10px; }
.ulp-tcard__text { font-size: 0.9rem; line-height: 1.6; color: #1C1917; font-style: italic; margin: 0 0 12px; }
.ulp-tcard__author { font-size: 0.85rem; font-weight: 700; color: #8B5CF6; margin: 0; }

/* OFFRE */
.ulp-offers { display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px; }
.ulp-offer-card { border: 2px solid rgba(139,92,246,0.15); border-radius: 16px; padding: 24px; position: relative; background: #fff; box-shadow: 0 2px 16px rgba(0,0,0,0.06); }
.ulp-offer-card--best { border-color: #8B5CF6; background: #F5F0FF; }
.ulp-offer-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #8B5CF6; color: #fff; font-size: 0.75rem; font-weight: 700; padding: 4px 16px; border-radius: 999px; white-space: nowrap; }
.ulp-offer-label { font-size: 0.8rem; font-weight: 600; color: #8B5CF6; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px; }
.ulp-offer-name { font-size: 1.2rem; font-weight: 700; margin: 0 0 4px; color: #1C1917; }
.ulp-offer-format { font-size: 0.85rem; color: #57534E; margin: 0 0 12px; }
.ulp-offer-price { font-size: 1.6rem; font-weight: 700; color: #1C1917; margin: 0 0 2px; }
.ulp-offer-price del { font-size: 1rem; color: #aaa; font-weight: 400; margin-right: 6px; }
.ulp-offer-daily { font-size: 0.85rem; color: #8B5CF6; font-weight: 600; margin: 0 0 16px; }

/* URGENCE */
.ulp-urgency { background: #fff; border: 1px solid rgba(139,92,246,0.2); border-radius: 12px; padding: 12px 16px; text-align: center; margin-bottom: 24px; }
.ulp-urgency p { margin: 0; font-size: 0.9rem; font-weight: 600; color: #8B5CF6; }

/* TRUST FINAL */
.ulp-trust-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 8px 20px; margin-top: 16px; }
.ulp-trust-row span { font-size: 0.8rem; color: #57534E; }

/* COMPARE */
.ulp-compare { background: #fff; border-radius: 16px; padding: 18px; margin: 16px 0; box-shadow: 0 2px 16px rgba(0,0,0,0.06); }
.ulp-compare__title { font-size: 0.85rem; color: #57534E; margin: 0 0 10px; font-weight: 600; }
.ulp-compare__row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; font-size: 0.9rem; }
.ulp-compare__row + .ulp-compare__row { border-top: 1px solid rgba(0,0,0,0.06); }
.ulp-compare__bad { color: #dc2626; }
.ulp-compare__good { color: #16a34a; font-weight: 700; }

/* FAQ */
.ulp-faq-item { border-bottom: 1px solid rgba(0,0,0,0.08); }
.ulp-faq-item summary { padding: 16px 0; font-size: 0.95rem; font-weight: 600; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: #1C1917; }
.ulp-faq-item summary::-webkit-details-marker { display: none; }
.ulp-faq-item summary::after { content: '+'; color: #8B5CF6; font-size: 1.3rem; font-weight: 300; flex-shrink: 0; margin-left: 12px; }
.ulp-faq-item[open] summary::after { content: '−'; }
.ulp-faq-item__body { padding: 0 0 16px; font-size: 0.9rem; color: #57534E; line-height: 1.6; }

/* FOOTER */
.ulp-footer { background: #111; color: #888; padding: 40px 20px; text-align: center; }
.ulp-footer__links { display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 16px; margin-bottom: 16px; }
.ulp-footer__links a { color: #999; font-size: 0.8rem; text-decoration: none; transition: color 0.2s; }
.ulp-footer__links a:hover { color: #fff; }
.ulp-footer__legal { font-size: 0.75rem; line-height: 1.6; margin-bottom: 16px; color: #666; }
.ulp-footer__copy { font-size: 0.75rem; color: #555; }

/* STICKY */
.ulp-sticky { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; z-index: 200; transform: translateY(100%); transition: transform 0.3s ease; box-shadow: 0 -4px 20px rgba(0,0,0,0.08); }
.ulp-sticky--visible { transform: translateY(0); }
.ulp-sticky__info { color: #1C1917; }
.ulp-sticky__info strong { display: block; font-size: 1rem; font-weight: 700; }
.ulp-sticky__info small { font-size: 0.75rem; color: #57534E; }
.ulp-sticky__btn { background: #8B5CF6; color: #fff; padding: 12px 24px; border-radius: 999px; font-weight: 700; font-size: 0.95rem; text-decoration: none; white-space: nowrap; cursor: pointer; border: none; transition: background 0.2s; }
