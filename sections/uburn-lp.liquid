  <div class="ulp-footer__links">
    <a href="/policies/terms-of-service">CGV</a>
    <a href="/policies/privacy-policy">Confidentialité</a>
    <a href="/pages/contact">Contact</a>
  </div>
  <p class="ulp-footer__copy">© {{ 'now' | date: '%Y' }} Uburn · Marque française</p>
</footer>

<!-- STICKY ATC MOBILE -->
<div class="ulp-sticky" id="ulp-sticky">
  <div class="ulp-sticky__info">
    <strong>Uburn — €34,50</strong>
    <small>Livraison offerte</small>
  </div>
  <button onclick="addAndCheckout('ube-poudre', 0)" class="ulp-sticky__btn">Commander →</button>
</div>

<script>
async function addAndCheckout(handle, variantIndex) {
  variantIndex = variantIndex || 0;
  try {
    var r = await fetch('/products/' + handle + '.js');
    var p = await r.json();
    var vid = p.variants[variantIndex] ? p.variants[variantIndex].id : p.variants[0].id;
    var res = await fetch('/cart/add.js', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:vid,quantity:1})});
    if(res.ok) window.location.href = '/checkout';
    else window.location.href = '/products/' + handle;
  } catch(e) { window.location.href = '/products/' + handle; }
}

// Sticky ATC
(function(){
  var s = document.getElementById('ulp-sticky');
  if (!s) return;
  window.addEventListener('scroll', function() {
    if ((window.scrollY || window.pageYOffset) > 300) {
      s.classList.add('ulp-sticky--visible');
    } else {
      s.classList.remove('ulp-sticky--visible');
    }
  }, { passive: true });
})();

// Countdown urgence
(function(){
  var el = document.getElementById('ulp-countdown');
  if(!el) return;
  var end = new Date(Date.now() + 24*3600*1000);
  function tick() {
    var diff = Math.max(0, end - new Date());
    var h = Math.floor(diff/3600000);
    var m = Math.floor((diff%3600000)/60000);
    var s = Math.floor((diff%60000)/1000);
    el.textContent = [h,m,s].map(function(n){return String(n).padStart(2,'0');}).join(':');
    if(diff > 0) setTimeout(tick, 1000);
  }
  tick();
})();
</script>

</div>

