<!-- ============================================================ -->
<!-- STICKY ATC MOBILE                                             -->
<!-- ============================================================ -->
<div class="ulp-sticky" id="ulp-sticky">
  <div class="ulp-sticky__info">
    Uburn · €34,50
    <small>Livraison gratuite</small>
  </div>
  <a href="/products/ube-poudre" class="ulp-sticky__btn">Essayer →</a>
</div>

<script>
(function(){
  var sticky = document.getElementById('ulp-sticky');
  if (!sticky) return;
  var shown = false;
  function check() {
    var st = window.scrollY || window.pageYOffset;
    if (st > 400 && !shown) { sticky.classList.add('ulp-sticky--visible'); shown = true; }
    else if (st <= 400 && shown) { sticky.classList.remove('ulp-sticky--visible'); shown = false; }
  }
  window.addEventListener('scroll', check, { passive: true });
  check();
})();
</script>

</div>

{% schema %}
{
  "name": "Uburn Landing Page",
  "tag": "section",
  "class": "uburn-lp-section"
}
{% endschema %}
