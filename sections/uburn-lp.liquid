<script>
/* Checkout — 1 seul POST, fallback vers checkout direct */
async function uburnAddToCart(qty) {
  var btn = event && event.target;
  if (btn && btn.tagName === 'BUTTON') {
    btn.disabled = true;
    btn.textContent = 'Ajout en cours…';
  }
  try {
    var r = await fetch('/products/ube-poudre.js');
    var p = await r.json();
    var vid = p.variants[0].id;
    var res = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: vid, quantity: qty || 1 }] })
    });
    if (res.ok) {
      window.location.href = '/checkout';
    } else {
      window.location.href = '/cart';
    }
  } catch (e) {
    window.location.href = '/cart';
  }
}

/* Sticky ATC mobile */
(function() {
  var s = document.getElementById('ulp-sticky');
  if (!s) return;
  window.addEventListener('scroll', function() {
    s.classList.toggle('ulp-sticky--visible', (window.scrollY || window.pageYOffset) > 400);
  }, { passive: true });
})();

/* Testimonial scroll dots */
(function() {
  var scroll = document.getElementById('ulp-testi-scroll');
  var dots = document.querySelectorAll('#ulp-testi-dots .ulp-testi__dot');
  if (!scroll || !dots.length) return;
  scroll.addEventListener('scroll', function() {
    var cardWidth = scroll.firstElementChild ? scroll.firstElementChild.offsetWidth + 16 : 306;
    var idx = Math.round(scroll.scrollLeft / cardWidth);
    dots.forEach(function(d, i) {
      d.classList.toggle('ulp-testi__dot--active', i === idx);
    });
  }, { passive: true });
})();

/* Scroll reveal */
(function() {
  var els = document.querySelectorAll('.ulp-reveal');
  if (!els.length) return;
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('ulp-reveal--visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(function(el) { obs.observe(el); });
  } else {
    els.forEach(function(el) { el.classList.add('ulp-reveal--visible'); });
  }
})();
</script>

