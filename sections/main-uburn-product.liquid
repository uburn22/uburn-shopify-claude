<script>
(function(){
  /* ===== PROMO BAR ===== */
  var params=new URLSearchParams(location.search);
  var promo=document.getElementById('updPromo');
  var promoTxt=document.getElementById('updPromoTxt');
  var promoBtn=document.getElementById('updPromoBtn');
  if(params.get('discount')==='UBE10'||params.get('code')==='UBE10'){
    promo.classList.add('applied');
    promoTxt.innerHTML='✓ Code <strong>UBE10</strong> appliqué — <strong>-10%</strong> sur ta commande';
  }
  promoBtn.addEventListener('click',function(){
    navigator.clipboard.writeText('UBE10').then(function(){
      promoBtn.textContent='Copié ✓';promoBtn.classList.add('copied');
      setTimeout(function(){promoBtn.textContent='Copier';promoBtn.classList.remove('copied');},2000);
    }).catch(function(){
      var ta=document.createElement('textarea');ta.value='UBE10';document.body.appendChild(ta);ta.select();try{document.execCommand('copy');promoBtn.textContent='Copié ✓';promoBtn.classList.add('copied');setTimeout(function(){promoBtn.textContent='Copier';promoBtn.classList.remove('copied');},2000);}catch(e){}document.body.removeChild(ta);
    });
  });

  /* ===== GALLERY ===== */
  var mainImg=document.getElementById('updMainImg');
  document.querySelectorAll('.upd-thumb').forEach(function(t){
    t.addEventListener('click',function(){
      document.querySelectorAll('.upd-thumb').forEach(function(x){x.classList.remove('active')});
      t.classList.add('active');
      mainImg.src=t.dataset.src;
    });
  });

  /* ===== VARIANT PICKER ===== */
  var stickyPrice=document.getElementById('updStickyPrice');
  var stickyDay=document.getElementById('updStickyDay');
  function updateSticky(label){
    if(!label) return;
    var pday=label.dataset.pday;
    var price=label.querySelector('.upd-variant__price-num').textContent;
    stickyPrice.textContent=price;
    stickyDay.textContent=pday+'/jour';
  }
  document.querySelectorAll('.upd-variant').forEach(function(label){
    label.addEventListener('click',function(){
      document.querySelectorAll('.upd-variant').forEach(function(x){x.classList.remove('selected')});
      label.classList.add('selected');
      label.querySelector('input').checked=true;
      updateSticky(label);
    });
  });
  updateSticky(document.querySelector('.upd-variant.selected'));

  /* ===== QTY ===== */
  var qty=document.getElementById('updQty');
  document.getElementById('updQtyMinus').addEventListener('click',function(){var v=parseInt(qty.value)||1;if(v>1)qty.value=v-1});
  document.getElementById('updQtyPlus').addEventListener('click',function(){var v=parseInt(qty.value)||1;if(v<10)qty.value=v+1});

  /* ===== ATC AJAX ===== */
  var form=document.getElementById('updForm');
  var atc=document.getElementById('updAtc');
  form.addEventListener('submit',function(e){
    e.preventDefault();
    atc.classList.add('loading');atc.disabled=true;
    var fd=new FormData(form);
    fetch('/cart/add.js',{method:'POST',body:fd,headers:{'Accept':'application/json'}})
      .then(function(r){return r.json()})
      .then(function(){
        if(typeof window.theme!=='undefined'&&window.theme.cartDrawer){window.theme.cartDrawer.open()}
        else{document.dispatchEvent(new CustomEvent('cart:refresh'))}
        // Pixel
        if(typeof fbq!=='undefined'){fbq('track','AddToCart');}
        if(typeof gtag!=='undefined'){gtag('event','add_to_cart');}
        // Try to open cart drawer via existing theme
        var btn=document.querySelector('[data-cart-drawer-trigger],.cart-drawer-trigger,.cart-icon-bubble,[data-action="open-cart"]');
        if(btn)btn.click();else location.href='/cart';
      })
      .catch(function(){location.href='/cart'})
      .finally(function(){atc.classList.remove('loading');atc.disabled=false});
  });

  /* Sticky button → submit form */
  document.getElementById('updStickyBtn').addEventListener('click',function(){form.requestSubmit?form.requestSubmit():form.dispatchEvent(new Event('submit',{cancelable:true}))});

  /* ===== FAQ — natural details handles open/close ===== */
  document.querySelectorAll('.upd-faq-item').forEach(function(d){
    d.addEventListener('toggle',function(){if(d.open)d.classList.add('open');else d.classList.remove('open')});
  });
})();
</script>

