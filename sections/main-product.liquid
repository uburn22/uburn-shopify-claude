<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@700;800&family=Red+Hat+Text:wght@400;500;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

<style>
  :root{
    --ub-purple-deep:#3d1873;--ub-purple-main:#6b2fa0;--ub-purple-mid:#8b47c5;
    --ub-purple-light:#b07de8;--ub-purple-pale:#e8dcf5;--ub-purple-wash:#f5f0fa;
    --ub-cream:#faf9f7;--ub-dark:#242220;--ub-body:#5a5654;--ub-muted:#8a8785;
    --ub-grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%);
  }

  /* Apply brand fonts to product info */
  .product-info .product-title,
  .product-info h1,
  .product-info h2,
  .product-info .h1,
  .product-info .h2 {
    font-family: 'Red Hat Display', sans-serif !important;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #242220;
  }
  .product-info,
  .product-info p,
  .product-info span,
  .product-info label {
    font-family: 'Red Hat Text', sans-serif;
  }

  /* Bonus block */
  .uburn-bonus-block {
    margin-top: 16px;
    background: var(--ub-purple-wash);
    border: 1px solid var(--ub-purple-pale);
    border-radius: 12px;
    padding: 14px 16px;
  }
  .uburn-bonus-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--ub-purple-main);
    text-transform: uppercase;
    letter-spacing: .6px;
    margin-bottom: 8px;
    font-family: 'Red Hat Text', sans-serif;
  }
  .uburn-bonus-items {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .uburn-bonus-items span {
    font-size: 12.5px;
    color: #242220;
    font-weight: 500;
    line-height: 1.4;
    font-family: 'Red Hat Text', sans-serif;
  }
  .uburn-bonus-items em {
    color: #8a8785;
    font-style: normal;
    font-size: 11px;
  }
  .uburn-bonus-total {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--ub-purple-pale);
    font-size: 12.5px;
    color: #5a5654;
    font-family: 'Red Hat Text', sans-serif;
  }
  .uburn-bonus-total strong {
    color: var(--ub-purple-deep);
    font-weight: 800;
  }

  {%- if section.settings.allow_transparent_header and section.settings.transparent_header_use_primary_colors -%}
    {%- comment -%}
    When this setting is enabled, we use the transparent header, but we force the header to use the primary colors and primary logo.
    {%- endcomment -%}

    .header {
      --header-show-transparent-logo: 0 !important;
      --header-transparent-header-text-color: initial;
    }
  {%- endif -%}

  {%- if section.settings.allow_transparent_header == false and section.settings.add_top_spacing -%}
    #shopify-section-{{ section.id }} .product {
      padding-block-start: min(1.75rem, var(--container-gutter));
    }
  {%- endif -%}

  /* Mobile hero — above the fold for paid traffic */
  .uburn-mobile-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 8px 16px;
    background: linear-gradient(135deg, var(--ub-purple-wash) 0%, var(--ub-purple-pale) 100%);
    border-radius: 8px;
    margin-bottom: 8px;
    max-height: 60px;
    overflow: hidden;
  }
  .uburn-hero-promise {
    font-size: 15px;
    font-weight: 700;
    color: #3d1873;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .uburn-hero-details {
    font-size: 11px;
    color: #6b2fa0;
    margin: 0;
  }
  @media screen and (min-width: 700px) {
    .uburn-mobile-hero { display: none; }
  }

  /* FIX 3 — Trust bar above the fold */
  .uburn-trust-bar {
    background: var(--ub-purple-wash);
    padding: 10px 20px;
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 0;
  }
  .uburn-trust-bar span {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ub-body);
    white-space: nowrap;
    padding: 0;
  }
  .uburn-trust-bar span + span {
    border-left: none;
  }

  /* Accordion science */
  .uburn-science-accordion {
    margin-top: 12px;
    border: 1px solid #e0dce6;
    border-radius: 8px;
    overflow: hidden;
  }
  .uburn-science-accordion summary {
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    background: #f9f7fc;
    list-style: none;
  }
  .uburn-science-accordion summary::-webkit-details-marker { display: none; }
  .uburn-science-accordion summary::after {
    content: '+';
    float: right;
    font-size: 18px;
    color: #6b2fa0;
  }
  .uburn-science-accordion[open] summary::after { content: '−'; }
  .uburn-science-steps {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .uburn-science-step {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 13px;
    line-height: 1.5;
  }
  .uburn-step-icon {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #6b2fa0;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
  }

  /* Emoji step icons (no background) */
  .uburn-step-icon--emoji {
    background: none;
    font-size: 20px;
    width: 26px;
    height: 26px;
  }

  /* FIX 4 — FAQ section */
  .uburn-faq-section {
    margin-top: 16px;
  }
  .uburn-faq-heading {
    font-size: 14px;
    font-weight: 700;
    color: #333;
    margin: 0 0 8px 0;
  }
  .uburn-faq-section .uburn-science-accordion {
    margin-top: 0;
    border-radius: 0;
    border-bottom: none;
  }
  .uburn-faq-section .uburn-science-accordion:first-of-type {
    border-radius: 8px 8px 0 0;
  }
  .uburn-faq-section .uburn-science-accordion:last-of-type {
    border-radius: 0 0 8px 8px;
    border-bottom: 1px solid #e0dce6;
  }
  .uburn-faq-answer {
    font-size: 13px;
    line-height: 1.6;
    color: #444;
    margin: 0;
  }

  /* TASK 3 — Antioxidant note */
  .uburn-antioxidant-note {
    font-size: 12px;
    color: #888;
    font-style: italic;
    margin: 6px 0 0 0;
  }

  /* TASK 3 — Prix comparison */
  .uburn-price-comparison {
    font-size: 12px;
    color: #16a34a;
    font-weight: 600;
    margin: 4px 0 0 0;
  }

  .uburn-no-subscription {
    font-size: 11px;
    color: #6b7280;
    text-align: center;
    margin: 8px 0 0 0;
  }


  /* Sticky ATC bottom padding on mobile */
  @media screen and (max-width: 699px) {
    .shopify-section--main-product { padding-bottom: 60px; }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --product-grid: auto / minmax(0, {{ section.settings.product_media_size | divided_by: 100.0 }}fr) minmax(0, {{ 100.0 | minus: section.settings.product_media_size | divided_by: 100.0 }}fr);
    }
  }
</style>

<div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }}" {% if section.settings.allow_transparent_header and product.media.size > 0 %}allow-transparent-header{% endif %}>
  <div class="container">
    {%- capture product_form_id -%}product-form-main-{{ product.id }}-{{ section.id }}{%- endcapture -%}

    <product-rerender id="product-info-{{ product.id }}-{{ section.id }}" observe-form="{{ product_form_id }}" allow-partial-rerender>
      <div class="product">
        <!-- Mobile hero banner for paid traffic — above the fold -->
        <div class="uburn-mobile-hero sm:hidden">
          <p class="uburn-hero-promise">Satiété longue durée · 30 kcal</p>
          <p class="uburn-hero-details">1500+ femmes l'utilisent · À partir de €1,15/jour</p>
        </div>

        <!-- Trust bar — 4 badges horizontal -->
        <div class="uburn-trust-bar">
          <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b2fa0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg> Ingrédients conformes EFSA</span>
          <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b2fa0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg> 100% Végétal</span>
          <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b2fa0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg> 0% caféine</span>
          <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6b2fa0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg> Livraison offerte</span>
        </div>

        {%- if product.media.size > 0 -%}
          {%- render 'product-gallery',
              product: product,
              product_form_id: product_form_id,
              desktop_layout: section.settings.desktop_media_layout,
              desktop_carousel_controls: section.settings.desktop_carousel_controls,
              mobile_controls: section.settings.mobile_controls,
              enable_media_autoplay: section.settings.enable_media_autoplay,
              enable_video_looping: section.settings.enable_video_looping,
              enable_image_zoom: section.settings.enable_image_zoom,
              max_image_zoom_level: section.settings.max_image_zoom_level
          -%}
        {%- endif -%}

        {%- render 'product-info',
            product: product,
            product_form_id: product_form_id,
            content_alignment: section.settings.content_alignment,
            context: 'main_product'
        -%}

      </div>
    </product-rerender>
  </div>
</div>

{%- render 'product-sticky-add-to-cart', product: product, product_form_id: product_form_id -%}
{%- render 'product-quick-buy', product: product -%}

<!-- ===== LP-STYLE BELOW FOLD ===== -->
<style>
  .pd-wrap{font-family:'Red Hat Text',sans-serif;color:var(--ub-body)}
  .pd-wrap *{box-sizing:border-box}
  .pd-section{padding:80px 40px}
  .pd-section-inner{max-width:1100px;margin:0 auto}
  .pd-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2.5px;color:var(--ub-purple-main);margin-bottom:14px}
  .pd-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(24px,3vw,38px);font-weight:700;color:var(--ub-dark);line-height:1.15;margin-bottom:16px}
  .pd-title .pd-accent{color:var(--ub-purple-mid)}
  .pd-cream{background:var(--ub-cream)}

  /* Marquee */
  .pd-marquee{padding:12px 0;overflow:hidden;border-top:1px solid rgba(0,0,0,.06);border-bottom:1px solid rgba(0,0,0,.06)}
  .pd-marquee-track{display:flex;gap:40px;animation:pd-slide 25s linear infinite;width:max-content}
  .pd-marquee-item{white-space:nowrap;font-size:12.5px;font-weight:600;color:var(--ub-muted);text-transform:uppercase;letter-spacing:1.2px;display:flex;align-items:center;gap:10px}
  .pd-marquee-dot{width:5px;height:5px;border-radius:50%;background:var(--ub-purple-light)}
  @keyframes pd-slide{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* How it works */
  .pd-how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;margin-top:56px;text-align:center;align-items:start}
  .pd-how-photo{width:100%;aspect-ratio:1/1;border-radius:20px;overflow:hidden;margin-bottom:16px;background:var(--ub-purple-wash)}
  .pd-how-photo img{width:100%;height:100%;object-fit:cover}
  .pd-how-num{width:52px;height:52px;margin:0 auto 16px;border-radius:50%;background:var(--ub-purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:var(--ub-purple-main)}
  .pd-how-step h4{font-family:'Red Hat Display',sans-serif;font-size:16px;font-weight:700;color:var(--ub-dark);margin-bottom:8px}
  .pd-how-step p{font-size:14px;color:var(--ub-muted);line-height:1.55;max-width:260px;margin:0 auto}

  /* Ingredients */
  .pd-ingr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
  .pd-ingr-card{background:#fff;border-radius:18px;overflow:hidden;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .pd-ingr-card:hover{box-shadow:0 8px 28px rgba(0,0,0,.06);transform:translateY(-2px)}
  .pd-ingr-img{width:100%;aspect-ratio:4/3;overflow:hidden;background:var(--ub-cream)}
  .pd-ingr-img img{width:100%;height:100%;object-fit:cover}
  .pd-ingr-body{padding:20px}
  .pd-ingr-body h4{font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:700;color:var(--ub-dark);margin-bottom:6px}
  .pd-ingr-body p{font-size:13px;color:var(--ub-muted);line-height:1.55}

  /* Testimonials */
  .pd-testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
  .pd-testi-card{background:var(--ub-cream);border-radius:20px;padding:32px;border:1px solid rgba(0,0,0,.04)}
  .pd-testi-stars{color:var(--ub-purple-main);font-size:14px;margin-bottom:14px;letter-spacing:2px}
  .pd-testi-text{font-size:14.5px;color:var(--ub-body);line-height:1.65;margin-bottom:20px}
  .pd-testi-verified{font-size:11.5px;color:var(--ub-purple-main);font-weight:600;margin-bottom:18px;display:flex;align-items:center;gap:4px}
  .pd-testi-author{display:flex;align-items:center;gap:12px}
  .pd-testi-avatar{width:36px;height:36px;border-radius:50%;background:var(--ub-purple-wash);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--ub-purple-main);font-size:15px;font-family:'Red Hat Display',sans-serif;flex-shrink:0}
  .pd-testi-name{font-size:14px;font-weight:600;color:var(--ub-dark)}
  .pd-testi-role{font-size:12px;color:var(--ub-muted)}

  /* FAQ */
  .pd-faq-list{margin-top:40px}
  .pd-faq-item{border-bottom:1px solid rgba(0,0,0,.07)}
  .pd-faq-q{padding:20px 0;font-size:15px;font-weight:600;color:var(--ub-dark);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:16px;user-select:none;font-family:'Red Hat Text',sans-serif}
  .pd-faq-q::after{content:'+';font-size:22px;color:var(--ub-purple-main);flex-shrink:0;transition:.2s;line-height:1}
  .pd-faq-item.open .pd-faq-q::after{content:'−'}
  .pd-faq-a{max-height:0;overflow:hidden;font-size:14px;line-height:1.7;color:var(--ub-body);transition:max-height .3s ease,padding .3s ease}
  .pd-faq-item.open .pd-faq-a{max-height:300px;padding-bottom:20px}

  /* Guarantee bar */
  .pd-guar-bar{padding:48px 40px;border-top:1px solid rgba(0,0,0,.06)}
  .pd-guar-grid{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:32px;text-align:center}
  .pd-guar-icon{width:44px;height:44px;margin:0 auto 12px}
  .pd-guar-icon img{width:100%;height:100%;object-fit:contain}
  .pd-guar-item h4{font-family:'Red Hat Display',sans-serif;font-size:14px;font-weight:700;color:var(--ub-dark);margin-bottom:4px}
  .pd-guar-item p{font-size:12.5px;color:var(--ub-muted)}

  /* CTA */
  .pd-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:100px;font-family:'Red Hat Text',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:.3s;border:none;background:var(--ub-purple-main);color:#fff;text-decoration:none}
  .pd-btn:hover{background:var(--ub-purple-deep);transform:translateY(-1px);box-shadow:0 6px 20px rgba(107,47,160,.3)}

  /* Responsive */
  @media(max-width:768px){
    .pd-section{padding:60px 20px}
    .pd-how-grid{grid-template-columns:1fr;gap:32px}
    .pd-ingr-grid{grid-template-columns:repeat(2,1fr)}
    .pd-testi-grid{grid-template-columns:1fr}
    .pd-guar-grid{grid-template-columns:repeat(2,1fr);gap:24px}
  }
  @media(max-width:480px){
    .pd-ingr-grid{grid-template-columns:1fr}
  }
</style>

