    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "the violet hour · est. 2024" },
    { "type": "text", "id": "hero_headline_pre", "label": "Headline — start", "default": "Crush the" },
    { "type": "text", "id": "hero_headline_em", "label": "Headline — italic emphasis", "default": "4 PM" },
    { "type": "text", "id": "hero_headline_post", "label": "Headline — end", "default": "crash." },
    { "type": "textarea", "id": "hero_sub", "label": "Hero sub", "default": "A violet wellness ritual. Plant-based satiety. 30 calories. Crafted in France." },
    { "type": "text", "id": "hero_cta", "label": "Hero CTA text", "default": "start my pack" }
