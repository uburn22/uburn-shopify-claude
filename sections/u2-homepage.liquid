{%- comment -%}
  UBurn V2 — Homepage (compact, 8 blocks composed inline)
  Order: Hero → Trust band → Formula grid → EFSA badge → Before/After → Craft → Final CTA → Newsletter
{%- endcomment -%}

{%- liquid
  assign hp = section.settings.product
  if hp == blank
    assign hp = all_products['ube-poudre']
  endif
  assign min_price = hp.price_min | default: hp.price
  assign display_price = min_price | money_without_trailing_zeros
  assign variant_id = section.settings.variant_id | default: '51289200034111'
  assign cta_link = hp.url
  if variant_id != blank
    assign cta_link = hp.url | append: '?variant=' | append: variant_id
  endif
-%}

<style>
  /* ========== HERO ========== */
  .u2-hero {
    position: relative;
    background: var(--u2-cream);
    padding: 32px 20px 56px;
    overflow: hidden;
    min-height: 88vh;
    display: flex;
    align-items: center;
    isolation: isolate;
  }
  .u2-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(58% 50% at 78% 30%, rgba(139, 111, 191, 0.22), transparent 70%),
      radial-gradient(50% 45% at 18% 82%, rgba(184, 157, 217, 0.18), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }
  .u2-hero__grid {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: center;
  }
  .u2-hero__copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
    order: 1;
  }
  .u2-hero__sub {
    font-size: 15px;
    line-height: 1.55;
    color: #3A2E4A;
    max-width: 34ch;
    margin: 4px 0 0;
  }
  .u2-hero__priceline {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 12px;
    font-size: 14px;
    color: var(--u2-plum);
    margin: 6px 0 4px;
  }
  .u2-hero__price-prefix {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
  }
  .u2-hero__price {
    font-size: 19px;
    font-weight: 700;
    color: var(--u2-plum-black);
    letter-spacing: -0.01em;
  }
  .u2-hero__price-divider { opacity: 0.4; }
  .u2-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
    list-style: none;
    padding: 0;
  }
  .u2-hero__media {
    position: relative;
    order: 2;
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .u2-hero__media::before {
    content: "";
    position: absolute;
    width: 78%; height: 78%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184,157,217,0.5), rgba(184,157,217,0) 65%);
    filter: blur(20px);
    z-index: 0;
  }
  .u2-hero__image {
    position: relative;
    z-index: 1;
    width: 92%;
    max-width: 520px;
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(58,31,89,0.45), 0 18px 36px -18px rgba(58,31,89,0.25);
    animation: u2-float 8s ease-in-out infinite alternate;
  }
  .u2-hero__image img {
    width: 100%; height: 100%; object-fit: cover;
  }
  @media (min-width: 1024px) {
    .u2-hero { padding: 64px 56px 96px; min-height: 92vh; }
    .u2-hero__grid { grid-template-columns: minmax(0,1.05fr) minmax(0,1fr); gap: 64px; }
    .u2-hero__copy { gap: 22px; }
    .u2-hero__media { order: 2; aspect-ratio: 4/5; }
    .u2-hero__image { max-width: 560px; aspect-ratio: 4/5; }
    .u2-hero__sub { font-size: 17px; max-width: 38ch; }
  }

  /* ========== TRUST BAND ========== */
  .u2-trustband {
    background: var(--u2-lavender-soft);
    padding: 18px 16px;
  }
  .u2-trustband__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px 28px;
    align-items: center;
  }
  .u2-trustband__sep {
    width: 1px; height: 12px;
    background: rgba(107, 78, 158, 0.25);
  }
  @media (min-width: 768px) {
    .u2-trustband { padding: 22px 24px; }
  }
  @media (max-width: 640px) {
    .u2-trustband__sep { display: none; }
  }

  /* ========== FORMULA GRID ========== */
  .u2-formula {
    background: var(--u2-plum-black);
    color: var(--u2-bone);
    padding: var(--u2-space-section) 20px;
  }
  .u2-formula__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .u2-formula__head {
    text-align: center;
    margin-bottom: 48px;
  }
  .u2-formula__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(34px,6vw,52px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--u2-bone);
    margin: 12px 0 12px;
  }
  .u2-formula__head h2 em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-lavender);
  }
  .u2-formula__head .u2-section-eyebrow { color: var(--u2-lavender); }
  .u2-formula__head .u2-section-eyebrow::before { background: var(--u2-lavender); }
  .u2-formula__head p {
    font-size: 15px;
    color: rgba(248,244,238,0.7);
    max-width: 52ch;
    margin: 12px auto 0;
  }
  .u2-formula__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 640px) { .u2-formula__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .u2-formula__grid { grid-template-columns: repeat(3, 1fr); } }
  .u2-formula__card {
    background: rgba(232,220,239,0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(184,157,217,0.18);
    border-radius: 20px;
    padding: 28px 24px;
    transition: transform .35s var(--u2-ease-smooth), border-color .35s var(--u2-ease-smooth);
  }
  .u2-formula__card:hover { transform: translateY(-4px); border-color: rgba(184,157,217,0.4); }
  .u2-formula__card--hero {
    background: linear-gradient(160deg, var(--u2-iris-deep) 0%, var(--u2-iris) 60%, var(--u2-iris-bright) 100%);
    border-color: transparent;
    grid-row: span 2;
  }
  @media (max-width: 1023px) {
    .u2-formula__card--hero { grid-row: span 1; grid-column: span 2; }
    @media (max-width: 639px) { .u2-formula__card--hero { grid-column: span 1; } }
  }
  .u2-formula__img {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 18px;
    background: var(--u2-plum-deep);
  }
  .u2-formula__img img { width:100%;height:100%;object-fit:cover; }
  .u2-formula__card--hero .u2-formula__img { aspect-ratio: 4/5; }
  .u2-formula__name {
    font-family: var(--u2-sans);
    font-size: 22px;
    font-weight: 700;
    color: var(--u2-bone);
    letter-spacing: -0.01em;
    margin: 0 0 4px;
  }
  .u2-formula__latin {
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 13px;
    color: var(--u2-lavender);
    margin: 0 0 12px;
  }
  .u2-formula__desc {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(248,244,238,0.75);
    margin: 0 0 14px;
  }
  .u2-formula__card--hero .u2-formula__desc { color: rgba(255,255,255,0.92); }
  .u2-formula__tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--u2-lavender);
    border: 1px solid rgba(184,157,217,0.4);
    border-radius: 999px;
    padding: 6px 12px;
  }
  .u2-formula__card--hero .u2-formula__tag {
    color: var(--u2-warm-white);
    border-color: rgba(255,255,255,0.4);
  }

  /* ========== EFSA BADGE ========== */
  .u2-efsa {
    background: var(--u2-lavender-soft);
    padding: var(--u2-space-section) 20px;
  }
  .u2-efsa__inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .u2-efsa__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    color: var(--u2-iris);
    padding: 8px 18px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 24px;
    box-shadow: 0 2px 12px rgba(107,78,158,0.12);
  }
  .u2-efsa__title {
    font-family: var(--u2-sans);
    font-size: clamp(32px,5vw,44px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 0 0 8px;
  }
  .u2-efsa__sub {
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--u2-iris);
    margin: 0 0 32px;
  }
  .u2-efsa__quote {
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: clamp(22px,3.5vw,28px);
    line-height: 1.4;
    color: var(--u2-plum-black);
    max-width: 28ch;
    margin: 0 auto 24px;
  }
  .u2-efsa__attribution {
    font-size: 13px;
    color: var(--u2-plum);
    line-height: 1.6;
    max-width: 44ch;
    margin: 0 auto;
  }

  /* ========== BEFORE / AFTER ========== */
  .u2-ba {
    background: var(--u2-cream);
    padding: var(--u2-space-section) 20px;
  }
  .u2-ba__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .u2-ba__head {
    text-align: center;
    margin-bottom: 48px;
  }
  .u2-ba__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(34px,5.5vw,48px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 12px 0 0;
  }
  .u2-ba__head h2 em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }
  .u2-ba__card {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(58,31,89,0.18);
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 56px auto;
  }
  @media (min-width: 768px) {
    .u2-ba__card { grid-template-columns: 1fr 56px 1fr; grid-template-rows: 1fr; }
  }
  .u2-ba__col { padding: 36px 32px; }
  .u2-ba__col--before { background: var(--u2-bone); }
  .u2-ba__col--after { background: white; }
  .u2-ba__divider {
    background: var(--u2-lavender-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .u2-ba__divider-icon {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--u2-iris);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }
  .u2-ba__pill {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 12px;
  }
  .u2-ba__pill--before {
    background: rgba(192,188,182,0.25);
    color: #5A5A5A;
  }
  .u2-ba__pill--after {
    background: rgba(107,78,158,0.15);
    color: var(--u2-iris);
  }
  .u2-ba__week {
    font-family: var(--u2-sans);
    font-size: 24px;
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.025em;
    margin: 0 0 16px;
  }
  .u2-ba__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .u2-ba__list li {
    font-size: 14px;
    line-height: 1.5;
    color: #3A2E4A;
    padding-left: 18px;
    position: relative;
  }
  .u2-ba__list li::before {
    content: '';
    position: absolute;
    left: 0; top: 8px;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: rgba(184,157,217,0.5);
  }
  .u2-ba__col--after .u2-ba__list li::before { background: var(--u2-iris); }
  .u2-ba__profile {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(107,78,158,0.15);
  }
  .u2-ba__avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--u2-lavender-soft);
  }
  .u2-ba__avatar img { width:100%; height:100%; object-fit:cover; }
  .u2-ba__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--u2-plum-black);
  }
  .u2-ba__meta {
    font-size: 12px;
    color: #7a7585;
    margin-top: 1px;
  }
  .u2-ba__disclaimer {
    text-align: center;
    margin-top: 24px;
    font-size: 11px;
    color: #7a7585;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  /* ========== CRAFT (Made in France) ========== */
  .u2-craft {
    background: linear-gradient(180deg, var(--u2-bone) 0%, var(--u2-lavender-soft) 100%);
    padding: var(--u2-space-section) 20px;
  }
  .u2-craft__inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .u2-craft__inner { grid-template-columns: 1fr 1fr; gap: 80px; }
  }
  .u2-craft__media {
    aspect-ratio: 4/5;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(58,31,89,0.3);
    position: relative;
  }
  .u2-craft__media img { width:100%;height:100%;object-fit:cover; }
  .u2-craft__tag {
    position: absolute;
    bottom: 18px; left: 18px;
    background: rgba(248,244,238,0.92);
    backdrop-filter: blur(10px);
    color: var(--u2-plum-black);
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .u2-craft__title {
    font-family: var(--u2-sans);
    font-size: clamp(34px,5vw,48px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 16px 0 16px;
  }
  .u2-craft__title em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }
  .u2-craft__body {
    font-size: 16px;
    line-height: 1.65;
    color: #3A2E4A;
    max-width: 44ch;
    margin: 0 0 36px;
  }
  .u2-craft__features {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 16px;
  }
  .u2-craft__feature {
    background: white;
    border-radius: 12px;
    padding: 18px;
    text-align: center;
  }
  .u2-craft__feature-num {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 32px;
    color: var(--u2-iris);
    line-height: 1;
    margin-bottom: 4px;
  }
  .u2-craft__feature-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--u2-plum);
    line-height: 1.3;
  }

  /* ========== FINAL CTA ========== */
  .u2-final {
    background: linear-gradient(135deg, var(--u2-plum-deep) 0%, var(--u2-iris-deep) 100%);
    color: var(--u2-warm-white);
    padding: calc(var(--u2-space-section) + 24px) 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .u2-final::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(40% 35% at 15% 20%, rgba(184,157,217,0.35), transparent 70%),
      radial-gradient(45% 40% at 85% 80%, rgba(139,111,191,0.35), transparent 70%);
    pointer-events: none;
  }
  .u2-final__inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .u2-final__eyebrow {
    color: var(--u2-lavender);
    margin-bottom: 16px;
  }
  .u2-final__eyebrow::before { background: var(--u2-lavender); }
  .u2-final__title {
    font-family: var(--u2-sans);
    font-size: clamp(40px,7vw,72px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--u2-warm-white);
    margin: 0 0 16px;
  }
  .u2-final__title em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-lavender);
  }
  .u2-final__sub {
    font-size: 17px;
    line-height: 1.55;
    color: rgba(255,255,255,0.85);
    max-width: 44ch;
    margin: 0 auto 36px;
  }
  .u2-final__meta {
    margin-top: 24px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-lavender);
    opacity: 0.9;
  }

  /* ========== NEWSLETTER ========== */
  .u2-news {
    background: var(--u2-bone);
    padding: var(--u2-space-section) 20px;
    text-align: center;
  }
  .u2-news__inner {
    max-width: 600px;
    margin: 0 auto;
  }
  .u2-news__title {
    font-family: var(--u2-sans);
    font-size: clamp(28px,4.5vw,40px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 12px 0 12px;
  }
  .u2-news__title em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }
  .u2-news__sub {
    font-size: 15px;
    color: #3A2E4A;
    line-height: 1.55;
    margin: 0 0 28px;
  }
  .u2-news__form {
    display: flex;
    gap: 8px;
    max-width: 460px;
    margin: 0 auto;
    flex-wrap: wrap;
    justify-content: center;
  }
  .u2-news__input {
    flex: 1;
    min-width: 240px;
    padding: 14px 18px;
    border: 1.5px solid rgba(107,78,158,0.2);
    border-radius: 999px;
    background: white;
    font-family: var(--u2-sans);
    font-size: 14px;
    color: var(--u2-plum-black);
  }
  .u2-news__input:focus {
    outline: 2px solid var(--u2-iris);
    outline-offset: 2px;
    border-color: var(--u2-iris);
  }
  .u2-news__privacy {
    font-size: 11px;
    color: #7a7585;
    margin-top: 16px;
  }
  .u2-news__privacy a { color: var(--u2-iris); text-decoration: underline; }
</style>

<div class="u2-root">

  {%- comment -%} ═══ HERO ═══ {%- endcomment -%}
  <section class="u2-hero" aria-label="UBurn — Crush the 4 PM crash">
    <div class="u2-hero__grid">
      <div class="u2-hero__copy u2-reveal">
        <span class="u2-eyebrow">{{ section.settings.hero_eyebrow | default: 'the violet hour · est. 2024' }}</span>
        <h1 class="u2-h1-hero">
          {{ section.settings.hero_headline_pre | default: 'Crush the' }} <em>{{ section.settings.hero_headline_em | default: '4 PM' }}</em> {{ section.settings.hero_headline_post | default: 'crash.' }}
        </h1>
        <p class="u2-hero__sub">{{ section.settings.hero_sub | default: 'A violet wellness ritual. Plant-based satiety. 30 calories. Crafted in France.' }}</p>

        {%- if hp != blank -%}
        <p class="u2-hero__priceline">
          <span class="u2-hero__price-prefix">from</span>
          <span class="u2-hero__price">{{ display_price }}</span>
          <span class="u2-hero__price-divider">·</span>
          <span>free us shipping</span>
        </p>
        {%- endif -%}

        {% render 'u2-cta-primary', text: section.settings.hero_cta | default: 'start my pack', link: cta_link %}

        <ul class="u2-hero__trust">
          <li>{% render 'u2-trust-pill', icon: 'check', text: 'EFSA-backed' %}</li>
          <li>{% render 'u2-trust-pill', icon: 'leaf', text: 'Caffeine-free' %}</li>
