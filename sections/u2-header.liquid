{%- comment -%}
  UBurn V2 — Header (sticky glassmorphism, mobile drawer)
{%- endcomment -%}
<style>
  .u2-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(248, 244, 238, 0.88);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(107, 78, 158, 0);
    transition: border-color 0.3s var(--u2-ease-smooth),
                background 0.3s var(--u2-ease-smooth);
  }
  .u2-header.is-scrolled {
    background: rgba(248, 244, 238, 0.96);
    border-bottom-color: rgba(107, 78, 158, 0.12);
  }
  .u2-header__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 14px 20px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
  }
  .u2-header__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .u2-header__nav {
    display: none;
  }
  .u2-header__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    justify-self: end;
  }
  .u2-header__icon-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: transparent;
    border: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--u2-plum-black);
    position: relative;
    transition: background 0.2s var(--u2-ease-smooth);
  }
  .u2-header__icon-btn:hover {
    background: rgba(107, 78, 158, 0.08);
  }
  .u2-header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    background: var(--u2-iris);
    color: white;
    font-size: 9px;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .u2-header__cta {
    display: none;
    background: var(--u2-iris);
    color: white;
    padding: 10px 22px;
    border-radius: 999px;
    font-family: var(--u2-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    text-decoration: none;
    transition: background 0.2s var(--u2-ease-smooth);
  }
  .u2-header__cta:hover {
    background: var(--u2-iris-deep);
  }

  @media (min-width: 1024px) {
    .u2-header__inner {
      grid-template-columns: 1fr auto 1fr;
      padding: 18px 32px;
    }
    .u2-header__logo {
      justify-self: start;
    }
    .u2-header__nav {
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
      margin: 0;
      padding: 0;
      justify-self: center;
    }
    .u2-header__nav a {
      font-family: var(--u2-sans);
      font-size: 14px;
      font-weight: 500;
      color: var(--u2-plum);
      letter-spacing: 0.02em;
      text-decoration: none;
      transition: color 0.2s var(--u2-ease-smooth);
    }
    .u2-header__nav a:hover {
      color: var(--u2-iris);
    }
    .u2-header__cta { display: inline-flex; align-items: center; }
    .u2-header__menu-btn { display: none; }
  }

  /* Mobile drawer */
  .u2-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(26, 15, 46, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s var(--u2-ease-smooth),
                visibility 0s 0.3s linear;
  }
  .u2-drawer.is-open {
    opacity: 1;
    visibility: visible;
    transition-delay: 0s;
  }
  .u2-drawer__panel {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 88%;
    max-width: 420px;
    background: var(--u2-cream);
    padding: 24px;
    transform: translateX(-100%);
    transition: transform 0.4s var(--u2-ease-liquid);
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow-y: auto;
  }
  .u2-drawer.is-open .u2-drawer__panel {
    transform: translateX(0);
  }
  .u2-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(107, 78, 158, 0.15);
  }
  .u2-drawer__close {
    background: transparent;
    border: 0;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--u2-plum-black);
  }
  .u2-drawer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .u2-drawer__nav a {
    font-family: var(--u2-sans);
    font-size: 22px;
    font-weight: 700;
    color: var(--u2-plum-black);
    letter-spacing: -0.01em;
    text-decoration: none;
  }
  .u2-drawer__nav a:hover { color: var(--u2-iris); }
  .u2-drawer__cta {
    margin-top: auto;
  }

  @media (min-width: 1024px) {
    .u2-drawer { display: none; }
  }
</style>

<header class="u2-root u2-header" data-u2-header>
  <div class="u2-header__inner">
    <a href="/" class="u2-header__logo" aria-label="UBurn — Home">
      {% render 'u2-logo-wordmark', size: 24, color: 'plum-black' %}
    </a>

    <nav class="u2-header__nav" aria-label="Primary navigation">
      <a href="/products/{{ section.settings.product_handle | default: 'ube-poudre' }}">{{ section.settings.nav_1 | default: 'Shop' }}</a>
      <a href="/pages/the-science">{{ section.settings.nav_2 | default: 'The science' }}</a>
      <a href="/pages/our-story">{{ section.settings.nav_3 | default: 'Our story' }}</a>
      <a href="/pages/reviews">{{ section.settings.nav_4 | default: 'Reviews' }}</a>
      <a href="/pages/contact">{{ section.settings.nav_5 | default: 'Contact' }}</a>
    </nav>

    <div class="u2-header__actions">
      <a class="u2-header__cta" href="/products/{{ section.settings.product_handle | default: 'ube-poudre' }}">start the ritual</a>
      <a class="u2-header__icon-btn" href="/cart" aria-label="Cart">
        {% render 'u2-icon', name: 'cart', size: 20 %}
        {% if cart.item_count > 0 %}<span class="u2-header__cart-count">{{ cart.item_count }}</span>{% endif %}
      </a>
      <button class="u2-header__icon-btn u2-header__menu-btn" type="button" data-u2-drawer-trigger aria-label="Open menu">
        {% render 'u2-icon', name: 'menu', size: 22 %}
      </button>
    </div>
  </div>
</header>

<div class="u2-root u2-drawer" data-u2-drawer aria-hidden="true">
  <div class="u2-drawer__panel" role="dialog" aria-label="Mobile navigation">
    <div class="u2-drawer__header">
      <a href="/" class="u2-header__logo" aria-label="UBurn — Home">
        {% render 'u2-logo-wordmark', size: 22, color: 'plum-black' %}
      </a>
      <button class="u2-drawer__close" type="button" data-u2-drawer-close aria-label="Close menu">
        {% render 'u2-icon', name: 'close', size: 22 %}
      </button>
    </div>
    <nav>
      <ul class="u2-drawer__nav">
        <li><a href="/products/{{ section.settings.product_handle | default: 'ube-poudre' }}">Shop</a></li>
        <li><a href="/pages/the-science">The science</a></li>
        <li><a href="/pages/our-story">Our story</a></li>
        <li><a href="/pages/reviews">Reviews</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </nav>
    <div class="u2-drawer__cta">
      {% render 'u2-cta-primary', text: 'order — from $34.50', link: '/products/ube-poudre', full_width: true %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "U2 Header",
  "tag": "section",
  "class": "shopify-section--u2-header",
  "settings": [
    { "type": "text", "id": "product_handle", "label": "Primary product handle", "default": "ube-poudre" },
    { "type": "text", "id": "nav_1", "label": "Nav link 1", "default": "Shop" },
    { "type": "text", "id": "nav_2", "label": "Nav link 2", "default": "The science" },
    { "type": "text", "id": "nav_3", "label": "Nav link 3", "default": "Our story" },
    { "type": "text", "id": "nav_4", "label": "Nav link 4", "default": "Reviews" },
    { "type": "text", "id": "nav_5", "label": "Nav link 5", "default": "Contact" }
  ],
  "presets": [
    { "name": "U2 Header" }
  ]
}
{% endschema %}
