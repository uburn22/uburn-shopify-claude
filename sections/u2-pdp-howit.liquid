{%- comment -%}
  UBurn V2 — PDP "How it works" — 3-step mechanism (Mix · Glucomannan gel · Stay full)
{%- endcomment -%}
<style>
  .u2-pdp-howit { padding: 80px 20px; background: var(--u2-cream); }
  .u2-pdp-howit__inner { max-width: 1200px; margin: 0 auto; }
  .u2-pdp-howit__head { text-align: center; margin-bottom: 56px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .u2-pdp-howit__eyebrow {
    display: inline-block;
    font-family: var(--u2-sans);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .u2-pdp-howit__title {
    font-family: var(--u2-serif);
    font-size: 42px;
    line-height: 1.1;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }
  .u2-pdp-howit__title em { font-style: italic; color: var(--u2-iris); }
  .u2-pdp-howit__lead {
    font-family: var(--u2-sans);
    font-size: 16px;
    color: var(--u2-plum);
    margin: 0;
  }
  .u2-pdp-howit__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .u2-pdp-howit-card {
    background: var(--u2-cream);
    border-radius: 20px;
    padding: 36px 28px;
    box-shadow: 0 4px 24px rgba(42, 16, 84, 0.06);
    border: 1px solid rgba(107, 78, 158, 0.08);
    position: relative;
  }
  .u2-pdp-howit-card__num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--u2-iris);
    color: white;
    font-family: var(--u2-sans);
    font-size: 16px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .u2-pdp-howit-card__title {
    font-family: var(--u2-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--u2-plum-black);
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .u2-pdp-howit-card__copy {
    font-family: var(--u2-sans);
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--u2-plum);
    margin: 0;
  }
  .u2-pdp-howit__legal {
    margin-top: 32px;
    background: rgba(107, 78, 158, 0.04);
    border-radius: 14px;
    padding: 20px 24px;
  }
  .u2-pdp-howit__legal summary {
    font-family: var(--u2-sans);
    font-size: 13px;
    font-weight: 700;
    color: var(--u2-iris-deep);
    cursor: pointer;
    letter-spacing: 0.02em;
    list-style: none;
  }
  .u2-pdp-howit__legal summary::after { content: '+'; float: right; font-size: 18px; line-height: 1; }
  .u2-pdp-howit__legal[open] summary::after { content: '−'; }
  .u2-pdp-howit__legal p {
    margin: 12px 0 0;
    font-family: var(--u2-sans);
    font-size: 13px;
    line-height: 1.6;
    color: var(--u2-plum);
  }
  @media (max-width: 900px) {
    .u2-pdp-howit { padding: 60px 16px; }
    .u2-pdp-howit__grid { grid-template-columns: 1fr; gap: 16px; }
    .u2-pdp-howit__title { font-size: 30px; }
  }
</style>
<section class="u2-root u2-pdp-howit" aria-labelledby="u2-pdp-howit-title">
  <div class="u2-pdp-howit__inner">
    <div class="u2-pdp-howit__head">
      <span class="u2-pdp-howit__eyebrow">{{ section.settings.eyebrow | default: 'How it works' }}</span>
      <h2 class="u2-pdp-howit__title" id="u2-pdp-howit-title">{{ section.settings.title | default: 'How UBurn <em>helps calm cravings naturally.*</em>' }}</h2>
      <p class="u2-pdp-howit__lead">{{ section.settings.lead | default: 'Mix. Sip. Konjac does the work.*' }}</p>
    </div>
    <ol class="u2-pdp-howit__grid">
      {% for block in section.blocks %}
        <li class="u2-pdp-howit-card" {{ block.shopify_attributes }}>
          <div class="u2-pdp-howit-card__num">{{ forloop.index | prepend: '0' }}</div>
          <h3 class="u2-pdp-howit-card__title">{{ block.settings.title }}</h3>
          <p class="u2-pdp-howit-card__copy">{{ block.settings.copy }}</p>
        </li>
      {% else %}
        <li class="u2-pdp-howit-card"><div class="u2-pdp-howit-card__num">01</div><h3 class="u2-pdp-howit-card__title">You mix</h3><p class="u2-pdp-howit-card__copy">One scoop in water, milk, or plant-based milk depending on the texture you prefer.</p></li>
        <li class="u2-pdp-howit-card"><div class="u2-pdp-howit-card__num">02</div><h3 class="u2-pdp-howit-card__title">Glucomannan absorbs water</h3><p class="u2-pdp-howit-card__copy">This konjac-derived fiber forms a natural gel on contact with water.</p></li>
        <li class="u2-pdp-howit-card"><div class="u2-pdp-howit-card__num">03</div><h3 class="u2-pdp-howit-card__title">You stay full longer*</h3><p class="u2-pdp-howit-card__copy">A simple way to get through the moments when you would normally snack.*</p></li>
      {% endfor %}
    </ol>
    <details class="u2-pdp-howit__legal">
      <summary>{{ section.settings.legal_summary | default: 'Recommended use guidelines' }}</summary>
      <p>{{ section.settings.legal_body | default: 'Recommended use: 3g/day in 3 doses of 1g, with 1-2 large glasses of water before meals, as part of a healthy lifestyle.*' }}</p>
    </details>
  </div>
</section>
{% schema %}
{
  "name": "U2 PDP How It Works",
  "tag": "section",
  "class": "shopify-section--u2",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it works" },
    { "type": "text", "id": "title", "label": "Title (em supported)", "default": "How UBurn <em>helps calm cravings naturally.*</em>" },
    { "type": "text", "id": "lead", "label": "Lead", "default": "Mix. Sip. Konjac does the work.*" },
    { "type": "text", "id": "legal_summary", "label": "Legal accordion title", "default": "Recommended use guidelines" },
    { "type": "textarea", "id": "legal_body", "label": "Legal body" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Step title" },
        { "type": "textarea", "id": "copy", "label": "Step copy" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "U2 PDP How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "You mix", "copy": "One scoop in water, milk, or plant-based milk depending on the texture you prefer." } },
        { "type": "step", "settings": { "title": "Glucomannan absorbs water", "copy": "This konjac-derived fiber forms a natural gel on contact with water." } },
        { "type": "step", "settings": { "title": "You stay full longer*", "copy": "A simple way to get through the moments when you would normally snack.*" } }
      ]
    }
  ]
}
{% endschema %}
