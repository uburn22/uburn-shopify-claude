{%- comment -%}
  UBurn V2 — Header (hamburger LEFT, logo center, cart right — all viewports)
  Drawer slide-in from LEFT with logo + 6 pages + social + email
  Cache-bust 2026-05-15-T08-40
{%- endcomment -%}
<style>
  .u2-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(248, 244, 238, 0.88);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(107, 78, 158, 0);
    transition: border-color 0.3s var(--u2-ease-smooth),
                background 0.3s var(--u2-ease-smooth);
  }
  .u2-header.is-scrolled {
    background: rgba(248, 244, 238, 0.96);
    border-bottom-color: rgba(107, 78, 158, 0.12);
  }
  .u2-header__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 14px 20px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
  }
  .u2-header__menu-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: transparent;
    border: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--u2-plum-black);
    transition: background 0.2s var(--u2-ease-smooth);
    justify-self: start;
  }
  .u2-header__menu-btn:hover {
    background: rgba(107, 78, 158, 0.08);
  }
  .u2-header__menu-icon {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    align-items: flex-start;
    width: 22px;
  }
  .u2-header__menu-icon span {
    display: block;
    height: 1.8px;
    background: currentColor;
    border-radius: 1px;
    transition: width 0.25s var(--u2-ease-smooth),
                transform 0.25s var(--u2-ease-smooth);
  }
  .u2-header__menu-icon span:nth-child(1) { width: 22px; }
  .u2-header__menu-icon span:nth-child(2) { width: 16px; }
  .u2-header__menu-icon span:nth-child(3) { width: 22px; }
  .u2-header__menu-btn:hover .u2-header__menu-icon span:nth-child(2) {
    width: 22px;
  }
  .u2-header__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    justify-self: center;
  }
  .u2-header__actions {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-self: end;
  }
  .u2-header__icon-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: transparent;
    border: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--u2-plum-black);
    text-decoration: none;
    position: relative;
    transition: background 0.2s var(--u2-ease-smooth);
  }
  .u2-header__icon-btn:hover {
    background: rgba(107, 78, 158, 0.08);
  }
  .u2-header__cart-count {
    position: absolute;
    top: 6px;
    right: 6px;
    background: var(--u2-iris);
    color: white;
    font-size: 9px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .u2-header__inner {
      padding: 18px 32px;
    }
  }

  /* Drawer slide from LEFT */
  .u2-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(26, 15, 46, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s var(--u2-ease-smooth),
                visibility 0s 0.35s linear;
  }
  .u2-drawer.is-open {
    opacity: 1;
    visibility: visible;
    transition-delay: 0s;
  }
  .u2-drawer__panel {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 88%;
    max-width: 440px;
    background: var(--u2-cream);
    padding: 28px 32px;
    transform: translateX(-100%);
    transition: transform 0.45s var(--u2-ease-liquid);
    display: flex;
    flex-direction: column;
    gap: 28px;
    overflow-y: auto;
    box-shadow: 8px 0 60px rgba(26, 15, 46, 0.18);
  }
  .u2-drawer.is-open .u2-drawer__panel {
    transform: translateX(0);
  }
  .u2-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(107, 78, 158, 0.15);
  }
  .u2-drawer__close {
    background: transparent;
    border: 0;
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--u2-plum-black);
  }
  .u2-drawer__close:hover { background: rgba(107, 78, 158, 0.08); }
  .u2-drawer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .u2-drawer__nav a {
    display: block;
    font-family: var(--u2-serif);
    font-size: 32px;
    font-weight: 400;
    color: var(--u2-plum-black);
    letter-spacing: -0.02em;
    line-height: 1.1;
    text-decoration: none;
    padding: 10px 0;
    transition: color 0.2s var(--u2-ease-smooth), transform 0.2s var(--u2-ease-smooth);
  }
  .u2-drawer__nav a:hover {
    color: var(--u2-iris);
    transform: translateX(4px);
  }
  .u2-drawer__nav em {
    font-style: italic;
    color: var(--u2-iris);
  }
  .u2-drawer__cta {
    margin-top: 12px;
  }
  .u2-drawer__footer {
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid rgba(107, 78, 158, 0.15);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .u2-drawer__social {
    display: flex;
    gap: 12px;
  }
  .u2-drawer__social a {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(107, 78, 158, 0.08);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--u2-plum-black);
    text-decoration: none;
    transition: background 0.2s var(--u2-ease-smooth), color 0.2s var(--u2-ease-smooth);
  }
  .u2-drawer__social a:hover {
    background: var(--u2-iris);
    color: white;
  }
  .u2-drawer__contact {
    font-family: var(--u2-sans);
    font-size: 13px;
    color: var(--u2-plum);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .u2-drawer__contact:hover { color: var(--u2-iris); }
  .u2-drawer__legal {
    font-family: var(--u2-sans);
    font-size: 11px;
    color: var(--u2-mauve);
    letter-spacing: 0.04em;
  }
</style>

<header class="u2-root u2-header" data-u2-header>
  <div class="u2-header__inner">
    <button class="u2-header__menu-btn" type="button" data-u2-drawer-trigger aria-label="Open menu" aria-expanded="false">
      <span class="u2-header__menu-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <a href="/" class="u2-header__logo" aria-label="UBurn — Home">
      {% render 'u2-logo-wordmark', size: 24, color: 'plum-black' %}
    </a>

    <div class="u2-header__actions">
      <a class="u2-header__icon-btn" href="/cart" aria-label="Cart" data-u2-cart-trigger>
        {% render 'u2-icon', name: 'cart', size: 20 %}
        {% if cart.item_count > 0 %}<span class="u2-header__cart-count">{{ cart.item_count }}</span>{% endif %}
      </a>
    </div>
  </div>
</header>

<div class="u2-root u2-drawer" data-u2-drawer aria-hidden="true">
  <div class="u2-drawer__panel" role="dialog" aria-label="Site navigation" aria-modal="true">
    <div class="u2-drawer__header">
      <a href="/" class="u2-header__logo" aria-label="UBurn — Home">
        {% render 'u2-logo-wordmark', size: 22, color: 'plum-black' %}
      </a>
      <button class="u2-drawer__close" type="button" data-u2-drawer-close aria-label="Close menu">
        {% render 'u2-icon', name: 'close', size: 22 %}
      </button>
    </div>
    <nav aria-label="Primary navigation">
      <ul class="u2-drawer__nav">
        <li><a href="/products/{{ section.settings.product_handle | default: 'ube-poudre' }}">{{ section.settings.nav_1 | default: 'Shop the ritual' }}</a></li>
        <li><a href="/pages/the-science">{{ section.settings.nav_2 | default: 'The science' }}</a></li>
        <li><a href="/pages/our-story">{{ section.settings.nav_3 | default: 'Our story' }}</a></li>
        <li><a href="/pages/reviews">{{ section.settings.nav_4 | default: 'Reviews' }}</a></li>
        <li><a href="/pages/faq">{{ section.settings.nav_5 | default: 'FAQ' }}</a></li>
        <li><a href="/pages/contact">{{ section.settings.nav_6 | default: 'Contact' }}</a></li>
      </ul>
    </nav>
    <div class="u2-drawer__cta">
      {% render 'u2-cta-primary', text: 'order — from $34.50', link: '/products/ube-poudre', full_width: true %}
    </div>
    <div class="u2-drawer__footer">
      <div class="u2-drawer__social" aria-label="Follow us">
        <a href="{{ section.settings.instagram_url | default: 'https://instagram.com/uburn.co' }}" aria-label="Instagram" rel="noopener" target="_blank">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"/></svg>
        </a>
        <a href="{{ section.settings.tiktok_url | default: 'https://tiktok.com/@uburn.co' }}" aria-label="TikTok" rel="noopener" target="_blank">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z"/></svg>
        </a>
      </div>
      <a class="u2-drawer__contact" href="mailto:hello@uburn.co">
        {% render 'u2-icon', name: 'mail', size: 14 %} hello@uburn.co
      </a>
      <div class="u2-drawer__legal">© {{ 'now' | date: '%Y' }} UBurn · French brand · Made for the U.S.</div>
    </div>
  </div>
</div>

<script>
(function(){
  const drawer = document.querySelector('[data-u2-drawer]');
  if(!drawer) return;
  const trigger = document.querySelector('[data-u2-drawer-trigger]');
  const closeBtn = document.querySelector('[data-u2-drawer-close]');
  const openDrawer = () => {
    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden','false');
    if(trigger) trigger.setAttribute('aria-expanded','true');
    document.body.style.overflow = 'hidden';
  };
  const closeDrawer = () => {
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden','true');
    if(trigger) trigger.setAttribute('aria-expanded','false');
    document.body.style.overflow = '';
  };
  if(trigger) trigger.addEventListener('click', openDrawer);
  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
  drawer.addEventListener('click', (e) => { if(e.target === drawer) closeDrawer(); });
  document.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeDrawer(); });
  // Sticky scroll state
  const header = document.querySelector('[data-u2-header]');
  if(header){
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 8);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
})();
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "shopify-section--u2-header",
  "settings": [
    { "type": "text", "id": "product_handle", "label": "Primary product handle", "default": "ube-poudre" },
    { "type": "text", "id": "nav_1", "label": "Nav 1", "default": "Shop the ritual" },
    { "type": "text", "id": "nav_2", "label": "Nav 2", "default": "The science" },
    { "type": "text", "id": "nav_3", "label": "Nav 3", "default": "Our story" },
    { "type": "text", "id": "nav_4", "label": "Nav 4", "default": "Reviews" },
    { "type": "text", "id": "nav_5", "label": "Nav 5", "default": "FAQ" },
    { "type": "text", "id": "nav_6", "label": "Nav 6", "default": "Contact" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" }
  ],
  "presets": [
    { "name": "Header" }
  ]
}
{% endschema %}
