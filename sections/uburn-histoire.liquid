    touch-action:manipulation; -webkit-tap-highlight-color:transparent;
  }
  .uhist3-cta-primary:hover { background:var(--up-purple-deep); transform:translateY(-2px); box-shadow:0 12px 36px rgba(107,47,160,.4); }

