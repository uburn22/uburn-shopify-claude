  .uhist3-formule__head { max-width:760px; margin:0 auto 32px; }
  .uhist3-formule__head .uhist3-h2 { color:var(--up-purple-deep); }
  .uhist3-formule__lead { max-width:620px; margin:0 auto 28px; }
  .uhist3-formule__pills {
    list-style:none; padding:0; margin:0;
    max-width:980px; margin-left:auto; margin-right:auto;
    display:flex; flex-wrap:wrap; justify-content:center; gap:10px;
  }
  .uhist3-formule__pill {
    display:inline-flex; align-items:center; gap:8px;
    padding:10px 16px;
    background:var(--up-purple-wash); color:var(--up-purple-deep);
    border:1px solid var(--up-purple-pale); border-radius:100px;
    font-family:'Red Hat Display',sans-serif; font-size:13.5px; font-weight:700;
    letter-spacing:.2px;
  }
  .uhist3-formule__pill::before {
    content:'·'; color:var(--up-purple-main); font-size:18px; line-height:0;
    margin-right:2px;
  }

  /* SIMPLE EFFICACE — 3 steps */
