  }
  .uhist3-h1 .accent { color:var(--up-purple-mid); }
  .uhist3-h2 {
    font-family:'Red Hat Display',sans-serif; font-size:clamp(28px,3.5vw,44px);
    font-weight:700; line-height:1.1; letter-spacing:-0.02em;
