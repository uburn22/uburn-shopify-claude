<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

<style>
main#main, .main-content { padding-top: 0 !important; margin-top: 0 !important; }
.uhist-root { font-family: 'Red Hat Text', sans-serif; -webkit-font-smoothing: antialiased; color: var(--uhome-dark); overflow-x: hidden; }
.uhist-root *, .uhist-root *::before, .uhist-root *::after { box-sizing: border-box; }
.uhist-root img { display: block; max-width: 100%; }
.uhist-root a { color: inherit; text-decoration: none; }

/* ── LABELS + TITRES ──────────────────────────────────────────────────── */
.uhist-label {
  display: block;
  font-family: 'Red Hat Text', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
  color: var(--uhome-purple-main); margin-bottom: 12px;
}
.uhist-label--light { color: rgba(255,255,255,.5); }
.uhist-h2 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(32px,4.5vw,54px); font-weight: 900;
  line-height: 1.08; letter-spacing: -.03em; color: var(--uhome-dark); text-wrap: balance;
}
.uhist-h2 em { font-style: italic; color: var(--uhome-purple-main); }
.uhist-h2--white { color: #fff; }
.uhist-h2--white em { color: var(--uhome-purple-light); }

/* ── ANIMATIONS ───────────────────────────────────────────────────────── */
@keyframes uhist-pulse { 0%,100%{box-shadow:0 4px 20px rgba(107,47,160,.25)} 50%{box-shadow:0 8px 40px rgba(107,47,160,.55)} }
@keyframes uhist-shimmer { from{background-position:-200% center} to{background-position:200% center} }
@keyframes uhist-feat-glow { 0%,100%{box-shadow:0 0 0 0 rgba(176,125,232,0)} 50%{box-shadow:0 0 0 3px rgba(176,125,232,.28)} }
@keyframes uhist-line-grow { from{width:14px} to{width:36px} }

.uhist-reveal {
  opacity: 0; transform: translateY(28px);
  transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
}
.uhist-reveal.visible { opacity: 1; transform: none; }
.uhist-reveal.rd1 { transition-delay: .1s; }
.uhist-reveal.rd2 { transition-delay: .2s; }
.uhist-reveal.rd3 { transition-delay: .32s; }

.uhist-stagger > * {
  opacity: 0; transform: translateY(22px);
  transition: opacity .55s cubic-bezier(.22,1,.36,1), transform .55s cubic-bezier(.22,1,.36,1);
}
.uhist-stagger.visible > *:nth-child(1) { opacity:1; transform:none; transition-delay:0s; }
.uhist-stagger.visible > *:nth-child(2) { opacity:1; transform:none; transition-delay:.08s; }
.uhist-stagger.visible > *:nth-child(3) { opacity:1; transform:none; transition-delay:.16s; }
.uhist-stagger.visible > *:nth-child(4) { opacity:1; transform:none; transition-delay:.24s; }
.uhist-stagger.visible > *:nth-child(5) { opacity:1; transform:none; transition-delay:.32s; }
.uhist-stagger.visible > *:nth-child(6) { opacity:1; transform:none; transition-delay:.40s; }

/* ── HERO ─────────────────────────────────────────────────────────────── */
.uhist-hero {
  position: relative; height: 88vh; min-height: 560px;
  display: grid; grid-template-columns: 1fr 1fr; overflow: hidden;
}
.uhist-hero-photo { position: relative; overflow: hidden; }
.uhist-hero-photo img {
  width: 100%; height: 100%; object-fit: cover; object-position: center 30%;
  transform: scale(1.05); transition: transform 8s ease;
}
.uhist-hero-photo.loaded img { transform: scale(1); }
.uhist-hero-text {
  background: linear-gradient(145deg, #1e0840 0%, #3d1873 40%, #6b2fa0 75%, #8b47c5 100%);
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 80px 64px; position: relative; overflow: hidden;
}
.uhist-hero-text::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at top right, rgba(139,71,197,.28) 0%, transparent 55%);
  pointer-events: none;
}
.uhist-hero-eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
  color: rgba(255,255,255,.45); margin-bottom: 22px;
  display: flex; align-items: center; gap: 10px; position: relative; z-index: 1;
}
.uhist-hero-eyebrow::before { content:''; width:22px; height:1px; background:rgba(255,255,255,.3); }
.uhist-hero h1 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(44px,5.5vw,68px); font-weight: 900;
  color: #fff; line-height: 1.05; margin-bottom: 22px;
  letter-spacing: -.03em; text-wrap: balance; position: relative; z-index: 1;
}
.uhist-hero h1 em { font-style: italic; color: var(--uhome-purple-light); }
.uhist-hero-sub {
  font-size: 16px; color: rgba(255,255,255,.62);
  line-height: 1.7; max-width: 38ch; margin-bottom: 36px;
  position: relative; z-index: 1;
}
.uhist-hero-scroll {
  font-size: 11px; color: rgba(255,255,255,.28);
  display: flex; align-items: center; gap: 8px;
  font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  position: relative; z-index: 1;
}
.uhist-hero-scroll::after {
  content: ''; width: 28px; height: 1px; background: rgba(255,255,255,.2);
  animation: uhist-line-grow 2s ease-in-out infinite alternate;
}
@media(max-width:768px){
  .uhist-hero { grid-template-columns: 1fr; height: auto; }
  .uhist-hero-photo { height: 45vh; }
  .uhist-hero-text { padding: 48px 24px; }
}

/* ── CONVICTION ───────────────────────────────────────────────────────── */
.uhist-conviction { padding: 100px 40px; background: var(--uhome-cream); }
.uhist-conviction-inner {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; align-items: center;
}
.uhist-conviction-body {
  font-size: 16px; color: var(--uhome-body); line-height: 1.75;
  display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px; max-width: 52ch;
}
.uhist-conviction-body strong { color: var(--uhome-dark); font-weight: 600; }
.uhist-pull {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 20px; font-weight: 800; color: var(--uhome-purple-deep);
  line-height: 1.35; letter-spacing: -.02em;
  padding: 28px 32px; background: var(--uhome-purple-wash); border-radius: 20px;
  position: relative; max-width: 44ch;
}
.uhist-pull::before {
  content: '\201C'; position: absolute; top: -10px; left: 20px;
  font-size: 72px; color: var(--uhome-purple-pale);
  font-family: 'Red Hat Display', sans-serif; line-height: 1;
}
.uhist-conviction-visual { position: relative; }
.uhist-conviction-img { border-radius: 24px; overflow: hidden; aspect-ratio: 3/4; }
.uhist-conviction-img img { width: 100%; height: 100%; object-fit: cover; }
.uhist-conviction-badge {
  position: absolute; bottom: 28px; right: -20px;
  background: #fff; border-radius: 18px; padding: 18px 24px;
  box-shadow: 0 8px 40px rgba(61,24,115,.18); min-width: 170px;
}
.uhist-conviction-badge-num {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 38px; font-weight: 900; color: var(--uhome-purple-deep);
  letter-spacing: -.04em; line-height: 1;
}
.uhist-conviction-badge-lbl { font-size: 12px; color: var(--uhome-body); margin-top: 4px; font-weight: 500; }
@media(max-width:900px){
  .uhist-conviction { padding: 72px 24px; }
  .uhist-conviction-inner { grid-template-columns: 1fr; gap: 48px; }
  .uhist-conviction-badge { right: 12px; }
}

/* ── SOURCING CINEMATIC ───────────────────────────────────────────────── */
.uhist-sourcing { position: relative; height: 68vh; min-height: 480px; overflow: hidden; }
.uhist-sourcing-bg { position: absolute; inset: 0; }
.uhist-sourcing-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center 40%; filter: brightness(.5); }
.uhist-sourcing-bg::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, rgba(42,16,84,.82) 0%, rgba(61,24,115,.45) 60%, transparent 100%);
}
.uhist-sourcing-content {
  position: relative; z-index: 2; height: 100%;
  display: flex; align-items: center; padding: 80px 60px;
}
.uhist-sourcing-text { max-width: 560px; }
.uhist-sourcing-text h2 { color: #fff; margin: 10px 0 20px; }
.uhist-sourcing-text p { font-size: 16px; color: rgba(255,255,255,.72); line-height: 1.7; max-width: 46ch; }
.uhist-coords {
  position: absolute; bottom: 32px; right: 60px;
  font-size: 11px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase;
  color: rgba(255,255,255,.32); z-index: 2;
}
@media(max-width:768px){
  .uhist-sourcing-content { padding: 36px 24px; }
  .uhist-coords { right: 24px; bottom: 22px; }
}

/* ── INGRÉDIENTS ──────────────────────────────────────────────────────── */
.uhist-ingr { padding: 100px 40px; background: var(--uhome-warm); }
.uhist-ingr-inner { max-width: 1100px; margin: 0 auto; }
.uhist-ingr-header {
  display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-bottom: 56px;
}
.uhist-ingr-header p { font-size: 16px; color: var(--uhome-body); line-height: 1.7; max-width: 46ch; }
.uhist-ingr-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }

.uhist-ic {
  background: #fff; border-radius: 18px; overflow: hidden;
  border: 1px solid rgba(0,0,0,.04);
  transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
  position: relative; isolation: isolate;
}
.uhist-ic:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(107,47,160,.12); }
.uhist-ic::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(105deg,transparent 35%,rgba(255,255,255,.4) 50%,transparent 65%);
  background-size: 200% 100%; background-position: -200% center;
  pointer-events: none; opacity: 0; z-index: 1; border-radius: inherit;
}
.uhist-ic:hover::after { opacity: 1; animation: uhist-shimmer .55s ease-out forwards; }
.uhist-ic-img { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: var(--uhome-cream); }
.uhist-ic-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s cubic-bezier(.22,1,.36,1); }
.uhist-ic:hover .uhist-ic-img img { transform: scale(1.04); }
.uhist-ic-body { padding: 20px; }
.uhist-ic-origin { font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--uhome-purple-main); margin-bottom: 6px; }
.uhist-ic-name { font-family: 'Red Hat Display', sans-serif; font-size: 16px; font-weight: 800; color: var(--uhome-dark); margin-bottom: 6px; letter-spacing: -.02em; }
.uhist-ic-desc { font-size: 13px; color: var(--uhome-body); line-height: 1.55; }
.uhist-ic-tag { display: inline-block; margin-top: 12px; padding: 4px 11px; border-radius: 100px; background: var(--uhome-purple-wash); font-size: 11px; font-weight: 700; color: var(--uhome-purple-main); }

/* Featured Konjac */
.uhist-ic.featured .uhist-ic-body { background: linear-gradient(145deg,#2e1060 0%,#5b2199 50%,#7c3abf 100%); }
.uhist-ic.featured .uhist-ic-origin { color: rgba(255,255,255,.52); }
.uhist-ic.featured .uhist-ic-name  { color: #fff; }
.uhist-ic.featured .uhist-ic-desc  { color: rgba(255,255,255,.72); }
.uhist-ic.featured .uhist-ic-tag   { background: rgba(255,255,255,.14); color: #d8b0ff; }
.uhist-ic.featured::after { display: none; }
.uhist-ic.featured { animation: uhist-feat-glow 3s ease-in-out infinite; }
.uhist-ic.featured:hover { animation: none; box-shadow: 0 16px 40px rgba(61,24,115,.3); }

@media(max-width:900px){
  .uhist-ingr { padding: 72px 24px; }
  .uhist-ingr-header { grid-template-columns: 1fr; gap: 16px; margin-bottom: 36px; }
  .uhist-ingr-grid { grid-template-columns: repeat(2,1fr); }
}
@media(max-width:560px){ .uhist-ingr-grid { grid-template-columns: 1fr; } }

/* ── HOW IT WORKS ─────────────────────────────────────────────────────── */
.uhist-how { padding: 100px 40px; background: var(--uhome-cream); }
.uhist-how-inner { max-width: 1100px; margin: 0 auto; }
.uhist-how-header { max-width: 560px; margin-bottom: 56px; }
.uhist-how-header p { font-size: 16px; color: var(--uhome-body); line-height: 1.7; margin-top: 16px; }
.uhist-how-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 0;
  background: #fff; border-radius: 24px; overflow: hidden;
  box-shadow: 0 4px 32px rgba(61,24,115,.07);
}
.uhist-step { padding: 44px 36px; position: relative; transition: background .3s; }
.uhist-step:not(:last-child)::after {
  content: ''; position: absolute; top: 40px; bottom: 40px; right: 0;
  width: 1px; background: var(--uhome-purple-pale);
}
.uhist-step:hover { background: var(--uhome-purple-wash); }
.uhist-step-num { font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--uhome-purple-main); margin-bottom: 18px; }
.uhist-step-photo { width: 100%; aspect-ratio: 1/1; border-radius: 16px; overflow: hidden; margin-bottom: 22px; background: var(--uhome-cream); }
.uhist-step-photo img { width: 100%; height: 100%; object-fit: cover; }
.uhist-step h3 { font-family: 'Red Hat Display', sans-serif; font-size: 18px; font-weight: 800; color: var(--uhome-dark); letter-spacing: -.02em; margin-bottom: 8px; }
.uhist-step p { font-size: 14px; color: var(--uhome-body); line-height: 1.6; }
@media(max-width:900px){
  .uhist-how { padding: 72px 24px; }
  .uhist-how-grid { grid-template-columns: 1fr; }
  .uhist-step:not(:last-child)::after { top: auto; left: 36px; right: 36px; bottom: 0; width: auto; height: 1px; }
}

/* ── SCIENCE / STATS ──────────────────────────────────────────────────── */
.uhist-science {
  background: linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%);
  padding: 100px 40px; position: relative; overflow: hidden;
}
.uhist-science::before {
  content: ''; position: absolute; inset: 0;
  background: url('https://uburn.co/cdn/shop/files/FOND_FIN.jpg?v=1749644803&width=1600') center/cover no-repeat;
  opacity: .06; pointer-events: none;
}
.uhist-science-inner {
  max-width: 1100px; margin: 0 auto; position: relative;
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
}
.uhist-science-text p { font-size: 16px; color: rgba(255,255,255,.68); line-height: 1.75; margin-bottom: 18px; max-width: 50ch; }
.uhist-science-text p strong { color: #fff; font-weight: 600; }
.uhist-science-certif {
  display: inline-flex; align-items: center; gap: 12px;
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14);
  border-radius: 14px; padding: 14px 20px; margin-top: 10px;
}
.uhist-certif-icon { font-size: 20px; }
.uhist-certif-text { font-size: 13px; color: rgba(255,255,255,.85); font-weight: 600; }
.uhist-certif-sub { font-size: 11px; color: rgba(255,255,255,.38); margin-top: 2px; }
.uhist-stats-col { display: flex; flex-direction: column; gap: 20px; }
.uhist-stat-card {
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  border-radius: 20px; padding: 28px 32px; transition: background .3s;
}
.uhist-stat-card:hover { background: rgba(107,47,160,.2); }
.uhist-stat-val {
  font-family: 'Red Hat Display', sans-serif;
  font-size: 52px; font-weight: 900; color: #fff;
  letter-spacing: -.04em; line-height: 1; margin-bottom: 8px;
  font-variant-numeric: tabular-nums;
}
.uhist-stat-val span { font-size: 26px; color: var(--uhome-purple-light); }
.uhist-stat-lbl { font-size: 14px; color: rgba(255,255,255,.55); line-height: 1.5; }
@media(max-width:900px){
  .uhist-science { padding: 72px 24px; }
  .uhist-science-inner { grid-template-columns: 1fr; gap: 48px; }
}

/* ── AVANT / APRÈS ────────────────────────────────────────────────────── */
.uhist-ba { background: var(--uhome-warm); padding: 100px 40px; }
.uhist-ba-inner { max-width: 980px; margin: 0 auto; }
.uhist-ba-card {
  display: grid; grid-template-columns: 1fr 56px 1fr;
  background: #fff; border-radius: 24px; overflow: hidden;
  box-shadow: 0 4px 48px rgba(61,24,115,.1); margin-top: 44px;
}
.uhist-ba-col { padding: 40px 36px; }
.uhist-ba-before { background: #f9f7f5; }
.uhist-ba-div {
  background: var(--uhome-purple-wash);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.uhist-ba-arrow {
  width: 36px; height: 36px; border-radius: 50%; background: var(--uhome-grad);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 14px; box-shadow: 0 4px 16px rgba(107,47,160,.4);
}
.uhist-ba-label { font-size: 10px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--uhome-muted); margin-bottom: 18px; }
.uhist-ba-week { font-family: 'Red Hat Display', sans-serif; font-size: 26px; font-weight: 900; color: var(--uhome-dark); letter-spacing: -.03em; margin-bottom: 14px; }
.uhist-ba-items { display: flex; flex-direction: column; gap: 10px; }
.uhist-ba-item { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; line-height: 1.55; color: var(--uhome-body); }
.uhist-ba-item::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--uhome-purple-pale); flex-shrink: 0; margin-top: 6px; }
.uhist-ba-after .uhist-ba-item::before { background: var(--uhome-purple-main); }
.uhist-ba-after .uhist-ba-item { color: var(--uhome-dark); }
.uhist-ba-profile { display: flex; align-items: center; gap: 12px; margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--uhome-purple-pale); }
.uhist-ba-avatar {
  width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
  background: var(--uhome-purple-pale);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Red Hat Display', sans-serif; font-weight: 800; font-size: 15px; color: var(--uhome-purple-main);
}
.uhist-ba-name { font-weight: 700; font-size: 14px; color: var(--uhome-dark); }
.uhist-ba-meta { font-size: 12px; color: var(--uhome-muted); margin-top: 1px; }
.uhist-ba-stars { color: #f4b942; font-size: 13px; margin-top: 3px; }
@media(max-width:720px){
  .uhist-ba { padding: 72px 24px; }
  .uhist-ba-card { grid-template-columns: 1fr; grid-template-rows: auto 48px auto; }
  .uhist-ba-div { height: 48px; flex-direction: row; }
  .uhist-ba-col { padding: 28px 24px; }
}

/* ── PLANTATION DIVIDER ───────────────────────────────────────────────── */
.uhist-plantation { position: relative; height: 54vh; min-height: 380px; overflow: hidden; }
.uhist-plantation img { width: 100%; height: 100%; object-fit: cover; object-position: center 35%; filter: brightness(.55); }
.uhist-plantation-text {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 40px;
}
.uhist-plantation-text h2 {
  font-family: 'Red Hat Display', sans-serif;
  font-size: clamp(32px,5vw,58px); font-weight: 900; color: #fff;
  letter-spacing: -.03em; line-height: 1.1; max-width: 20ch; margin-bottom: 16px; text-wrap: balance;
}
.uhist-plantation-text h2 em { font-style: italic; color: var(--uhome-purple-light); }
.uhist-plantation-text p { font-size: 16px; color: rgba(255,255,255,.62); }

/* ── VALEURS ──────────────────────────────────────────────────────────── */
.uhist-valeurs { padding: 100px 40px; background: var(--uhome-cream); }
.uhist-valeurs-inner { max-width: 1100px; margin: 0 auto; }
.uhist-valeurs-header { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-bottom: 56px; }
.uhist-valeurs-header p { font-size: 16px; color: var(--uhome-body); line-height: 1.7; max-width: 48ch; }
.uhist-valeurs-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.uhist-valeur {
  padding: 32px 28px; background: var(--uhome-warm); border-radius: 20px;
  transition: transform .3s cubic-bezier(.22,1,.36,1), background .3s, box-shadow .3s;
  border: 1px solid transparent;
}
.uhist-valeur:hover { transform: translateY(-4px); background: var(--uhome-purple-wash); box-shadow: 0 12px 32px rgba(107,47,160,.1); border-color: var(--uhome-purple-pale); }
.uhist-valeur-icon { width: 48px; height: 48px; border-radius: 14px; background: var(--uhome-purple-pale); display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 20px; }
.uhist-valeur h3 { font-family: 'Red Hat Display', sans-serif; font-size: 17px; font-weight: 800; color: var(--uhome-dark); letter-spacing: -.02em; margin-bottom: 8px; }
.uhist-valeur p { font-size: 14px; color: var(--uhome-body); line-height: 1.6; }
@media(max-width:900px){
  .uhist-valeurs { padding: 72px 24px; }
  .uhist-valeurs-header { grid-template-columns: 1fr; gap: 16px; margin-bottom: 36px; }
  .uhist-valeurs-grid { grid-template-columns: repeat(2,1fr); }
}
