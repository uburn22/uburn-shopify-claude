{%- comment -%}
  UBurn LP MASTER (US) — monolithic LP template
  Originally lp-4pm-killer-us; renamed to lp-master-us on 2026-05-17.
  This is the TEMPLATE for all future US LPs. Workflow:
   - Never redesign. Adapt only via schema settings + blocks.
   - Adaptive content: hero, founder quote, problem cards, testimonials,
     final CTA, FAQ items.
   - Locked content (do not edit per variant): nav, USP strip, 3 gestes,
     ingredients table, stats, press bar, offer, shipping strip, footer,
     sticky ATC, live proof popup.
   - Hero image: Charles generates via Nano Banana 2 (never invent).
   - ETA per variant: 2-3h max.
  Compliance: 4h satiety, 30 kcal, no refund/guarantee, FDA disclaimer footer.
{%- endcomment -%}

{%- liquid
  assign hp = section.settings.product | default: all_products['ube-poudre']
  assign v_starter_id = section.settings.variant_starter_id | default: '51289200034111'
  assign v_maximum_id = section.settings.variant_maximum_id | default: '51289200066879'
  assign v_starter = hp.variants | where: 'id', v_starter_id | first
  if v_starter == nil
    assign v_starter = hp.variants[0]
  endif
  assign v_maximum = hp.variants | where: 'id', v_maximum_id | first
  if v_maximum == nil
    assign v_maximum = hp.variants[1] | default: hp.variants[0]
  endif
-%}

{%- comment -%} Noindex/nofollow — LP is for ads only, not for SEO {%- endcomment -%}
<meta name="robots" content="noindex,nofollow">
{{ 'lp-master-us.css' | asset_url | stylesheet_tag }}

<script id="lp-master-data">
  window.__UB_LP = {
    product_id: 'shopify_US_{{ hp.id }}',
    product_handle: '{{ hp.handle }}',
    starter: { id: {{ v_starter.id }}, variant_id: 'shopify_US_{{ hp.id }}_{{ v_starter.id }}', price: 34.50, name: 'UBurn Starter Pack 90g' },
    maximum: { id: {{ v_maximum.id }}, variant_id: 'shopify_US_{{ hp.id }}_{{ v_maximum.id }}', price: 54.50, name: 'UBurn Maximum Pack 270g' },
    currency: 'USD',
    pixel_id: '1207776051409154'
  };
</script>

