    </div>
  </footer>

  {%- comment -%} ═════════ STICKY ATC ═════════ {%- endcomment -%}
  <div class="lp4-sticky" id="lp4-sticky" aria-hidden="true">
    <div class="lp4-sticky__inner">
      <div class="lp4-sticky__info">
        <div class="lp4-sticky__name">UBurn Maximum Pack</div>
