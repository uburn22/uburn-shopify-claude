              <summary class="lp4-faq__q">{{ block.settings.question }}<span class="lp4-faq__icon">✚</span></summary>
              <div class="lp4-faq__a">{{ block.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} ═════════ 15. FINAL CTA ═════════ {%- endcomment -%}
  <section class="lp4-final">
    <div class="lp4__shell">
      <h2 class="lp4-final__h2">{{ section.settings.final_h2 | default: 'Your 4pm <em>changes today.</em>' }}</h2>
      <p class="lp4-final__sub">{{ section.settings.final_sub | default: 'One scoop. One glass. Four hours of calm. Crafted in France, made for the US.' }}</p>
      <button class="lp4__cta lp4-final__cta" data-lp-atc="maximum" type="button">
