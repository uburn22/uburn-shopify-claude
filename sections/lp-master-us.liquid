      </div>
      <button class="lp4__cta lp4-sticky__cta" data-lp-atc="maximum" type="button">
        <span>order →</span>
      </button>
    </div>
  </div>

  {%- comment -%} ═════════ LIVE PROOF POPUP ═════════ {%- endcomment -%}
  <div class="lp4-proof" id="lp4-proof" aria-hidden="true" aria-live="polite">
    <button class="lp4-proof__close" type="button" data-lp-proof-close aria-label="Close notification">×</button>
    <div class="lp4-proof__avatar" id="lp4-proof-avatar">S</div>
