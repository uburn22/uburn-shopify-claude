{%- comment -%}
  ════════════════════════════════════════════════════════════════
  UBURN FAQ v2 — clean accordion, premium wellness
  Sections: Hero → 12 Q&A → CTA
  ════════════════════════════════════════════════════════════════
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

<style>
  .ufaq3 {
    --up-purple-deep:#3d1873; --up-purple-main:#6b2fa0; --up-purple-mid:#8b47c5;
    --up-purple-pale:#e8dcf5; --up-purple-wash:#f5f0fa;
    --up-cream:#faf9f7; --up-dark:#242220; --up-body:#5a5654; --up-muted:#8a8785;
    --up-ease:cubic-bezier(.22,1,.36,1);
    font-family:'Red Hat Text',sans-serif; -webkit-font-smoothing:antialiased; color:var(--up-dark);
  }
  .ufaq3 *,.ufaq3 *::before,.ufaq3 *::after { box-sizing:border-box; }
  .ufaq3-section { padding:56px 16px 64px; }
  @media(min-width:900px){ .ufaq3-section{ padding:80px 32px 96px; } }
  .ufaq3-eyebrow {
    display:inline-block; font-family:'Red Hat Text',sans-serif;
    font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1.6px;
    color:var(--up-purple-main); margin-bottom:14px;
  }
  .ufaq3-h1 {
    font-family:'Red Hat Display',sans-serif; font-size:clamp(36px,5vw,60px);
    font-weight:800; line-height:1.06; color:var(--up-dark);
    margin-bottom:20px; text-wrap:balance;
  }
  .ufaq3-h1 .accent { color:var(--up-purple-mid); }
  .ufaq3-h2 {
    font-family:'Red Hat Display',sans-serif; font-size:clamp(26px,3.2vw,40px);
    font-weight:700; line-height:1.15; letter-spacing:-0.02em;
    color:var(--up-purple-deep); margin-bottom:16px; text-wrap:balance;
  }
  .ufaq3-h2 .accent { color:var(--up-purple-mid); }
  .ufaq3-lead {
    font-family:'Red Hat Text',sans-serif; font-size:17px; line-height:1.65;
    color:var(--up-body); font-weight:400; max-width:62ch; margin:0 auto 24px;
  }
  .ufaq3-slot {
    background:var(--up-purple-wash); border:1px dashed var(--up-purple-pale);
    border-radius:16px; display:flex; align-items:center; justify-content:center;
    color:var(--up-muted); font-family:'Red Hat Text',sans-serif;
    font-size:11.5px; text-transform:uppercase; letter-spacing:1.2px;
  }
  .ufaq3-slot--ratio-16-9 { aspect-ratio:16/9; }
  .ufaq3-cta-primary {
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding:18px 32px; min-height:56px;
    background:var(--up-purple-main); color:#fff; border:none; border-radius:100px;
    text-decoration:none; font-family:'Red Hat Display',sans-serif;
    font-size:16px; font-weight:800; letter-spacing:.3px;
    box-shadow:0 8px 28px rgba(107,47,160,.28);
    transition:background .25s var(--up-ease),transform .25s var(--up-ease),box-shadow .25s var(--up-ease);
    -webkit-appearance:none; appearance:none;
    touch-action:manipulation; -webkit-tap-highlight-color:transparent;
  }
  .ufaq3-cta-primary:hover { background:var(--up-purple-deep); transform:translateY(-2px); box-shadow:0 12px 36px rgba(107,47,160,.4); }
  .ufaq3-cta-primary:focus-visible { outline:3px solid var(--up-purple-pale); outline-offset:4px; }
  .ufaq3-hero { padding:56px 16px 48px; background:linear-gradient(180deg,#fff 0%,var(--up-purple-wash) 100%); text-align:center; }
  @media(min-width:900px){ .ufaq3-hero{ padding:80px 32px 64px; } }
  .ufaq3-hero__inner { max-width:820px; margin:0 auto; }
  .ufaq3-hero__sub {
    font-family:'Red Hat Text',sans-serif; font-size:17px; line-height:1.65;
    color:var(--up-body); font-weight:400; max-width:560px; margin:0 auto 24px;
  }
  /* FAQ list */
  .ufaq3-list { background:var(--up-purple-wash); padding:48px 16px 56px; }
  @media(min-width:900px){ .ufaq3-list{ padding:64px 32px 80px; } }
  .ufaq3-list__inner { max-width:820px; margin:0 auto; }
  .ufaq3-acc {
    background:#fff; border:1px solid var(--up-purple-pale); border-radius:14px;
    margin-bottom:10px; overflow:hidden;
  }
  .ufaq3-acc__q {
    font-family:'Red Hat Display',sans-serif; font-size:15px; font-weight:700;
    color:var(--up-purple-deep); padding:16px 18px; cursor:pointer;
    list-style:none; display:flex; justify-content:space-between; align-items:center;
    gap:12px; letter-spacing:-0.01em;
  }
  .ufaq3-acc__q::-webkit-details-marker { display:none; }
  .ufaq3-acc__q::after {
    content:'+'; font-family:'Red Hat Display',sans-serif;
    font-size:22px; font-weight:400; color:var(--up-purple-main);
    flex-shrink:0; transition:transform .2s var(--up-ease);
  }
  .ufaq3-acc[open] > .ufaq3-acc__q::after { transform:rotate(45deg); }
  .ufaq3-acc__a { padding:0 18px 18px; }
  .ufaq3-acc__a p {
    font-family:'Red Hat Text',sans-serif; font-size:14.5px; line-height:1.6;
    color:var(--up-body); margin:0 0 8px;
  }
  .ufaq3-acc__a p:last-child { margin-bottom:0; }
  .ufaq3-cta-sec {
    background:linear-gradient(180deg,#fff 0%,var(--up-purple-wash) 100%);
    text-align:center;
  }
  .ufaq3-cta-sec__inner { max-width:720px; margin:0 auto; }
  .ufaq3-cta-sec__inner .ufaq3-h2 { margin-bottom:14px; }
</style>

<div class="ufaq3">

  {%- comment -%} ─── HERO ─── {%- endcomment -%}
  <section class="ufaq3-hero">
    <div class="ufaq3-hero__inner">
      <span class="ufaq3-eyebrow">FAQ</span>
      <h1 class="ufaq3-h1">Questions <span class="accent">fréquentes.</span></h1>
      <p class="ufaq3-hero__sub">Tout ce qu'il faut savoir avant de commencer votre routine UBURN.</p>
      {%- comment -%} IMAGE SLOT — FAQ lifestyle doux (16:9) — optionnel {%- endcomment -%}
    </div>
  </section>

  {%- comment -%} ─── 12 Q&A ─── {%- endcomment -%}
  <section class="ufaq3-list">
    <div class="ufaq3-list__inner">
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Quand prendre UBURN ?</summary>
        <div class="ufaq3-acc__a"><p>Tu peux le prendre avant un repas ou au moment où les fringales arrivent, par exemple vers 16h. Pour le glucomannane, le bénéfice réglementaire est associé à 3 prises de 1 g par jour avant les repas, avec suffisamment d'eau.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Avec quoi mélanger UBURN ?</summary>
        <div class="ufaq3-acc__a"><p>Tu peux le mélanger avec de l'eau pour une version légère, ou avec du lait, du lait d'amande ou du lait d'avoine pour une texture plus douce et crémeuse.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Quel goût a UBURN ?</summary>
        <div class="ufaq3-acc__a"><p>UBURN a un goût doux autour de l'ube violet, avec des notes naturelles de vanille et de noisette.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Est-ce qu'UBURN contient de la caféine ?</summary>
        <div class="ufaq3-acc__a"><p>Non, UBURN est sans caféine.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Combien de temps dure une cure ?</summary>
        <div class="ufaq3-acc__a"><p>Selon le format choisi, une cure est pensée pour environ 30 jours d'utilisation.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Quelle différence entre la cure Découverte et la cure Résultats Maximum ?</summary>
        <div class="ufaq3-acc__a"><p>La cure Découverte est pensée pour installer un premier rituel quotidien. La cure Résultats Maximum est pensée pour une utilisation plus complète, avec plusieurs prises dans la journée.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Est-ce compatible avec un régime ?</summary>
        <div class="ufaq3-acc__a"><p>Oui, UBURN peut s'intégrer dans une alimentation équilibrée et un régime hypocalorique. Ce n'est pas une solution miracle, mais une routine pour aider à mieux gérer les fringales.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Est-ce un médicament ?</summary>
        <div class="ufaq3-acc__a"><p>Non, UBURN est un complément alimentaire.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Est-ce adapté pendant la grossesse ou l'allaitement ?</summary>
        <div class="ufaq3-acc__a"><p>Non, par précaution, UBURN est déconseillé pendant la grossesse et l'allaitement.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Puis-je le prendre avec un traitement médical ?</summary>
        <div class="ufaq3-acc__a"><p>En cas de traitement médical ou de doute, demande l'avis d'un professionnel de santé avant utilisation.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">La livraison est-elle offerte ?</summary>
        <div class="ufaq3-acc__a"><p>Oui, selon les conditions affichées au moment de la commande.</p></div>
      </details>
      <details class="ufaq3-acc">
        <summary class="ufaq3-acc__q">Y a-t-il un abonnement ?</summary>
        <div class="ufaq3-acc__a"><p>Non, UBURN est sans abonnement.</p></div>
      </details>
    </div>
  </section>

  {%- comment -%} ─── CTA FINAL ─── {%- endcomment -%}
  <section class="ufaq3-section ufaq3-cta-sec">
    <div class="ufaq3-cta-sec__inner">
      <span class="ufaq3-eyebrow">Une autre question ?</span>
      <h2 class="ufaq3-h2">Une autre <span class="accent">question ?</span></h2>
      <p class="ufaq3-lead">Notre équipe peut vous aider à choisir la routine la plus adaptée.</p>
      <a href="/products/ube-poudre" class="ufaq3-cta-primary">Découvrir UBURN</a>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "UBurn FAQ v2",
  "tag": "section",
  "class": "ufaq3-wrap",
  "settings": [],
  "presets": [{ "name": "UBurn FAQ v2" }]
}
{% endschema %}
