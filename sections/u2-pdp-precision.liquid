{%- comment -%}
  UBurn V2 — PDP "Made with precision" Atelier France
{%- endcomment -%}
<style>
  .u2-prec { background: linear-gradient(180deg, var(--u2-bone) 0%, var(--u2-lavender-soft) 100%); padding: var(--u2-space-section) 20px; }
  .u2-prec__inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 1024px) { .u2-prec__inner { grid-template-columns: 1fr 1fr; gap: 80px; } }
  .u2-prec__media {
    aspect-ratio: 4/5;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(58,31,89,0.3);
    position: relative;
  }
  .u2-prec__media img { width:100%; height:100%; object-fit: cover; }
  .u2-prec__tag {
    position: absolute;
    bottom: 18px; left: 18px;
    background: rgba(248,244,238,0.92);
    backdrop-filter: blur(10px);
    color: var(--u2-plum-black);
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .u2-prec__title {
    font-family: var(--u2-sans);
    font-size: clamp(32px,5vw,46px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 16px 0 16px;
  }
  .u2-prec__title em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-prec__body {
    font-size: 16px;
    line-height: 1.65;
    color: #3A2E4A;
    max-width: 44ch;
    margin: 0 0 28px;
  }
  .u2-prec__features {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .u2-prec__feature {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .u2-prec__feature-icon {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: white;
    color: var(--u2-iris);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(58,31,89,0.08);
  }
  .u2-prec__feature-body { flex: 1; }
  .u2-prec__feature-title {
    font-family: var(--u2-sans);
    font-size: 14px;
    font-weight: 700;
    color: var(--u2-plum-black);
    margin: 0 0 2px;
  }
  .u2-prec__feature-desc {
    font-size: 13px;
    line-height: 1.5;
    color: #5a5a5a;
    margin: 0;
  }
</style>
<section class="u2-root u2-prec" aria-label="Made with precision">
  <div class="u2-prec__inner">
    <div class="u2-prec__media u2-reveal">
      <img src="{{ 'u2-atelier-france.jpg' | asset_url }}" alt="UBurn atelier in France" loading="lazy" width="1200" height="1500">
      <span class="u2-prec__tag">{% render 'u2-icon', name: 'globe', size: 12 %} French heritage · Since 2024</span>
    </div>
    <div class="u2-reveal delay-1">
      <span class="u2-section-eyebrow">— precision standard</span>
      <h2 class="u2-prec__title">Made with <em>precision.</em> Tested for purity.</h2>
      <p class="u2-prec__body">Every batch is researched, formulated, and quality-controlled in our French laboratory. Third-party tested for purity before shipping to the U.S. Packed in plant-based recyclable materials.</p>
      <div class="u2-prec__features">
        <div class="u2-prec__feature">
          <div class="u2-prec__feature-icon">{% render 'u2-icon', name: 'flask', size: 16 %}</div>
          <div class="u2-prec__feature-body">
            <h4 class="u2-prec__feature-title">Third-party lab tested</h4>
            <p class="u2-prec__feature-desc">Every batch tested for purity, heavy metals, and microbial safety.</p>
          </div>
        </div>
        <div class="u2-prec__feature">
          <div class="u2-prec__feature-icon">{% render 'u2-icon', name: 'leaf', size: 16 %}</div>
          <div class="u2-prec__feature-body">
            <h4 class="u2-prec__feature-title">100% plant-based formula</h4>
            <p class="u2-prec__feature-desc">Vegan. No artificial coloring. Purple comes from ube itself.</p>
          </div>
        </div>
        <div class="u2-prec__feature">
          <div class="u2-prec__feature-icon">{% render 'u2-icon', name: 'globe', size: 16 %}</div>
          <div class="u2-prec__feature-body">
            <h4 class="u2-prec__feature-title">French brand</h4>
            <p class="u2-prec__feature-desc">Small atelier in Paris. European Food Safety standards.</p>
          </div>
        </div>
        <div class="u2-prec__feature">
          <div class="u2-prec__feature-icon">{% render 'u2-icon', name: 'check', size: 16 %}</div>
          <div class="u2-prec__feature-body">
            <h4 class="u2-prec__feature-title">EFSA-recognized fiber</h4>
            <p class="u2-prec__feature-desc">Konjac glucomannan · EU Regulation 432/2012 · ID 3120.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "U2 PDP Precision",
  "tag": "section",
  "class": "shopify-section--u2-prec",
  "settings": [],
  "presets": [ { "name": "U2 PDP Precision" } ]
}
{% endschema %}
