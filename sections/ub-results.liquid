{%- comment -%}
  Section: ub-results-v2
  Design: Uburn 2026 · Red Hat Display + Red Hat Text
  Generated from HTML prototype
{%- endcomment -%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap'); 
/* Hide Shopify default header/footer — custom nav rendered inline */
#shopify-section-group-header-group, .shopify-section-group--header-group, #shopify-section-group-footer-group, .shopify-section-group--footer-group { display: none !important; }
main#main { padding: 0 !important; }

:root{
  --purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;
  --purple-light:#b07de8;--purple-pale:#e8dcf5;--purple-wash:#f5f0fa;
  --cream:#faf9f7;--warm:#f2f0ed;--dark:#1a1118;--body:#5a5654;--muted:#8a8785;
  --grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Red Hat Text',sans-serif;background:var(--cream);color:var(--dark);-webkit-font-smoothing:antialiased;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Red Hat Display',sans-serif;letter-spacing:-0.02em}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:20px 48px;display:flex;align-items:center;justify-content:space-between;transition:background 0.4s,padding 0.4s,box-shadow 0.4s}
.nav.scrolled{background:rgba(250,249,247,0.96);backdrop-filter:blur(12px);padding:14px 48px;box-shadow:0 1px 0 var(--purple-pale)}
.nav-logo{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:22px;color:var(--purple-main);letter-spacing:-0.03em;transition:color 0.4s}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none}
.nav-links a{font-size:14px;font-weight:500;color:var(--body);transition:color 0.2s}
.nav-links a:hover{color:var(--purple-main)}
.nav-cta{background:var(--grad);color:#fff;padding:9px 22px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13.5px;transition:opacity 0.2s}
.nav-cta:hover{opacity:0.9}
@media(max-width:768px){.nav{padding:16px 20px}.nav.scrolled{padding:12px 20px}.nav-links{display:none}}

/* SECTION COMMONS */
.section-label{font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--purple-mid);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.section-label::before{content:'';width:20px;height:1px;background:currentColor}
.section-title{font-size:clamp(32px,4vw,54px);font-weight:900;line-height:1.08;letter-spacing:-0.03em}
.section-title em{font-style:italic;font-weight:800;color:var(--purple-main)}

/* ═══ HERO STATS ═══ */
.hero-results{
  background:var(--dark);
  padding:160px 80px 100px;
  position:relative;overflow:hidden;
}
.hero-results::before{
  content:'';
  position:absolute;top:-300px;right:-200px;
  width:800px;height:800px;border-radius:50%;
  background:radial-gradient(circle,rgba(107,47,160,0.25) 0%,transparent 65%);
  pointer-events:none;
}
.hero-results::after{
  content:'';
  position:absolute;bottom:-100px;left:-100px;
  width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(61,24,115,0.3) 0%,transparent 70%);
  pointer-events:none;
}
.hero-results-inner{max-width:1140px;margin:0 auto;position:relative;z-index:1}
.hero-results-eyebrow{
  font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--purple-light);margin-bottom:24px;
  display:flex;align-items:center;gap:10px;
}
.hero-results-eyebrow::before{content:'';width:28px;height:1px;background:var(--purple-light)}
.hero-results h1{
  font-size:clamp(48px,7vw,88px);font-weight:900;color:#fff;
  line-height:1.02;letter-spacing:-0.04em;
  max-width:18ch;margin-bottom:32px;
}
.hero-results h1 em{font-style:italic;color:var(--purple-light)}
.hero-results-sub{font-size:18px;color:rgba(255,255,255,0.6);max-width:48ch;line-height:1.7;margin-bottom:72px}
/* Big stats row */
.hero-stats-row{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:0;
  border-top:1px solid rgba(255,255,255,0.1);
  padding-top:48px;
}
.hero-stat{
  padding:0 40px;
  position:relative;
}
.hero-stat:not(:last-child)::after{
  content:'';position:absolute;right:0;top:0;bottom:0;
  width:1px;background:rgba(255,255,255,0.08);
}
.hero-stat:first-child{padding-left:0}
.hero-stat-val{
  font-family:'Red Hat Display',sans-serif;
  font-size:clamp(48px,6vw,72px);font-weight:900;color:#fff;
  letter-spacing:-0.04em;line-height:1;margin-bottom:10px;
}
.hero-stat-val span{font-size:0.5em;color:var(--purple-light);vertical-align:super}
.hero-stat-lbl{font-size:13px;color:rgba(255,255,255,0.5);line-height:1.5;max-width:20ch}
@media(max-width:900px){
  .hero-results{padding:120px 24px 72px}
  .hero-stats-row{grid-template-columns:1fr 1fr;gap:32px;padding-top:36px}
  .hero-stat:not(:last-child)::after{display:none}
  .hero-stat{padding:0}
}

/* ═══ PULL QUOTE ═══ */
.pull-quote{
  background:var(--purple-deep);padding:80px;
  position:relative;overflow:hidden;
}
.pull-quote::before{
  content:'\201C';
  position:absolute;top:-20px;left:60px;
  font-size:240px;color:rgba(255,255,255,0.04);
  font-family:'Red Hat Display',sans-serif;
  line-height:1;pointer-events:none;
}
.pull-quote-inner{max-width:900px;margin:0 auto;text-align:center;position:relative}
.pull-quote blockquote{
  font-family:'Red Hat Display',sans-serif;
  font-size:clamp(22px,3.5vw,38px);font-weight:800;
  color:#fff;line-height:1.3;letter-spacing:-0.02em;
  font-style:italic;margin-bottom:32px;
}
.pull-quote-attr{font-size:14px;color:rgba(255,255,255,0.5);font-weight:500}
.pull-quote-attr strong{color:rgba(255,255,255,0.85)}
@media(max-width:768px){.pull-quote{padding:60px 24px}}

/* ═══ BEFORE/AFTER STORIES ═══ */
.ba-section{background:var(--warm);padding:120px 80px}
.ba-inner{max-width:1100px;margin:0 auto}
.ba-stories{display:flex;flex-direction:column;gap:40px;margin-top:56px}

.ba-card{
  display:grid;grid-template-columns:1fr 56px 1fr;
  background:#fff;border-radius:24px;overflow:hidden;
  box-shadow:0 4px 60px rgba(61,24,115,0.08);
}
.ba-col{padding:44px 40px}
.ba-before{background:#f9f7f5}
.ba-divider{
  background:var(--purple-wash);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:6px;
}
.ba-divider-arrow{
  width:36px;height:36px;border-radius:50%;
  background:var(--grad);
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:14px;
  box-shadow:0 4px 16px rgba(107,47,160,0.4);
  flex-shrink:0;
}
.ba-label{font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:20px}
.ba-week{font-family:'Red Hat Display',sans-serif;font-size:28px;font-weight:900;color:var(--dark);letter-spacing:-0.03em;margin-bottom:16px}
.ba-items{display:flex;flex-direction:column;gap:12px}
.ba-item{display:flex;align-items:flex-start;gap:10px;font-size:14.5px;line-height:1.5;color:var(--body)}
.ba-item::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--purple-pale);flex-shrink:0;margin-top:7px}
.ba-after .ba-item::before{background:var(--purple-main)}
.ba-after .ba-item{color:var(--dark)}
.ba-profile{display:flex;align-items:center;gap:12px;margin-top:32px;padding-top:24px;border-top:1px solid var(--purple-pale)}
.ba-avatar{width:44px;height:44px;border-radius:50%;flex-shrink:0;background:var(--purple-pale);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:16px;color:var(--purple-main)}
.ba-name{font-weight:700;font-size:14px;color:var(--dark)}
.ba-meta{font-size:12.5px;color:var(--muted);margin-top:1px}
.ba-stars{color:#f4b942;font-size:14px;margin-top:3px}
.ba-result-pill{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--purple-wash);padding:5px 12px;border-radius:20px;
  font-size:12px;font-weight:700;color:var(--purple-main);
  margin-top:12px;
}
@media(max-width:720px){
  .ba-section{padding:72px 24px}
  .ba-card{grid-template-columns:1fr;grid-template-rows:auto 48px auto}
  .ba-divider{width:auto;height:48px;flex-direction:row;padding:0 20px}
  .ba-col{padding:28px 24px}
}

/* ═══ TESTIMONIALS GRID ═══ */
.testimonials{padding:120px 80px;background:var(--cream)}
.testimonials-inner{max-width:1140px;margin:0 auto}
.testi-header{margin-bottom:64px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end}
.testi-header p{font-size:16px;color:var(--body);line-height:1.7;max-width:46ch;padding-bottom:4px}
.testi-filter{
  display:flex;gap:8px;flex-wrap:wrap;margin-bottom:40px;
}
.testi-tag{
  padding:7px 16px;border-radius:20px;
  font-size:12.5px;font-weight:600;
  background:var(--warm);color:var(--body);
  cursor:pointer;transition:all 0.2s;border:none;font-family:inherit;
}
.testi-tag.active,.testi-tag:hover{background:var(--purple-wash);color:var(--purple-main)}
.testi-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:20px;
  align-items:start;
}
.testi-card{
  background:#fff;border-radius:20px;padding:28px;
  transition:transform 0.3s cubic-bezier(0.16,1,0.3,1);
}
.testi-card:hover{transform:translateY(-4px)}
.testi-card--featured{background:var(--purple-deep);grid-column:span 2}
.testi-stars{color:#f4b942;font-size:15px;margin-bottom:14px}
.testi-text{
  font-size:15px;line-height:1.65;color:var(--body);margin-bottom:20px;max-width:55ch;
}
.testi-card--featured .testi-text{color:rgba(255,255,255,0.8);font-size:16px}
.testi-author{display:flex;align-items:center;gap:10px}
.testi-avatar{
  width:36px;height:36px;border-radius:50%;
  background:var(--purple-pale);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:13px;color:var(--purple-main);
}
.testi-card--featured .testi-avatar{background:rgba(255,255,255,0.15);color:#fff}
.testi-name{font-weight:700;font-size:13.5px;color:var(--dark)}
.testi-card--featured .testi-name{color:#fff}
.testi-loc{font-size:12px;color:var(--muted)}
.testi-card--featured .testi-loc{color:rgba(255,255,255,0.5)}
.testi-tag-pill{
  display:inline-block;margin-top:12px;padding:4px 10px;border-radius:12px;
  font-size:11px;font-weight:600;letter-spacing:0.06em;
  background:var(--purple-wash);color:var(--purple-main);
}
.testi-card--featured .testi-tag-pill{background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.9)}
@media(max-width:900px){
  .testimonials{padding:72px 24px}
  .testi-header{grid-template-columns:1fr;gap:20px;margin-bottom:40px}
  .testi-grid{grid-template-columns:1fr}
  .testi-card--featured{grid-column:span 1}
}

/* ═══ STATS SPLIT ═══ */
.stats-split{
  display:grid;grid-template-columns:420px 1fr;
  min-height:500px;background:var(--purple-deep);
}
.stats-photo{position:relative;overflow:hidden}
.stats-photo img{width:100%;height:100%;object-fit:cover;object-position:center 20%;filter:brightness(0.72)}
.stats-photo-cap{position:absolute;bottom:24px;left:20px;right:20px;color:rgba(255,255,255,0.6);font-size:12px;font-style:italic}
.stats-body{padding:72px 64px;display:flex;flex-direction:column;justify-content:center}
.stats-body .section-label{color:var(--purple-light)}
.stats-body .section-label::before{background:var(--purple-light)}
.stats-body .section-title{color:#fff;margin-bottom:48px}
.stats-layout{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
.stat-big-val{font-family:'Red Hat Display',sans-serif;font-size:clamp(72px,9vw,108px);font-weight:900;color:#fff;line-height:1;letter-spacing:-0.04em}
.stat-big-label{font-size:15px;color:rgba(255,255,255,0.55);line-height:1.5;margin-top:10px;max-width:22ch}
.stats-list{display:flex;flex-direction:column;gap:22px;padding-top:8px}
.stat-row{padding-bottom:22px}
.stat-row:not(:last-child){border-bottom:1px solid rgba(255,255,255,0.1)}
.stat-row-val{font-family:'Red Hat Display',sans-serif;font-size:30px;font-weight:800;color:#fff;letter-spacing:-0.02em}
.stat-row-lbl{font-size:13px;color:rgba(255,255,255,0.45);margin-top:2px}
.stats-disclaimer{margin-top:32px;font-size:11px;color:rgba(255,255,255,0.3);line-height:1.6}
@media(max-width:900px){
  .stats-split{grid-template-columns:1fr}
  .stats-photo{height:280px}
  .stats-body{padding:48px 24px}
  .stats-layout{grid-template-columns:1fr;gap:24px}
}

/* ═══ PRESS ═══ */
.press{background:var(--warm);padding:80px;text-align:center}
.press-inner{max-width:900px;margin:0 auto}
.press h2{font-size:clamp(28px,3.5vw,42px);font-weight:900;color:var(--dark);margin-bottom:12px;letter-spacing:-0.03em}
.press h2 em{font-style:italic;color:var(--purple-main)}
.press-sub{font-size:15px;color:var(--body);margin-bottom:48px;max-width:50ch;margin-left:auto;margin-right:auto}
.press-logos{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:40px;margin-bottom:56px}
.press-logo img{height:20px;width:auto;opacity:0.35;filter:grayscale(1);transition:opacity 0.2s,filter 0.2s}
.press-logo img:hover{opacity:0.7;filter:grayscale(0.5)}
.press-quotes{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;text-align:left}
.press-quote{background:#fff;border-radius:20px;padding:28px 32px}
.press-quote-text{font-size:15px;color:var(--body);line-height:1.65;font-style:italic;margin-bottom:16px}
.press-quote-text::before{content:'\201C';color:var(--purple-pale);font-size:2em;font-family:'Red Hat Display',sans-serif;font-weight:900;line-height:0.8;display:block;margin-bottom:6px}
.press-quote-source{font-size:12px;font-weight:700;color:var(--purple-main);text-transform:uppercase;letter-spacing:0.1em}
@media(max-width:900px){
  .press{padding:72px 24px}
  .press-quotes{grid-template-columns:1fr}
}

/* ═══ SCIENCE PROOF ═══ */
.science-proof{background:var(--cream);padding:100px 80px}
.science-proof-inner{max-width:1000px;margin:0 auto}
.science-proof-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:20px;
  margin-top:48px;
}
.proof-card{
  padding:36px 32px;border-radius:20px;
  background:var(--warm);
  transition:transform 0.3s cubic-bezier(0.16,1,0.3,1);
}
.proof-card:hover{transform:translateY(-3px)}
.proof-card--dark{background:var(--purple-deep)}
.proof-num{
  font-family:'Red Hat Display',sans-serif;
  font-size:48px;font-weight:900;color:var(--purple-main);
  letter-spacing:-0.04em;line-height:1;margin-bottom:10px;
}
.proof-card--dark .proof-num{color:var(--purple-light)}
.proof-lbl{font-size:15px;font-weight:700;color:var(--dark);margin-bottom:8px}
.proof-card--dark .proof-lbl{color:#fff}
.proof-desc{font-size:13.5px;color:var(--body);line-height:1.6}
.proof-card--dark .proof-desc{color:rgba(255,255,255,0.6)}
.proof-source{font-size:11px;color:var(--muted);margin-top:12px;font-style:italic}
.proof-card--dark .proof-source{color:rgba(255,255,255,0.3)}
@media(max-width:768px){
  .science-proof{padding:72px 24px}
  .science-proof-grid{grid-template-columns:1fr}
}

/* ═══ FINAL CTA ═══ */
.final-cta{
  position:relative;overflow:hidden;
  background:var(--dark);
}
.final-bg{position:absolute;inset:0}
.final-bg img{width:100%;height:100%;object-fit:cover;object-position:center 25%;filter:brightness(0.3)}
.final-bg::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(to right,rgba(26,17,24,0.9) 0%,rgba(26,17,24,0.7) 50%,rgba(26,17,24,0.85) 100%);
}
.final-content{
  position:relative;z-index:1;
  padding:120px 80px;
  max-width:640px;
}
.final-label{font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--purple-light);margin-bottom:20px;display:flex;align-items:center;gap:10px}
.final-label::before{content:'';width:20px;height:1px;background:var(--purple-light)}
.final-content h2{font-size:clamp(40px,5.5vw,66px);font-weight:900;color:#fff;line-height:1.06;letter-spacing:-0.03em;margin-bottom:24px}
.final-content h2 em{font-style:italic;color:var(--purple-light)}
.final-content p{font-size:17px;color:rgba(255,255,255,0.65);line-height:1.7;max-width:44ch;margin-bottom:40px}
.btn-primary-lg{display:inline-flex;align-items:center;gap:8px;background:var(--grad);color:#fff;padding:18px 36px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:16px;transition:transform 0.2s,opacity 0.2s}
.btn-primary-lg:hover{transform:translateY(-2px);opacity:0.9}
.final-guarantees{display:flex;align-items:center;gap:24px;margin-top:24px;flex-wrap:wrap}
.final-g{font-size:12.5px;color:rgba(255,255,255,0.5);display:flex;align-items:center;gap:6px;font-weight:500}
.final-g::before{content:'✓';color:var(--purple-light)}
@media(max-width:768px){.final-content{padding:80px 24px}}

/* FOOTER */
.footer{background:var(--dark);padding:72px 80px 40px;color:rgba(255,255,255,0.6)}
.footer-inner{max-width:1140px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:56px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:40px}
.footer-brand-name{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:20px;color:#fff;margin-bottom:16px;letter-spacing:-0.02em}
.footer-brand-desc{font-size:14px;line-height:1.7;max-width:34ch;color:rgba(255,255,255,0.55);margin-bottom:24px}
.footer-legal-note{font-size:11.5px;line-height:1.7;color:rgba(255,255,255,0.3)}
.footer-col-title{font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13px;color:rgba(255,255,255,0.9);margin-bottom:16px;letter-spacing:0.3px}
.footer-col-links{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-col-links a{font-size:13.5px;color:rgba(255,255,255,0.45);transition:color 0.2s}
.footer-col-links a:hover{color:rgba(255,255,255,0.9)}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:12px;color:rgba(255,255,255,0.25)}
@media(max-width:900px){.footer{padding:56px 24px 32px}.footer-top{grid-template-columns:1fr 1fr;gap:32px}}
@media(max-width:600px){.footer-top{grid-template-columns:1fr}}

/* REVEAL */
.reveal{opacity:0;transform:translateY(24px);transition:opacity 0.65s ease,transform 0.65s cubic-bezier(0.16,1,0.3,1)}
.reveal.visible{opacity:1;transform:none}
.rd1{transition-delay:0.1s}.rd2{transition-delay:0.2s}.rd3{transition-delay:0.3s}.rd4{transition-delay:0.4s}


/* Shopify section wrapper */
#shopify-section-{{ section.id }} {
  display: block;
}
</style>



