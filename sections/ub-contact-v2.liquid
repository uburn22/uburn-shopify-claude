{% comment %}Section: UB Contact · Uburn 2026{% endcomment %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap');

:root{--purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;--purple-light:#b07de8;--purple-pale:#e8dcf5;--purple-wash:#f5f0fa;--cream:#faf9f7;--warm:#f2f0ed;--dark:#1a1118;--body:#5a5654;--muted:#8a8785;--grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Red Hat Text',sans-serif;background:var(--cream);color:var(--dark);-webkit-font-smoothing:antialiased;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Red Hat Display',sans-serif;letter-spacing:-0.02em}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
/* Hide Shopify default sections */
[id^="shopify-section-sections--"]{display:none !important}
main#main{padding:0 !important}
/* Nav */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:18px 48px;display:flex;align-items:center;justify-content:space-between;transition:background 0.4s,padding 0.4s,box-shadow 0.4s;background:rgba(250,249,247,0.96);backdrop-filter:blur(12px);box-shadow:0 1px 0 var(--purple-pale)}
.nav-logo{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:22px;color:var(--purple-main);letter-spacing:-0.03em}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none}
.nav-links a{font-size:14px;font-weight:500;color:var(--body);transition:color 0.2s}
.nav-links a:hover,.nav-links a.active{color:var(--purple-main)}
.nav-cta{background:var(--grad);color:#fff;padding:9px 22px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13.5px;transition:opacity 0.2s}
.nav-cta:hover{opacity:0.9}
@media(max-width:768px){.nav{padding:14px 20px}.nav-links{display:none}}
/* Section commons */
.section-label{font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--purple-mid);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.section-label::before{content:'';width:20px;height:1px;background:currentColor}
.section-title{font-size:clamp(32px,4vw,54px);font-weight:900;line-height:1.08;letter-spacing:-0.03em}
.section-title em{font-style:italic;font-weight:800;color:var(--purple-main)}
/* Before/After */
.ba-section{background:var(--warm);padding:100px 80px}
.ba-inner{max-width:1000px;margin:0 auto}
.ba-card{display:grid;grid-template-columns:1fr 56px 1fr;background:#fff;border-radius:24px;overflow:hidden;box-shadow:0 4px 60px rgba(61,24,115,0.1);margin-top:48px}
.ba-col{padding:40px 36px}
.ba-before{background:#f9f7f5}
.ba-divider{background:var(--purple-wash);display:flex;flex-direction:column;align-items:center;justify-content:center}
.ba-divider-arrow{width:36px;height:36px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;box-shadow:0 4px 16px rgba(107,47,160,0.4)}
.ba-label{font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.ba-week{font-family:'Red Hat Display',sans-serif;font-size:26px;font-weight:900;color:var(--dark);letter-spacing:-0.03em;margin-bottom:14px}
.ba-items{display:flex;flex-direction:column;gap:11px}
.ba-item{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.5;color:var(--body)}
.ba-item::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--purple-pale);flex-shrink:0;margin-top:6px}
.ba-after .ba-item::before{background:var(--purple-main)}
.ba-after .ba-item{color:var(--dark)}
.ba-profile{display:flex;align-items:center;gap:12px;margin-top:28px;padding-top:20px;border-top:1px solid var(--purple-pale)}
.ba-avatar{width:40px;height:40px;border-radius:50%;flex-shrink:0;background:var(--purple-pale);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;color:var(--purple-main)}
.ba-name{font-weight:700;font-size:14px;color:var(--dark)}
.ba-meta{font-size:12px;color:var(--muted);margin-top:1px}
.ba-stars{color:#f4b942;font-size:13px;margin-top:3px}
@media(max-width:720px){.ba-section{padding:72px 24px}.ba-card{grid-template-columns:1fr;grid-template-rows:auto 48px auto}.ba-divider{height:48px;flex-direction:row}.ba-col{padding:28px 24px}}
/* Reveal */
.reveal{opacity:0;transform:translateY(22px);transition:opacity 0.6s ease,transform 0.6s cubic-bezier(0.16,1,0.3,1)}
.reveal.visible{opacity:1;transform:none}
.rd1{transition-delay:0.1s}.rd2{transition-delay:0.2s}.rd3{transition-delay:0.3s}
/* Footer */
.footer{background:var(--dark);padding:64px 80px 36px;color:rgba(255,255,255,0.55)}
.footer-inner{max-width:1140px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:36px}
.footer-brand{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:20px;color:#fff;margin-bottom:14px;letter-spacing:-0.02em}
.footer-desc{font-size:13.5px;line-height:1.7;max-width:34ch;color:rgba(255,255,255,0.5);margin-bottom:20px}
.footer-legal{font-size:11px;line-height:1.7;color:rgba(255,255,255,0.28)}
.footer-col-title{font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13px;color:rgba(255,255,255,0.85);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:9px}
.footer-links a{font-size:13px;color:rgba(255,255,255,0.4);transition:color 0.2s}
.footer-links a:hover{color:rgba(255,255,255,0.85)}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:12px;color:rgba(255,255,255,0.22)}
@media(max-width:900px){.footer{padding:48px 24px 28px}.footer-top{grid-template-columns:1fr 1fr;gap:28px}}
@media(max-width:600px){.footer-top{grid-template-columns:1fr}}
/* Btn */
.btn-main{display:inline-flex;align-items:center;gap:8px;background:var(--grad);color:#fff;padding:16px 32px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;transition:transform 0.2s,opacity 0.2s;border:none;cursor:pointer}
.btn-main:hover{transform:translateY(-2px);opacity:0.92}


.contact-wrap{min-height:100vh;display:grid;grid-template-columns:1fr 1fr}
.contact-left{background:var(--purple-deep);padding:140px 72px 80px;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center}
.contact-left::before{content:'';position:absolute;top:-150px;right:-150px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(139,71,197,0.3) 0%,transparent 70%);pointer-events:none}
.contact-left .section-label{color:var(--purple-light)}
.contact-left .section-label::before{background:var(--purple-light)}
.contact-left h1{color:#fff;font-size:clamp(36px,4.5vw,56px);font-weight:900;letter-spacing:-0.03em;line-height:1.08;margin-bottom:28px}
.contact-left h1 em{font-style:italic;color:var(--purple-light)}
.contact-left p{font-size:16px;color:rgba(255,255,255,0.6);line-height:1.75;max-width:42ch;margin-bottom:40px}
.contact-info{display:flex;flex-direction:column;gap:20px}
.contact-info-item{display:flex;align-items:center;gap:14px}
.contact-info-icon{width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.contact-info-text strong{display:block;font-size:14px;color:#fff;font-weight:700;margin-bottom:2px}
.contact-info-text span{font-size:13px;color:rgba(255,255,255,0.5)}
.contact-right{background:var(--cream);padding:140px 72px 80px;display:flex;flex-direction:column;justify-content:center}
.contact-right h2{font-family:'Red Hat Display',sans-serif;font-size:28px;font-weight:800;color:var(--dark);letter-spacing:-0.02em;margin-bottom:32px}
.form-group{margin-bottom:20px}
.form-label{display:block;font-size:13px;font-weight:600;color:var(--dark);margin-bottom:8px;letter-spacing:0.03em}
.form-input,.form-textarea{width:100%;padding:14px 18px;border:1.5px solid var(--purple-pale);border-radius:12px;font-family:'Red Hat Text',sans-serif;font-size:15px;color:var(--dark);background:#fff;transition:border-color 0.2s,box-shadow 0.2s;outline:none}
.form-input:focus,.form-textarea:focus{border-color:var(--purple-main);box-shadow:0 0 0 3px rgba(107,47,160,0.1)}
.form-textarea{min-height:140px;resize:vertical;line-height:1.6}
.form-submit{background:var(--grad);color:#fff;padding:16px 36px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;border:none;cursor:pointer;width:100%;transition:opacity 0.2s,transform 0.2s;margin-top:8px}
.form-submit:hover{opacity:0.9;transform:translateY(-1px)}
.form-note{font-size:12px;color:var(--muted);margin-top:12px;text-align:center}
@media(max-width:900px){.contact-wrap{grid-template-columns:1fr;min-height:auto}.contact-left,.contact-right{padding:100px 24px 60px}}

</style>
<nav class="nav">
  <a href="/" class="nav-logo">Uburn</a>
  <ul class="nav-links">
    <li><a href="/products/ube-poudre">Produit</a></li>
    <li><a href="/pages/ingredients">Ingrédients</a></li>
    <li><a href="/pages/about">Notre histoire</a></li>
    <li><a href="/pages/resultats">Résultats</a></li>
  </ul>
  <a href="/products/ube-poudre" class="nav-cta">Commander →</a>
</nav>

<div class="contact-wrap">
  <div class="contact-left">
    <div style="position:relative;z-index:1">
      <div class="section-label">Contact</div>
      <h1>On vous répond.<br><em>Vraiment.</em></h1>
      <p>Une question sur le produit, une commande, un retour — notre équipe répond sous 24h ouvrées. Pas de chatbot, une vraie personne.</p>
      <div class="contact-info">
        <div class="contact-info-item">
          <div class="contact-info-icon">✉️</div>
          <div class="contact-info-text">
            <strong>Email</strong>
            <span>hello@uburn.co</span>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-icon">⏱️</div>
          <div class="contact-info-text">
            <strong>Temps de réponse</strong>
            <span>Sous 24h ouvrées</span>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-icon">📦</div>
          <div class="contact-info-text">
            <strong>Remboursements</strong>
            <span>Traités sous 5 jours ouvrés</span>
          </div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-icon">🇫🇷</div>
          <div class="contact-info-text">
            <strong>Marque française</strong>
            <span>R Glow F.Z.E. — Uburn</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="contact-right">
    <h2>Écrivez-nous</h2>
    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div style="background:var(--purple-wash);border-radius:16px;padding:24px;text-align:center;margin-bottom:24px">
          <div style="font-size:28px;margin-bottom:8px">✅</div>
          <p style="font-family:'Red Hat Display',sans-serif;font-weight:800;color:var(--dark);margin-bottom:4px">Message envoyé !</p>
          <p style="font-size:14px;color:var(--body)">On vous répond sous 24h ouvrées.</p>
        </div>
      {% endif %}
      <div class="form-group">
        <label class="form-label" for="ContactFormName">Votre nom</label>
        <input type="text" id="ContactFormName" class="form-input" name="contact[name]" value="{{ form.name }}" placeholder="Marie Dupont" autocomplete="name">
      </div>
      <div class="form-group">
        <label class="form-label" for="ContactFormEmail">Email</label>
        <input type="email" id="ContactFormEmail" class="form-input" name="contact[email]" value="{{ form.email }}" placeholder="marie@email.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label" for="ContactFormSubject">Sujet</label>
        <input type="text" id="ContactFormSubject" class="form-input" name="contact[subject]" placeholder="Ma commande / Question produit / Autre">
      </div>
      <div class="form-group">
        <label class="form-label" for="ContactFormMessage">Message</label>
        <textarea id="ContactFormMessage" class="form-textarea" name="contact[body]" placeholder="Décrivez votre question ou situation...">{{ form.body }}</textarea>
      </div>
      <button type="submit" class="form-submit">Envoyer le message →</button>
      <p class="form-note">Réponse garantie sous 24h ouvrées · hello@uburn.co</p>
    {% endform %}
  </div>
</div>

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <div class="footer-brand">Uburn</div>
        <p class="footer-desc">Complément alimentaire à base de glucomannane. Marque française — R Glow F.Z.E.</p>
        <p class="footer-legal">Le glucomannane contribue au contrôle de l'appétit dans le cadre d'un régime hypocalorique (EFSA ID 3120). Conditions : 3g/jour en 3 doses avec 1-2 verres d'eau avant les repas.</p>
      </div>
      <div><div class="footer-col-title">Produit</div><ul class="footer-links"><li><a href="/products/ube-poudre">Ube Poudre</a></li><li><a href="/pages/ingredients">Ingrédients</a></li><li><a href="/pages/resultats">Résultats</a></li><li><a href="/pages/faq">FAQ</a></li></ul></div>
      <div><div class="footer-col-title">Support</div><ul class="footer-links"><li><a href="/pages/faq">FAQ</a></li><li><a href="/pages/contact">Contact</a></li><li><a href="#">Livraison</a></li><li><a href="#">Retours</a></li></ul></div>
      <div><div class="footer-col-title">Entreprise</div><ul class="footer-links"><li><a href="/pages/about">Notre histoire</a></li><li><a href="/pages/resultats">Résultats</a></li><li><a href="#">Presse</a></li><li><a href="#">CGV</a></li></ul></div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 UBurn. Tous droits réservés.</span>
      <span>hello@uburn.co</span>
      <div style="display:flex;gap:16px"><a href="#" style="color:rgba(255,255,255,0.22)">Confidentialité</a><a href="#" style="color:rgba(255,255,255,0.22)">Mentions légales</a></div>
    </div>
  </div>
</footer>
<script>
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible')}),{threshold:0.08,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
</script>
{% schema %}
{"name":"UB Contact","settings":[]}
{% endschema %}