<script>
(function(){
  var root = document.querySelector('.ubpdpx');
  if(!root) return;

  // Scroll reveal
  var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}})},{threshold:.12});
  root.querySelectorAll('.reveal,.stagger-children,.stagger-scale').forEach(function(el){obs.observe(el)});

  // Count-up
  var countObs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){
    var el=e.target,target=+el.dataset.count,suffix=el.dataset.suffix||'',dur=1400;
    var start=null;
    function step(ts){if(!start)start=ts;var p=Math.min((ts-start)/dur,1);el.textContent=Math.round(p*target)+suffix;if(p<1)requestAnimationFrame(step);}
    requestAnimationFrame(step);
    countObs.unobserve(el);
  }})},{threshold:.3});
  root.querySelectorAll('[data-count]').forEach(function(el){countObs.observe(el)});

  // FAQ accordion
  root.querySelectorAll('.faq-item').forEach(function(item){
    item.querySelector('.faq-q').addEventListener('click',function(){
      root.querySelectorAll('.faq-item').forEach(function(i){if(i!==item)i.classList.remove('open')});
      item.classList.toggle('open');
    });
  });

  // 6 bienfaits
  var benefits = {
    satiete: {label: 'Glucomannane · EFSA · Fibres', title: 'Satiété durable', desc: 'Système complet basé sur le glucomannane (EFSA ID 3120) et 5g de fibres par dose. Le konjac absorbe jusqu\'à 100x son poids en eau pour former un gel qui occupe naturellement l\'estomac.'},
    energie: {label: 'MCT · L-Carnitine', title: 'Énergie stable', desc: 'MCT coco et L-Carnitine 400mg pour une énergie sans pic ni crash. Parfait pour les après-midis longs.'},
    digestion: {label: 'Gingembre · Acacia', title: 'Digestion apaisée', desc: 'Gingembre bio et fibre d\'acacia prébiotique pour un confort digestif au quotidien.'},
    antioxydants: {label: 'Ubé · Anthocyanes', title: 'Antioxydants puissants', desc: 'Ubé violet riche en anthocyanes naturelles pour la protection cellulaire et l\'éclat de la peau.'},
    metabolisme: {label: 'L-Carnitine · Gingembre', title: 'Métabolisme soutenu', desc: 'L-Carnitine 400mg et gingembre pour un support métabolique naturel et durable.'},
    bien_etre: {label: 'Formule complète', title: 'Équilibre global', desc: 'Une formule synergique de 6 actifs pour un bien-être quotidien apaisé et durable.'}
  };
  root.querySelectorAll('[data-benefit]').forEach(function(card){
    card.addEventListener('click', function(){
      var key = card.getAttribute('data-benefit');
      root.querySelectorAll('[data-benefit]').forEach(function(c){c.classList.remove('active')});
      card.classList.add('active');
      var detail = root.querySelector('.benefit-detail');
      if (detail && benefits[key]) {
        detail.querySelector('.benefit-label').textContent = benefits[key].label;
        detail.querySelector('.benefit-title').textContent = benefits[key].title;
        detail.querySelector('.benefit-desc').textContent = benefits[key].desc;
      }
    });
  });
})();
</script>

