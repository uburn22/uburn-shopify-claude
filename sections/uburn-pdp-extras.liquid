{%- comment -%}
  UBurn PDP — Extras LP-style
  Renders AFTER main-product on templates/product.uburn-lp.json.
  Goal: bring LP art direction (Red Hat Display, purple, animations, content sections)
  to the native Shopify product page WITHOUT replacing main-product.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

<style>
  /* === LP MOOD OVERRIDE pour main-product (typo + couleurs) === */
  body.template-product, .shopify-section--main-product, .shopify-section--main-product * {
    font-family: 'Red Hat Text', sans-serif !important;
  }
  .shopify-section--main-product h1,
  .shopify-section--main-product h2,
  .shopify-section--main-product h3,
  .shopify-section--main-product .heading,
  .shopify-section--main-product [class*="title"] {
    font-family: 'Red Hat Display', sans-serif !important;
    letter-spacing: -0.02em !important;
  }
  /* Buy buttons → violet LP */
  .shopify-section--main-product .button--primary,
  .shopify-section--main-product [name="add"],
  .shopify-section--main-product .product-form__submit,
  .shopify-section--main-product .buy-buttons button[type="submit"]:not(.shopify-payment-button__button) {
    background: #6b2fa0 !important;
    color: #fff !important;
    border: none !important;
    border-radius: 100px !important;
    font-family: 'Red Hat Text', sans-serif !important;
    font-weight: 700 !important;
    letter-spacing: .3px !important;
    transition: .3s !important;
  }
  .shopify-section--main-product .button--primary:hover,
  .shopify-section--main-product [name="add"]:hover,
  .shopify-section--main-product .buy-buttons button[type="submit"]:hover:not(.shopify-payment-button__button) {
    background: #3d1873 !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 20px rgba(107,47,160,.3) !important;
  }
  /* Variant picker → LP look */
  .shopify-section--main-product variant-picker [type="radio"]:checked + label,
  .shopify-section--main-product variant-picker .selected,
  .shopify-section--main-product .variant-option--selected {
    border-color: #6b2fa0 !important;
    color: #6b2fa0 !important;
  }
  /* Subtle spacing */
  .shopify-section--main-product { padding-top: 12px; }

  /* === EXTRAS SECTION SCOPE === */
  .ubpdpx,.ubpdpx *,.ubpdpx *::before,.ubpdpx *::after{box-sizing:border-box}
  .ubpdpx{font-family:'Red Hat Text',sans-serif;color:#242220;background:#fff;-webkit-font-smoothing:antialiased;display:block}
  .ubpdpx a{text-decoration:none;color:inherit}
  .ubpdpx img{max-width:100%;display:block}
  .ubpdpx ul{list-style:none;padding:0;margin:0}
  .ubpdpx h1,.ubpdpx h2,.ubpdpx h3,.ubpdpx h4,.ubpdpx p{margin:0;padding:0}

  .ubpdpx{
    --purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;--purple-light:#b07de8;
    --purple-pale:#e8dcf5;--purple-wash:#f5f0fa;--cream:#faf9f7;--warm:#f2f0ed;
    --dark:#242220;--body:#5a5654;--muted:#8a8785;
    --grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%);
  }

  .ubpdpx .btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;border-radius:100px;font-family:'Red Hat Text',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:.3s;border:none}
  .ubpdpx .btn-fill{background:var(--purple-main);color:#fff}
  .ubpdpx .btn-fill:hover{background:var(--purple-deep);transform:translateY(-1px);box-shadow:0 6px 20px rgba(107,47,160,.3)}
  .ubpdpx .btn-white{background:#fff;color:var(--purple-deep)}
  .ubpdpx .btn-white:hover{background:var(--purple-wash);transform:translateY(-1px);box-shadow:0 6px 24px rgba(0,0,0,.15)}
  .ubpdpx .btn-outline{background:transparent;color:var(--purple-main);border:1.5px solid var(--purple-pale)}
  .ubpdpx .btn-outline:hover{background:var(--purple-wash)}

  /* MARQUEE */
  .ubpdpx .marquee{padding:14px 0;overflow:hidden;border-top:1px solid rgba(0,0,0,.04);border-bottom:1px solid rgba(0,0,0,.04);background:var(--purple-wash)}
  .ubpdpx .marquee-track{display:flex;gap:40px;animation:ubpdpx-slide 25s linear infinite;width:max-content}
  .ubpdpx .marquee-item{white-space:nowrap;font-size:12.5px;font-weight:600;color:var(--purple-deep);text-transform:uppercase;letter-spacing:1.2px;display:flex;align-items:center;gap:10px}
  .ubpdpx .marquee-dot{width:5px;height:5px;border-radius:50%;background:var(--purple-light)}
  @keyframes ubpdpx-slide{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* SECTIONS */
  .ubpdpx .section{padding:100px 40px}
  .ubpdpx .section-inner{max-width:1100px;margin:0 auto}
  .ubpdpx .section-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:2.5px;color:var(--purple-main);margin-bottom:14px}
  .ubpdpx .section-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3.2vw,40px);font-weight:700;color:var(--dark);line-height:1.15;margin-bottom:16px}
  .ubpdpx .section-title .accent{color:var(--purple-mid)}

  /* EXPERT */
  .ubpdpx .expert-section{background:var(--purple-wash);padding:80px 40px}
  .ubpdpx .expert-card{max-width:950px;margin:0 auto;background:#fff;border-radius:24px;padding:48px 56px;box-shadow:0 8px 30px rgba(61,24,115,.08);display:grid;grid-template-columns:40% 60%;gap:48px;align-items:center}
  .ubpdpx .expert-img{border-radius:20px;overflow:hidden;aspect-ratio:1/1;background:var(--cream)}
  .ubpdpx .expert-img img{width:100%;height:100%;object-fit:cover}
  .ubpdpx .expert-quote{font-family:'Red Hat Display',sans-serif;font-size:26px;font-weight:700;color:var(--purple-deep);line-height:1.25;letter-spacing:-0.02em;margin-bottom:20px}
  .ubpdpx .expert-body{border-left:3px solid var(--purple-main);padding-left:20px;font-size:15px;color:var(--body);line-height:1.7;font-style:italic;margin-bottom:20px}
  .ubpdpx .expert-name{font-weight:700;color:var(--dark);font-size:15px;margin-bottom:4px}
  .ubpdpx .expert-credentials{text-transform:uppercase;letter-spacing:1.5px;font-size:11px;color:var(--muted);margin-bottom:10px;font-weight:600}
  .ubpdpx .expert-link{color:var(--purple-main);font-size:13px;font-weight:600;display:inline-block}
  @media(max-width:700px){.ubpdpx .expert-card{grid-template-columns:1fr;padding:32px 24px;gap:32px}.ubpdpx .expert-quote{font-size:22px}}

  /* PROBLEM */
  .ubpdpx .problem-section{background:var(--cream)}
  .ubpdpx .prob-cards{display:grid;grid-template-columns:repeat(3,1fr);margin-top:48px;border-radius:20px;overflow:hidden;box-shadow:0 4px 32px rgba(61,24,115,.1)}
  .ubpdpx .prob-card{background:linear-gradient(145deg,#2e1060 0%,#5b2199 60%,#7c3abf 100%);padding:40px 32px;border-right:1px solid rgba(255,255,255,.08);position:relative;transition:filter .25s}
  .ubpdpx .prob-card:last-child{border-right:none}
  .ubpdpx .prob-card:hover{filter:brightness(1.08)}
  .ubpdpx .prob-num{font-family:'Red Hat Display',sans-serif;font-size:68px;font-weight:900;color:rgba(255,255,255,.08);line-height:1;letter-spacing:-0.04em;margin-bottom:20px;user-select:none}
  .ubpdpx .prob-title{font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:14px}
  .ubpdpx .prob-sub{font-size:14px;color:rgba(255,255,255,.7);line-height:1.6;padding-top:14px;border-top:1px solid rgba(255,255,255,.15)}
  @media(max-width:700px){.ubpdpx .prob-cards{grid-template-columns:1fr;border-radius:16px}.ubpdpx .prob-card{border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}.ubpdpx .prob-card:last-child{border-bottom:none}}

  /* HOW IT WORKS */
  .ubpdpx .how-section{text-align:center}
  .ubpdpx .how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;margin-top:56px;text-align:center}
  .ubpdpx .how-num{width:52px;height:52px;margin:0 auto 16px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:var(--purple-main)}
  .ubpdpx .how-step h4{font-family:'Red Hat Display',sans-serif;font-size:16px;font-weight:700;color:var(--dark);margin-bottom:8px}
  .ubpdpx .how-step-photo{width:100%;aspect-ratio:1/1;border-radius:20px;overflow:hidden;margin-bottom:16px;background:var(--purple-wash)}
  .ubpdpx .how-step-photo img{width:100%;height:100%;object-fit:cover}

  /* COMPARE TABLE */
  .ubpdpx .compare-section{background:linear-gradient(160deg,#3d1873 0%,#6b2fa0 100%);padding:100px 40px;color:#fff}
  .ubpdpx .compare-inner{max-width:1000px;margin:0 auto}
  .ubpdpx .compare-section .section-label{color:var(--purple-light);text-align:center;display:block}
  .ubpdpx .compare-section h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(28px,3.5vw,42px);font-weight:700;color:#fff;letter-spacing:-0.02em;margin-bottom:16px;text-align:center;line-height:1.15}
  .ubpdpx .compare-section h2 .accent{color:var(--purple-light)}
  .ubpdpx .compare-table{background:rgba(255,255,255,.04);border-radius:20px;overflow:hidden;backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.08);margin-top:48px}
  .ubpdpx .compare-head{display:grid;grid-template-columns:1.2fr 1.2fr 1.3fr 1.3fr;text-transform:uppercase;letter-spacing:1.5px;font-size:10.5px;color:rgba(255,255,255,.5);padding:18px 24px;border-bottom:1px solid rgba(255,255,255,.1);font-weight:600}
  .ubpdpx .compare-row{display:grid;grid-template-columns:1.2fr 1.2fr 1.3fr 1.3fr;padding:18px 24px;border-bottom:1px solid rgba(255,255,255,.06);font-size:14px;align-items:center;transition:background .2s}
  .ubpdpx .compare-row:hover{background:rgba(255,255,255,.04)}
  .ubpdpx .compare-row:last-child{border-bottom:none}
  .ubpdpx .compare-actif{font-weight:600;color:#fff}
  .ubpdpx .compare-market{color:rgba(255,255,255,.5)}
  .ubpdpx .compare-uburn{font-weight:700;color:#fff;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .ubpdpx .compare-pill{background:var(--purple-main);color:#fff;font-size:9.5px;font-weight:800;padding:3px 9px;border-radius:100px;letter-spacing:.8px;text-transform:uppercase}
  .ubpdpx .compare-pill.new{background:#b07de8;color:#3d1873}
  .ubpdpx .compare-benefit{color:rgba(255,255,255,.75);font-size:13.5px}
  @media(max-width:800px){.ubpdpx .compare-head{display:none}.ubpdpx .compare-row{grid-template-columns:1fr;gap:8px;padding:20px 18px}.ubpdpx .compare-row>*::before{content:attr(data-label);display:block;font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,.4);margin-bottom:2px;font-weight:600}}

  /* INGREDIENTS */
  .ubpdpx .ingr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
  .ubpdpx .ingr-card{background:#fff;border-radius:18px;overflow:hidden;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .ubpdpx .ingr-card:hover{box-shadow:0 8px 28px rgba(0,0,0,.06);transform:translateY(-2px)}
  .ubpdpx .ingr-card-img{width:100%;aspect-ratio:4/3;overflow:hidden;background:var(--cream)}
  .ubpdpx .ingr-card-img img{width:100%;height:100%;object-fit:cover}
  .ubpdpx .ingr-card-body{padding:20px}
  .ubpdpx .ingr-card h4{font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:700;color:var(--dark);margin-bottom:6px}
  .ubpdpx .ingr-card p{font-size:13px;color:var(--muted);line-height:1.55}

  /* 6 BIENFAITS INTERACTIFS */
  .ubpdpx .benefits-section{background:#fafafa;padding:100px 40px}
  .ubpdpx .benefits-inner{max-width:1000px;margin:0 auto}
  .ubpdpx .benefits-head{text-align:center;margin-bottom:48px}
  .ubpdpx .benefits-grid-layout{display:grid;grid-template-columns:1fr 1.3fr;gap:40px;align-items:start}
  .ubpdpx .benefit-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .ubpdpx .benefit-card{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:16px;padding:22px 16px;text-align:center;cursor:pointer;transition:all .3s}
  .ubpdpx .benefit-card:hover{border-color:var(--purple-pale)}
  .ubpdpx .benefit-card.active{background:var(--purple-deep);border-color:var(--purple-deep);color:#fff}
  .ubpdpx .benefit-card.active .benefit-icon svg{stroke:#fff}
  .ubpdpx .benefit-icon{width:32px;height:32px;margin:0 auto 8px;display:flex;align-items:center;justify-content:center}
  .ubpdpx .benefit-icon svg{width:24px;height:24px;stroke:var(--purple-main);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;transition:stroke .3s}
  .ubpdpx .benefit-name{font-size:13px;font-weight:600;color:inherit}
  .ubpdpx .benefit-detail{background:#fff;border-radius:20px;padding:40px 36px;box-shadow:0 4px 24px rgba(61,24,115,.06);border:1px solid rgba(0,0,0,.04)}
  .ubpdpx .benefit-detail-icon{width:52px;height:52px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;margin-bottom:18px}
  .ubpdpx .benefit-detail-icon svg{width:24px;height:24px;stroke:var(--purple-main);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .ubpdpx .benefit-label{text-transform:uppercase;letter-spacing:2px;font-size:11px;color:var(--purple-main);font-weight:700;margin-bottom:10px}
  .ubpdpx .benefit-title{font-family:'Red Hat Display',sans-serif;font-size:26px;font-weight:700;color:var(--dark);letter-spacing:-0.02em;margin-bottom:14px;line-height:1.2}
  .ubpdpx .benefit-desc{font-size:15px;color:var(--body);line-height:1.7;margin-bottom:20px}
  .ubpdpx .benefit-badge{display:inline-block;background:var(--purple-wash);color:var(--purple-main);padding:7px 14px;border-radius:100px;font-size:12px;font-weight:600}
  @media(max-width:780px){.ubpdpx .benefits-grid-layout{grid-template-columns:1fr;gap:32px}.ubpdpx .benefit-cards{grid-template-columns:repeat(3,1fr);gap:8px}.ubpdpx .benefit-card{padding:16px 10px}.ubpdpx .benefit-detail{padding:32px 24px}}

  /* PRESS */
  .ubpdpx .press-bar{padding:40px;text-align:center;border-top:1px solid rgba(0,0,0,.04);border-bottom:1px solid rgba(0,0,0,.04)}
  .ubpdpx .press-bar p{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);font-weight:600;margin-bottom:24px}
  .ubpdpx .press-logos{display:flex;gap:40px;justify-content:center;align-items:center;flex-wrap:wrap;opacity:.5}
  .ubpdpx .press-logos img{height:22px;width:auto}

  /* STATS */
  .ubpdpx .stats-section{padding:100px 40px;background:var(--grad);text-align:center;color:#fff;position:relative;overflow:hidden}
  .ubpdpx .stats-section::before{content:'';position:absolute;inset:0;background:url('https://uburn.co/cdn/shop/files/FOND_FIN.jpg?v=1749644803&width=1600') center/cover no-repeat;opacity:.08;mix-blend-mode:luminosity}
  .ubpdpx .stats-section>*{position:relative;z-index:1}
  .ubpdpx .stats-section .section-inner{max-width:700px}
  .ubpdpx .stats-section h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:700;margin-bottom:16px;line-height:1.15;color:#fff}
  .ubpdpx .big-stats-row{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-bottom:40px}
  .ubpdpx .big-stat{text-align:center;min-width:140px}
  .ubpdpx .big-stat-num{font-family:'Red Hat Display',sans-serif;font-size:56px;font-weight:800;color:#fff;letter-spacing:-0.03em;line-height:1}
  .ubpdpx .big-stat-label{font-size:13px;color:rgba(255,255,255,.65);margin-top:8px;max-width:160px;margin-left:auto;margin-right:auto;line-height:1.4}
  .ubpdpx .stats-row{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-top:48px;opacity:.85}
  .ubpdpx .stat{text-align:center}
  .ubpdpx .stat-num{font-family:'Red Hat Display',sans-serif;font-size:42px;font-weight:800}
  .ubpdpx .stat-label{font-size:13px;color:rgba(255,255,255,.6);margin-top:4px}
  .ubpdpx .stats-note{font-size:11px;color:rgba(255,255,255,.4);margin-top:32px;text-align:center;font-style:italic}
  @media(max-width:700px){.ubpdpx .big-stat-num{font-size:42px}.ubpdpx .big-stats-row{gap:24px}}

  /* TESTIMONIALS */
  .ubpdpx .testi-section{text-align:center}
  .ubpdpx .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;text-align:left}
  .ubpdpx .testi-card{background:var(--cream);border-radius:20px;padding:32px;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .ubpdpx .testi-card:hover{box-shadow:0 8px 30px rgba(0,0,0,.06)}
  .ubpdpx .testi-stars{color:var(--purple-main);font-size:14px;margin-bottom:14px;letter-spacing:2px}
  .ubpdpx .testi-text{font-size:14.5px;color:var(--body);line-height:1.65;margin-bottom:20px}
  .ubpdpx .testi-verified{font-size:11px;color:var(--purple-main);font-weight:600;margin-bottom:12px}
  .ubpdpx .testi-author{display:flex;align-items:center;gap:10px}
  .ubpdpx .testi-avatar{width:38px;height:38px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:13px;font-weight:700;color:var(--purple-main)}
  .ubpdpx .testi-name{font-weight:600;font-size:13px;color:var(--dark)}
  .ubpdpx .testi-role{font-size:12px;color:var(--muted)}

  /* FAQ */
  .ubpdpx .faq-section{background:var(--cream)}
  .ubpdpx .faq-list{max-width:700px;margin:48px auto 0}
  .ubpdpx .faq-item{border-bottom:1px solid rgba(0,0,0,.06);padding:20px 0;cursor:pointer}
  .ubpdpx .faq-q{display:flex;justify-content:space-between;align-items:center;font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:600;color:var(--dark)}
  .ubpdpx .faq-q::after{content:'+';font-size:20px;color:var(--purple-main);transition:.3s}
  .ubpdpx .faq-item.open .faq-q::after{content:'\2212'}
  .ubpdpx .faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease;font-size:14px;color:var(--body);line-height:1.65}
  .ubpdpx .faq-item.open .faq-a{max-height:400px;padding-top:12px}

  /* GUARANTEE */
  .ubpdpx .guar-bar{padding:44px 40px;border-top:1px solid rgba(0,0,0,.05);border-bottom:1px solid rgba(0,0,0,.05)}
  .ubpdpx .guar-grid{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
  .ubpdpx .guar-icon{width:48px;height:48px;margin:0 auto 10px}
  .ubpdpx .guar-icon img{width:100%;height:100%}
  .ubpdpx .guar-item h4{font-family:'Red Hat Display',sans-serif;font-size:13px;font-weight:700;color:var(--dark);margin-bottom:2px}
  .ubpdpx .guar-item p{font-size:12px;color:var(--muted)}

  /* DISCLAIMER */
  .ubpdpx .disc-bar{background:var(--cream);padding:24px 16px}
  .ubpdpx .disc-bar-inner{max-width:1000px;margin:0 auto;padding:16px;background:var(--warm);border-radius:10px}
  .ubpdpx .disc-bar-inner p{font-size:11px;color:var(--muted);line-height:1.6}

  /* LIFESTYLE */
  .ubpdpx .lifestyle-section{position:relative;min-height:640px;overflow:hidden;display:flex;align-items:center;padding:100px 40px}
  .ubpdpx .lifestyle-bg{position:absolute;inset:0;background:linear-gradient(135deg,#2a1054 0%,#6b2fa0 60%,#8b47c5 100%);background-image:url('https://uburn.co/cdn/shop/files/focus_product_1_3dab8125-eab7-4b9d-a33f-e28cdd57aa67.jpg?v=1776425406&width=1600&format=webp');background-size:cover;background-position:center top;z-index:0}
  .ubpdpx .lifestyle-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(42,16,84,.85) 0%,rgba(61,24,115,.5) 60%,rgba(61,24,115,.2) 100%)}
  .ubpdpx .lifestyle-inner{position:relative;z-index:1;max-width:560px;color:#fff}
  .ubpdpx .lifestyle-inner .section-label{color:var(--purple-light)}
  .ubpdpx .lifestyle-inner h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(30px,4vw,48px);font-weight:700;line-height:1.1;letter-spacing:-0.02em;margin-bottom:20px;color:#fff}
  .ubpdpx .lifestyle-inner h2 em{font-style:italic;color:var(--purple-light);font-weight:700}
  .ubpdpx .lifestyle-inner p{color:rgba(255,255,255,.85);font-size:16px;line-height:1.7;margin-bottom:28px}

  /* ANIMATIONS */
