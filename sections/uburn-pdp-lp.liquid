{%- comment -%}
  UBurn — Product page (LP-style)
  Forked from sections/uburn-lp.liquid → adapted to product context.
  - Uses default theme layout (header-group + footer-group + cart drawer)
  - Variant IDs pulled dynamically from product.variants (no hardcoded IDs)
  - Direct-to-checkout pattern preserved (cart/{id}:1?checkout)
  - Adds product JSON-LD for SEO
{%- endcomment -%}

{%- liquid
  assign v_decouverte = product.variants[0]
  assign v_maximum = product.variants[1] | default: product.variants[0]
  assign hero_image = product.featured_image | default: product.media[0]
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
<link rel="preload" as="image" fetchpriority="high" href="https://uburn.co/cdn/shop/files/WhatsApp_Image_2026-04-17_at_12.46.02_1.jpg?v=1776421390&width=900&format=webp">
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

<style>
  /* === UBPDP scope: tout le CSS est scopé à .ubpdp pour ne pas casser le theme === */
  .ubpdp,.ubpdp *,.ubpdp *::before,.ubpdp *::after{box-sizing:border-box}
  .ubpdp{font-family:'Red Hat Text',sans-serif;color:#242220;background:#fff;-webkit-font-smoothing:antialiased}
  .ubpdp a{text-decoration:none;color:inherit}
  .ubpdp img{max-width:100%;display:block}
  .ubpdp ul{list-style:none;padding:0;margin:0}
  .ubpdp h1,.ubpdp h2,.ubpdp h3,.ubpdp h4,.ubpdp p{margin:0;padding:0}

  .ubpdp{
    --purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;--purple-light:#b07de8;
    --purple-pale:#e8dcf5;--purple-wash:#f5f0fa;--cream:#faf9f7;--warm:#f2f0ed;
    --dark:#242220;--body:#5a5654;--muted:#8a8785;
    --grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%);
  }

  /* PROMO STICKY — UBE10 */
  .ubpdp .promo-bar{position:sticky;top:0;z-index:300;background:linear-gradient(90deg,#6B21A8 0%,#8b47c5 100%);color:#fff;padding:10px 16px;display:flex;align-items:center;justify-content:center;gap:12px;font-size:13px;font-weight:600;text-align:center;line-height:1.3;flex-wrap:wrap}
  .ubpdp .promo-bar strong{font-weight:800;letter-spacing:.5px}
  .ubpdp .promo-copy{background:#fff;color:#3b0764;border:none;padding:6px 14px;border-radius:100px;font-size:12px;font-weight:800;cursor:pointer;white-space:nowrap;transition:transform .15s}
  .ubpdp .promo-copy:active{transform:scale(.95)}
  .ubpdp .promo-copy.copied{background:#16a34a;color:#fff}
  .ubpdp .promo-bar.applied{background:linear-gradient(90deg,#16a34a 0%,#22c55e 100%)}
  .ubpdp .promo-bar.applied .promo-copy{display:none}
  @media(max-width:500px){.ubpdp .promo-bar{font-size:12px;padding:8px 12px;gap:8px}.ubpdp .promo-copy{padding:5px 12px;font-size:11px}}

  /* BTN */
  .ubpdp .btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;border-radius:100px;font-family:'Red Hat Text',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:.3s;border:none}
  .ubpdp .btn-fill{background:var(--purple-main);color:#fff}
  .ubpdp .btn-fill:hover{background:var(--purple-deep);transform:translateY(-1px);box-shadow:0 6px 20px rgba(107,47,160,.3)}
  .ubpdp .btn-white{background:#fff;color:var(--purple-deep)}
  .ubpdp .btn-white:hover{background:var(--purple-wash);transform:translateY(-1px);box-shadow:0 6px 24px rgba(0,0,0,.15)}
  .ubpdp .btn-outline{background:transparent;color:var(--purple-main);border:1.5px solid var(--purple-pale)}
  .ubpdp .btn-outline:hover{background:var(--purple-wash)}

  /* TRUST RIBBON */
  .ubpdp .ribbon{background:var(--purple-wash);padding:10px 20px;display:flex;justify-content:center;gap:24px;flex-wrap:wrap;font-size:13px;color:var(--body);font-weight:500}

  /* MARQUEE */
  .ubpdp .marquee{padding:12px 0;overflow:hidden;border-bottom:1px solid rgba(0,0,0,.04)}
  .ubpdp .marquee-track{display:flex;gap:40px;animation:ubp-slide 25s linear infinite;width:max-content}
  .ubpdp .marquee-item{white-space:nowrap;font-size:12.5px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px;display:flex;align-items:center;gap:10px}
  .ubpdp .marquee-dot{width:5px;height:5px;border-radius:50%;background:var(--purple-light)}
  @keyframes ubp-slide{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* HERO */
  .ubpdp .hero{padding:80px 40px 60px;max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
  .ubpdp .hero-tag{display:inline-block;padding:8px 18px;border-radius:100px;background:var(--purple-wash);font-size:13px;font-weight:600;color:var(--purple-main);margin-bottom:24px}
  .ubpdp .hero h1{font-family:'Red Hat Display',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:800;line-height:1.06;margin-bottom:24px;color:var(--dark)}
  .ubpdp .hero h1 .accent{color:var(--purple-mid)}
  .ubpdp .hero-sub{font-size:17px;color:var(--body);line-height:1.65;margin-bottom:28px;max-width:460px}
  .ubpdp .hero-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px}
  .ubpdp .hero-badge{padding:8px 16px;border-radius:100px;border:1px solid rgba(0,0,0,.08);font-size:13px;font-weight:500;color:var(--body);display:flex;align-items:center;gap:6px}
  .ubpdp .hero-visual{position:relative;display:flex;justify-content:center;align-items:center}
  .ubpdp .hero-visual img{width:100%;max-width:520px;height:auto;border-radius:24px;box-shadow:0 32px 80px rgba(61,24,115,.22),0 0 0 1px rgba(107,47,160,.1);display:block}
  .ubpdp .hero-float{position:absolute;background:#fff;border-radius:14px;padding:12px 18px;box-shadow:0 8px 30px rgba(0,0,0,.1);display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;color:var(--dark)}
  .ubpdp .hero-float.top{top:20px;right:0}
  .ubpdp .hero-float.bottom{bottom:40px;left:0}
  .ubpdp .float-badge{padding:4px 10px;border-radius:100px;background:var(--purple-wash);color:var(--purple-main);font-size:11px;font-weight:700}

  /* HERO BONUS BLOCK */
  .ubpdp .hero-bonus{margin-top:20px;background:var(--purple-wash);border:1px solid var(--purple-pale);border-radius:14px;padding:14px 18px}
  .ubpdp .hero-bonus-label{font-size:12px;font-weight:700;color:var(--purple-main);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px}
  .ubpdp .hero-bonus-items{display:flex;flex-direction:column;gap:5px}
  .ubpdp .hero-bonus-items span{font-size:13px;color:var(--dark);font-weight:500;line-height:1.4}
  .ubpdp .hero-bonus-items em{color:var(--muted);font-style:normal;font-size:12px}
  .ubpdp .hero-bonus-total{margin-top:10px;padding-top:10px;border-top:1px solid var(--purple-pale);font-size:13px;color:var(--body)}
  .ubpdp .hero-bonus-total strong{color:var(--purple-deep);font-weight:800}

  /* SECTIONS */
  .ubpdp .section{padding:100px 40px}
  .ubpdp .section-inner{max-width:1100px;margin:0 auto}
  .ubpdp .section-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:2.5px;color:var(--purple-main);margin-bottom:14px}
  .ubpdp .section-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3.2vw,40px);font-weight:700;color:var(--dark);line-height:1.15;margin-bottom:16px}
  .ubpdp .section-title .accent{color:var(--purple-mid)}

  /* PROBLEM */
  .ubpdp .problem-section{background:var(--cream)}
  .ubpdp .problem-punchline{margin-top:40px;font-family:'Red Hat Display',sans-serif;font-size:clamp(20px,2.5vw,28px);font-weight:700;color:var(--dark);text-align:center;line-height:1.3}
  .ubpdp .problem-punchline .accent{color:var(--purple-mid)}

  /* PROD 2-COL */
  .ubpdp .prod-block{padding:100px 40px;overflow:hidden}
  .ubpdp .prod-block.alt{background:var(--cream)}
  .ubpdp .prod-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
  .ubpdp .prod-block.reverse .prod-inner{direction:rtl}
  .ubpdp .prod-block.reverse .prod-text,.ubpdp .prod-block.reverse .prod-visual{direction:ltr}
  .ubpdp .prod-text h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3vw,38px);font-weight:700;color:var(--dark);line-height:1.12;margin-bottom:12px}
  .ubpdp .prod-text h2 .accent{color:var(--purple-mid)}
  .ubpdp .prod-text h3{font-family:'Red Hat Display',sans-serif;font-size:17px;font-weight:500;color:var(--body);margin-bottom:20px;line-height:1.45}
  .ubpdp .prod-text>p{font-size:15px;color:var(--body);line-height:1.7;margin-bottom:28px}
  .ubpdp .feats{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
  .ubpdp .feat{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--body)}
  .ubpdp .feat-ck{width:20px;height:20px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .ubpdp .feat-ck svg{width:12px;height:12px;stroke:var(--purple-main);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
  .ubpdp .prod-img{width:100%;border-radius:24px;overflow:hidden;background:linear-gradient(145deg,#e8dcf5,#f5f0fa);display:flex;align-items:center;justify-content:center;aspect-ratio:1/1}
  .ubpdp .prod-img img{width:85%;height:auto;filter:drop-shadow(0 12px 30px rgba(61,24,115,.15))}
  .ubpdp .prod-img-full img{width:100%;height:100%;object-fit:cover}

  /* HOW */
  .ubpdp .how-section{text-align:center}
  .ubpdp .how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px;margin-top:56px;text-align:center}
  .ubpdp .how-num{width:52px;height:52px;margin:0 auto 16px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:var(--purple-main)}
  .ubpdp .how-step h4{font-family:'Red Hat Display',sans-serif;font-size:16px;font-weight:700;color:var(--dark);margin-bottom:8px}
  .ubpdp .how-step-photo{width:100%;aspect-ratio:1/1;border-radius:20px;overflow:hidden;margin-bottom:16px;background:var(--purple-wash)}
  .ubpdp .how-step-photo img{width:100%;height:100%;object-fit:cover}

  /* INGREDIENTS */
  .ubpdp .ingr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
  .ubpdp .ingr-card{background:#fff;border-radius:18px;overflow:hidden;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .ubpdp .ingr-card:hover{box-shadow:0 8px 28px rgba(0,0,0,.06);transform:translateY(-2px)}
  .ubpdp .ingr-card-img{width:100%;aspect-ratio:4/3;overflow:hidden;background:var(--cream)}
  .ubpdp .ingr-card-img img{width:100%;height:100%;object-fit:cover}
  .ubpdp .ingr-card-body{padding:20px}
  .ubpdp .ingr-card h4{font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:700;color:var(--dark);margin-bottom:6px}
  .ubpdp .ingr-card p{font-size:13px;color:var(--muted);line-height:1.55}

  /* PRESS */
  .ubpdp .press-bar{padding:40px;text-align:center;border-top:1px solid rgba(0,0,0,.04);border-bottom:1px solid rgba(0,0,0,.04)}
  .ubpdp .press-bar p{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--muted);font-weight:600;margin-bottom:24px}
  .ubpdp .press-logos{display:flex;gap:40px;justify-content:center;align-items:center;flex-wrap:wrap;opacity:.5}
  .ubpdp .press-logos img{height:22px;width:auto}

  /* STATS */
  .ubpdp .stats-section{padding:100px 40px;background:var(--grad);text-align:center;color:#fff;position:relative;overflow:hidden}
  .ubpdp .stats-section::before{content:'';position:absolute;inset:0;background:url('https://uburn.co/cdn/shop/files/FOND_FIN.jpg?v=1749644803&width=1600') center/cover no-repeat;opacity:.08;mix-blend-mode:luminosity}
  .ubpdp .stats-section>*{position:relative;z-index:1}
  .ubpdp .stats-section .section-inner{max-width:700px}
  .ubpdp .stats-section h2{font-family:'Red Hat Display',sans-serif;font-size:clamp(26px,3.5vw,42px);font-weight:700;margin-bottom:16px;line-height:1.15;color:#fff}
  .ubpdp .stats-section p{font-size:16px;color:rgba(255,255,255,.7);line-height:1.65;margin-bottom:36px}
  .ubpdp .stats-row{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-top:48px}
  .ubpdp .stat{text-align:center}
  .ubpdp .stat-num{font-family:'Red Hat Display',sans-serif;font-size:42px;font-weight:800}
  .ubpdp .stat-label{font-size:13px;color:rgba(255,255,255,.6);margin-top:4px}

  /* TESTIMONIALS */
  .ubpdp .testi-section{text-align:center}
  .ubpdp .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;text-align:left}
  .ubpdp .testi-card{background:var(--cream);border-radius:20px;padding:32px;border:1px solid rgba(0,0,0,.04);transition:.3s}
  .ubpdp .testi-card:hover{box-shadow:0 8px 30px rgba(0,0,0,.06)}
  .ubpdp .testi-stars{color:var(--purple-main);font-size:14px;margin-bottom:14px;letter-spacing:2px}
  .ubpdp .testi-text{font-size:14.5px;color:var(--body);line-height:1.65;margin-bottom:20px}
  .ubpdp .testi-verified{font-size:11px;color:var(--purple-main);font-weight:600;margin-bottom:12px}
  .ubpdp .testi-author{display:flex;align-items:center;gap:10px}
  .ubpdp .testi-avatar{width:38px;height:38px;border-radius:50%;background:var(--purple-wash);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-size:13px;font-weight:700;color:var(--purple-main)}
  .ubpdp .testi-name{font-weight:600;font-size:13px;color:var(--dark)}
  .ubpdp .testi-role{font-size:12px;color:var(--muted)}

  /* PRICING */
  .ubpdp .pricing-section{text-align:center}
  .ubpdp .pricing-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;max-width:700px;margin:48px auto 0}
  .ubpdp .pricing-card{background:var(--cream);border-radius:22px;padding:36px;border:2px solid transparent;transition:.3s;position:relative;cursor:pointer}
  .ubpdp .pricing-card.pop{border-color:var(--purple-main);background:#fff}
  .ubpdp .pricing-pop-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);padding:5px 18px;border-radius:100px;background:var(--purple-main);color:#fff;font-size:11px;font-weight:700;white-space:nowrap}
  .ubpdp .pricing-card h3{font-family:'Red Hat Display',sans-serif;font-size:20px;font-weight:700;color:var(--dark);margin-bottom:4px}
  .ubpdp .pricing-desc{font-size:13px;color:var(--muted);margin-bottom:20px}
  .ubpdp .pricing-price{font-family:'Red Hat Display',sans-serif;font-size:38px;font-weight:800;color:var(--purple-deep)}
  .ubpdp .pricing-price small{font-size:14px;font-weight:500;color:var(--muted)}
  .ubpdp .pricing-per{font-size:13px;color:var(--muted);margin-bottom:24px}

  /* FAQ */
  .ubpdp .faq-section{background:var(--cream)}
  .ubpdp .faq-list{max-width:700px;margin:48px auto 0}
  .ubpdp .faq-item{border-bottom:1px solid rgba(0,0,0,.06);padding:20px 0;cursor:pointer}
  .ubpdp .faq-q{display:flex;justify-content:space-between;align-items:center;font-family:'Red Hat Display',sans-serif;font-size:15px;font-weight:600;color:var(--dark)}
  .ubpdp .faq-q::after{content:'+';font-size:20px;color:var(--purple-main);transition:.3s}
  .ubpdp .faq-item.open .faq-q::after{content:'\2212'}
  .ubpdp .faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease;font-size:14px;color:var(--body);line-height:1.65}
  .ubpdp .faq-item.open .faq-a{max-height:400px;padding-top:12px}

  /* GUARANTEE */
  .ubpdp .guar-bar{padding:44px 40px;border-top:1px solid rgba(0,0,0,.05);border-bottom:1px solid rgba(0,0,0,.05)}
  .ubpdp .guar-grid{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
  .ubpdp .guar-icon{width:48px;height:48px;margin:0 auto 10px}
  .ubpdp .guar-icon img{width:100%;height:100%}
  .ubpdp .guar-item h4{font-family:'Red Hat Display',sans-serif;font-size:13px;font-weight:700;color:var(--dark);margin-bottom:2px}
  .ubpdp .guar-item p{font-size:12px;color:var(--muted)}

  /* DISCLAIMER */
  .ubpdp .disc-bar{background:var(--cream);padding:24px 16px}
  .ubpdp .disc-bar-inner{max-width:1000px;margin:0 auto;padding:16px;background:var(--warm);border-radius:10px}
  .ubpdp .disc-bar-inner p{font-size:11px;color:var(--muted);line-height:1.6}

  /* ANIMATIONS */
  .ubpdp .reveal{opacity:0;transform:translateY(36px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1)}
  .ubpdp .reveal.visible{opacity:1;transform:translateY(0)}
  .ubpdp .reveal-d{transition-delay:.15s}
  @keyframes ubp-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
  @keyframes ubp-pulse-glow{0%,100%{box-shadow:0 4px 20px rgba(107,47,160,.25)}50%{box-shadow:0 8px 40px rgba(107,47,160,.5)}}
  @keyframes ubp-slide-up{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
  .ubpdp .hero-visual img{animation:ubp-float 5s ease-in-out infinite}
  .ubpdp .hero-visual img:hover{animation-play-state:paused}
  @media(max-width:900px){.ubpdp .hero-visual img{max-width:380px!important;animation:none}}
  .ubpdp .btn-fill{animation:ubp-pulse-glow 2.5s ease-in-out infinite}
  .ubpdp .btn-fill:hover{animation-play-state:paused}
  .ubpdp .stagger-children > *{opacity:0;transform:translateY(22px);transition:opacity .55s ease,transform .55s ease}
  .ubpdp .stagger-children.visible > *:nth-child(1){opacity:1;transform:none;transition-delay:0s}
  .ubpdp .stagger-children.visible > *:nth-child(2){opacity:1;transform:none;transition-delay:.1s}
  .ubpdp .stagger-children.visible > *:nth-child(3){opacity:1;transform:none;transition-delay:.2s}
  .ubpdp .stagger-children.visible > *:nth-child(4){opacity:1;transform:none;transition-delay:.3s}
  .ubpdp .stagger-children.visible > *:nth-child(5){opacity:1;transform:none;transition-delay:.4s}
  .ubpdp .stagger-children.visible > *:nth-child(6){opacity:1;transform:none;transition-delay:.5s}
  .ubpdp .stagger-scale > *{opacity:0;transform:scale(.88) translateY(16px);transition:opacity .5s ease,transform .5s ease}
  .ubpdp .stagger-scale.visible > *:nth-child(1){opacity:1;transform:none;transition-delay:0s}
  .ubpdp .stagger-scale.visible > *:nth-child(2){opacity:1;transform:none;transition-delay:.08s}
  .ubpdp .stagger-scale.visible > *:nth-child(3){opacity:1;transform:none;transition-delay:.16s}
  .ubpdp .stagger-scale.visible > *:nth-child(4){opacity:1;transform:none;transition-delay:.24s}
  .ubpdp .stagger-scale.visible > *:nth-child(5){opacity:1;transform:none;transition-delay:.32s}
  .ubpdp .stagger-scale.visible > *:nth-child(6){opacity:1;transform:none;transition-delay:.4s}

  /* PROBLEM CARDS */
  .ubpdp .prob-cards{display:grid;grid-template-columns:repeat(3,1fr);margin-top:48px;border-radius:20px;overflow:hidden;box-shadow:0 4px 32px rgba(61,24,115,.1)}
  .ubpdp .prob-card{background:linear-gradient(145deg,#2e1060 0%,#5b2199 60%,#7c3abf 100%);padding:40px 32px;border-right:1px solid rgba(255,255,255,.08);position:relative;transition:filter .25s}
  .ubpdp .prob-card:last-child{border-right:none}
  .ubpdp .prob-card:hover{filter:brightness(1.08)}
  .ubpdp .prob-num{font-family:'Red Hat Display',sans-serif;font-size:68px;font-weight:900;color:rgba(255,255,255,.08);line-height:1;letter-spacing:-0.04em;margin-bottom:20px;user-select:none}
  .ubpdp .prob-title{font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:14px}
  .ubpdp .prob-sub{font-size:14px;color:rgba(255,255,255,.7);line-height:1.6;padding-top:14px;border-top:1px solid rgba(255,255,255,.15)}
