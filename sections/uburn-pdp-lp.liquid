<script>
(function(){
  var root = document.querySelector('.ubpdp');
  if(!root) return;

  // PROMO BAR — copy UBE10
  (function(){
    var params=new URLSearchParams(window.location.search);
    var bar=document.getElementById('ubpdp-promoBar');
    var txt=document.getElementById('ubpdp-promoText');
    var btn=document.getElementById('ubpdp-promoCopy');
    if(!bar||!txt||!btn) return;
    if(params.get('discount')==='UBE10'||params.get('code')==='UBE10'){
      bar.classList.add('applied');
      txt.innerHTML='✓ Code <strong>UBE10</strong> appliqué — <strong>-10%</strong> sur ta commande';
    }
    btn.addEventListener('click',function(){
      navigator.clipboard.writeText('UBE10').then(function(){
        btn.textContent='Copié ✓';btn.classList.add('copied');
        setTimeout(function(){btn.textContent='Copier';btn.classList.remove('copied');},2000);
      }).catch(function(){
        var ta=document.createElement('textarea');ta.value='UBE10';document.body.appendChild(ta);ta.select();
        try{document.execCommand('copy');btn.textContent='Copié ✓';btn.classList.add('copied');setTimeout(function(){btn.textContent='Copier';btn.classList.remove('copied');},2000);}catch(e){}
        document.body.removeChild(ta);
      });
    });
  })();

  // UTM-driven hero copy
  (function(){
    var params = new URLSearchParams(window.location.search);
    var utmContent = (params.get('utm_content') || '').toLowerCase();
    var map = {
      'violet': {h1:'La boisson <span class="accent">violette</span> qui coupe les fringales 4h', sub:'30 kcal · 0% caféine · satisfaction durable.'},
      'ube':    {h1:'Ube + Konjac = <span class="accent">4h</span> sans fringales', sub:'100% naturel · 30 kcal · Marque Française.'},
      'soir':   {h1:'Votre nouvelle <span class="accent">routine</span> commence ici', sub:'0% caféine · se prend à toute heure · 30 kcal.'},
      'energie':{h1:'Pourquoi vous avez un coup de pompe <span class="accent">à 15h</span>&nbsp;?', sub:'MCT de coco · énergie stable · sans excitants.'}
    };
    var v = map[utmContent];
    if(v){
      var h1 = root.querySelector('.hero h1');
      var sub = root.querySelector('.hero-sub');
      if(h1) h1.innerHTML = v.h1;
      if(sub) sub.textContent = v.sub;
    }
  })();

  // OFFER cart-preview toggle
  (function() {
    var cartBlock = root.querySelector('#cart-preview-block');
    var cardDec = root.querySelector('#card-decouverte');
    var cardMax = root.querySelector('#card-maximum');
    if (!cartBlock || !cardDec || !cardMax) return;
    function selectMax() { cartBlock.style.display = ''; cardMax.style.outline = '2px solid var(--purple-main)'; cardDec.style.outline = ''; }
    function selectDec() { cartBlock.style.display = 'none'; cardDec.style.outline = '2px solid var(--purple-main)'; cardMax.style.outline = ''; }
    cardDec.addEventListener('click', function(e){ if(e.target.tagName!=='A') selectDec(); });
    cardMax.addEventListener('click', function(e){ if(e.target.tagName!=='A') selectMax(); });
    selectDec();
  })();

  // Scroll reveal
  var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}})},{threshold:.12});
  root.querySelectorAll('.reveal,.stagger-children,.stagger-scale').forEach(function(el){obs.observe(el)});

  // Count-up
  var countObs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){
    var el=e.target,target=+el.dataset.count,suffix=el.dataset.suffix||'',dur=1400;
    var start=null;
    function step(ts){if(!start)start=ts;var p=Math.min((ts-start)/dur,1);el.textContent=Math.round(p*target)+suffix;if(p<1)requestAnimationFrame(step);}
    requestAnimationFrame(step);
    countObs.unobserve(el);
  }})},{threshold:.3});
  root.querySelectorAll('[data-count]').forEach(function(el){countObs.observe(el)});

  // FAQ accordion
  root.querySelectorAll('.faq-item').forEach(function(item){
    item.querySelector('.faq-q').addEventListener('click',function(){
      root.querySelectorAll('.faq-item').forEach(function(i){if(i!==item)i.classList.remove('open')});
      item.classList.toggle('open');
    });
  });

  // 6 bienfaits
  var benefits = {
    satiete: {label: 'Glucomannane · EFSA · Fibres', title: 'Satiété durable', desc: 'Système complet basé sur le glucomannane (EFSA ID 3120) et 5g de fibres par dose. Le konjac absorbe jusqu\'à 100x son poids en eau pour former un gel qui occupe naturellement l\'estomac.'},
    energie: {label: 'MCT · L-Carnitine', title: 'Énergie stable', desc: 'MCT coco et L-Carnitine 400mg pour une énergie sans pic ni crash. Parfait pour les après-midis longs.'},
    digestion: {label: 'Gingembre · Acacia', title: 'Digestion apaisée', desc: 'Gingembre bio et fibre d\'acacia prébiotique pour un confort digestif au quotidien.'},
    antioxydants: {label: 'Ubé · Anthocyanes', title: 'Antioxydants puissants', desc: 'Ubé violet riche en anthocyanes naturelles pour la protection cellulaire et l\'éclat de la peau.'},
    metabolisme: {label: 'L-Carnitine · Gingembre', title: 'Métabolisme soutenu', desc: 'L-Carnitine 400mg et gingembre pour un support métabolique naturel et durable.'},
    bien_etre: {label: 'Formule complète', title: 'Équilibre global', desc: 'Une formule synergique de 6 actifs pour un bien-être quotidien apaisé et durable.'}
  };
  root.querySelectorAll('[data-benefit]').forEach(function(card){
    card.addEventListener('click', function(){
      var key = card.getAttribute('data-benefit');
      root.querySelectorAll('[data-benefit]').forEach(function(c){c.classList.remove('active')});
      card.classList.add('active');
      var detail = root.querySelector('.benefit-detail');
      if (detail && benefits[key]) {
        detail.querySelector('.benefit-label').textContent = benefits[key].label;
        detail.querySelector('.benefit-title').textContent = benefits[key].title;
        detail.querySelector('.benefit-desc').textContent = benefits[key].desc;
      }
    });
  });
})();
</script>

