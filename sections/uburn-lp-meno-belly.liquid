{%- comment -%}
  UBurn LP Meno Belly — Violet Matcha · aligned on PDP DA (u2-* tokens)
  Rev 2026-05-19 v3 — drop Bloom Fraunces, adopt Times serif + Helvetica Neue from u2-base.css
{%- endcomment -%}
{%- liquid
  assign hp = section.settings.product
  if hp == blank
    assign hp = all_products['ube-poudre']
  endif
  assign v_starter = hp.variants[0]
  assign v_maximum = hp.variants[1] | default: hp.variants[0]
  assign sub_plan = null
  for spg in hp.selling_plan_groups
    for sp in spg.selling_plans
      assign sub_plan = sp
      break
    endfor
    if sub_plan != null
      break
    endif
  endfor
-%}

