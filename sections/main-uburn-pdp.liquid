{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign discount_code = 'UBE10'
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://uburn.co" crossorigin>
<link rel="preload" as="image" fetchpriority="high" href="{{ product.featured_image | image_url: width: 900 }}&format=webp">

<style>
  /* ===== UBURN PDP V2 — Mobile-first · ADN preserved (Poppins, #7d3fff, cream) ===== */
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  .upd2{font-family:'Poppins',sans-serif;color:#1c1c1c;background:#fff;-webkit-font-smoothing:antialiased;line-height:1.55}
  .upd2 *,.upd2 *::before,.upd2 *::after{box-sizing:border-box}
  .upd2 a{color:inherit;text-decoration:none}
  .upd2 img{max-width:100%;display:block;height:auto}
  .upd2 button{font-family:inherit;cursor:pointer}
  .upd2 ul,.upd2 ol{list-style:none}

  :root{
    --u-primary:#7d3fff;--u-primary-dark:#6328d6;--u-primary-light:#9f7aea;
    --u-purple-deep:#2b1e4d;--u-purple-pale:#f8f5ff;
    --u-cream:#FAF7F2;--u-gold:#D4A574;
    --u-text:#1c1c1c;--u-text-muted:#6b6b6b;--u-border:#e8e8e8;
    --u-success:#16a34a;--u-rating:#fbbf24;
  }

  /* ============================================================
     1. STICKY TOP BAR
  ============================================================ */
  .upd2-topbar{position:sticky;top:0;z-index:99;background:linear-gradient(90deg,#7d3fff 0%,#9f7aea 100%);color:#fff;padding:9px 14px;font-size:12.5px;font-weight:500;letter-spacing:.2px;display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;text-align:center}
  .upd2-topbar__item{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
  .upd2-topbar strong{font-weight:700;letter-spacing:.5px}
  .upd2-topbar__copy{background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:0;font-size:11px;font-weight:700;letter-spacing:.5px;cursor:pointer;text-transform:uppercase;transition:background .15s}
  .upd2-topbar__copy:hover{background:rgba(255,255,255,.28)}
  .upd2-topbar__copy.copied{background:#fff;color:#7d3fff}
  .upd2-topbar.applied{background:linear-gradient(90deg,#16a34a 0%,#22c55e 100%)}
  @media(max-width:600px){.upd2-topbar{font-size:11.5px;gap:10px;padding:8px 10px}.upd2-topbar__item:nth-child(3){display:none}}

  /* ============================================================
     2. HERO + ATC
  ============================================================ */
  .upd2-hero{padding:24px 16px 32px;max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
  @media(max-width:900px){.upd2-hero{grid-template-columns:1fr;gap:20px;padding:16px 16px 24px}}

  /* Gallery */
  .upd2-gallery{position:relative}
  .upd2-gallery__main{aspect-ratio:1/1;background:var(--u-purple-pale);border-radius:0;overflow:hidden;position:relative}
  .upd2-gallery__main img{width:100%;height:100%;object-fit:cover;display:block;transition:opacity .25s}
  .upd2-gallery__nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.92);border:none;width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--u-purple-deep);font-size:20px;font-weight:300;box-shadow:0 4px 14px rgba(0,0,0,.12);transition:.15s;z-index:2}
  .upd2-gallery__nav:hover{background:#fff;transform:translateY(-50%) scale(1.05)}
  .upd2-gallery__nav--prev{left:14px}
  .upd2-gallery__nav--next{right:14px}
  .upd2-gallery__counter{position:absolute;bottom:14px;right:14px;background:rgba(0,0,0,.55);color:#fff;font-size:11px;font-weight:600;padding:5px 10px;border-radius:0;letter-spacing:.5px}
  .upd2-gallery__thumbs{display:flex;gap:6px;margin-top:8px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:4px;scrollbar-width:none}
  .upd2-gallery__thumbs::-webkit-scrollbar{display:none}
  .upd2-thumb{flex-shrink:0;width:64px;height:64px;border-radius:0;overflow:hidden;border:2px solid transparent;background:var(--u-purple-pale);transition:border-color .15s;padding:0}
  .upd2-thumb img{width:100%;height:100%;object-fit:cover}
  .upd2-thumb.active{border-color:var(--u-primary)}

  /* Buy block */
  .upd2-buy{padding:6px 0}
  .upd2-buy__rating{display:flex;align-items:center;gap:8px;margin-bottom:12px;font-size:13px;color:var(--u-text)}
  .upd2-buy__stars{color:var(--u-rating);letter-spacing:1px;font-size:14px}
  .upd2-buy__rating a{color:var(--u-text-muted);text-decoration:underline;font-size:13px}
  .upd2-buy__brand{display:block;font-size:11px;font-weight:600;color:var(--u-primary);text-transform:uppercase;letter-spacing:2.5px;margin-bottom:8px}
  .upd2-buy h1{font-family:'Poppins',sans-serif;font-size:clamp(26px,3.8vw,40px);font-weight:800;line-height:1.05;color:var(--u-purple-deep);margin-bottom:10px;text-transform:uppercase;letter-spacing:-.01em}
  .upd2-buy h1 .accent{color:var(--u-primary)}
  .upd2-buy__sub{font-size:15px;color:var(--u-text-muted);line-height:1.5;margin-bottom:18px}
  .upd2-buy__badges{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:22px}
  .upd2-buy__badge{padding:6px 11px;background:var(--u-purple-pale);color:var(--u-primary);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px}

  /* Variant picker */
  .upd2-vlabel{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--u-text-muted);margin-bottom:10px}
  .upd2-variants{display:grid;gap:10px;margin-bottom:18px}
  .upd2-variant{position:relative;border:2px solid var(--u-border);padding:14px 16px;cursor:pointer;transition:.15s;background:#fff;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:14px}
  .upd2-variant:hover{border-color:var(--u-primary-light)}
  .upd2-variant input{position:absolute;opacity:0;pointer-events:none}
  .upd2-variant.selected{border-color:var(--u-primary);background:var(--u-purple-pale)}
  .upd2-variant.selected .upd2-variant__check{background:var(--u-primary);border-color:var(--u-primary)}
  .upd2-variant.selected .upd2-variant__check::after{content:'';width:8px;height:4px;border-left:2px solid #fff;border-bottom:2px solid #fff;transform:rotate(-45deg);margin-top:-2px}
  .upd2-variant__check{width:20px;height:20px;border-radius:50%;border:2px solid var(--u-border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:.15s}
  .upd2-variant__txt{min-width:0}
  .upd2-variant__name{font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;color:var(--u-text);margin-bottom:2px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;text-transform:uppercase;letter-spacing:.3px}
  .upd2-variant__pop{background:var(--u-gold);color:#1c1c1c;font-size:9px;font-weight:800;padding:2px 7px;letter-spacing:.5px;text-transform:uppercase}
  .upd2-variant__meta{font-size:12px;color:var(--u-text-muted)}
  .upd2-variant__price{text-align:right;font-family:'Poppins',sans-serif}
  .upd2-variant__price-num{font-size:18px;font-weight:700;color:var(--u-purple-deep);line-height:1}
  .upd2-variant__price-day{font-size:11px;color:var(--u-success);font-weight:600;margin-top:3px;white-space:nowrap}
  .upd2-variant__save{font-size:10px;color:var(--u-primary);font-weight:700;margin-top:2px;text-transform:uppercase;letter-spacing:.5px}

  /* ATC */
  .upd2-atc{width:100%;background:var(--u-primary);color:#fff;border:none;padding:18px 24px;font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center;gap:12px;margin-top:6px}
  .upd2-atc:hover{background:var(--u-primary-dark)}
  .upd2-atc[disabled]{opacity:.6;cursor:not-allowed}
  .upd2-atc__loading{display:none;width:18px;height:18px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:upd2-spin .6s linear infinite}
  .upd2-atc.loading .upd2-atc__loading{display:inline-block}
  .upd2-atc.loading .upd2-atc__txt{display:none}
  @keyframes upd2-spin{to{transform:rotate(360deg)}}

  /* Trust strip */
  .upd2-trust{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:16px;padding:14px;background:var(--u-purple-pale)}
  .upd2-trust-item{display:flex;align-items:flex-start;gap:8px;font-size:12px;color:var(--u-text);font-weight:600;line-height:1.4}
  .upd2-trust-item svg{flex-shrink:0;color:var(--u-primary);margin-top:1px}

  /* ============================================================
     3. STATS BANNER (4h / 30 kcal / 0 sucre / 1200+ clientes)
  ============================================================ */
  .upd2-stats{background:linear-gradient(160deg,#2b1e4d 0%,#7d3fff 100%);color:#fff;padding:48px 16px;text-align:center}
  .upd2-stats__grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
  @media(max-width:700px){.upd2-stats__grid{grid-template-columns:repeat(2,1fr);gap:24px 16px}}
  .upd2-stat__num{font-family:'Poppins',sans-serif;font-size:clamp(36px,5vw,52px);font-weight:800;line-height:1;letter-spacing:-.02em;color:#fff;margin-bottom:6px}
  .upd2-stat__num small{font-size:.45em;font-weight:600;color:rgba(255,255,255,.7);margin-left:2px}
  .upd2-stat__label{font-size:12px;color:rgba(255,255,255,.85);font-weight:500;text-transform:uppercase;letter-spacing:1.8px;line-height:1.4}

  /* ============================================================
     4. WHY UBURN — 4 PILLARS
  ============================================================ */
  .upd2-section{padding:64px 16px;max-width:1100px;margin:0 auto}
  @media(max-width:600px){.upd2-section{padding:48px 16px}}
  .upd2-section--cream{background:var(--u-cream);max-width:none}
  .upd2-section--cream .upd2-inner{max-width:1100px;margin:0 auto}
  .upd2-section--pale{background:var(--u-purple-pale);max-width:none}
  .upd2-section--pale .upd2-inner{max-width:1100px;margin:0 auto}
  .upd2-eyebrow{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2.5px;color:var(--u-primary);margin-bottom:14px;text-align:center}
  .upd2-h2{font-family:'Poppins',sans-serif;font-size:clamp(26px,3.6vw,42px);font-weight:800;color:var(--u-purple-deep);line-height:1.1;text-align:center;margin-bottom:14px;text-transform:uppercase;letter-spacing:-.01em}
  .upd2-h2 .accent{color:var(--u-primary)}
  .upd2-lead{font-size:15px;color:var(--u-text-muted);text-align:center;max-width:580px;margin:0 auto 36px;line-height:1.65}

  .upd2-pillars{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:28px}
  @media(max-width:900px){.upd2-pillars{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:500px){.upd2-pillars{grid-template-columns:1fr;max-width:380px;margin-left:auto;margin-right:auto}}
  .upd2-pillar{background:#fff;border:1px solid var(--u-border);padding:28px 22px;text-align:left;transition:.25s}
  .upd2-pillar:hover{border-color:var(--u-primary);transform:translateY(-2px)}
  .upd2-pillar__icon{width:42px;height:42px;background:var(--u-purple-pale);display:flex;align-items:center;justify-content:center;color:var(--u-primary);margin-bottom:16px}
  .upd2-pillar h3{font-family:'Poppins',sans-serif;font-size:15px;font-weight:700;color:var(--u-purple-deep);margin-bottom:8px;text-transform:uppercase;letter-spacing:.3px;line-height:1.25}
  .upd2-pillar p{font-size:13.5px;color:var(--u-text-muted);line-height:1.6}

  /* ============================================================
     5. INGREDIENTS TABLE (AG1-style)
  ============================================================ */
  .upd2-ingr-table{margin-top:28px;background:#fff;border:1px solid var(--u-border)}
  .upd2-ingr-row{display:grid;grid-template-columns:80px 1fr 110px 100px;align-items:center;gap:16px;padding:18px 20px;border-bottom:1px solid var(--u-border);transition:.15s}
  .upd2-ingr-row:last-child{border-bottom:none}
  .upd2-ingr-row:hover{background:var(--u-purple-pale)}
  .upd2-ingr-row.head{background:var(--u-purple-deep);color:#fff;font-size:10.5px;text-transform:uppercase;letter-spacing:1.5px;font-weight:700;padding:14px 20px;cursor:default}
  .upd2-ingr-row.head:hover{background:var(--u-purple-deep)}
  .upd2-ingr__img{width:60px;height:60px;object-fit:cover;border-radius:50%;background:var(--u-purple-pale)}
  .upd2-ingr__info h4{font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;color:var(--u-purple-deep);margin-bottom:3px;text-transform:uppercase;letter-spacing:.3px}
  .upd2-ingr__info p{font-size:12.5px;color:var(--u-text-muted);line-height:1.4}
  .upd2-ingr__dose{font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;color:var(--u-text)}
  .upd2-ingr__pill{display:inline-block;background:var(--u-purple-pale);color:var(--u-primary);font-size:9.5px;font-weight:800;padding:4px 8px;text-transform:uppercase;letter-spacing:.5px}
  .upd2-ingr__pill--gold{background:#fef3e2;color:var(--u-gold)}
  @media(max-width:700px){
    .upd2-ingr-row{grid-template-columns:60px 1fr;gap:12px;padding:14px 14px}
    .upd2-ingr-row.head{display:none}
    .upd2-ingr__img{width:50px;height:50px}
    .upd2-ingr__dose{display:block;font-size:12px;margin-top:4px;color:var(--u-text-muted)}
    .upd2-ingr__claim{display:block;margin-top:6px}
    .upd2-ingr__col-dose,.upd2-ingr__col-claim{grid-column:2}
  }
  .upd2-ingr-foot{background:var(--u-cream);padding:18px 20px;font-size:11px;color:var(--u-text-muted);text-align:center;line-height:1.6;border-top:1px solid var(--u-border)}

  /* ============================================================
     6. HOW IT WORKS (4 steps)
  ============================================================ */
  .upd2-how{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;margin-top:32px;position:relative}
  @media(max-width:900px){.upd2-how{grid-template-columns:repeat(2,1fr);gap:32px 20px}}
  @media(max-width:500px){.upd2-how{grid-template-columns:1fr;max-width:340px;margin-left:auto;margin-right:auto}}
  .upd2-how-step{text-align:center;position:relative}
  .upd2-how-step__num{position:absolute;top:-8px;right:-8px;width:32px;height:32px;background:var(--u-primary);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-size:13px;font-weight:800;z-index:2}
  .upd2-how-step__img{width:100%;aspect-ratio:1/1;object-fit:cover;background:var(--u-purple-pale);margin-bottom:16px}
  .upd2-how-step h4{font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;color:var(--u-purple-deep);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px}
  .upd2-how-step p{font-size:13px;color:var(--u-text-muted);line-height:1.55;max-width:240px;margin:0 auto}

  /* ============================================================
     7. REVIEWS (mock — Loox-ready)
  ============================================================ */
  .upd2-reviews-head{display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:32px;flex-wrap:wrap}
  .upd2-reviews-rating{display:flex;align-items:center;gap:10px}
  .upd2-reviews-rating__stars{color:var(--u-rating);font-size:20px;letter-spacing:2px}
  .upd2-reviews-rating__num{font-family:'Poppins',sans-serif;font-size:24px;font-weight:800;color:var(--u-purple-deep)}
  .upd2-reviews-rating__count{font-size:13px;color:var(--u-text-muted)}
  .upd2-reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:24px}
  @media(max-width:900px){.upd2-reviews-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.upd2-reviews-grid{grid-template-columns:1fr;max-width:480px;margin-left:auto;margin-right:auto}}
  .upd2-review{background:#fff;border:1px solid var(--u-border);padding:24px;text-align:left}
  .upd2-review__stars{color:var(--u-rating);font-size:14px;letter-spacing:2px;margin-bottom:10px}
  .upd2-review__title{font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;color:var(--u-purple-deep);margin-bottom:8px;text-transform:uppercase;letter-spacing:.3px;line-height:1.3}
  .upd2-review__text{font-size:13.5px;color:var(--u-text);line-height:1.65;margin-bottom:14px}
  .upd2-review__photo{width:100%;aspect-ratio:1/1;object-fit:cover;background:var(--u-purple-pale);margin-bottom:12px}
  .upd2-review__author{display:flex;align-items:center;gap:10px;border-top:1px solid var(--u-border);padding-top:12px}
  .upd2-review__avatar{width:32px;height:32px;border-radius:50%;background:var(--u-purple-pale);display:flex;align-items:center;justify-content:center;color:var(--u-primary);font-family:'Poppins',sans-serif;font-weight:700;font-size:12px;flex-shrink:0}
  .upd2-review__info{flex:1;min-width:0}
  .upd2-review__name{font-size:12.5px;font-weight:700;color:var(--u-text);line-height:1.2}
  .upd2-review__verified{font-size:10px;color:var(--u-success);font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-top:2px}
  .upd2-reviews-cta{text-align:center;margin-top:32px}
  .upd2-reviews-cta a{display:inline-block;border:2px solid var(--u-primary);color:var(--u-primary);padding:12px 28px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;transition:.15s}
  .upd2-reviews-cta a:hover{background:var(--u-primary);color:#fff}

  /* ============================================================
     8. TESTIMONIAL "AVANT/APRÈS COMPORTEMENTAL"
  ============================================================ */
  .upd2-quote{max-width:880px;margin:32px auto 0;background:#fff;padding:48px 56px;border-left:4px solid var(--u-primary);position:relative}
  @media(max-width:700px){.upd2-quote{padding:32px 24px}}
  .upd2-quote::before{content:'"';position:absolute;top:14px;left:24px;font-family:Georgia,serif;font-size:96px;color:var(--u-purple-pale);line-height:1;font-weight:700}
  .upd2-quote__text{font-family:'Poppins',sans-serif;font-size:clamp(17px,2vw,21px);font-weight:600;color:var(--u-purple-deep);line-height:1.4;margin-bottom:18px;position:relative;z-index:1;font-style:italic}
  .upd2-quote__author{display:flex;align-items:center;gap:14px;border-top:1px solid var(--u-border);padding-top:18px}
  .upd2-quote__avatar{width:50px;height:50px;border-radius:50%;background:var(--u-purple-pale);display:flex;align-items:center;justify-content:center;color:var(--u-primary);font-family:'Poppins',sans-serif;font-weight:700;font-size:16px;flex-shrink:0}
  .upd2-quote__name{font-family:'Poppins',sans-serif;font-size:14px;font-weight:700;color:var(--u-text);text-transform:uppercase;letter-spacing:.3px}
  .upd2-quote__loc{font-size:12px;color:var(--u-text-muted);margin-top:2px}

  /* ============================================================
     9. FAQ (12 accordions)
  ============================================================ */
  .upd2-faq{max-width:760px;margin:32px auto 0}
  .upd2-faq-item{border-bottom:1px solid var(--u-border);padding:20px 0}
  .upd2-faq-item summary{display:flex;justify-content:space-between;align-items:center;font-family:'Poppins',sans-serif;font-size:14.5px;font-weight:600;color:var(--u-purple-deep);gap:16px;cursor:pointer;list-style:none;text-transform:uppercase;letter-spacing:.3px;line-height:1.35}
  .upd2-faq-item summary::-webkit-details-marker{display:none}
  .upd2-faq-item summary::after{content:'+';font-size:24px;color:var(--u-primary);transition:transform .25s;flex-shrink:0;line-height:1;font-weight:300}
  .upd2-faq-item[open] summary::after{transform:rotate(45deg)}
  .upd2-faq-item__a{font-size:14px;color:var(--u-text-muted);line-height:1.7;padding-top:14px;animation:upd2-fade .25s ease}
  @keyframes upd2-fade{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:none}}

  /* ============================================================
     10. NEWSLETTER -10%
  ============================================================ */
  .upd2-newsletter{background:linear-gradient(135deg,#7d3fff 0%,#9f7aea 100%);color:#fff;padding:64px 20px;text-align:center}
  .upd2-newsletter__inner{max-width:560px;margin:0 auto}
  .upd2-newsletter__eyebrow{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2.5px;color:rgba(255,255,255,.85);margin-bottom:14px;display:block}
