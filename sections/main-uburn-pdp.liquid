      <div class="upd-buy__rating">
        <span class="upd-buy__stars">★★★★★</span>
        <strong>4.7/5</strong>
        <a href="#avis">· 243 avis vérifiés</a>
      </div>

      <form id="updForm" action="/cart/add" method="post">
        <span class="upd-vlabel">Choisis ta cure</span>
        <div class="upd-variants" role="radiogroup">
          {%- for v in product.variants -%}
            {%- assign v_days = 30 -%}
            {%- assign v_pop = false -%}
            {%- assign v_label = 'Cure Découverte' -%}
            {%- assign v_size = '90g · 1 dose / jour' -%}
            {%- if v.id == 51289200066879 -%}
              {%- assign v_days = 90 -%}
              {%- assign v_pop = true -%}
              {%- assign v_label = 'Cure Maximum' -%}
              {%- assign v_size = '270g · 1 dose / jour' -%}
            {%- endif -%}
            {%- assign p_jour = v.price | divided_by: v_days | money_without_trailing_zeros -%}
            <label class="upd-variant{% if v.id == current_variant.id %} selected{% endif %}" data-vid="{{ v.id }}" data-pday="{{ p_jour }}">
              <span class="upd-variant__check"></span>
              <input type="radio" name="id" value="{{ v.id }}"{% if v.id == current_variant.id %} checked{% endif %}>
              <div class="upd-variant__txt">
                <div class="upd-variant__name">
                  {{ v_label }}
                  {%- if v_pop %}<span class="upd-variant__pop">Best</span>{%- endif -%}
                </div>
                <div class="upd-variant__meta">{{ v_size }} · {{ v_days }} jours</div>
              </div>
              <div class="upd-variant__price">
                <div class="upd-variant__num">{{ v.price | money_without_trailing_zeros }}</div>
                <div class="upd-variant__day">{{ p_jour }} / jour</div>
                {%- if v_pop %}<div class="upd-variant__save">Économise 36%</div>{%- endif -%}
              </div>
            </label>
          {%- endfor -%}
        </div>

        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="upd-atc" id="updAtc">
          <span class="upd-atc__loading"></span>
          <span class="upd-atc__txt">Ajouter au panier</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>

      <div class="upd-trust">
        <div class="upd-trust-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Livraison 24-48h offerte</div>
        <div class="upd-trust-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Sans abonnement caché</div>
        <div class="upd-trust-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Paiement sécurisé</div>
        <div class="upd-trust-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Fabriqué en France</div>
      </div>
    </div>
  </div>
</section>

