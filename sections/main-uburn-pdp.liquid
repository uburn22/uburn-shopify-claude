<script>
(function(){
  /* === 1. PROMO BAR ===*/
  var params=new URLSearchParams(location.search);
  var bar=document.getElementById('upd2Topbar');
  var btnCopy=document.getElementById('upd2TopbarCopy');
  if(params.get('discount')==='UBE10'||params.get('code')==='UBE10'){
    bar.classList.add('applied');
  }
  if(btnCopy){
    btnCopy.addEventListener('click',function(){
      navigator.clipboard.writeText('UBE10').then(function(){
        btnCopy.textContent='Copié ✓';btnCopy.classList.add('copied');
        setTimeout(function(){btnCopy.textContent='Copier';btnCopy.classList.remove('copied');},2000);
      }).catch(function(){
        var ta=document.createElement('textarea');ta.value='UBE10';document.body.appendChild(ta);ta.select();try{document.execCommand('copy');btnCopy.textContent='Copié ✓';btnCopy.classList.add('copied');setTimeout(function(){btnCopy.textContent='Copier';btnCopy.classList.remove('copied');},2000);}catch(e){}document.body.removeChild(ta);
      });
    });
  }

  /* === 2. GALLERY === */
  var mainImg=document.getElementById('upd2MainImg');
  var idxLabel=document.getElementById('upd2GalleryIdx');
  var thumbs=document.querySelectorAll('.upd2-thumb');
  var idx=0;
  function setImg(i){
    if(i<0)i=thumbs.length-1;if(i>=thumbs.length)i=0;
    idx=i;
    var t=thumbs[i];
    if(!t)return;
    mainImg.src=t.dataset.src;
    thumbs.forEach(function(x){x.classList.remove('active')});
    t.classList.add('active');
    if(idxLabel)idxLabel.textContent=(i+1);
  }
  thumbs.forEach(function(t,i){t.addEventListener('click',function(){setImg(i)})});
  var prevBtn=document.getElementById('upd2GalleryPrev');
  var nextBtn=document.getElementById('upd2GalleryNext');
  if(prevBtn)prevBtn.addEventListener('click',function(){setImg(idx-1)});
  if(nextBtn)nextBtn.addEventListener('click',function(){setImg(idx+1)});

  /* === Variant picker === */
  var stickyPrice=document.getElementById('upd2StickyPrice');
  var stickyDay=document.getElementById('upd2StickyDay');
  function refreshSticky(label){
    if(!label||!stickyPrice)return;
    var pday=label.dataset.pday;
    var priceTxt=label.querySelector('.upd2-variant__price-num').textContent;
    stickyPrice.textContent=priceTxt;
    if(stickyDay)stickyDay.textContent=pday+' / jour';
  }
  document.querySelectorAll('.upd2-variant').forEach(function(label){
    label.addEventListener('click',function(){
      document.querySelectorAll('.upd2-variant').forEach(function(x){x.classList.remove('selected')});
      label.classList.add('selected');
      label.querySelector('input').checked=true;
      refreshSticky(label);
    });
  });
  refreshSticky(document.querySelector('.upd2-variant.selected'));

  /* === ATC AJAX === */
  var form=document.getElementById('upd2Form');
  var atc=document.getElementById('upd2Atc');
  function addToCart(){
    if(!form)return;
    atc.classList.add('loading');atc.disabled=true;
    var fd=new FormData(form);
    fetch('/cart/add.js',{method:'POST',body:fd,headers:{'Accept':'application/json'}})
      .then(function(r){return r.json()})
      .then(function(){
        if(typeof fbq!=='undefined')fbq('track','AddToCart');
        if(typeof gtag!=='undefined')gtag('event','add_to_cart');
        // Try to open cart drawer via existing theme triggers
        var trigger=document.querySelector('[data-cart-drawer-trigger],.cart-drawer-trigger,.cart-icon-bubble,[data-action="open-cart"],.header__cart');
        if(trigger){trigger.click()}else{location.href='/cart'}
      })
      .catch(function(){location.href='/cart'})
      .finally(function(){atc.classList.remove('loading');atc.disabled=false});
  }
  form.addEventListener('submit',function(e){e.preventDefault();addToCart()});
  var stickyBtn=document.getElementById('upd2StickyBtn');
  if(stickyBtn)stickyBtn.addEventListener('click',addToCart);

  /* === STICKY ATC visible after hero (mobile only) === */
  var sticky=document.getElementById('upd2Sticky');
  var hero=document.querySelector('.upd2-hero');
  if(sticky&&hero&&'IntersectionObserver' in window){
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting||e.boundingClientRect.top>=0){
          sticky.classList.remove('visible');
        }else{
          sticky.classList.add('visible');
        }
      });
    },{threshold:0,rootMargin:'-100px 0px 0px 0px'});
    io.observe(hero);
  }

  /* === FORCE VISIBILITY (theme JS hides our section by default) === */
  function forceVisible(){
    document.querySelectorAll('.shopify-section').forEach(function(s){
      if(s.querySelector('.upd2')){
        s.style.setProperty('display','block','important');
        s.style.setProperty('visibility','visible','important');
      }
    });
    document.querySelectorAll('.upd2-section[style*="display: none"], .upd2 section[style*="display: none"]').forEach(function(s){
      s.style.setProperty('display','block','important');
    });
  }
  forceVisible();
  // Re-apply periodically in case theme JS hides again
  var visibilityChecks = 0;
  var visibilityInterval = setInterval(function(){
    forceVisible();
    if(++visibilityChecks > 20) clearInterval(visibilityInterval);
  }, 200);
})();
</script>

<style>
  /* CSS belt + suspenders: override theme's display:none on our wrapper */
  .shopify-section:has(> .upd2),
  .shopify-section:has(.upd2-hero){display:block!important;visibility:visible!important}
  section.upd2-section{display:block!important}
</style>

