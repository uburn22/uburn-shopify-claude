<script>
(function(){
  /* === Force visibility (theme JS bug) === */
  function forceVisible(){
    document.querySelectorAll('.shopify-section').forEach(function(s){
      if(s.querySelector('.upd')){
        s.style.setProperty('display','block','important');
        s.style.setProperty('visibility','visible','important');
      }
    });
  }
  forceVisible();
  var fv=0;var fvI=setInterval(function(){forceVisible();if(++fv>15)clearInterval(fvI)},250);

  /* === Reveal on scroll === */
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}
      });
    },{threshold:.1,rootMargin:'0px 0px -60px 0px'});
    document.querySelectorAll('[data-reveal]').forEach(function(el){io.observe(el)});
  }else{
    document.querySelectorAll('[data-reveal]').forEach(function(el){el.classList.add('in')});
  }

  /* === Gallery === */
  var mainImg=document.getElementById('updMainImg');
  var idxLabel=document.getElementById('updIdx');
  var thumbs=document.querySelectorAll('.upd-thumb');
  var idx=0;
  function setImg(i){
    if(i<0)i=thumbs.length-1;if(i>=thumbs.length)i=0;
    idx=i;var t=thumbs[i];if(!t)return;
    mainImg.style.opacity=0;
    setTimeout(function(){
      mainImg.src=t.dataset.src;
      mainImg.style.opacity=1;
    },150);
    thumbs.forEach(function(x){x.classList.remove('active')});
    t.classList.add('active');
    if(idxLabel)idxLabel.textContent=(i+1);
  }
  thumbs.forEach(function(t,i){t.addEventListener('click',function(){setImg(i)})});
  var prev=document.getElementById('updPrev');var next=document.getElementById('updNext');
  if(prev)prev.addEventListener('click',function(){setImg(idx-1)});
  if(next)next.addEventListener('click',function(){setImg(idx+1)});

  /* === Variant picker + sticky sync === */
  var stickyNum=document.getElementById('updStickyNum');
  var stickyDay=document.getElementById('updStickyDay');
  function refreshSticky(label){
    if(!label||!stickyNum)return;
    stickyNum.textContent=label.querySelector('.upd-variant__num').textContent;
    if(stickyDay)stickyDay.textContent=label.dataset.pday+' / jour';
  }
  document.querySelectorAll('.upd-variant').forEach(function(label){
    label.addEventListener('click',function(){
      document.querySelectorAll('.upd-variant').forEach(function(x){x.classList.remove('selected')});
      label.classList.add('selected');
      label.querySelector('input').checked=true;
      refreshSticky(label);
    });
  });
  refreshSticky(document.querySelector('.upd-variant.selected'));

  /* === ATC AJAX === */
  var form=document.getElementById('updForm');
  var atc=document.getElementById('updAtc');
  function addToCart(){
    if(!form)return;
    atc.classList.add('loading');atc.disabled=true;
    var fd=new FormData(form);
    fetch('/cart/add.js',{method:'POST',body:fd,headers:{'Accept':'application/json'}})
      .then(function(r){return r.json()})
      .then(function(){
        if(typeof fbq!=='undefined')fbq('track','AddToCart');
        if(typeof gtag!=='undefined')gtag('event','add_to_cart');
        var trigger=document.querySelector('[data-cart-drawer-trigger],.cart-drawer-trigger,.cart-icon-bubble,[data-action="open-cart"],.header__cart');
        if(trigger){trigger.click()}else{location.href='/cart'}
      })
      .catch(function(){location.href='/cart'})
      .finally(function(){atc.classList.remove('loading');atc.disabled=false});
  }
  form.addEventListener('submit',function(e){e.preventDefault();addToCart()});
  var sb=document.getElementById('updStickyBtn');
  if(sb)sb.addEventListener('click',addToCart);

  /* === Sticky visibility on scroll === */
  var sticky=document.getElementById('updSticky');
  var hero=document.querySelector('.upd-hero');
  if(sticky&&hero&&'IntersectionObserver' in window){
    var sio=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting||e.boundingClientRect.top>=0){sticky.classList.remove('visible')}
        else{sticky.classList.add('visible')}
      });
    },{threshold:0,rootMargin:'-100px 0px 0px 0px'});
    sio.observe(hero);
  }

  /* === Auto-apply UBE10 from URL === */
  var params=new URLSearchParams(location.search);
  if(params.get('discount')==='UBE10'||params.get('code')==='UBE10'){
    var first=document.querySelector('.upd-promo__item');
    if(first)first.innerHTML='✓ <strong>UBE10</strong> appliqué — -10% sur ta commande';
  }
})();
</script>

