<!-- ═══ 2. HERO ═══ -->
<section class="upd-hero">
  <div class="upd-hero__inner">

    <!-- Gallery -->
    <div class="upd-gallery" data-reveal>
      <div class="upd-gallery__main" id="updMain">
        <span class="upd-gallery__badge">Marque française</span>
        <img id="updMainImg" src="{{ first_clean | image_url: width: 900 }}&format=webp" alt="{{ product.title | escape }}" width="900" height="1125" fetchpriority="high">
        {%- assign clean_count = 0 -%}
        {%- for img in product.images -%}
          {%- assign s = img.src | downcase -%}
          {%- unless s contains 'listing_ecom' or s contains 'productpage_0004_3' or s contains 'product_page_0005' or s contains 'productpage_0003_4' -%}
            {%- assign clean_count = clean_count | plus: 1 -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- if clean_count > 1 -%}
        <button type="button" class="upd-gallery__nav upd-gallery__nav--prev" id="updPrev" aria-label="Image précédente">‹</button>
        <button type="button" class="upd-gallery__nav upd-gallery__nav--next" id="updNext" aria-label="Image suivante">›</button>
        <span class="upd-gallery__counter"><span id="updIdx">1</span> / {{ clean_count }}</span>
        {%- endif -%}
      </div>
      {%- if clean_count > 1 -%}
      <div class="upd-gallery__thumbs" id="updThumbs">
        {%- assign thumb_idx = 0 -%}
        {%- for img in product.images limit: 12 -%}
          {%- assign s = img.src | downcase -%}
          {%- unless s contains 'listing_ecom' or s contains 'productpage_0004_3' or s contains 'product_page_0005' or s contains 'productpage_0003_4' -%}
            <button type="button" class="upd-thumb{% if thumb_idx == 0 %} active{% endif %}" data-src="{{ img | image_url: width: 900 }}&format=webp" data-idx="{{ thumb_idx }}" aria-label="Image {{ thumb_idx | plus: 1 }}">
              <img src="{{ img | image_url: width: 160 }}&format=webp" alt="" width="160" height="200" loading="lazy">
            </button>
            {%- assign thumb_idx = thumb_idx | plus: 1 -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>

    <!-- Buy -->
