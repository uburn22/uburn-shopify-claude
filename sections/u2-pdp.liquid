<script>
  // Variant price sync
  (function(){
    var form = document.getElementById('u2-pdp-form');
    if(!form) return;
    var radios = form.querySelectorAll('input[type=radio][name=id]');
    var priceEl = document.getElementById('u2-atc-price');
    var variantPrices = { {%- for v in product.variants -%}'{{ v.id }}': '{{ v.price | money_without_trailing_zeros }}'{% unless forloop.last %},{% endunless %}{%- endfor -%} };
    var subBenefits = document.querySelector('[data-u2-sub-benefits]');
    radios.forEach(function(r){
      r.addEventListener('change', function(){
        if(priceEl && variantPrices[r.value]) priceEl.textContent = variantPrices[r.value];
        if(subBenefits) subBenefits.hidden = !r.dataset.u2Subscribe;
        // Real Shopify Subscriptions: add hidden selling_plan input
        var existingPlan = form.querySelector('input[name="selling_plan"]');
        if(r.dataset.u2Subscribe && r.dataset.u2SellingPlan){
          if(!existingPlan){
            existingPlan = document.createElement('input');
            existingPlan.type = 'hidden';
            existingPlan.name = 'selling_plan';
            form.appendChild(existingPlan);
          }
          existingPlan.value = r.dataset.u2SellingPlan;
          // Update displayed ATC price to subscription price
          if(priceEl){
            var basePrice = variantPrices[r.value] || priceEl.textContent;
            // Display already discounted via selling_plan at checkout
            priceEl.textContent = basePrice;
          }
        } else if(existingPlan){
          existingPlan.remove();
        }
      });
    });
    // Thumbnail click → swap main image (visual only)
    var thumbs = document.querySelectorAll('.u2-pdp-gallery__thumb');
    var main = document.querySelector('.u2-pdp-gallery__main img');
    thumbs.forEach(function(t){
      t.addEventListener('click', function(){
        thumbs.forEach(function(o){ o.classList.remove('is-active'); });
        t.classList.add('is-active');
        var img = t.querySelector('img');
        if(img && main) main.src = img.src.replace(/width=240/, 'width=1200');
      });
    });
  })();
</script>

