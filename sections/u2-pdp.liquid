{%- comment -%}
  UBurn V2 — PDP (compact, all key blocks composed inline)
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured = product.featured_image
  for img in product.images
    assign s = img.src | downcase
    if s contains 'productpage_0000' or s contains 'uburn_listing'
      assign featured = img
      break
    endif
  endfor
  assign rating = product.metafields.loox.avg_rating | default: product.metafields.reviews.rating.value.rating | default: 4.7 | round: 1
-%}

<style>
  /* PDP container */
  .u2-pdp { background: var(--u2-cream); padding-bottom: 80px; }

  /* TRUST BAND (re-used) */
  .u2-trustband { background: var(--u2-lavender-soft); padding: 18px 16px; }
  .u2-trustband__inner { max-width: 1280px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: center; gap: 14px 28px; align-items: center; }

  /* MAIN SPLIT (gallery + info) */
  .u2-pdp-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 20px 40px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 1024px) {
    .u2-pdp-main {
      grid-template-columns: minmax(0,1.1fr) minmax(0,1fr);
      gap: 64px;
      padding: 48px 32px 60px;
    }
  }

  /* GALLERY */
  .u2-pdp-gallery {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .u2-pdp-gallery__main {
    aspect-ratio: 1 / 1;
    border-radius: 20px;
    overflow: hidden;
    background: var(--u2-lavender-soft);
    box-shadow: 0 30px 60px -30px rgba(58,31,89,0.2);
  }
  .u2-pdp-gallery__main img { width:100%; height:100%; object-fit:cover; }
  .u2-pdp-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 8px;
  }
  .u2-pdp-gallery__thumb {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    background: var(--u2-bone);
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s var(--u2-ease-smooth);
  }
  .u2-pdp-gallery__thumb:hover,
  .u2-pdp-gallery__thumb.is-active { border-color: var(--u2-iris); }
  .u2-pdp-gallery__thumb img { width:100%; height:100%; object-fit:cover; }

  /* INFO */
  .u2-pdp-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .u2-pdp-info__h1 {
    font-family: var(--u2-sans);
    font-size: clamp(34px,6vw,52px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 0;
  }
  .u2-pdp-info__h1 em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }
  .u2-pdp-info__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .u2-pdp-info__desc {
    font-size: 16px;
    line-height: 1.6;
    color: #3A2E4A;
  }

  /* OFFER STACK pills */
  .u2-pdp-offers {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .u2-pdp-offer {
    background: var(--u2-lavender-soft);
    color: var(--u2-iris-deep);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* VARIANT SELECTOR — radio cards */
  .u2-pdp-variants { display: flex; flex-direction: column; gap: 10px; margin-top: 6px; }
  .u2-pdp-variant {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 22px;
    background: white;
    border: 2px solid rgba(107,78,158,0.18);
    border-radius: 16px;
    cursor: pointer;
    transition: border-color 0.2s var(--u2-ease-smooth), background 0.2s var(--u2-ease-smooth);
  }
  .u2-pdp-variant input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .u2-pdp-variant:has(input:checked) {
    border-color: var(--u2-iris);
    background: linear-gradient(135deg, rgba(232,220,239,0.6), white);
  }
  .u2-pdp-variant__body { flex: 1; }
  .u2-pdp-variant__title {
    font-family: var(--u2-sans);
    font-size: 15px;
    font-weight: 700;
    color: var(--u2-plum-black);
    margin: 0 0 2px;
  }
  .u2-pdp-variant__sub {
    font-size: 12px;
    color: #7a7585;
    letter-spacing: 0.02em;
  }
  .u2-pdp-variant__price {
    font-family: var(--u2-sans);
    font-size: 19px;
    font-weight: 700;
    color: var(--u2-plum-black);
    letter-spacing: -0.01em;
  }
  .u2-pdp-variant__badge {
    background: var(--u2-iris);
    color: white;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    margin-left: 8px;
  }

  /* SUBSCRIBE variant accent */
  .u2-pdp-variant--subscribe {
    border-color: rgba(107,78,158,0.3);
  }
  .u2-pdp-variant--subscribe:has(input:checked) {
    border-color: var(--u2-iris);
    background: linear-gradient(135deg, rgba(232,220,239,0.6), white);
  }
  .u2-pdp-variant__badge--sub {
    background: var(--u2-iris-deep) !important;
  }
  .u2-pdp-variant__per {
    font-size: 12px;
    color: #7a7585;
    font-weight: 500;
    margin-left: 2px;
  }
  .u2-pdp-sub-benefits {
    background: var(--u2-lavender-soft);
    border-radius: 14px;
    padding: 18px 20px;
    margin-top: -2px;
  }
  .u2-pdp-sub-benefits[hidden] { display: none; }
  .u2-pdp-sub-benefits__title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--u2-iris);
    margin: 0 0 10px;
  }
  .u2-pdp-sub-benefits ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .u2-pdp-sub-benefits li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--u2-plum-black);
  }
  .u2-pdp-sub-benefits li svg {
    color: var(--u2-iris);
    flex-shrink: 0;
  }

  /* PRIMARY ATC CTA */
  .u2-pdp-atc {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }
  .u2-pdp-atc__btn {
    background: var(--u2-plum-black);
    color: var(--u2-warm-white);
    border: 1.5px solid var(--u2-plum-black);
    padding: 18px 24px;
    border-radius: 999px;
    font-family: var(--u2-sans);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 8px 24px -8px rgba(26,15,46,0.4);
  }
  .u2-pdp-atc__btn:hover {
    background: var(--u2-iris);
    border-color: var(--u2-iris);
    transform: translateY(-2px);
  }
  .u2-pdp-atc__note {
    text-align: center;
    font-size: 12px;
    color: #7a7585;
    letter-spacing: 0.04em;
  }

  /* COMPLIANCE TRUST */
  .u2-pdp-trust-strip {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 10px;
    padding: 16px;
    background: var(--u2-bone);
    border-radius: 16px;
    margin-top: 8px;
  }
  @media (min-width: 768px) { .u2-pdp-trust-strip { grid-template-columns: repeat(3,1fr); } }
  .u2-pdp-trust-strip__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    color: var(--u2-plum);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .u2-pdp-trust-strip__item svg { color: var(--u2-iris); flex-shrink: 0; }

  /* RITUAL 3 STEPS */
  .u2-pdp-ritual { padding: var(--u2-space-section) 20px; background: white; }
  .u2-pdp-ritual__inner { max-width: 1180px; margin: 0 auto; }
  .u2-pdp-ritual__head { text-align: center; margin-bottom: 48px; }
  .u2-pdp-ritual__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(32px,5vw,44px);
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.025em;
    margin: 12px 0 0;
  }
  .u2-pdp-ritual__head h2 em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }
  .u2-pdp-ritual__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) { .u2-pdp-ritual__grid { grid-template-columns: repeat(3,1fr); } }
  .u2-pdp-ritual__step {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .u2-pdp-ritual__img {
    aspect-ratio: 4/5;
    border-radius: 16px;
    overflow: hidden;
    background: var(--u2-lavender-soft);
  }
  .u2-pdp-ritual__img img { width:100%; height:100%; object-fit:cover; }
  .u2-pdp-ritual__num {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    color: var(--u2-iris);
    line-height: 1;
  }
  .u2-pdp-ritual__title {
    font-family: var(--u2-sans);
    font-size: 20px;
    font-weight: 700;
    color: var(--u2-plum-black);
    margin: 0;
  }
  .u2-pdp-ritual__desc {
    font-size: 14px;
    line-height: 1.6;
    color: #3A2E4A;
  }

  /* TESTIMONIALS */
  .u2-pdp-testi { padding: var(--u2-space-section) 20px; background: var(--u2-bone); }
  .u2-pdp-testi__inner { max-width: 1180px; margin: 0 auto; text-align: center; }
  .u2-pdp-testi__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(32px,5vw,44px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 12px 0 32px;
  }
  .u2-pdp-testi__head h2 em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }
  .u2-pdp-testi__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    text-align: left;
  }
  @media (min-width: 768px) { .u2-pdp-testi__grid { grid-template-columns: repeat(3,1fr); } }
  .u2-pdp-testi__card {
    background: white;
    border-radius: 18px;
    padding: 28px 24px;
    box-shadow: 0 16px 40px -20px rgba(58,31,89,0.15);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .u2-pdp-testi__stars {
    color: #F5B400;
    font-size: 14px;
    letter-spacing: 0.1em;
  }
  .u2-pdp-testi__quote {
    font-family: var(--u2-serif);
    font-style: italic;
    font-size: 17px;
    line-height: 1.5;
    color: var(--u2-plum-black);
    margin: 0;
  }
  .u2-pdp-testi__verified {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--u2-iris);
  }
  .u2-pdp-testi__author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 14px;
    border-top: 1px solid rgba(107,78,158,0.12);
  }
  .u2-pdp-testi__avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--u2-lavender-soft);
    flex-shrink: 0;
  }
  .u2-pdp-testi__avatar img { width:100%; height:100%; object-fit:cover; }
  .u2-pdp-testi__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--u2-plum-black);
  }
  .u2-pdp-testi__loc {
    font-size: 12px;
    color: #7a7585;
  }

  /* FAQ */
  .u2-pdp-faq { padding: var(--u2-space-section) 20px; background: var(--u2-cream); }
  .u2-pdp-faq__inner { max-width: 820px; margin: 0 auto; }
  .u2-pdp-faq__head { text-align: center; margin-bottom: 32px; }
  .u2-pdp-faq__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(32px,5vw,44px);
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.025em;
    margin: 12px 0 0;
  }
  .u2-pdp-faq__head h2 em {
    font-family: var(--u2-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--u2-iris);
  }

  /* SCIENCE LINK */
  .u2-pdp-science {
    background: linear-gradient(135deg, var(--u2-plum-deep), var(--u2-iris-deep));
    color: var(--u2-warm-white);
    padding: 64px 20px;
    text-align: center;
  }
  .u2-pdp-science__inner { max-width: 720px; margin: 0 auto; }
  .u2-pdp-science h2 {
    font-family: var(--u2-sans);
    font-size: clamp(26px,3.5vw,36px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--u2-warm-white);
    margin: 0 0 16px;
  }
  .u2-pdp-science p {
    font-size: 15px;
    color: rgba(255,255,255,0.85);
    margin: 0 0 28px;
  }
</style>

<div class="u2-root u2-pdp">

  {%- comment -%} TRUST BAND {%- endcomment -%}
  <section class="u2-trustband" aria-label="Trust">
    <div class="u2-trustband__inner">
      {% render 'u2-trust-pill', icon: 'check', text: 'Research-backed' %}
      {% render 'u2-trust-pill', icon: 'leaf', text: '100% plant-based' %}
      {% render 'u2-trust-pill', icon: 'sparkle', text: 'Cancel anytime' %}
      {% render 'u2-trust-pill', icon: 'truck', text: 'Free U.S. shipping' %}
    </div>
  </section>

  {%- comment -%} GALLERY + INFO MAIN SPLIT {%- endcomment -%}
  <div class="u2-pdp-main" data-u2-sticky-trigger>

    <div class="u2-pdp-gallery u2-reveal">
      <div class="u2-pdp-gallery__main">
        {{ featured | image_url: width: 1200 | image_tag: loading: 'eager', fetchpriority: 'high', alt: product.title, width: featured.width, height: featured.height, sizes: '(min-width: 1024px) 640px, 100vw' }}
      </div>
      {%- if product.images.size > 1 -%}
      <div class="u2-pdp-gallery__thumbs">
        {%- for img in product.images limit: 4 -%}
          <div class="u2-pdp-gallery__thumb {% if img == featured %}is-active{% endif %}">
            {{ img | image_url: width: 240 | image_tag: loading: 'lazy', alt: product.title, width: 240, height: 240 }}
          </div>
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>

    <div class="u2-pdp-info u2-reveal delay-1">
      <h1 class="u2-pdp-info__h1">Crush the <em>4 PM</em> crash.</h1>

      <div class="u2-pdp-info__meta">
        {% render 'u2-review-stars', rating: rating %}
        <span style="font-size:12px;color:#7a7585;letter-spacing:0.06em;text-transform:uppercase;">Verified Loox reviews</span>
      </div>

      <p class="u2-pdp-info__desc">A violet wellness ritual. Plant-based satiety up to 4 hours.* 30 calories. Caffeine-free. French heritage.</p>

      <div class="u2-pdp-offers">
        <span class="u2-pdp-offer">$25 off welcome</span>
        <span class="u2-pdp-offer">Save with auto-refill</span>
      </div>

      <form method="post" action="/cart/add" id="u2-pdp-form" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="form_type" value="product">
        <input type="hidden" name="utf8" value="✓">

        <div class="u2-pdp-variants" role="radiogroup" aria-label="Choose your pack">
          {%- for v in product.variants -%}
            <label class="u2-pdp-variant">
              <input type="radio" name="id" value="{{ v.id }}">
              <div class="u2-pdp-variant__body">
                <div class="u2-pdp-variant__title">
                  {{ v.title | split: '|' | first | strip }}{% if forloop.last %} <span class="u2-pdp-variant__badge">Best value · −33%</span>{% endif %}
                </div>
                <div class="u2-pdp-variant__sub">{{ v.title | split: '|' | last | strip }} · {% if forloop.first %}Best for first-timers · 30 days{% else %}90 days · save −33% per scoop{% endif %}</div>
              </div>
              <div class="u2-pdp-variant__price">{{ v.price | money_without_trailing_zeros }}</div>
            </label>
          {%- endfor -%}
          {%- liquid
            assign sub_variant = product.variants | last
            assign sub_plan = null
            for spg in product.selling_plan_groups
              for sp in spg.selling_plans
                assign sub_plan = sp
                break
              endfor
              if sub_plan != null
                break
              endif
            endfor
            assign sub_price = sub_variant.price | times: 90 | divided_by: 100
          -%}
          {%- if sub_plan -%}
          <label class="u2-pdp-variant u2-pdp-variant--subscribe">
            <input type="radio" name="id" value="{{ sub_variant.id }}" data-u2-subscribe="1" data-u2-selling-plan="{{ sub_plan.id }}">
            <div class="u2-pdp-variant__body">
              <div class="u2-pdp-variant__title">Subscribe &amp; Save <span class="u2-pdp-variant__badge u2-pdp-variant__badge--sub">−10% · most flexible</span></div>
              <div class="u2-pdp-variant__sub">Auto-refill every 30 days · Free shipping always · Cancel anytime</div>
            </div>
            <div class="u2-pdp-variant__price">{{ sub_price | money_without_trailing_zeros }}<span class="u2-pdp-variant__per">/mo</span></div>
          </label>
          {%- endif -%}
        </div>
        <div class="u2-pdp-sub-benefits" data-u2-sub-benefits hidden>
          <p class="u2-pdp-sub-benefits__title">🎁 $250 in free bonuses included</p>
          <ul>
            <li><span aria-hidden="true">📖</span> 30-day "Reset your 4 PM" e-book · <strong style="color:var(--u2-iris);">$50 value</strong></li>
            <li><span aria-hidden="true">👯</span> Private UBurn Collective group · <strong style="color:var(--u2-iris);">$45 value</strong></li>
            <li><span aria-hidden="true">📣</span> Online UBurn community events · <strong style="color:var(--u2-iris);">$55 value</strong></li>
            <li><span aria-hidden="true">💬</span> WhatsApp nutrition support · 30 days · <strong style="color:var(--u2-iris);">$50 value</strong></li>
            <li><span aria-hidden="true">💎</span> <span style="background:var(--u2-iris);color:white;font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;padding:3px 7px;border-radius:999px;margin-right:4px;">NEW</span><strong>Free Violet Bottle</strong> · 500 ml glass · UB monogram · <strong style="color:var(--u2-iris);">$29 value</strong></li>
          </ul>
          <p style="margin:10px 0 0;font-size:11px;color:#7a7585;">Ships every 30 days · Cancel, skip or pause anytime · Free U.S. shipping always</p>
        </div>

        <div class="u2-pdp-atc">
          <button type="submit" class="u2-pdp-atc__btn">
            Add to bag — <span id="u2-atc-price">{{ current_variant.price | money_without_trailing_zeros }}</span>
          </button>
          <span class="u2-pdp-atc__note">Free U.S. shipping on orders $40+ · Cancel anytime</span>
        </div>
      </form>

      <div class="u2-pdp-trust-strip">
        <span class="u2-pdp-trust-strip__item">{% render 'u2-icon', name: 'leaf', size: 14 %} Plant-based</span>
        <span class="u2-pdp-trust-strip__item">{% render 'u2-icon', name: 'check', size: 14 %} Caffeine-free</span>
        <span class="u2-pdp-trust-strip__item">{% render 'u2-icon', name: 'flask', size: 14 %} Third-party lab tested</span>
        <span class="u2-pdp-trust-strip__item">{% render 'u2-icon', name: 'shield', size: 14 %} EFSA-backed fiber</span>
        <span class="u2-pdp-trust-strip__item">{% render 'u2-icon', name: 'sparkle', size: 14 %} Non-GMO</span>
        <span class="u2-pdp-trust-strip__item">{% render 'u2-icon', name: 'globe', size: 14 %} French brand</span>
      </div>
    </div>
  </div>

  {%- comment -%} RITUAL — Pour / Stir / Breathe (editorial version) {%- endcomment -%}
  <section class="u2-pdp-ritual" aria-label="The 30-second ritual">
    <div class="u2-pdp-ritual__inner">
      <div class="u2-pdp-ritual__head u2-reveal">
        <span class="u2-section-eyebrow">— the 30-second ritual</span>
        <h2>30 seconds. <em>One moment of clarity.</em></h2>
      </div>
      <div class="u2-pdp-ritual__grid">
        <div class="u2-pdp-ritual__step u2-reveal delay-1">
          <div class="u2-pdp-ritual__img"><img src="{{ 'u2-ritual-step1.jpg' | asset_url }}" alt="Pour" loading="lazy" width="800" height="1000"></div>
          <div class="u2-pdp-ritual__num">01</div>
