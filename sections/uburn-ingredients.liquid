{{- 'uburn-home.css' | asset_url | stylesheet_tag -}}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,700;0,800;0,900;1,700&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

<style>
  main#main, .main-content { padding-top: 0 !important; margin-top: 0 !important; }
  .uhome-root { font-family: 'Red Hat Text', sans-serif; -webkit-font-smoothing: antialiased; }
  .uhome-root h1, .uhome-root h2, .uhome-root h3, .uhome-root h4 {
    font-family: 'Red Hat Display', sans-serif; letter-spacing: -0.02em;
  }

  /* ── HERO INGRÉDIENTS ── */
  .uingr-hero {
    background: var(--uhome-dark);
    padding: 140px 80px 96px;
    position: relative; overflow: hidden;
  }
  .uingr-hero::before {
    content: '';
    position: absolute; top: -200px; right: -100px;
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(107,47,160,.28) 0%, transparent 70%);
    pointer-events: none;
  }
  .uingr-hero-inner { position: relative; z-index: 1; max-width: 720px; }
  .uingr-hero .uhome-section-label { color: var(--uhome-purple-light); }
  .uingr-hero h1 {
    font-family: 'Red Hat Display', sans-serif;
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 900; line-height: 1.04;
    letter-spacing: -0.04em; color: #fff; margin-bottom: 20px;
  }
  .uingr-hero h1 em { font-style: italic; color: var(--uhome-purple-light); }
  .uingr-hero p {
    font-size: 17px; color: rgba(255,255,255,.62);
    max-width: 50ch; line-height: 1.7;
  }

  /* ── GRILLE INGRÉDIENTS ── */
  .uingr-grid-section {
    padding: 100px 80px;
    background: var(--uhome-cream);
  }
  .uingr-grid-inner { max-width: 1140px; margin: 0 auto; }
  .uingr-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-radius: 24px; overflow: hidden;
    box-shadow: 0 4px 48px rgba(61,24,115,.08);
    border: 1px solid rgba(61,24,115,.06);
  }
  .uingr-card {
    padding: 44px 36px;
    background: #fff;
    border-right: 1px solid rgba(61,24,115,.07);
    position: relative;
    transition: background .25s;
  }
  .uingr-card:nth-child(3n) { border-right: none; }
  .uingr-card:nth-child(n+4) { border-top: 1px solid rgba(61,24,115,.07); }
  .uingr-card:hover { background: var(--uhome-purple-wash); }
  .uingr-card.featured {
    background: linear-gradient(145deg, #2e1060 0%, #5b2199 60%, #7c3abf 100%);
    border-right-color: rgba(255,255,255,.08);
  }
  .uingr-card.featured:hover { filter: brightness(1.05); background: linear-gradient(145deg, #2e1060 0%, #5b2199 60%, #7c3abf 100%); }
  .uingr-icon { font-size: 36px; margin-bottom: 18px; }
  .uingr-name {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 19px; font-weight: 800;
    color: var(--uhome-dark); letter-spacing: -0.02em; margin-bottom: 5px;
  }
  .uingr-latin {
    font-size: 11px; color: var(--uhome-purple-mid);
    font-weight: 600; letter-spacing: .12em;
    text-transform: uppercase; margin-bottom: 14px;
  }
  .uingr-desc {
    font-size: 14px; color: var(--uhome-body); line-height: 1.65;
  }
  .uingr-tag {
    display: inline-block; margin-top: 16px;
    padding: 5px 12px; border-radius: 100px;
    background: var(--uhome-purple-wash);
    font-size: 11px; font-weight: 700;
    color: var(--uhome-purple-main); letter-spacing: .08em;
  }
  .uingr-card.featured .uingr-name,
  .uingr-card.featured .uingr-desc { color: #fff; }
  .uingr-card.featured .uingr-desc { color: rgba(255,255,255,.72); }
  .uingr-card.featured .uingr-latin { color: var(--uhome-purple-light); }
  .uingr-card.featured .uingr-tag {
    background: rgba(255,255,255,.15); color: rgba(255,255,255,.9);
  }

  /* ── EFSA BANNER ── */
  .uingr-efsa {
    background: var(--uhome-purple-wash);
    padding: 80px 40px; text-align: center;
  }
  .uingr-efsa-inner { max-width: 700px; margin: 0 auto; }
  .uingr-efsa-badge {
    display: inline-flex; align-items: center; gap: 14px;
    background: #fff; border-radius: 20px;
    padding: 20px 28px;
    box-shadow: 0 4px 24px rgba(107,47,160,.12);
    margin-bottom: 28px;
  }
  .uingr-efsa-badge-icon { font-size: 32px; }
  .uingr-efsa-badge-text {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 18px; font-weight: 800; color: var(--uhome-dark); letter-spacing: -0.02em;
  }
  .uingr-efsa-badge-sub { font-size: 12px; color: var(--uhome-muted); margin-top: 2px; }
  .uingr-efsa-desc {
    font-size: 16px; color: var(--uhome-body);
    line-height: 1.7; max-width: 52ch; margin: 0 auto;
  }

  /* ── BEFORE / AFTER PAGE INGRÉDIENTS ── */
  .uingr-ba-section { background: var(--uhome-warm); padding: 100px 80px; }
  .uingr-ba-inner { max-width: 1000px; margin: 0 auto; }
  .uingr-ba-card {
    display: grid; grid-template-columns: 1fr 56px 1fr;
    background: #fff; border-radius: 24px; overflow: hidden;
    box-shadow: 0 4px 60px rgba(61,24,115,.1); margin-top: 48px;
  }
  .uingr-ba-col { padding: 40px 36px; }
  .uingr-ba-before { background: #f9f7f5; }
  .uingr-ba-divider {
    background: var(--uhome-purple-wash);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }
  .uingr-ba-divider-arrow {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--uhome-grad);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 14px;
    box-shadow: 0 4px 16px rgba(107,47,160,.4);
  }
  .uingr-ba-label {
    font-size: 10px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: var(--uhome-muted); margin-bottom: 16px;
  }
  .uingr-ba-week {
    font-family: 'Red Hat Display', sans-serif;
    font-size: 26px; font-weight: 900; color: var(--uhome-dark);
    letter-spacing: -0.03em; margin-bottom: 14px;
  }
  .uingr-ba-items { display: flex; flex-direction: column; gap: 11px; }
  .uingr-ba-item {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 14px; line-height: 1.5; color: var(--uhome-body);
  }
  .uingr-ba-item::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: var(--uhome-purple-pale); flex-shrink: 0; margin-top: 6px;
  }
  .uingr-ba-after .uingr-ba-item::before { background: var(--uhome-purple-main); }
  .uingr-ba-after .uingr-ba-item { color: var(--uhome-dark); }
  .uingr-ba-profile {
    display: flex; align-items: center; gap: 12px;
    margin-top: 28px; padding-top: 20px;
    border-top: 1px solid var(--uhome-purple-pale);
  }
  .uingr-ba-avatar {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: var(--uhome-purple-wash);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Red Hat Display', sans-serif; font-weight: 800; font-size: 15px;
    color: var(--uhome-purple-main);
  }
  .uingr-ba-name { font-weight: 700; font-size: 14px; color: var(--uhome-dark); }
  .uingr-ba-meta { font-size: 12px; color: var(--uhome-muted); margin-top: 1px; }
  .uingr-ba-stars { color: #f4b942; font-size: 13px; margin-top: 3px; }
  .uingr-legal { text-align: center; font-size: 11.5px; color: var(--uhome-muted); margin-top: 18px; line-height: 1.6; }

  /* Responsive */
  @media(max-width:900px) {
    .uingr-hero { padding: 110px 24px 60px; }
    .uingr-grid-section { padding: 72px 24px; }
    .uingr-grid { grid-template-columns: 1fr 1fr; }
    .uingr-efsa { padding: 60px 24px; }
    .uingr-ba-section { padding: 72px 24px; }
  }
  @media(max-width:600px) {
    .uingr-hero { padding: 56px 20px 40px; }
    .uingr-grid { grid-template-columns: 1fr; }
    .uingr-ba-card { grid-template-columns: 1fr; grid-template-rows: auto 48px auto; }
    .uingr-ba-divider { height: 48px; flex-direction: row; }
    .uingr-ba-col { padding: 28px 20px; }
  }
</style>

<div class="uhome-root">

  {%- comment -%} HERO {%- endcomment -%}
  <section class="uingr-hero">
    <div class="uingr-hero-inner">
      <span class="uhome-section-label uhome-reveal">La formule</span>
      <h1 class="uhome-reveal uhome-rd1">6 actifs.<br><em>Un seul objectif.</em></h1>
      <p class="uhome-reveal uhome-rd2">Chaque ingrédient est sélectionné pour sa complémentarité. Ensemble, ils agissent sur la faim, l'énergie et la digestion — simultanément.</p>
    </div>
  </section>

  {%- comment -%} GRILLE 6 ACTIFS {%- endcomment -%}
  <section class="uingr-grid-section">
    <div class="uingr-grid-inner">
      <div class="uingr-grid uhome-stagger">

        <div class="uingr-card featured">
          <div class="uingr-icon">🟣</div>
          <div class="uingr-name">Konjac · Glucomannane</div>
          <div class="uingr-latin">Amorphophallus konjac</div>
          <div class="uingr-desc">L'actif principal. 3g par dose — la dose exacte validée par l'EFSA pour contribuer au contrôle de l'appétit dans le cadre d'un régime hypocalorique. Le seul ingrédient de cette catégorie officiellement reconnu en Europe.</div>
          <span class="uingr-tag">EFSA ID 3120 · Dose validée 3g</span>
        </div>

        <div class="uingr-card">
          <div class="uingr-icon">🌿</div>
          <div class="uingr-name">Ubé · Igname violet</div>
          <div class="uingr-latin">Dioscorea alata · Asie du Sud-Est</div>
          <div class="uingr-desc">L'ingrédient signature. Riche en anthocyanes, des antioxydants puissants qui protègent les cellules. Responsable de la couleur violette naturelle — aucun colorant artificiel.</div>
          <span class="uingr-tag">Antioxydants naturels</span>
        </div>

        <div class="uingr-card">
          <div class="uingr-icon">🥥</div>
          <div class="uingr-name">MCT · Coco</div>
          <div class="uingr-latin">Acides gras à chaîne moyenne</div>
          <div class="uingr-desc">Énergie rapide et stable dès 15 minutes après la prise. Les MCT sont métabolisés directement par le foie — sans pic d'insuline, sans crash de l'après-midi.</div>
          <span class="uingr-tag">Énergie stable</span>
        </div>

        <div class="uingr-card">
          <div class="uingr-icon">⚡</div>
          <div class="uingr-name">L-Carnitine</div>
          <div class="uingr-latin">Acide aminé · Naturel</div>
          <div class="uingr-desc">Contribue à l'utilisation des acides gras comme source d'énergie. Favorise le métabolisme lipidique — complémentaire au glucomannane pour une action complète.</div>
          <span class="uingr-tag">Métabolisme actif</span>
        </div>

        <div class="uingr-card">
          <div class="uingr-icon">🫚</div>
          <div class="uingr-name">Gingembre violet</div>
          <div class="uingr-latin">Zingiber zerumbet</div>
          <div class="uingr-desc">Soutient la digestion et réduit l'inconfort digestif. Propriétés anti-inflammatoires naturelles. Renforce l'action du glucomannane sur le transit.</div>
          <span class="uingr-tag">Confort digestif</span>
        </div>

        <div class="uingr-card">
          <div class="uingr-icon">🌾</div>
          <div class="uingr-name">Fibre d'acacia</div>
          <div class="uingr-latin">Acacia senegal · Prébiotique</div>
          <div class="uingr-desc">Prébiotique naturel qui nourrit les bonnes bactéries du microbiote intestinal. Contribue à une digestion équilibrée et à la santé intestinale sur le long terme.</div>
          <span class="uingr-tag">Microbiote équilibré</span>
        </div>

      </div>
    </div>
  </section>

  {%- comment -%} EFSA BANNER {%- endcomment -%}
  <div class="uingr-efsa">
    <div class="uingr-efsa-inner">
      <div class="uingr-efsa-badge uhome-reveal">
        <div class="uingr-efsa-badge-icon">🏛️</div>
        <div>
          <div class="uingr-efsa-badge-text">Allégation officielle EFSA</div>
          <div class="uingr-efsa-badge-sub">Règlement CE 432/2012 · ID 3120</div>
        </div>
      </div>
      <p class="uingr-efsa-desc uhome-reveal uhome-rd1">Le glucomannane est l'unique ingrédient dont l'allégation "contrôle de l'appétit" est officiellement validée par l'Autorité Européenne de Sécurité des Aliments. Conditions : 3g en 3 doses avec 1-2 verres d'eau avant les repas, dans le cadre d'un régime hypocalorique.</p>
    </div>
  </div>

  {%- comment -%} AVANT / APRÈS {%- endcomment -%}
  <section class="uingr-ba-section">
    <div class="uingr-ba-inner">
      <span class="uhome-section-label uhome-reveal">Résultat réel</span>
      <h2 class="uhome-section-title uhome-reveal uhome-rd1">Ce qui change.<br><em>Pas les nôtres.</em></h2>
      <div class="uingr-ba-card uhome-reveal uhome-rd2">
        <div class="uingr-ba-col uingr-ba-before">
          <div class="uingr-ba-label">Avant Uburn</div>
          <div class="uingr-ba-week">Semaine 1</div>
          <div class="uingr-ba-items">
            <div class="uingr-ba-item">Fringales incontrôlables à 16h — placard ouvert quotidiennement</div>
            <div class="uingr-ba-item">Culpabilité après chaque craquage, frustration chronique</div>
            <div class="uingr-ba-item">Dîner trop copieux pour compenser la faim accumulée</div>
            <div class="uingr-ba-item">Fatigue l'après-midi, digestion difficile</div>
          </div>
          <div class="uingr-ba-profile">
            <div class="uingr-ba-avatar">M</div>
            <div>
              <div class="uingr-ba-name">Marie D.</div>
              <div class="uingr-ba-meta">42 ans · Paris 11e</div>
            </div>
          </div>
        </div>
        <div class="uingr-ba-divider">
          <div class="uingr-ba-divider-arrow">→</div>
        </div>
        <div class="uingr-ba-col uingr-ba-after">
          <div class="uingr-ba-label">Après 4 semaines</div>
          <div class="uingr-ba-week">Semaine 4</div>
          <div class="uingr-ba-items">
            <div class="uingr-ba-item">Plus de fringale à 16h — elle oublie même d'ouvrir le placard</div>
            <div class="uingr-ba-item">Dîner naturellement plus léger, sans effort de volonté</div>
            <div class="uingr-ba-item">Digestion fluide, ventre moins gonflé dès la 2e semaine</div>
            <div class="uingr-ba-item">Perte de 2,8 kg sur 4 semaines sans régime particulier</div>
          </div>
          <div class="uingr-ba-profile">
            <div class="uingr-ba-avatar">M</div>
            <div>
              <div class="uingr-ba-name">Marie D. — Cliente vérifiée</div>
              <div class="uingr-ba-meta">Après 28 jours · Résultats individuels</div>
              <div class="uingr-ba-stars">★★★★★</div>
            </div>
          </div>
        </div>
      </div>
      <p class="uingr-legal">Les résultats varient selon les individus. Glucomannane — EFSA ID 3120. Conditions : 3g/jour avec eau avant les repas.</p>
    </div>
  </section>

  {%- comment -%} BARRE GARANTIES + CTA {%- endcomment -%}
  <div class="uhome-guar">
    <div class="uhome-guar-grid">
      <div class="uhome-guar-item">
        <div class="uhome-guar-icon">
          <img src="https://uburn.co/cdn/shop/files/Picto_World.svg" alt="" aria-hidden="true">
        </div>
        <h4>Formule EFSA</h4>
        <p>Glucomannane ID 3120</p>
      </div>
      <div class="uhome-guar-item">
        <div class="uhome-guar-icon">
          <img src="https://uburn.co/cdn/shop/files/Picto_Fast_shipping.svg" alt="" aria-hidden="true">
        </div>
        <h4>Livraison gratuite</h4>
        <p>En France</p>
      </div>
      <div class="uhome-guar-item">
        <div class="uhome-guar-icon">
          <img src="https://uburn.co/cdn/shop/files/Picto_secure_payment.svg" alt="" aria-hidden="true">
        </div>
        <h4>Paiement sécurisé</h4>
        <p>100% sécurisé</p>
      </div>
      <div class="uhome-guar-item">
        <div class="uhome-guar-icon">
          <img src="https://uburn.co/cdn/shop/files/Picto_customer.svg" alt="" aria-hidden="true">
        </div>
        <h4>Sans abonnement</h4>
        <p>Commandez quand vous voulez</p>
      </div>
    </div>
  </div>

  <div style="background:var(--uhome-purple-deep);padding:64px 40px;text-align:center">
    <h2 class="uhome-section-title uhome-reveal" style="color:#fff;margin-bottom:24px">Prête à essayer ?</h2>
    <a href="/products/ube-poudre?variant=51289200066879" class="uhome-btn uhome-btn-white uhome-reveal uhome-rd1" style="font-size:16px;font-weight:800;padding:18px 40px">
      Commander — dès 34,50&nbsp;€
    </a>
    <p class="uhome-reveal uhome-rd2" style="margin-top:16px;font-size:13px;color:rgba(255,255,255,.45)">Livraison offerte · Sans abonnement · Paiement sécurisé</p>
  </div>

</div>

<script>
(function() {
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('uhome-visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.uhome-reveal, .uhome-stagger, .uhome-stagger-scale').forEach(function(el) { obs.observe(el); });
  requestAnimationFrame(function() {
    document.querySelectorAll('.uhome-reveal, .uhome-stagger, .uhome-stagger-scale').forEach(function(el) {
      var r = el.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('uhome-visible');
    });
  });
})();
</script>

