@media(min-width:900px){.upd8-ingrs{grid-template-columns:repeat(3,1fr)}}
.upd8-ingr{
  background:#fff;border:1px solid var(--u-line);border-radius:14px;
  overflow:hidden;transition:.25s
}
.upd8-ingr:hover{box-shadow:0 8px 24px rgba(0,0,0,.06);transform:translateY(-2px)}
.upd8-ingr__img{width:100%;aspect-ratio:4/3;object-fit:cover;background:var(--u-cream)}
.upd8-ingr__body{padding:16px 18px}
.upd8-ingr__name{font-size:14px;font-weight:700;color:var(--u-deep);margin-bottom:4px}
.upd8-ingr__dose{font-size:12px;color:var(--u-primary);font-weight:600;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
.upd8-ingr__desc{font-size:13px;color:var(--u-text-soft);line-height:1.55}
.upd8-ingr__pill{display:inline-block;margin-top:10px;background:var(--u-cream);color:var(--u-primary);font-size:10px;font-weight:800;padding:4px 9px;border-radius:100px;letter-spacing:.5px;text-transform:uppercase}

/* ════════════════════════════════════════════════════════════════
   11. TESTIMONIALS — stack mobile, 3 cols desktop
═══════════════════════════════════════════════════════════════════ */
.upd8-testis{display:grid;grid-template-columns:1fr;gap:16px;margin-top:8px}
@media(min-width:768px){.upd8-testis{grid-template-columns:repeat(3,1fr)}}
.upd8-testi{
  background:#fff;border:1px solid var(--u-line);
  border-radius:14px;padding:22px;display:flex;flex-direction:column
}
.upd8-testi__stars{color:var(--u-rating);font-size:14px;letter-spacing:2px;margin-bottom:10px}
.upd8-testi__title{font-size:14px;font-weight:700;color:var(--u-deep);margin-bottom:8px;line-height:1.3}
.upd8-testi__text{font-size:13.5px;color:var(--u-text);line-height:1.6;margin-bottom:14px;flex:1}
.upd8-testi__author{
  display:flex;align-items:center;gap:10px;
  padding-top:12px;border-top:1px solid var(--u-line)
}
.upd8-testi__avatar{
  width:36px;height:36px;border-radius:50%;background:var(--u-cream);
  display:flex;align-items:center;justify-content:center;
  color:var(--u-primary);font-weight:800;font-size:12px;flex-shrink:0
}
.upd8-testi__name{font-size:12.5px;font-weight:700;color:var(--u-deep);line-height:1.2}
.upd8-testi__check{font-size:10px;color:var(--u-success);font-weight:700;margin-top:2px;letter-spacing:.3px}

/* ════════════════════════════════════════════════════════════════
   12. FAQ
═══════════════════════════════════════════════════════════════════ */
.upd8-faq{max-width:760px;margin:0 auto}
.upd8-faq-item{
  background:#fff;border:1px solid var(--u-line);border-radius:12px;
  margin-bottom:10px;overflow:hidden
}
.upd8-faq-item summary{
  display:flex;justify-content:space-between;align-items:center;gap:14px;
  font-size:14.5px;font-weight:600;color:var(--u-deep);
  padding:18px 20px;cursor:pointer;list-style:none;line-height:1.35
}
.upd8-faq-item summary::-webkit-details-marker{display:none}
.upd8-faq-item summary::after{
  content:'+';font-size:22px;color:var(--u-primary);
  transition:transform .25s;flex-shrink:0;line-height:1;font-weight:300
}
.upd8-faq-item[open] summary::after{transform:rotate(45deg)}
.upd8-faq-item__a{
  padding:0 20px 18px;font-size:14px;color:var(--u-text-soft);line-height:1.65
}

/* ════════════════════════════════════════════════════════════════
   13. FINAL OFFER RECAP
═══════════════════════════════════════════════════════════════════ */
.upd8-offer{
