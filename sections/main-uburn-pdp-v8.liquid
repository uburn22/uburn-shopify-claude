  font-size:13px;color:var(--u-deep)
}
.upd8-offer__total strong{font-size:16px;color:var(--u-primary);font-weight:800}
.upd8-offer__trust{
  display:grid;grid-template-columns:1fr 1fr;gap:10px;
  margin-top:18px;font-size:12px;color:var(--u-text-soft)
}
.upd8-offer__trust div{display:flex;align-items:center;gap:6px}
.upd8-offer__trust svg{color:var(--u-primary);flex-shrink:0}

/* ════════════════════════════════════════════════════════════════
   14. STICKY ATC MOBILE
═══════════════════════════════════════════════════════════════════ */
.upd8-sticky{
  display:none;position:fixed;bottom:0;left:0;right:0;
  background:#fff;border-top:1px solid var(--u-line);
  padding:10px 14px calc(14px + env(safe-area-inset-bottom));
  z-index:200;box-shadow:0 -8px 24px rgba(0,0,0,.08);
  align-items:center;gap:10px;
  transform:translateY(110%);transition:transform .3s cubic-bezier(.22,1,.36,1)
}
.upd8-sticky.visible{transform:translateY(0)}
.upd8-sticky__price{flex-shrink:0;line-height:1}
.upd8-sticky__num{font-size:17px;font-weight:800;color:var(--u-deep);letter-spacing:-.01em}
.upd8-sticky__day{font-size:10.5px;color:var(--u-success);font-weight:700;margin-top:2px}
.upd8-sticky__btn{
