.upd8-hero__photo img{animation:upd8-float 5s ease-in-out infinite}

/* Counter spin for stat numbers (subtle) */
.upd8-stat__num{transition:transform .4s cubic-bezier(.22,1,.36,1)}
.upd8-stat:hover .upd8-stat__num{transform:scale(1.06)}

