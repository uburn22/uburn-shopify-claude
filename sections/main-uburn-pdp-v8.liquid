<script>
(function(){
  /* Force visibility */
  function fv(){document.querySelectorAll('.shopify-section').forEach(function(s){if(s.querySelector('.upd8')){s.style.setProperty('display','block','important');s.style.setProperty('visibility','visible','important')}})}
  fv();var c=0;var ci=setInterval(function(){fv();if(++c>15)clearInterval(ci)},250);

  /* Reveal on scroll */
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('[data-reveal]').forEach(function(el){io.observe(el)});
  }else{document.querySelectorAll('[data-reveal]').forEach(function(el){el.classList.add('in')})}

  /* Variant picker — sync between hero and offer block + sticky */
  var stickyNum=document.getElementById('upd8StickyNum');
  var stickyDay=document.getElementById('upd8StickyDay');
  function syncSticky(label){
    if(!label)return;
    if(stickyNum)stickyNum.textContent=label.querySelector('.upd8-variant__num').textContent;
    if(stickyDay)stickyDay.textContent=label.dataset.pday+' / jour';
  }
  function selectVariant(vid){
    document.querySelectorAll('.upd8-variant').forEach(function(label){
      var match=label.dataset.vid===vid;
      label.classList.toggle('selected',match);
      label.querySelector('input').checked=match;
      if(match)syncSticky(label);
    });
  }
  document.querySelectorAll('.upd8-variant').forEach(function(label){
    label.addEventListener('click',function(){selectVariant(label.dataset.vid)});
  });
  syncSticky(document.querySelector('.upd8-variant.selected'));

  /* ATC AJAX */
  function ajaxAdd(form){
    var cta=form.querySelector('.upd8-cta');
    if(cta){cta.classList.add('loading');cta.disabled=true}
    var fd=new FormData(form);
    fetch('/cart/add.js',{method:'POST',body:fd,headers:{'Accept':'application/json'}})
      .then(function(r){return r.json()})
      .then(function(){
        if(typeof fbq!=='undefined')fbq('track','AddToCart');
        if(typeof gtag!=='undefined')gtag('event','add_to_cart');
        var trigger=document.querySelector('[data-cart-drawer-trigger],.cart-drawer-trigger,.cart-icon-bubble,.header__cart');
        if(trigger){trigger.click()}else{location.href='/cart'}
      })
      .catch(function(){location.href='/cart'})
      .finally(function(){if(cta){cta.classList.remove('loading');cta.disabled=false}});
  }
  ['upd8Form','upd8FormFinal'].forEach(function(id){
    var f=document.getElementById(id);
    if(f)f.addEventListener('submit',function(e){e.preventDefault();ajaxAdd(f)});
  });
  var sb=document.getElementById('upd8StickyBtn');
  if(sb)sb.addEventListener('click',function(){
    var f=document.getElementById('upd8Form');if(f)ajaxAdd(f);
  });

  /* Sticky visibility */
  var sticky=document.getElementById('upd8Sticky');
  var hero=document.querySelector('.upd8-hero');
  if(sticky&&hero&&'IntersectionObserver' in window){
    var sio=new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting||e.boundingClientRect.top>=0)sticky.classList.remove('visible');
        else sticky.classList.add('visible');
      });
    },{threshold:0,rootMargin:'-100px 0px 0px 0px'});
    sio.observe(hero);
  }
})();
</script>

