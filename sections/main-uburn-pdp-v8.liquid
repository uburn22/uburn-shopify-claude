/* === Animations === */
[data-reveal]{opacity:0;transform:translateY(24px);transition:opacity .8s cubic-bezier(.22,1,.36,1),transform .8s cubic-bezier(.22,1,.36,1)}
[data-reveal].in{opacity:1;transform:none}
[data-reveal-delay="1"]{transition-delay:.1s}
[data-reveal-delay="2"]{transition-delay:.2s}
[data-reveal-delay="3"]{transition-delay:.3s}

/* Pulse on Best badge */
@keyframes upd8-pulse{0%,100%{transform:scale(1);box-shadow:0 0 0 0 rgba(212,165,116,.4)}50%{transform:scale(1.05);box-shadow:0 0 0 8px rgba(212,165,116,0)}}
.upd8-variant__pop{animation:upd8-pulse 2.4s ease-in-out infinite}

