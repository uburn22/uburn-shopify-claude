  padding:14px;font-size:14px;font-weight:700;letter-spacing:.3px;
  display:flex;align-items:center;justify-content:center;gap:8px
}
.upd8-sticky__btn:active{background:var(--u-primary-dark)}
@media(max-width:767px){.upd8-sticky{display:flex}body{padding-bottom:84px}}

