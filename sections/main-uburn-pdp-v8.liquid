{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured = product.featured_image
  for img in product.images
    assign s = img.src | downcase
    if s contains 'productpage_0000' or s contains 'product_page_0001'
      assign featured = img
      break
    endif
  endfor
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://uburn.co" crossorigin>
<link rel="preload" as="image" fetchpriority="high" href="{{ featured | image_url: width: 720 }}&format=webp">

<style>
/* ════════════════════════════════════════════════════════════════
   UBURN PDP V8 — Mobile-first · Cloned from LP structure
   ADN: Poppins + #7d3fff + cream #f8f5ff + deep #2b1e4d
═══════════════════════════════════════════════════════════════════ */

/* === HIDE THEME PARASITES ON THIS PAGE === */
.shopify-section--announcement-bar{display:none!important}
.shopify-section ~ .shopify-section--multi-column,
.shopify-section ~ .shopify-section--text-with-media,
.shopify-section ~ .shopify-section--trust-icons,
.shopify-section ~ .shopify-section--ss-scrolling-logo-cloud,
.shopify-section ~ .shopify-section--separator-adjustable,
.shopify-section ~ .shopify-section--apps,
.shopify-section ~ .shopify-section--collection-list,
.shopify-section ~ .shopify-section--scrolling-content,
.shopify-section ~ .shopify-section--faq{display:none!important}
.shopify-section:has(.upd8){display:block!important;visibility:visible!important}

/* === Reset scoped to .upd8 === */
.upd8,.upd8 *{box-sizing:border-box}
.upd8{
  font-family:'Poppins',-apple-system,BlinkMacSystemFont,sans-serif;
  color:#1a1a1a;background:#fff;
  -webkit-font-smoothing:antialiased;line-height:1.55
}
.upd8 a{color:inherit;text-decoration:none}
.upd8 img{max-width:100%;display:block;height:auto}
.upd8 button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
.upd8 ul,.upd8 ol{list-style:none;padding:0;margin:0}
.upd8 p,.upd8 h1,.upd8 h2,.upd8 h3,.upd8 h4{margin:0}

:root{
  --u-primary:#7d3fff;
  --u-primary-dark:#6328d6;
  --u-deep:#2b1e4d;
  --u-text:#1a1a1a;
  --u-text-soft:#6b6b6b;
  --u-cream:#f8f5ff;
  --u-cream-warm:#fff9f0;
  --u-gold:#d4a574;
  --u-gold-bg:#fff4e6;
  --u-line:#ebe6f5;
  --u-success:#16a34a;
  --u-rating:#fbbf24;
  --u-radius:14px;
}

/* ════════════════════════════════════════════════════════════════
   1. STICKY TOP BAR — carousel 3 messages
═══════════════════════════════════════════════════════════════════ */
.upd8-top{
  position:sticky;top:0;z-index:99;
  background:var(--u-deep);color:#fff;
  padding:10px 14px;font-size:12px;font-weight:500;letter-spacing:.3px;
  display:flex;align-items:center;justify-content:center;
  text-align:center;overflow:hidden
}
.upd8-top__track{
  display:flex;gap:36px;align-items:center;white-space:nowrap;
  animation:upd8-marquee 24s linear infinite
}
.upd8-top__item{display:inline-flex;align-items:center;gap:6px}
.upd8-top__dot{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,.4)}
@keyframes upd8-marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ════════════════════════════════════════════════════════════════
   2. HERO PDP — mobile-first photo + ATC
═══════════════════════════════════════════════════════════════════ */
.upd8-hero{
  padding:20px 16px 32px;max-width:1180px;margin:0 auto;
  background:radial-gradient(ellipse at center top,var(--u-cream) 0%,#fff 60%)
}
.upd8-hero__inner{
  display:grid;grid-template-columns:1fr;gap:20px;align-items:center
}
@media(min-width:900px){
  .upd8-hero{padding:56px 32px}
  .upd8-hero__inner{grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:64px}
}

/* Hero photo */
.upd8-hero__photo{
  aspect-ratio:1/1;
  background:radial-gradient(circle at center,var(--u-cream) 0%,#fff 100%);
  border-radius:18px;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  position:relative;max-width:340px;margin:0 auto;width:100%
}
@media(min-width:900px){.upd8-hero__photo{max-width:520px;border-radius:24px}}
.upd8-hero__photo img{width:90%;height:90%;object-fit:contain;display:block}
.upd8-hero__badge{
  position:absolute;top:12px;left:12px;
  background:#fff;color:var(--u-deep);
  padding:6px 12px;border-radius:100px;
  font-size:10.5px;font-weight:700;letter-spacing:1px;
  text-transform:uppercase;
  box-shadow:0 4px 12px rgba(0,0,0,.08)
}

/* Buy block */
.upd8-buy{display:flex;flex-direction:column;gap:18px}
.upd8-buy__rating{
  display:flex;align-items:center;gap:8px;
  font-size:13px;color:var(--u-text)
}
.upd8-buy__stars{color:var(--u-rating);letter-spacing:1.5px;font-size:14px}
.upd8-buy__rating strong{color:var(--u-deep)}
.upd8-buy__rating a{color:var(--u-text-soft);text-decoration:underline;text-underline-offset:2px}

.upd8-buy h1{
  font-family:'Poppins',sans-serif;
  font-size:clamp(22px,5.8vw,40px);font-weight:800;line-height:1.08;
  letter-spacing:-.025em;color:var(--u-deep);
  overflow-wrap:break-word;hyphens:auto;max-width:100%;text-wrap:balance
}
.upd8-buy h1 em{font-style:normal;color:var(--u-primary);display:inline}
.upd8-buy__sub{
  font-size:15px;color:var(--u-text-soft);line-height:1.5
}
.upd8-buy__sub strong{color:var(--u-deep);font-weight:600}

/* Variant cards (vertical stack on mobile) */
.upd8-variants{display:flex;flex-direction:column;gap:10px}
.upd8-variant{
  position:relative;background:#fff;
  border:2px solid var(--u-line);border-radius:var(--u-radius);
  padding:14px 16px;cursor:pointer;transition:.2s;
  display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:12px
}
.upd8-variant:hover{border-color:var(--u-primary)}
.upd8-variant input{position:absolute;opacity:0;pointer-events:none}
.upd8-variant.selected{border-color:var(--u-primary);background:var(--u-cream)}
.upd8-variant.selected .upd8-variant__check{
  background:var(--u-primary);border-color:var(--u-primary)
}
.upd8-variant.selected .upd8-variant__check::after{
  content:'';width:8px;height:4px;
  border-left:2px solid #fff;border-bottom:2px solid #fff;
  transform:rotate(-45deg);margin-top:-2px
}
.upd8-variant__check{
  width:20px;height:20px;border-radius:50%;border:2px solid var(--u-line);
  flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:.15s
}
.upd8-variant__txt{min-width:0}
.upd8-variant__name{
  font-size:14.5px;font-weight:700;color:var(--u-deep);line-height:1.2;
  display:flex;align-items:center;gap:8px;flex-wrap:wrap
}
.upd8-variant__pop{
  display:inline-block;background:var(--u-gold);color:#fff;
  font-size:10px;font-weight:800;padding:2px 8px;border-radius:100px;
  letter-spacing:.5px;text-transform:uppercase
}
.upd8-variant__meta{font-size:12px;color:var(--u-text-soft);margin-top:3px}
.upd8-variant__price{text-align:right;line-height:1.1}
.upd8-variant__num{
  font-size:17px;font-weight:800;color:var(--u-deep);letter-spacing:-.01em
}
.upd8-variant__day{
  font-size:11px;color:var(--u-success);font-weight:700;margin-top:3px;white-space:nowrap
}

/* CTA */
.upd8-cta{
  width:100%;background:var(--u-primary);color:#fff;
  padding:17px 24px;border-radius:100px;
  font-size:15px;font-weight:700;letter-spacing:.3px;
  display:flex;align-items:center;justify-content:center;gap:10px;
  transition:.2s;box-shadow:0 6px 16px rgba(125,63,255,.25)
}
.upd8-cta:hover{background:var(--u-primary-dark);transform:translateY(-1px);box-shadow:0 8px 22px rgba(125,63,255,.35)}
.upd8-cta[disabled]{opacity:.6;cursor:not-allowed}
.upd8-cta__loading{display:none;width:18px;height:18px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:upd8-spin .6s linear infinite}
.upd8-cta.loading .upd8-cta__loading{display:inline-block}
.upd8-cta.loading .upd8-cta__txt{display:none}
@keyframes upd8-spin{to{transform:rotate(360deg)}}

/* Payments line */
.upd8-pays{
  display:flex;justify-content:center;gap:8px;flex-wrap:wrap;
  font-size:11.5px;color:var(--u-text-soft);font-weight:500;
  align-items:center
}
.upd8-pays span{display:inline-flex;align-items:center;gap:5px}

/* Trust ticks */
.upd8-ticks{display:flex;flex-direction:column;gap:6px;font-size:13px}
.upd8-tick{display:flex;align-items:center;gap:8px;color:var(--u-text)}
.upd8-tick svg{flex-shrink:0;color:var(--u-primary)}

/* ════════════════════════════════════════════════════════════════
   3. BANDEAU BONUS 184€
═══════════════════════════════════════════════════════════════════ */
.upd8-bonus{
  background:var(--u-gold-bg);
  border-top:1px solid #f0e3cd;border-bottom:1px solid #f0e3cd;
  padding:24px 16px;margin:8px 0
}
.upd8-bonus__inner{max-width:560px;margin:0 auto}
.upd8-bonus__head{
  display:flex;align-items:center;gap:8px;
  font-size:12.5px;font-weight:700;color:var(--u-deep);
  text-transform:uppercase;letter-spacing:1.2px;margin-bottom:14px
}
.upd8-bonus__list{display:flex;flex-direction:column;gap:9px}
.upd8-bonus__item{
  display:flex;justify-content:space-between;align-items:center;gap:12px;
  font-size:13.5px;color:var(--u-text);font-weight:500
}
.upd8-bonus__item::before{
  content:'✓';color:var(--u-primary);font-weight:800;flex-shrink:0
}
.upd8-bonus__item span{flex:1;line-height:1.3}
.upd8-bonus__item em{font-style:normal;color:var(--u-text-soft);font-size:12px;font-weight:600}
.upd8-bonus__total{
  margin-top:14px;padding-top:14px;border-top:1px dashed #d9c294;
  display:flex;justify-content:space-between;align-items:center;
  font-size:13px;color:var(--u-deep)
}
.upd8-bonus__total strong{font-size:17px;font-weight:800;color:var(--u-primary);letter-spacing:-.01em}

/* ════════════════════════════════════════════════════════════════
   4. PRESS LOGOS
═══════════════════════════════════════════════════════════════════ */
.upd8-press{
  padding:28px 16px;text-align:center;
  border-bottom:1px solid var(--u-line)
}
.upd8-press__lead{
  font-size:11px;text-transform:uppercase;letter-spacing:2px;
  color:var(--u-text-soft);font-weight:600;margin-bottom:18px
}
.upd8-press__logos{
  display:flex;gap:24px;justify-content:center;align-items:center;
  flex-wrap:wrap;opacity:.55;max-width:720px;margin:0 auto
}
.upd8-press__logos img{height:18px;width:auto;filter:grayscale(1)}
@media(min-width:600px){.upd8-press__logos img{height:22px}.upd8-press__logos{gap:36px}}

/* ════════════════════════════════════════════════════════════════
   GENERIC SECTION
═══════════════════════════════════════════════════════════════════ */
.upd8-sec{padding:56px 16px;max-width:1100px;margin:0 auto}
@media(min-width:768px){.upd8-sec{padding:80px 32px}}
.upd8-sec--cream{background:var(--u-cream);max-width:none;padding-left:0;padding-right:0}
.upd8-sec--cream .upd8-inner{max-width:1100px;margin:0 auto;padding:0 16px}
@media(min-width:768px){.upd8-sec--cream .upd8-inner{padding:0 32px}}
.upd8-sec--purple{
  background:linear-gradient(160deg,#3d1873 0%,#7d3fff 100%);
  color:#fff;max-width:none
}
.upd8-eyebrow{
  display:block;font-size:11px;font-weight:700;
  text-transform:uppercase;letter-spacing:2.5px;
  color:var(--u-primary);text-align:center;margin-bottom:12px
}
.upd8-sec--purple .upd8-eyebrow{color:#d8b4fe}
.upd8-h2{
  font-family:'Poppins',sans-serif;
  font-size:clamp(24px,5.5vw,36px);font-weight:800;line-height:1.1;
  letter-spacing:-.02em;color:var(--u-deep);text-align:center;margin-bottom:14px
}
.upd8-h2 em{font-style:normal;color:var(--u-primary)}
.upd8-sec--purple .upd8-h2{color:#fff}
.upd8-sec--purple .upd8-h2 em{color:#d8b4fe}
.upd8-lead{
  font-size:15px;color:var(--u-text-soft);text-align:center;
  line-height:1.6;max-width:560px;margin:0 auto 36px
}
.upd8-sec--purple .upd8-lead{color:rgba(255,255,255,.8)}

/* ════════════════════════════════════════════════════════════════
   5. PROBLEM — 3 cards (11h / 16h / 21h)
═══════════════════════════════════════════════════════════════════ */
.upd8-problem{display:flex;flex-direction:column;gap:12px}
@media(min-width:700px){.upd8-problem{flex-direction:row;gap:1px;background:rgba(255,255,255,.1);border-radius:18px;overflow:hidden;box-shadow:0 8px 32px rgba(45,24,115,.12)}}
.upd8-prob-card{
  background:linear-gradient(150deg,#3d1873 0%,#6b2fa0 60%,#8b47c5 100%);
  color:#fff;padding:28px 24px;border-radius:14px;
  position:relative;overflow:hidden
}
@media(min-width:700px){.upd8-prob-card{flex:1;border-radius:0}}
.upd8-prob-card__time{
  display:inline-block;background:rgba(255,255,255,.15);
  padding:5px 12px;border-radius:100px;
  font-size:12px;font-weight:700;color:#d8b4fe;
  letter-spacing:1px;margin-bottom:14px
}
.upd8-prob-card h3{
  font-size:16px;font-weight:700;margin-bottom:10px;line-height:1.25
}
.upd8-prob-card p{font-size:13.5px;color:rgba(255,255,255,.8);line-height:1.6}

/* ════════════════════════════════════════════════════════════════
   6. HOW IT WORKS — 3 steps stacked
═══════════════════════════════════════════════════════════════════ */
.upd8-how{display:grid;grid-template-columns:1fr;gap:20px;margin-top:8px;max-width:520px;margin-left:auto;margin-right:auto}
@media(min-width:768px){.upd8-how{grid-template-columns:repeat(3,1fr);gap:32px;max-width:none}}
.upd8-step{
  display:grid;grid-template-columns:96px 1fr;gap:16px;align-items:center;
  background:#fff;padding:14px;border-radius:14px;
  border:1px solid var(--u-line);
  transition:transform .25s ease,box-shadow .25s ease
}
.upd8-step:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(45,24,115,.10)}
@media(min-width:768px){
  .upd8-step{grid-template-columns:1fr;gap:14px;text-align:center;padding:24px 18px;background:transparent;border:none}
  .upd8-step:hover{transform:translateY(-3px)}
  .upd8-step__img{margin:0 auto}
}
.upd8-step__img{
  width:96px;height:96px;border-radius:12px;object-fit:cover;
  background:var(--u-cream);box-shadow:0 4px 14px rgba(45,24,115,.08)
}
@media(min-width:768px){.upd8-step__img{width:140px;height:140px;border-radius:14px}}
.upd8-step__num{
  font-size:10.5px;font-weight:700;color:var(--u-primary);
  text-transform:uppercase;letter-spacing:2px;margin-bottom:5px
}
.upd8-step h4{
  font-size:15px;font-weight:700;color:var(--u-deep);margin-bottom:4px;letter-spacing:-.005em
}
.upd8-step p{font-size:13px;color:var(--u-text-soft);line-height:1.55}

/* ════════════════════════════════════════════════════════════════
   7. EXPERT — Dr. Claire Dubois
═══════════════════════════════════════════════════════════════════ */
.upd8-expert{
  max-width:880px;margin:0 auto;background:#fff;
  border-radius:18px;padding:28px 24px;
  box-shadow:0 8px 30px rgba(45,24,115,.08);
  display:flex;flex-direction:column;gap:18px;align-items:center;text-align:center
}
@media(min-width:700px){.upd8-expert{flex-direction:row;text-align:left;padding:36px 44px;gap:36px}}
.upd8-expert__img{
  width:96px;height:96px;border-radius:50%;object-fit:cover;
  background:var(--u-cream);flex-shrink:0
}
.upd8-expert__quote{
  font-size:18px;font-weight:600;color:var(--u-deep);
  line-height:1.4;letter-spacing:-.005em;font-style:italic
}
.upd8-expert__name{
  margin-top:14px;font-size:13px;font-weight:700;color:var(--u-deep)
}
.upd8-expert__role{
  font-size:11.5px;color:var(--u-text-soft);
  text-transform:uppercase;letter-spacing:1.5px;margin-top:2px
}

/* ════════════════════════════════════════════════════════════════
   8. STATS — grid 2x2 mobile, 4x1 desktop
═══════════════════════════════════════════════════════════════════ */
.upd8-stats__grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:32px 16px;
  max-width:900px;margin:0 auto
}
@media(min-width:768px){.upd8-stats__grid{grid-template-columns:repeat(4,1fr);gap:32px}}
.upd8-stat{text-align:center;padding:0 4px;min-width:0}
.upd8-stat__num{
  font-family:'Poppins',sans-serif;
  font-size:clamp(38px,9vw,56px);font-weight:800;line-height:1;
  letter-spacing:-.03em;font-variant-numeric:tabular-nums
}
.upd8-stat__num small{
  font-size:.5em;font-weight:600;color:rgba(255,255,255,.6);margin-left:2px
}
.upd8-stat__label{
  margin-top:10px;font-size:11.5px;font-weight:500;color:rgba(255,255,255,.78);
  text-transform:uppercase;letter-spacing:1.2px;line-height:1.4
}

/* ════════════════════════════════════════════════════════════════
   9. COMPARISON — desktop table, mobile cards
═══════════════════════════════════════════════════════════════════ */
.upd8-comp-cards{display:flex;flex-direction:column;gap:14px;margin-top:8px;max-width:520px;margin-left:auto;margin-right:auto}
.upd8-comp-card{
  background:#fff;border:1px solid var(--u-line);
  border-radius:14px;padding:20px 18px;
  transition:transform .25s ease,box-shadow .25s ease
}
.upd8-comp-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(45,24,115,.08)}
.upd8-comp-card__name{
  font-size:15px;font-weight:800;color:var(--u-deep);
  letter-spacing:-.005em;margin-bottom:14px;text-align:center;
  padding-bottom:12px;border-bottom:2px solid var(--u-line)
}
.upd8-comp-card__row{
  display:flex;justify-content:space-between;align-items:center;gap:14px;
  padding:11px 0;border-bottom:1px solid var(--u-line);font-size:13px;line-height:1.45
}
.upd8-comp-card__row:last-child{border-bottom:none}
.upd8-comp-card__row > span{display:block}
.upd8-comp-card__row > span:first-child{color:var(--u-text-soft);font-weight:500;flex:0 1 auto;min-width:0;max-width:55%}
.upd8-comp-card__row > span:last-child{font-weight:700;color:var(--u-deep);text-align:right;flex:1 1 auto;max-width:50%}
.upd8-comp-card__row .upd8-good{color:var(--u-success)}
.upd8-comp-card__row .upd8-bad{color:#dc2626}
.upd8-comp-card--hero{
  background:linear-gradient(160deg,#fff 0%,var(--u-cream) 100%);
  border:2px solid var(--u-primary);box-shadow:0 12px 32px rgba(125,63,255,.18);position:relative
}
.upd8-comp-card--hero .upd8-comp-card__name{color:var(--u-primary);border-bottom-color:var(--u-primary);font-size:18px;font-weight:800;letter-spacing:-.01em}
.upd8-comp-card--hero::before{
  content:'★ Notre choix';position:absolute;top:-12px;right:18px;
  background:var(--u-primary);color:#fff;font-size:10.5px;font-weight:800;
  padding:5px 12px;border-radius:100px;letter-spacing:.5px;text-transform:uppercase;
  box-shadow:0 4px 12px rgba(125,63,255,.3)
}
@media(min-width:769px){.upd8-comp-cards{display:none}}
.upd8-comp-table{display:none;width:100%;border-collapse:collapse;background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 4px 14px rgba(0,0,0,.04)}
@media(min-width:769px){.upd8-comp-table{display:table}}
.upd8-comp-table th,.upd8-comp-table td{padding:14px 16px;text-align:center;border-bottom:1px solid var(--u-line);font-size:14px}
.upd8-comp-table thead th{background:var(--u-deep);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:1.5px}
.upd8-comp-table tbody td:first-child{text-align:left;font-weight:600;color:var(--u-deep)}
.upd8-comp-table .upd8-comp-uburn{background:var(--u-cream);font-weight:700;color:var(--u-primary)}

/* ════════════════════════════════════════════════════════════════
   10. INGREDIENTS DETAIL — 1 col mobile, 3 col desktop
═══════════════════════════════════════════════════════════════════ */
