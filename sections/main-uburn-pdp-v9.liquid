<script>
  /* PROGRESSIVE ENHANCEMENT (no visibility gate on core content):
     1. Price-per dynamique selon variant
     2. Sticky CTA mobile : slide-up quand main ATC sort du viewport
     Si JS fail : tout reste fonctionnel (price-per garde valeur Liquid,
     sticky reste caché par défaut). */
  (function(){
    var form = document.getElementById('pdpv9-pdp-form');
    if (!form) return;

    // 1. ALL price/text refs — dynamic on variant change
    var mainPrice   = document.getElementById('pdpv9-price');         // main hero price
    var pricePrefix = document.getElementById('pdpv9-price-prefix');  // "From " — removed on variant click
    var per         = document.getElementById('pdpv9-price-per');     // sub-price meta line
    var atcPrice    = document.getElementById('pdpv9-atc-price');     // "— $35" inside CTA
    var atcText     = document.getElementById('pdpv9-atc-text');      // "Start my 30-day routine"
    var cartMeta    = document.getElementById('pdpv9-cart-meta');     // cart product meta line
    var cartPrice   = document.getElementById('pdpv9-cart-price');    // cart product price
    var cartTotal   = document.getElementById('pdpv9-cart-total');    // cart total
    var cartPerDay  = document.getElementById('pdpv9-cart-per-day');  // cart per-day line
    var stickyPrice = document.getElementById('pdpv9-sticky-price');  // sticky CTA price

    function formatPrice(cents) {
      var n = parseInt(cents, 10);
      if (isNaN(n)) return '';
      return (n / 100).toFixed(2).replace('.', ',') + '$';
    }

    function updateOnVariant() {
      var checked = form.querySelector('input[name="id"]:checked');
      if (!checked) return;
      var unit       = checked.getAttribute('data-vunit-price');
      var days       = checked.getAttribute('data-vdays')       || '30';
      var price      = checked.getAttribute('data-vprice');
      var priceMoney = checked.getAttribute('data-vprice-money'); // pre-formatted by Liquid
      var idx        = checked.getAttribute('data-vidx');
      var priceStr   = priceMoney || formatPrice(price);
      var doses      = (idx === '2') ? '1 scoop/day' : '1 scoop/day';

      // 1. Main hero price
      if (mainPrice && priceStr) mainPrice.textContent = priceStr;

      // 2. Sub-price meta line
      if (per && unit && days) {
        per.textContent = unit + ' · Pack ' + days + ' days · No subscription trap';
      }

      // 3. ATC button price ("— $X,XX")
      if (atcPrice && priceStr) atcPrice.textContent = '— ' + priceStr;

      // 4. ATC button text (uniform "30 days")
      if (atcText && days) atcText.textContent = 'Start my routine ' + days + ' days';

      // 5. Cart-recap product meta + price + total
      if (cartMeta && days) {
        cartMeta.textContent = 'Hazelnut-vanilla flavor · Pack ' + days + ' days · ' + doses;
      }
      if (cartPrice && priceStr) cartPrice.textContent = priceStr;
      if (cartTotal && priceStr) cartTotal.textContent = priceStr;
      if (cartPerDay && unit && days) {
        cartPerDay.textContent = 'soit ' + unit + ' sur ' + days + ' days';
      }

      // 6. Sticky CTA mobile price (synced with selected variant)
      if (stickyPrice && priceStr) stickyPrice.textContent = priceStr;

      // 7. Hero price : remove "From" prefix on first explicit selection
      if (pricePrefix && pricePrefix.textContent) pricePrefix.textContent = '';
    }
    form.querySelectorAll('input[name="id"]').forEach(function(r){
      r.addEventListener('change', updateOnVariant);
    });

    // 2. Sticky CTA — appears only after the entire purchase block has scrolled out
    // Observe the LAST element of the purchase panel (bonus stack) — sticky stays
    // hidden as long as the user is anywhere within the purchase area.
    var lastPurchaseEl = document.querySelector('.pdpv9-pdp__bonus--collapsible')
                       || form.querySelector('.pdpv9-pdp__atc');
    var sticky = document.querySelector('.pdpv9-sticky-cta');
    if (lastPurchaseEl && sticky && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          // visible = last purchase element NOT in viewport (user has scrolled past hero)
          sticky.classList.toggle('pdpv9-sticky-cta--visible', !e.isIntersecting);
        });
      }, { rootMargin: '0px 0px -60px 0px', threshold: 0 });
      io.observe(lastPurchaseEl);
    }
  })();
</script>

