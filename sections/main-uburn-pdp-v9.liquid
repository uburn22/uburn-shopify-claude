{%- comment -%}
  ════════════════════════════════════════════════════════════════
  UBURN PDP V9 — Complete redesign avec ADN visuel exact de la LP
  ────────────────────────────────────────────────────────────────
  - CSS prefix: .pdpv9-* (zéro conflit avec la LP)
  - Single main-* section that replaces all native main-product
  - Hides theme parasites via scoped CSS
  - Variant picker + native Shopify form between sections 7 & 9
  - Mobile-first 375x812
  ════════════════════════════════════════════════════════════════
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured = product.featured_image

  for img in product.images
    assign s = img.src | downcase
    if s contains 'productpage_0000' or s contains 'product_page_0001' or s contains 'uburn_listing'
      assign featured = img
      break
    endif
  endfor

  assign v_decouverte = product.variants[0]
  assign v_maximum = product.variants[1] | default: product.variants[0]
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="image" fetchpriority="high" href="{{ featured | image_url: width: 900 }}&format=webp">
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

{{ 'uburn-pdp-v9.css' | asset_url | stylesheet_tag }}

<style>
  /* Force visibility minimal — sans debug couleurs */
  .shopify-section.uburn-pdp-v9-section {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
  .pdpv9-root {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }

  /* Sibling-based hide pour theme parasites */
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--multi-column,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--text-with-media,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--trust-icons,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--ss-scrolling-logo-cloud,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--separator-adjustable,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--apps,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--collection-list,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--faq { display: none !important; }

  /* Reveal toudays visible — pas de gate */
  .pdpv9-reveal, .pdpv9-stagger-children > *, .pdpv9-stagger-scale > * {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<div class="pdpv9-root">

  <div class="pdpv9-announce">FREE U.S. SHIPPING ON ORDERS $40+</div>

  <div class="pdpv9-promo-bar" id="pdpv9-promoBar">
    <span id="pdpv9-promoText">🎁 <strong>10% off</strong> your first order · Code <strong>UBE10</strong></span>
    <button type="button" class="pdpv9-promo-copy" id="pdpv9-promoCopy" aria-label="Copy code UBE10">Copy</button>
  </div>

  <div class="pdpv9-ribbon">
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Research-backed glucomannan*</span>
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> 100% Plant-based</span>
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> No subscription trap</span>
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Caffeine-free</span>
  </div>

  {%- comment -%} ═══ PDP HERO ABOVE-FOLD — real PDP structure ═══ {%- endcomment -%}
  <section class="pdpv9-pdp" id="pdpv9-pdp">
    <div class="pdpv9-pdp__grid">

      {%- comment -%} ─── LEFT: Gallery (CSS-only carousel, mobile swipe via scroll-snap) ─── {%- endcomment -%}
      <div class="pdpv9-pdp__gallery">
        {%- if product.media.size > 0 -%}
          <div class="pdpv9-pdp__slides" role="region" aria-label="Galerie produit" tabindex="0">
            {%- for media in product.media -%}
              <div class="pdpv9-pdp__slide" id="pdpv9-slide-{{ forloop.index }}">
                {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                  {{ media | media_tag: image_size: '1200x', autoplay: false, loop: false, controls: true, preload: 'metadata' }}
                {%- else -%}
                  <img src="{{ media | image_url: width: 1200 }}&format=webp" alt="{{ media.alt | default: product.title | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" decoding="async" width="1200" height="1200">
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
          {%- if product.media.size > 1 -%}
            <div class="pdpv9-pdp__thumbs" role="tablist" aria-label="Vignettes">
              {%- for media in product.media -%}
                <a href="#pdpv9-slide-{{ forloop.index }}" class="pdpv9-pdp__thumb" aria-label="Image {{ forloop.index }}">
                  <img src="{{ media | image_url: width: 200 }}&format=webp" alt="" loading="lazy" decoding="async" width="200" height="200">
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- elsif featured -%}
          <div class="pdpv9-pdp__slides">
            <div class="pdpv9-pdp__slide">
              <img src="{{ featured | image_url: width: 1200 }}&format=webp" alt="{{ featured.alt | default: product.title | escape }}" loading="eager" decoding="async" width="1200" height="1200">
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ─── RIGHT: Purchase panel ─── {%- endcomment -%}
      <div class="pdpv9-pdp__purchase">

        {%- comment -%} Header: rating + social pill + title + subtitle + benefits bullets {%- endcomment -%}
        <div class="pdpv9-pdp__header">
          <div class="pdpv9-pdp__rating" aria-label="Now in the U.S., limited launch stock">
            <span class="pdpv9-pdp__stars pdpv9-pdp__stars--badge" aria-hidden="true">●</span>
            <span class="pdpv9-pdp__rating-text">Now in the U.S. · Limited launch stock</span>
          </div>
          <div class="pdpv9-pdp__social-pill" role="note">
            <svg class="pdpv9-pdp__social-pill-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            <span>Formulated with ube, konjac, and coconut MCT</span>
          </div>
          <h1 class="pdpv9-pdp__title">The <span class="pdpv9-pdp__title-accent">4PM Crash</span><br>Killer.*</h1>
          <p class="pdpv9-pdp__subtitle">Plant-based satiety drink that calms cravings naturally. Up to 4 hours of fullness. 30 calories. No caffeine. No jitters.*</p>
          <ul class="pdpv9-pdp__bullets" aria-label="Bénéfices clés">
            <li><span class="pdpv9-pdp__bullet-emoji" aria-hidden="true">🔥</span> For 4PM and evening cravings</li>
            <li><span class="pdpv9-pdp__bullet-emoji" aria-hidden="true">⏱️</span> Up to 4 hours of satiety*</li>
            <li><span class="pdpv9-pdp__bullet-emoji" aria-hidden="true">☕</span> Caffeine-free, routine douce</li>
          </ul>
        </div>

        {%- comment -%} Price — initial render shows "From $35" if no explicit user choice yet. JS removes prefix on first variant click. {%- endcomment -%}
        <div class="pdpv9-pdp__price-wrap">
          <span class="pdpv9-pdp__price-prefix" id="pdpv9-price-prefix">From </span>
          <span class="pdpv9-pdp__price" id="pdpv9-price">{{ v_decouverte.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="pdpv9-pdp__compare-price"><s>{{ current_variant.compare_at_price | money }}</s></span>
          {%- endif -%}
        </div>

        {%- comment -%} ATC FORM — native Shopify {%- endcomment -%}
        <form action="/cart/add" method="post" enctype="multipart/form-data" class="pdpv9-pdp__form" id="pdpv9-pdp-form" novalidate>
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="✓">

          {%- if product.variants.size > 1 -%}
            <fieldset class="pdpv9-pdp__variants" role="radiogroup" aria-label="Pick your pack">
              <legend class="pdpv9-pdp__variants-legend">Pick your pack</legend>
              {%- for v in product.variants -%}
                {%- liquid
                  assign vmeta = '90g · 1 scoop/day · 30 days'
                  assign vunit = '$1.16/day'
                  assign vdays = '30'
                  assign vtag = 'Pour tester la routine'
                  if forloop.index == 2
                    assign vmeta = '270g · 1 scoop/day · 90 days'
                    assign vunit = '0,65$/day'
                    assign vdays = '30'
                    assign vtag = 'Best price per scoop'
                  endif
                -%}
                <label class="pdpv9-pdp__variant{% if forloop.index == 2 %} pdpv9-pdp__variant--pop{% endif %}{% if v.id == current_variant.id %} pdpv9-pdp__variant--selected{% endif %}{% unless v.available %} pdpv9-pdp__variant--sold{% endunless %}">
                  <input type="radio" name="id" value="{{ v.id }}"{% if v.id == current_variant.id %} checked{% endif %}{% unless v.available %} disabled{% endunless %} class="pdpv9-pdp__variant-input" data-vidx="{{ forloop.index }}" data-vprice="{{ v.price }}" data-vprice-money="{{ v.price | money }}" data-vunit-price="{{ vunit }}" data-vdays="{{ vdays }}">
                  {%- if forloop.index == 2 -%}<span class="pdpv9-pdp__variant-badge">Best Value</span>{%- endif -%}
                  <span class="pdpv9-pdp__variant-body">
                    <span class="pdpv9-pdp__variant-name">{{ v.title | split: ' | ' | first | replace: ' ⭐', '' }}</span>
                    <span class="pdpv9-pdp__variant-tag">{{ vtag }}</span>
                    <span class="pdpv9-pdp__variant-meta">{{ vmeta }}</span>
                    <span class="pdpv9-pdp__variant-price-row">
                      <span class="pdpv9-pdp__variant-price">{{ v.price | money }}{% if v.compare_at_price > v.price %} <s>{{ v.compare_at_price | money }}</s>{% endif %}</span>
                      <span class="pdpv9-pdp__variant-perday">{{ vunit }}</span>
                    </span>
                  </span>
                  {%- unless v.available -%}<span class="pdpv9-pdp__variant-sold">Rupture</span>{%- endunless -%}
                </label>
              {%- endfor -%}
            </fieldset>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endif -%}

          <div class="pdpv9-pdp__qty-row">
            <label for="pdpv9-pdp-qty" class="pdpv9-pdp__qty-label">Quantity</label>
            <div class="pdpv9-pdp__qty-input-wrap">
              <input id="pdpv9-pdp-qty" type="number" name="quantity" value="1" min="1" max="10" inputmode="numeric" class="pdpv9-pdp__qty-input" aria-label="Quantity">
            </div>
          </div>

          <button type="submit" name="add" class="pdpv9-pdp__atc"{% unless current_variant.available %} disabled{% endunless %}>
            {%- if current_variant.available -%}
              <span class="pdpv9-pdp__atc-text" id="pdpv9-atc-text">Start my 30-day routine</span>
              <span class="pdpv9-pdp__atc-price" id="pdpv9-atc-price">— {{ current_variant.price | money }}</span>
            {%- else -%}
              En rupture
            {%- endif -%}
          </button>
        </form>

        {%- comment -%} Sub-CTA trust line (under the CTA) {%- endcomment -%}
        <p class="pdpv9-pdp__atc-trust">Free U.S. shipping · Sepack checkout · Bonuses included</p>

        {%- comment -%} Reassurance compact (post-ATC) — 4 trust signals factuels {%- endcomment -%}
        <ul class="pdpv9-pdp__reassurance">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h13l3 4v6h-3"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg> Free U.S. shipping</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Sepack checkout</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Ships from France</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Customer support available</li>
        </ul>

        {%- comment -%} ─── BLOC DÉCISION : Which pack is right for you? (CRO V1 — sous reassurance) ─── {%- endcomment -%}
        <div class="pdpv9-decide" aria-labelledby="pdpv9-decide-title">
          <h3 class="pdpv9-decide__title" id="pdpv9-decide-title">Which pack is right for you?</h3>
          <div class="pdpv9-decide__grid">
            <article class="pdpv9-decide__card">
              <span class="pdpv9-decide__label">Starter 90g</span>
              <p class="pdpv9-decide__desc">Ideal if you want to try UBurn at your own pace, 1 scoop per day.</p>
            </article>
            <article class="pdpv9-decide__card pdpv9-decide__card--pop">
              <span class="pdpv9-decide__pop">Best Value</span>
              <span class="pdpv9-decide__label">Maximum Pack 270g</span>
              <p class="pdpv9-decide__desc">Ideal for your daily routine and best value per scoop — 90-day supply.</p>
            </article>
          </div>
          <a href="#pdpv9-pdp-form" class="pdpv9-cta-secondary pdpv9-decide__cta">Pick my pack →</a>
        </div>

        {%- comment -%} ─── BLOC BÉNÉFICES : Why UBurn helps handle cravings naturally* ─── {%- endcomment -%}
        <div class="pdpv9-why" aria-labelledby="pdpv9-why-title">
          <h3 class="pdpv9-why__title" id="pdpv9-why-title">Why UBurn helps handle cravings naturally*</h3>
          <ul class="pdpv9-why__list">
            <li class="pdpv9-why__item"><span class="pdpv9-why__bullet" aria-hidden="true">🌿</span><span>Konjac fiber contributes to a feeling of fullness within a balanced diet.*</span></li>
            <li class="pdpv9-why__item"><span class="pdpv9-why__bullet" aria-hidden="true">💜</span><span>Purple ube brings a comforting, naturally vibrant ritual.</span></li>
            <li class="pdpv9-why__item"><span class="pdpv9-why__bullet" aria-hidden="true">🥥</span><span>Coconut MCT adds a smooth texture and lasting fullness sensation.*</span></li>
            <li class="pdpv9-why__item"><span class="pdpv9-why__bullet" aria-hidden="true">☕</span><span>Caffeine-free: drink any time, even at night.</span></li>
          </ul>
          <a href="#pdpv9-pdp-form" class="pdpv9-cta-secondary pdpv9-why__cta">Try UBurn risk-free →</a>
        </div>

        {%- comment -%} Bonus stack — collapsible <details> on mobile, expanded on desktop {%- endcomment -%}
        <details class="pdpv9-pdp__bonus pdpv9-pdp__bonus--collapsible">
          <summary class="pdpv9-pdp__bonus-summary">
            <span class="pdpv9-pdp__bonus-summary-label">🎁 <strong>$184 in bonuses</strong> offerts</span>
            <span class="pdpv9-pdp__bonus-count">+4</span>
          </summary>
          <div class="pdpv9-pdp__bonus-items">
            <div><span>E-book "30 Days to Reset"</span><span class="pdpv9-pdp__bonus-val"><s>$47</s> 0$</span></div>
            <div><span>Private community: UBurn Collective</span><span class="pdpv9-pdp__bonus-val"><s>$40</s> 0$</span></div>
            <div><span>UBurn online events</span><span class="pdpv9-pdp__bonus-val"><s>$50</s> 0$</span></div>
            <div><span>30-day nutrition support via WhatsApp</span><span class="pdpv9-pdp__bonus-val"><s>$47</s> 0$</span></div>
          </div>
        </details>

      </div>
    </div>

  </section>

  {%- comment -%} ─── STORIES CAROUSEL — humanise avant moment 16h ─── {%- endcomment -%}
  {{ 'uburn-stories-carousel.css' | asset_url | stylesheet_tag }}
  <section class="pdpv9-stories" aria-labelledby="pdpv9-stories-title">
