  {%- comment -%}
    Sticky mobile CTA — submits the native PDP form via HTML5 form attribute.
    No JS required. Falls back to anchor link if form not present (defensive).
  {%- endcomment -%}
  <div class="pdpv9-sticky-cta">
    {%- if current_variant.available -%}
      <button type="submit" form="pdpv9-pdp-form" name="add" class="pdpv9-sticky-cta__btn" aria-label="Ajouter au panier">
        Ajouter au panier — <span id="pdpv9-sticky-price">{{ current_variant.price | money }}</span>
      </button>
    {%- else -%}
      <a href="#pdpv9-pdp" class="pdpv9-sticky-cta__btn pdpv9-sticky-cta__btn--disabled" aria-disabled="true">En rupture</a>
    {%- endif -%}
