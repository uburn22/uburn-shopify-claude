      </div>
      <div class="pdpv9-stories__dots">
        <button class="pdpv9-stories__dot is-active" data-stories-dot="0"></button>
        <button class="pdpv9-stories__dot" data-stories-dot="1"></button>
        <button class="pdpv9-stories__dot" data-stories-dot="2"></button>
        <button class="pdpv9-stories__dot" data-stories-dot="3"></button>
      </div>
    </div>
  </section>
  {{ 'uburn-stories-carousel.js' | asset_url | script_tag }}

  {%- comment -%} ─── 16H. LE MOMENT OÙ TOUT SE JOUE — placée juste après hero ─── {%- endcomment -%}
  <section class="pdpv9-moment16h" aria-labelledby="pdpv9-moment16h-title">
    <div class="pdpv9-moment16h__inner">
      <div class="pdpv9-moment16h__copy">
        <span class="pdpv9-eyebrow">The critical moment</span>
        <h2 class="pdpv9-h2" id="pdpv9-moment16h-title">4PM. <span class="pdpv9-h2-accent">When everything's on the line.</span></h2>
        <p class="pdpv9-lead">Sugar cravings. The afternoon crash. The snacking that creeps back in. UBurn turns that moment into a purple ritual — comforting and simple.</p>
        <p class="pdpv9-moment16h__sub">Water, milk, or plant-based milk. Your choice.</p>

        <ul class="pdpv9-moment16h__pills" aria-label="Notes et préparation">
          <li class="pdpv9-moment16h__pill">Natural vanilla notes</li>
          <li class="pdpv9-moment16h__pill">Hazelnut touch</li>
          <li class="pdpv9-moment16h__pill">Water, milk, or plant-based milk</li>
          <li class="pdpv9-moment16h__pill">Comforting purple ritual</li>
        </ul>

        <a href="#pdpv9-pdp" class="pdpv9-cta-secondary pdpv9-moment16h__cta">Create my 4PM ritual →</a>
      </div>

      <aside class="pdpv9-moment16h__ritual" aria-label="Your UBurn ritual">
        <div class="pdpv9-moment16h__ritual-head">
          <span class="pdpv9-eyebrow">Your UBurn ritual</span>
