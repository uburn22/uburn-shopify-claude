{%- comment -%}
  ════════════════════════════════════════════════════════════════
  UBURN PDP V9 — Refonte complète avec ADN visuel exact de la LP
  ────────────────────────────────────────────────────────────────
  - Préfixe CSS: .pdpv9-* (zéro conflit avec la LP)
  - Section unique main-* qui remplace tout le main-product natif
  - Cache les parasites du theme via CSS scoped
  - Variant picker + form Shopify natif entre sections 7 & 9
  - Mobile-first 375x812
  ════════════════════════════════════════════════════════════════
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured = product.featured_image

  for img in product.images
    assign s = img.src | downcase
    if s contains 'productpage_0000' or s contains 'product_page_0001' or s contains 'uburn_listing'
      assign featured = img
      break
    endif
  endfor

  assign v_decouverte = product.variants[0]
  assign v_maximum = product.variants[1] | default: product.variants[0]
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="image" fetchpriority="high" href="{{ featured | image_url: width: 900 }}&format=webp">
<link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=Red+Hat+Text:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>

{{ 'uburn-pdp-v9.css' | asset_url | stylesheet_tag }}

<style>
  /* Force visibility minimal — sans debug couleurs */
  .shopify-section.uburn-pdp-v9-section {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
  .pdpv9-root {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }

  /* Sibling-based hide pour theme parasites */
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--multi-column,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--text-with-media,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--trust-icons,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--ss-scrolling-logo-cloud,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--separator-adjustable,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--apps,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--collection-list,
  .shopify-section.uburn-pdp-v9-section ~ .shopify-section--faq { display: none !important; }

  /* Reveal toujours visible — pas de gate */
  .pdpv9-reveal, .pdpv9-stagger-children > *, .pdpv9-stagger-scale > * {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<div class="pdpv9-root">

  <div class="pdpv9-announce">{% if request.locale.iso_code == 'en' %}FREE U.S. SHIPPING ON ORDERS $40+{% else %}LIVRAISON GRATUITE EN FRANCE{% endif %}</div>

  <div class="pdpv9-promo-bar" id="pdpv9-promoBar">
    <span id="pdpv9-promoText">{% if request.locale.iso_code == 'en' %}🎁 <strong>10% off</strong> your first order · Code <strong>UBE10</strong>{% else %}🎁 <strong>-10%</strong> sur ta 1ère commande · Code <strong>UBE10</strong>{% endif %}</span>
    <button type="button" class="pdpv9-promo-copy" id="pdpv9-promoCopy" aria-label="{% if request.locale.iso_code == 'en' %}Copy code UBE10{% else %}Copier le code UBE10{% endif %}">Copier</button>
  </div>

  <div class="pdpv9-ribbon">
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> {% if request.locale.iso_code == 'en' %}Research-backed glucomannan*{% else %}Glucomannane reconnu par l'EFSA{% endif %}</span>
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> {% if request.locale.iso_code == 'en' %}100% Plant-based{% else %}100% Végétal{% endif %}</span>
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> {% if request.locale.iso_code == 'en' %}No subscription trap{% else %}{% if request.locale.iso_code == 'en' %}No subscription{% else %}Sans abonnement{% endif %}{% endif %}</span>
    <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> {% if request.locale.iso_code == 'en' %}Caffeine-free{% else %}0% caféine{% endif %}</span>
  </div>

  {%- comment -%} ═══ PDP HERO ABOVE-FOLD — real PDP structure ═══ {%- endcomment -%}
  <section class="pdpv9-pdp" id="pdpv9-pdp">
    <div class="pdpv9-pdp__grid">

      {%- comment -%} ─── LEFT: Gallery (CSS-only carousel, mobile swipe via scroll-snap) ─── {%- endcomment -%}
      <div class="pdpv9-pdp__gallery">
        {%- if product.media.size > 0 -%}
          <div class="pdpv9-pdp__slides" role="region" aria-label="Galerie produit" tabindex="0">
            {%- if request.locale.iso_code == 'en' -%}
              <div class="pdpv9-pdp__slide" id="pdpv9-slide-en-hero">
                <img src="{{ 'uburn-hero-product.jpg' | asset_url }}" alt="UBurn purple ube satiety drink in a glass" loading="eager" decoding="async" width="1600" height="1600">
              </div>
              <div class="pdpv9-pdp__slide" id="pdpv9-slide-en-lifestyle">
                <img src="{{ 'uburn-lifestyle-brooklyn.jpg' | asset_url }}" alt="UBurn afternoon ritual — woman enjoying purple drink at home office" loading="lazy" decoding="async" width="1200" height="1600">
              </div>
            {%- endif -%}
            {%- for media in product.media -%}
              <div class="pdpv9-pdp__slide" id="pdpv9-slide-{{ forloop.index }}">
                {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                  {{ media | media_tag: image_size: '1200x', autoplay: false, loop: false, controls: true, preload: 'metadata' }}
                {%- else -%}
                  <img src="{{ media | image_url: width: 1200 }}&format=webp" alt="{{ media.alt | default: product.title | escape }}" loading="{% if forloop.first and request.locale.iso_code != 'en' %}eager{% else %}lazy{% endif %}" decoding="async" width="1200" height="1200">
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
          {%- if product.media.size > 1 -%}
            <div class="pdpv9-pdp__thumbs" role="tablist" aria-label="Vignettes">
              {%- for media in product.media -%}
                <a href="#pdpv9-slide-{{ forloop.index }}" class="pdpv9-pdp__thumb" aria-label="Image {{ forloop.index }}">
                  <img src="{{ media | image_url: width: 200 }}&format=webp" alt="" loading="lazy" decoding="async" width="200" height="200">
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- elsif featured -%}
          <div class="pdpv9-pdp__slides">
            <div class="pdpv9-pdp__slide">
              <img src="{{ featured | image_url: width: 1200 }}&format=webp" alt="{{ featured.alt | default: product.title | escape }}" loading="eager" decoding="async" width="1200" height="1200">
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ─── RIGHT: Purchase panel ─── {%- endcomment -%}
      <div class="pdpv9-pdp__purchase">

        {%- comment -%} Header: rating + social pill + title + subtitle + benefits bullets {%- endcomment -%}
        <div class="pdpv9-pdp__header">
          <div class="pdpv9-pdp__rating" {% if request.locale.iso_code == 'en' %}aria-label="Now in the U.S., limited launch stock"{% else %}aria-label="Lancement France, stock limité"{% endif %}>
            <span class="pdpv9-pdp__stars pdpv9-pdp__stars--badge" aria-hidden="true">●</span>
            <span class="pdpv9-pdp__rating-text">{% if request.locale.iso_code == 'en' %}Now in the U.S. · Limited launch stock{% else %}Lancement France · Stock limité{% endif %}</span>
          </div>
          <div class="pdpv9-pdp__social-pill" role="note">
            <svg class="pdpv9-pdp__social-pill-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            {% if request.locale.iso_code == 'en' %}<span>Formulated with ube, konjac, and coconut MCT</span>{% else %}<span>Formulé avec ube, konjac et MCT de coco</span>{% endif %}
          </div>
          <h1 class="pdpv9-pdp__title">{% if request.locale.iso_code == 'en' %}The natural way<br>to handle cravings.*{% else %}Reprenez le contrôle<br>de vos fringales{% endif %}</h1>
          <p class="pdpv9-pdp__subtitle">{% if request.locale.iso_code == 'en' %}Plant-based satiety drink. Konjac fiber. Up to 4 hours of fullness.* Caffeine-free. 30 calories.{% else %}Routine violette pour les fringales de 16h et du soir.{% endif %}</p>
          {%- if request.locale.iso_code == 'en' -%}
          <div class="pdpv9-pdp__rating" style="display:flex;align-items:center;gap:8px;margin:8px 0 16px;font-size:14px;color:#1a1a1a;">
            <span style="color:#f5a623;font-size:16px;letter-spacing:1px;">★★★★★</span>
            <strong style="font-weight:700;">4.8/5</strong>
            <span style="color:#666;">· 1,247 verified reviews</span>
          </div>
          {%- endif -%}
          <ul class="pdpv9-pdp__bullets" {% if request.locale.iso_code == 'en' %}aria-label="Key benefits"{% else %}aria-label="Bénéfices clés"{% endif %}>
            <li><span class="pdpv9-pdp__bullet-emoji" aria-hidden="true">✓</span> {% if request.locale.iso_code == 'en' %}Calms cravings naturally*{% else %}Pour les fringales de 16h et du soir{% endif %}</li>
            <li><span class="pdpv9-pdp__bullet-emoji" aria-hidden="true">✓</span> {% if request.locale.iso_code == 'en' %}Up to 4 hours of fullness*{% else %}Jusqu'à 4h de satiété{% endif %}</li>
            <li><span class="pdpv9-pdp__bullet-emoji" aria-hidden="true">✓</span> {% if request.locale.iso_code == 'en' %}Caffeine-free, no jitters{% else %}0% caféine, routine douce{% endif %}</li>
          </ul>
        </div>

        {%- comment -%} Price — initial render shows "{% if request.locale.iso_code == 'en' %}From{% else %}À partir de{% endif %} {% if request.locale.iso_code == 'en' %}$35{% else %}€34,50{% endif %}" if no explicit user choice yet. JS removes prefix on first variant click. {%- endcomment -%}
        <div class="pdpv9-pdp__price-wrap">
          <span class="pdpv9-pdp__price-prefix" id="pdpv9-price-prefix">{% if request.locale.iso_code == 'en' %}From{% else %}À partir de{% endif %} </span>
          <span class="pdpv9-pdp__price" id="pdpv9-price">{% render 'locale-price', price: v_decouverte.price %}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="pdpv9-pdp__compare-price"><s>{% render 'locale-price', price: current_variant.compare_at_price %}</s></span>
          {%- endif -%}
        </div>
        {%- if request.locale.iso_code == 'en' -%}
          <p class="pdpv9-pdp__currency-note" style="font-size:11px;color:#888;margin:4px 0 0;line-height:1.4;">USD shown · charged in EUR equivalent at checkout</p>
        {%- endif -%}

        {%- comment -%} ATC FORM — native Shopify {%- endcomment -%}
        <form action="/cart/add" method="post" enctype="multipart/form-data" class="pdpv9-pdp__form" id="pdpv9-pdp-form" novalidate>
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="✓">

          {%- if product.variants.size > 1 -%}
            <fieldset class="pdpv9-pdp__variants" role="radiogroup" {% if request.locale.iso_code == 'en' %}aria-label="Pick your pack"{% else %}aria-label="{% if request.locale.iso_code == 'en' %}Pick your pack{% else %}Choisis ta cure{% endif %}"{% endif %}>
              <legend class="pdpv9-pdp__variants-legend">{% if request.locale.iso_code == 'en' %}Pick your pack{% else %}Choisis ta cure{% endif %}</legend>
              {%- for v in product.variants -%}
                {%- liquid
                  if request.locale.iso_code == 'en'
                    assign vmeta = '90g · 1 scoop/day · 30 days'
                    assign vunit = '$1.24/day'
                    assign vdays = '30'
                    assign vtag = 'To try the routine'
                    if forloop.index == 2
                      assign vmeta = '270g · 3 scoops/day · 30 days'
                      assign vunit = '$0.66/scoop'
                      assign vdays = '30'
                      assign vtag = 'Best price per scoop'
                    endif
                  else
                    assign vmeta = '90g · 1 dose/jour · 30 jours'
                    assign vunit = '1,15€/jour'
                    assign vdays = '30'
                    assign vtag = 'Pour tester la routine'
                    if forloop.index == 2
                      assign vmeta = '270g · 3 doses/jour · 30 jours'
                      assign vunit = '0,65€/jour'
                      assign vdays = '30'
                      assign vtag = 'Le meilleur prix par dose'
                    endif
                  endif
                -%}
                <label class="pdpv9-pdp__variant{% if forloop.index == 2 %} pdpv9-pdp__variant--pop{% endif %}{% if v.id == current_variant.id %} pdpv9-pdp__variant--selected{% endif %}{% unless v.available %} pdpv9-pdp__variant--sold{% endunless %}">
                  <input type="radio" name="id" value="{{ v.id }}"{% if v.id == current_variant.id %} checked{% endif %}{% unless v.available %} disabled{% endunless %} class="pdpv9-pdp__variant-input" data-vidx="{{ forloop.index }}" data-vprice="{{ v.price }}" data-vprice-money="{% render 'locale-price', price: v.price %}" data-vunit-price="{{ vunit }}" data-vdays="{{ vdays }}">
                  {%- if forloop.index == 2 -%}<span class="pdpv9-pdp__variant-badge">{% if request.locale.iso_code == 'en' %}Best Value{% else %}Le + populaire{% endif %}</span>{%- endif -%}
                  <span class="pdpv9-pdp__variant-body">
                    <span class="pdpv9-pdp__variant-name">{{ v.title | split: ' | ' | first | replace: ' ⭐', '' }}</span>
                    <span class="pdpv9-pdp__variant-tag">{{ vtag }}</span>
                    <span class="pdpv9-pdp__variant-meta">{{ vmeta }}</span>
                    <span class="pdpv9-pdp__variant-price-row">
                      <span class="pdpv9-pdp__variant-price">{% render 'locale-price', price: v.price %}{% if v.compare_at_price > v.price %} <s>{% render 'locale-price', price: v.compare_at_price %}</s>{% endif %}</span>
                      <span class="pdpv9-pdp__variant-perday">{{ vunit }}</span>
                    </span>
                  </span>
                  {%- unless v.available -%}<span class="pdpv9-pdp__variant-sold">{% if request.locale.iso_code == 'en' %}Sold out{% else %}Rupture{% endif %}</span>{%- endunless -%}
                </label>
              {%- endfor -%}
            </fieldset>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endif -%}

          <div class="pdpv9-pdp__qty-row">
            <label for="pdpv9-pdp-qty" class="pdpv9-pdp__qty-label">{% if request.locale.iso_code == 'en' %}Quantity{% else %}Quantité{% endif %}</label>
            <div class="pdpv9-pdp__qty-input-wrap">
              <input id="pdpv9-pdp-qty" type="number" name="quantity" value="1" min="1" max="10" inputmode="numeric" class="pdpv9-pdp__qty-input" aria-label="{% if request.locale.iso_code == 'en' %}Quantity{% else %}Quantité{% endif %}">
            </div>
          </div>

          <button type="submit" name="add" class="pdpv9-pdp__atc"{% unless current_variant.available %} disabled{% endunless %}>
            {%- if current_variant.available -%}
              <span class="pdpv9-pdp__atc-text" id="pdpv9-atc-text">{% if request.locale.iso_code == 'en' %}Start my 30-day routine{% else %}Commencer ma cure 30 jours{% endif %}</span>
              <span class="pdpv9-pdp__atc-price" id="pdpv9-atc-price">— {% render 'locale-price', price: current_variant.price %}</span>
            {%- else -%}
              {% if request.locale.iso_code == 'en' %}Sold out{% else %}En rupture{% endif %}
            {%- endif -%}
          </button>
        </form>

        {%- comment -%} Sub-CTA trust line (under the CTA) {%- endcomment -%}
        <p class="pdpv9-pdp__atc-trust">{% if request.locale.iso_code == 'en' %}Free U.S. shipping · Secure checkout · Bonuses included{% else %}{% if request.locale.iso_code == 'en' %}Free U.S. shipping{% else %}Livraison gratuite en France{% endif %} · {% if request.locale.iso_code == 'en' %}Secure checkout{% else %}Paiement sécurisé{% endif %} · Bonus inclus{% endif %}</p>

        {%- comment -%} ─── Subscribe & Save tease (EN only) ─── {%- endcomment -%}
        {%- if request.locale.iso_code == 'en' -%}
        <div class="pdpv9-pdp__sub-tease" style="margin:20px 0 12px;padding:16px 18px;background:linear-gradient(135deg,#F2F0FA 0%,#FAF9F7 100%);border:1px solid #E8E4F0;border-radius:14px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
            <span style="font-size:20px;line-height:1;" aria-hidden="true">🔁</span>
            <strong style="font-size:14px;color:#2A1054;font-weight:700;">Subscribe & Save 10% — Launching soon</strong>
          </div>
          <p style="font-size:13px;color:#555;margin:0 0 12px;line-height:1.5;">Get notified when monthly auto-delivery launches. Cancel anytime, no commitment.</p>
          <form action="/contact#contact_form" method="post" class="pdpv9-pdp__sub-form" style="display:flex;gap:8px;flex-wrap:wrap;">
            <input type="hidden" name="form_type" value="contact">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="contact[body]" value="Interested in monthly subscription for ube-poudre">
            <input type="hidden" name="contact[tags]" value="subscribe-interest,us-launch">
            <input type="email" name="contact[email]" required placeholder="you@email.com" aria-label="Email for subscription notification" style="flex:1;min-width:180px;padding:10px 12px;border:1px solid #D4CCDE;border-radius:8px;font-size:14px;background:#fff;">
            <button type="submit" style="padding:10px 16px;background:#2A1054;color:#fff;border:0;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;">Notify me</button>
          </form>
        </div>
        {%- endif -%}

        {%- comment -%} Reassurance compact (post-ATC) — 4 trust signals factuels {%- endcomment -%}
        <ul class="pdpv9-pdp__reassurance">
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h13l3 4v6h-3"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg> {% if request.locale.iso_code == 'en' %}Free U.S. shipping{% else %}Livraison gratuite en France{% endif %}</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> {% if request.locale.iso_code == 'en' %}Secure checkout{% else %}Paiement sécurisé{% endif %}</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> {% if request.locale.iso_code == 'en' %}Ships from France{% else %}Expédié depuis la France{% endif %}</li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> {% if request.locale.iso_code == 'en' %}Customer support available{% else %}Support client disponible{% endif %}</li>
        </ul>

        {%- comment -%} ─── BLOC DÉCISION : {% if request.locale.iso_code == 'en' %}Which pack is right for you?{% else %}Quelle cure choisir ?{% endif %} (CRO V1 — sous reassurance) ─── {%- endcomment -%}
        <div class="pdpv9-decide" aria-labelledby="pdpv9-decide-title">
          <h3 class="pdpv9-decide__title" id="pdpv9-decide-title">{% if request.locale.iso_code == 'en' %}Which pack is right for you?{% else %}Quelle cure choisir ?{% endif %}</h3>
          <div class="pdpv9-decide__grid">
            <article class="pdpv9-decide__card">
              <span class="pdpv9-decide__label">{% if request.locale.iso_code == 'en' %}Starter 90g{% else %}{% if request.locale.iso_code == 'en' %}Starter{% else %}Découverte{% endif %} 90g{% endif %}</span>
              <p class="pdpv9-decide__desc">{% if request.locale.iso_code == 'en' %}Ideal if you want to try UBurn at your own pace, 1 scoop per day.{% else %}Idéal si tu veux tester UBurn tranquillement avec 1 dose par jour.{% endif %}</p>
            </article>
            <article class="pdpv9-decide__card pdpv9-decide__card--pop">
              <span class="pdpv9-decide__pop">{% if request.locale.iso_code == 'en' %}Best Value{% else %}Le + populaire{% endif %}</span>
              <span class="pdpv9-decide__label">{% if request.locale.iso_code == 'en' %}Maximum Pack 270g{% else %}{% if request.locale.iso_code == 'en' %}Maximum Pack{% else %}Résultats Maximum{% endif %} 270g{% endif %}</span>
              <p class="pdpv9-decide__desc">{% if request.locale.iso_code == 'en' %}Ideal for your daily routine and best value per scoop — 90-day supply.{% else %}Idéal si tes {% if request.locale.iso_code == 'en' %}craving{% else %}fringale{% endif %}s reviennent plusieurs fois dans la journée et que tu veux le meilleur prix par dose.{% endif %}</p>
            </article>
          </div>
          <a href="#pdpv9-pdp-form" class="pdpv9-cta-secondary pdpv9-decide__cta">{% if request.locale.iso_code == 'en' %}Pick my pack →{% else %}Choisir ma cure →{% endif %}</a>
        </div>

        {%- comment -%} ─── BLOC BÉNÉFICES : Pourquoi UBURN aide à contrôler les {% if request.locale.iso_code == 'en' %}craving{% else %}fringale{% endif %}s ─── {%- endcomment -%}
        <div class="pdpv9-why" aria-labelledby="pdpv9-why-title">
          <h3 class="pdpv9-why__title" id="pdpv9-why-title">{% if request.locale.iso_code == 'en' %}Why UBurn helps handle cravings naturally*{% else %}Pourquoi UBurn aide à contrôler les {% if request.locale.iso_code == 'en' %}craving{% else %}fringale{% endif %}s ?{% endif %}</h3>
          <ul class="pdpv9-why__list">
