{% comment %}Section: UB Page Router · Uburn 2026 · Routes FAQ / Ingrédients / Contact by page.handle{% endcomment %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,400;0,500;0,700;0,800;0,900;1,700;1,800&family=Red+Hat+Text:wght@300;400;500;600;700&display=swap');

:root{--purple-deep:#3d1873;--purple-main:#6b2fa0;--purple-mid:#8b47c5;--purple-light:#b07de8;--purple-pale:#e8dcf5;--purple-wash:#f5f0fa;--cream:#faf9f7;--warm:#f2f0ed;--dark:#1a1118;--body:#5a5654;--muted:#8a8785;--grad:linear-gradient(160deg,#3d1873 0%,#6b2fa0 40%,#8b47c5 100%)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Red Hat Text',sans-serif;background:var(--cream);color:var(--dark);-webkit-font-smoothing:antialiased;overflow-x:hidden}
h1,h2,h3,h4{font-family:'Red Hat Display',sans-serif;letter-spacing:-0.02em}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
[id^="shopify-section-sections--"]{display:none !important}
main#main{padding:0 !important}
/* Nav */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:18px 48px;display:flex;align-items:center;justify-content:space-between;transition:background 0.4s,padding 0.4s,box-shadow 0.4s;background:rgba(250,249,247,0.96);backdrop-filter:blur(12px);box-shadow:0 1px 0 var(--purple-pale)}
.nav-logo{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:22px;color:var(--purple-main);letter-spacing:-0.03em}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none}
.nav-links a{font-size:14px;font-weight:500;color:var(--body);transition:color 0.2s}
.nav-links a:hover,.nav-links a.active{color:var(--purple-main)}
.nav-cta{background:var(--grad);color:#fff;padding:9px 22px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13.5px;transition:opacity 0.2s}
.nav-cta:hover{opacity:0.9}
@media(max-width:768px){.nav{padding:14px 20px}.nav-links{display:none}}
/* Commons */
.section-label{font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--purple-mid);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.section-label::before{content:'';width:20px;height:1px;background:currentColor}
.section-title{font-size:clamp(32px,4vw,54px);font-weight:900;line-height:1.08;letter-spacing:-0.03em}
.section-title em{font-style:italic;font-weight:800;color:var(--purple-main)}
/* BA */
.ba-section{background:var(--warm);padding:100px 80px}
.ba-inner{max-width:1000px;margin:0 auto}
.ba-card{display:grid;grid-template-columns:1fr 56px 1fr;background:#fff;border-radius:24px;overflow:hidden;box-shadow:0 4px 60px rgba(61,24,115,0.1);margin-top:48px}
.ba-col{padding:40px 36px}
.ba-before{background:#f9f7f5}
.ba-divider{background:var(--purple-wash);display:flex;flex-direction:column;align-items:center;justify-content:center}
.ba-divider-arrow{width:36px;height:36px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;box-shadow:0 4px 16px rgba(107,47,160,0.4)}
.ba-label{font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.ba-week{font-family:'Red Hat Display',sans-serif;font-size:26px;font-weight:900;color:var(--dark);letter-spacing:-0.03em;margin-bottom:14px}
.ba-items{display:flex;flex-direction:column;gap:11px}
.ba-item{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.5;color:var(--body)}
.ba-item::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--purple-pale);flex-shrink:0;margin-top:6px}
.ba-after .ba-item::before{background:var(--purple-main)}
.ba-after .ba-item{color:var(--dark)}
.ba-profile{display:flex;align-items:center;gap:12px;margin-top:28px;padding-top:20px;border-top:1px solid var(--purple-pale)}
.ba-avatar{width:40px;height:40px;border-radius:50%;flex-shrink:0;background:var(--purple-pale);display:flex;align-items:center;justify-content:center;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;color:var(--purple-main)}
.ba-name{font-weight:700;font-size:14px;color:var(--dark)}
.ba-meta{font-size:12px;color:var(--muted);margin-top:1px}
.ba-stars{color:#f4b942;font-size:13px;margin-top:3px}
@media(max-width:720px){.ba-section{padding:72px 24px}.ba-card{grid-template-columns:1fr;grid-template-rows:auto 48px auto}.ba-divider{height:48px;flex-direction:row}.ba-col{padding:28px 24px}}
/* Reveal */
.reveal{opacity:0;transform:translateY(22px);transition:opacity 0.6s ease,transform 0.6s cubic-bezier(0.16,1,0.3,1)}
.reveal.visible{opacity:1;transform:none}
.rd1{transition-delay:0.1s}.rd2{transition-delay:0.2s}.rd3{transition-delay:0.3s}
/* Footer */
.footer{background:var(--dark);padding:64px 80px 36px;color:rgba(255,255,255,0.55)}
.footer-inner{max-width:1140px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:36px}
.footer-brand{font-family:'Red Hat Display',sans-serif;font-weight:900;font-size:20px;color:#fff;margin-bottom:14px;letter-spacing:-0.02em}
.footer-desc{font-size:13.5px;line-height:1.7;max-width:34ch;color:rgba(255,255,255,0.5);margin-bottom:20px}
.footer-legal{font-size:11px;line-height:1.7;color:rgba(255,255,255,0.28)}
.footer-col-title{font-family:'Red Hat Display',sans-serif;font-weight:700;font-size:13px;color:rgba(255,255,255,0.85);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:9px}
.footer-links a{font-size:13px;color:rgba(255,255,255,0.4);transition:color 0.2s}
.footer-links a:hover{color:rgba(255,255,255,0.85)}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:12px;color:rgba(255,255,255,0.22)}
@media(max-width:900px){.footer{padding:48px 24px 28px}.footer-top{grid-template-columns:1fr 1fr;gap:28px}}
@media(max-width:600px){.footer-top{grid-template-columns:1fr}}
.btn-main{display:inline-flex;align-items:center;gap:8px;background:var(--grad);color:#fff;padding:16px 32px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;transition:transform 0.2s,opacity 0.2s;border:none;cursor:pointer}
.btn-main:hover{transform:translateY(-2px);opacity:0.92}

/* ═══ FAQ ═══ */
.faq-hero{padding:140px 80px 80px;background:var(--cream);text-align:center}
.faq-hero h1{font-size:clamp(40px,5vw,64px);font-weight:900;letter-spacing:-0.03em;margin-bottom:16px}
.faq-hero p{font-size:17px;color:var(--body);max-width:48ch;margin:0 auto}
.faq-body{padding:0 80px 80px;max-width:820px;margin:0 auto}
.faq-group{margin-bottom:56px}
.faq-group-title{font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:800;color:var(--dark);letter-spacing:-0.02em;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid var(--purple-pale)}
.faq-item{border-bottom:1px solid var(--purple-pale)}
.faq-q{font-family:'Red Hat Display',sans-serif;font-size:16px;font-weight:700;color:var(--dark);padding:20px 48px 20px 0;cursor:pointer;position:relative;letter-spacing:-0.01em}
.faq-q::after{content:'▾';position:absolute;right:0;top:50%;transform:translateY(-50%);color:var(--purple-main);transition:transform 0.3s;font-size:14px}
.faq-item.open .faq-q::after{transform:translateY(-50%) rotate(180deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height 0.4s cubic-bezier(0.16,1,0.3,1)}
.faq-item.open .faq-a{max-height:400px}
.faq-a-inner{font-size:15px;color:var(--body);line-height:1.7;padding:0 48px 20px 0;max-width:65ch}
.faq-a-inner strong{color:var(--dark);font-weight:600}
@media(max-width:768px){.faq-hero{padding:110px 24px 60px}.faq-body{padding:0 24px 60px}}

/* ═══ INGRÉDIENTS ═══ */
.ing-hero{padding:140px 80px 80px;background:var(--dark);position:relative;overflow:hidden}
.ing-hero::before{content:'';position:absolute;top:-200px;right:-100px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(107,47,160,0.25) 0%,transparent 70%);pointer-events:none}
.ing-hero .section-label{color:var(--purple-light)}
.ing-hero .section-label::before{background:var(--purple-light)}
.ing-hero h1{color:#fff;font-size:clamp(40px,5.5vw,68px);font-weight:900;letter-spacing:-0.04em;line-height:1.04;margin-bottom:20px}
.ing-hero h1 em{font-style:italic;color:var(--purple-light)}
.ing-hero p{font-size:17px;color:rgba(255,255,255,0.6);max-width:50ch;line-height:1.7}
.ing-grid-section{padding:100px 80px;background:var(--cream)}
.ing-grid-inner{max-width:1140px;margin:0 auto}
.ing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
.ing-card{padding:48px 40px;position:relative}
.ing-card:not(:nth-child(3n))::after{content:'';position:absolute;top:40px;bottom:40px;right:0;width:1px;background:var(--purple-pale)}
.ing-card:nth-child(n+4){border-top:1px solid var(--purple-pale)}
.ing-icon{font-size:40px;margin-bottom:20px}
.ing-name{font-family:'Red Hat Display',sans-serif;font-size:20px;font-weight:800;color:var(--dark);letter-spacing:-0.02em;margin-bottom:6px}
.ing-latin{font-size:12px;color:var(--purple-mid);font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:14px}
.ing-desc{font-size:14.5px;color:var(--body);line-height:1.65}
.ing-tag{display:inline-block;margin-top:16px;padding:5px 12px;border-radius:20px;background:var(--purple-wash);font-size:11.5px;font-weight:600;color:var(--purple-main);letter-spacing:0.08em}
.ing-card.featured{background:var(--purple-deep)}
.ing-card.featured .ing-name,.ing-card.featured .ing-desc{color:#fff}
.ing-card.featured .ing-desc{color:rgba(255,255,255,0.7)}
.ing-card.featured .ing-latin{color:var(--purple-light)}
.ing-card.featured .ing-tag{background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.9)}
.ing-card.featured::after{background:rgba(255,255,255,0.1) !important}
.efsa-banner{background:var(--purple-wash);padding:60px 80px;text-align:center}
.efsa-inner{max-width:700px;margin:0 auto}
.efsa-badge{display:inline-flex;align-items:center;gap:14px;background:#fff;border-radius:20px;padding:20px 28px;box-shadow:0 4px 24px rgba(107,47,160,0.12);margin-bottom:24px}
.efsa-badge-icon{font-size:32px}
.efsa-badge-text{font-family:'Red Hat Display',sans-serif;font-size:18px;font-weight:800;color:var(--dark);letter-spacing:-0.02em}
.efsa-badge-sub{font-size:12px;color:var(--muted);margin-top:2px}
.efsa-desc{font-size:16px;color:var(--body);line-height:1.7;max-width:52ch;margin:0 auto}
@media(max-width:900px){.ing-hero{padding:110px 24px 60px}.ing-grid-section{padding:72px 24px}.ing-grid{grid-template-columns:1fr 1fr}.efsa-banner{padding:56px 24px}}
@media(max-width:600px){.ing-grid{grid-template-columns:1fr}.ing-card::after{display:none !important}}

/* ═══ CONTACT ═══ */
.contact-wrap{min-height:100vh;display:grid;grid-template-columns:1fr 1fr}
.contact-left{background:var(--purple-deep);padding:140px 72px 80px;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center}
.contact-left::before{content:'';position:absolute;top:-150px;right:-150px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(139,71,197,0.3) 0%,transparent 70%);pointer-events:none}
.contact-left .section-label{color:var(--purple-light)}
.contact-left .section-label::before{background:var(--purple-light)}
.contact-left h1{color:#fff;font-size:clamp(36px,4.5vw,56px);font-weight:900;letter-spacing:-0.03em;line-height:1.08;margin-bottom:28px}
.contact-left h1 em{font-style:italic;color:var(--purple-light)}
.contact-left p{font-size:16px;color:rgba(255,255,255,0.6);line-height:1.75;max-width:42ch;margin-bottom:40px}
.contact-info{display:flex;flex-direction:column;gap:20px}
.contact-info-item{display:flex;align-items:center;gap:14px}
.contact-info-icon{width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.contact-info-text strong{display:block;font-size:14px;color:#fff;font-weight:700;margin-bottom:2px}
.contact-info-text span{font-size:13px;color:rgba(255,255,255,0.5)}
.contact-right{background:var(--cream);padding:140px 72px 80px;display:flex;flex-direction:column;justify-content:center}
.contact-right h2{font-family:'Red Hat Display',sans-serif;font-size:28px;font-weight:800;color:var(--dark);letter-spacing:-0.02em;margin-bottom:32px}
.form-group{margin-bottom:20px}
.form-label{display:block;font-size:13px;font-weight:600;color:var(--dark);margin-bottom:8px;letter-spacing:0.03em}
.form-input,.form-textarea{width:100%;padding:14px 18px;border:1.5px solid var(--purple-pale);border-radius:12px;font-family:'Red Hat Text',sans-serif;font-size:15px;color:var(--dark);background:#fff;transition:border-color 0.2s,box-shadow 0.2s;outline:none}
.form-input:focus,.form-textarea:focus{border-color:var(--purple-main);box-shadow:0 0 0 3px rgba(107,47,160,0.1)}
.form-textarea{min-height:140px;resize:vertical;line-height:1.6}
.form-submit{background:var(--grad);color:#fff;padding:16px 36px;border-radius:50px;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:15px;border:none;cursor:pointer;width:100%;transition:opacity 0.2s,transform 0.2s;margin-top:8px}
.form-submit:hover{opacity:0.9;transform:translateY(-1px)}
.form-note{font-size:12px;color:var(--muted);margin-top:12px;text-align:center}
@media(max-width:900px){.contact-wrap{grid-template-columns:1fr;min-height:auto}.contact-left,.contact-right{padding:100px 24px 60px}}

/* ═══ COMMENT ÇA MARCHE ═══ */
.ccm-hero{background:var(--grad);padding:120px 48px 80px;text-align:center;color:#fff}
.ccm-hero-label{font-size:11px;font-weight:700;letter-spacing:1.8px;text-transform:uppercase;opacity:.7;margin-bottom:12px}
.ccm-hero-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(36px,5vw,60px);font-weight:900;line-height:1.05;letter-spacing:-0.03em;margin-bottom:16px}
.ccm-hero-sub{font-size:18px;opacity:.8;max-width:50ch;margin:0 auto}
.ccm-steps{padding:96px 48px;max-width:900px;margin:0 auto;display:flex;flex-direction:column;gap:72px}
.ccm-step{display:grid;grid-template-columns:80px 1fr;gap:32px;align-items:start}
.ccm-step-num{width:64px;height:64px;border-radius:50%;background:var(--grad);color:#fff;font-family:'Red Hat Display',sans-serif;font-size:28px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ccm-step-title{font-family:'Red Hat Display',sans-serif;font-size:24px;font-weight:800;color:var(--dark);margin-bottom:10px}
.ccm-step-body{font-size:16px;line-height:1.75;color:var(--body)}
.ccm-step-badge{display:inline-block;background:var(--purple-wash);color:var(--purple-main);font-size:12px;font-weight:700;padding:5px 12px;border-radius:50px;margin-top:12px;letter-spacing:.5px}
.ccm-science{background:var(--warm);padding:80px 48px;text-align:center}
.ccm-science-inner{max-width:700px;margin:0 auto}
.ccm-science-title{font-family:'Red Hat Display',sans-serif;font-size:28px;font-weight:900;color:var(--dark);margin-bottom:16px}
.ccm-science-body{font-size:16px;line-height:1.75;color:var(--body);margin-bottom:24px}
.ccm-science-badge{display:inline-block;background:var(--purple-main);color:#fff;font-size:12px;font-weight:700;padding:8px 20px;border-radius:50px;letter-spacing:.5px}
.ccm-cta{background:var(--grad);padding:72px 48px;text-align:center;color:#fff}
.ccm-cta-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(28px,4vw,44px);font-weight:900;margin-bottom:12px;letter-spacing:-0.02em}
.ccm-cta-sub{font-size:17px;opacity:.8;margin-bottom:32px}
.ccm-cta-btn{display:inline-block;background:#fff;color:var(--purple-main);font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:16px;padding:16px 40px;border-radius:100px;transition:transform .2s,box-shadow .2s}
.ccm-cta-btn:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(0,0,0,.2)}
@media(max-width:768px){.ccm-hero,.ccm-steps,.ccm-science,.ccm-cta{padding-left:24px;padding-right:24px}.ccm-step{grid-template-columns:52px 1fr;gap:16px}.ccm-step-num{width:48px;height:48px;font-size:20px}}

/* ═══ AVIS ═══ */
.avis-hero{background:var(--grad);padding:120px 48px 80px;text-align:center;color:#fff}
.avis-hero-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(36px,5vw,58px);font-weight:900;line-height:1.05;letter-spacing:-0.03em;margin-bottom:12px}
.avis-hero-sub{font-size:18px;opacity:.8;max-width:48ch;margin:0 auto}
.avis-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;padding:64px 48px;max-width:900px;margin:0 auto}
.avis-stat{text-align:center;background:#fff;border-radius:20px;padding:36px 24px;box-shadow:0 4px 32px rgba(61,24,115,.08)}
.avis-stat-num{font-family:'Red Hat Display',sans-serif;font-size:48px;font-weight:900;color:var(--purple-main);margin-bottom:8px;line-height:1}
.avis-stat-label{font-size:14px;color:var(--body);line-height:1.4}
.avis-grid{padding:0 48px 96px;max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.avis-card{background:#fff;border-radius:20px;padding:32px;box-shadow:0 4px 24px rgba(61,24,115,.07)}
.avis-stars{color:#f4c430;font-size:18px;margin-bottom:14px}
.avis-text{font-size:15px;line-height:1.7;color:var(--dark);font-style:italic;margin-bottom:20px}
.avis-author{display:flex;align-items:center;gap:12px}
.avis-author-init{width:40px;height:40px;border-radius:50%;background:var(--grad);color:#fff;font-family:'Red Hat Display',sans-serif;font-weight:800;font-size:16px;display:flex;align-items:center;justify-content:center}
.avis-author-name{font-weight:700;font-size:14px;color:var(--dark)}
.avis-author-meta{font-size:12px;color:var(--muted)}
.avis-badge{display:inline-block;background:var(--purple-wash);color:var(--purple-main);font-size:10px;font-weight:700;padding:3px 10px;border-radius:50px;margin-top:4px;letter-spacing:.5px}
.avis-cta{background:var(--warm);padding:72px 48px;text-align:center}
.avis-cta-title{font-family:'Red Hat Display',sans-serif;font-size:clamp(28px,4vw,42px);font-weight:900;color:var(--dark);margin-bottom:12px;letter-spacing:-0.02em}
.avis-cta-sub{font-size:17px;color:var(--body);margin-bottom:32px}
@media(max-width:768px){.avis-hero,.avis-cta{padding-left:24px;padding-right:24px}.avis-stats{grid-template-columns:1fr;padding:48px 24px;gap:16px}.avis-grid{grid-template-columns:1fr;padding:0 24px 64px}}
</style>

{% render 'ub-nav' %}

{%- if page.handle == 'faq' -%}

<section class="faq-hero">
  <div class="section-label reveal" style="justify-content:center">{% if request.locale.iso_code == 'en' %}Frequently asked questions{% else %}Questions fréquentes{% endif %}</div>
  <h1 class="reveal rd1">{% if request.locale.iso_code == 'en' %}All your questions.<br><em>Really.</em>{% else %}Toutes vos questions.<br><em>Vraiment.</em>{% endif %}</h1>
  <p class="reveal rd2">{% if request.locale.iso_code == 'en' %}Clear answers, no jargon. If your question isn't here, write to us.{% else %}Des réponses claires, sans jargon. Si votre question n'est pas ici, écrivez-nous.{% endif %}</p>
</section>

<div class="faq-body">
  <div class="faq-group reveal">
