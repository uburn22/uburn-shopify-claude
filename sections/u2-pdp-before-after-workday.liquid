{%- comment -%}
  UBurn V2 — PDP "Your 4 PM, rewritten" Before/After workday
  Emotional hook section using before-stress / after-calm photos
{%- endcomment -%}
<style>
  .u2-bawd { background: var(--u2-cream); padding: var(--u2-space-section) 20px; }
  .u2-bawd__inner { max-width: 1180px; margin: 0 auto; }
  .u2-bawd__head { text-align: center; margin-bottom: 48px; }
  .u2-bawd__head h2 {
    font-family: var(--u2-sans);
    font-size: clamp(34px,5.5vw,52px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--u2-plum-black);
    margin: 12px 0 0;
  }
  .u2-bawd__head h2 em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-bawd__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) { .u2-bawd__grid { grid-template-columns: 1fr 1fr; gap: 28px; } }
  .u2-bawd__card {
    background: white;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid rgba(107,78,158,0.08);
    display: flex;
    flex-direction: column;
  }
  .u2-bawd__card--after {
    border-color: var(--u2-iris);
    box-shadow: 0 22px 50px -22px rgba(107,78,158,0.25);
  }
  .u2-bawd__img {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--u2-lavender-soft);
  }
  .u2-bawd__img img { width:100%; height:100%; object-fit: cover; }
  .u2-bawd__body { padding: 28px 24px; flex: 1; }
  .u2-bawd__pill {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 14px;
  }
  .u2-bawd__pill--before { background: rgba(192,188,182,0.25); color: #5a5a5a; }
  .u2-bawd__pill--after { background: rgba(107,78,158,0.15); color: var(--u2-iris); }
  .u2-bawd__title {
    font-family: var(--u2-sans);
    font-size: 22px;
    font-weight: 800;
    color: var(--u2-plum-black);
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }
  .u2-bawd__title em { font-family: var(--u2-serif); font-style: italic; font-weight: 400; color: var(--u2-iris); }
  .u2-bawd__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .u2-bawd__list li {
    font-size: 14px;
    line-height: 1.5;
    color: #3A2E4A;
    padding-left: 22px;
    position: relative;
  }
  .u2-bawd__list li::before {
    content: '';
    position: absolute;
    left: 0; top: 8px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(184,157,217,0.45);
  }
  .u2-bawd__card--after .u2-bawd__list li::before { background: var(--u2-iris); }
  .u2-bawd__disc {
    text-align: center;
    margin-top: 24px;
    font-size: 11px;
    color: #7a7585;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
</style>
<section class="u2-root u2-bawd" aria-label="Your 4 PM rewritten">
  <div class="u2-bawd__inner">
    <div class="u2-bawd__head u2-reveal">
      <span class="u2-section-eyebrow">— your afternoon, rewritten</span>
      <h2>Your 4 PM. <em>Rewritten.</em></h2>
    </div>
    <div class="u2-bawd__grid">
      <article class="u2-bawd__card u2-reveal delay-1">
        <div class="u2-bawd__img"><img src="{{ 'u2-before-stress.jpg' | asset_url }}" alt="Stressed afternoon — before UBurn" loading="lazy" width="1024" height="768"></div>
        <div class="u2-bawd__body">
          <span class="u2-bawd__pill u2-bawd__pill--before">Without UBurn</span>
          <h3 class="u2-bawd__title">Same routine, <em>same crash.</em></h3>
          <ul class="u2-bawd__list">
            <li>4 PM crash hits like clockwork</li>
            <li>Pantry calls, willpower drops</li>
            <li>Sugar snacks fuel a stronger crash</li>
            <li>Afternoon fog, scattered focus</li>
            <li>Heavy dinner to compensate</li>
          </ul>
        </div>
      </article>
      <article class="u2-bawd__card u2-bawd__card--after u2-reveal delay-2">
        <div class="u2-bawd__img"><img src="{{ 'u2-after-calm.jpg' | asset_url }}" alt="Calm afternoon — with UBurn" loading="lazy" width="1024" height="768"></div>
        <div class="u2-bawd__body">
          <span class="u2-bawd__pill u2-bawd__pill--after">With UBurn</span>
          <h3 class="u2-bawd__title">Same hour. <em>Different feeling.</em></h3>
          <ul class="u2-bawd__list">
            <li>Calmer afternoons, smoother digestion*</li>
            <li>No willpower needed — physiology takes over</li>
            <li>Stable focus, no sugar swings</li>
            <li>Mood lifts. Energy stays steady.</li>
            <li>Lighter dinner, naturally</li>
          </ul>
        </div>
      </article>
    </div>
    <p class="u2-bawd__disc">*Individual results may vary. EFSA Reg 432/2012 · ID 3120 · 3g/day with water before meals. These statements have not been evaluated by the FDA.</p>
  </div>
</section>
{% schema %}
{
  "name": "U2 PDP Before/After Workday",
  "tag": "section",
  "class": "shopify-section--u2-bawd",
  "settings": [],
  "presets": [ { "name": "U2 PDP Before/After Workday" } ]
}
{% endschema %}
