    maximum: { id: {{ v_maximum.id }}, price_one: 5899, price_sub: 5309, label: 'Maximum — 270g · 90 servings' },
    {%- if sub_plan -%}
    selling_plan_id: {{ sub_plan.id }},
    {%- else -%}
    selling_plan_id: null,
    {%- endif -%}
    currency: 'USD',
    cart_add_url: '/cart/add.js'
